# Workaround temporal para que el código heredado del 2021 corra sobre MySQL 8.
#
# El sql_mode por defecto en MySQL 8 incluye ONLY_FULL_GROUP_BY, que rechaza
# queries con GROUP BY incompletos. El código original tiene varias así
# (ej: dashboard contra la tabla 'lay') y reescribirlas todas ahora nos
# desvía del objetivo de "boot e inventario".
#
# Cuando entremos en la fase de modernización las arreglamos una a una y
# reactivamos ONLY_FULL_GROUP_BY (es buena disciplina).
#
# Sql_mode por defecto de MySQL 8 = STRICT_TRANS_TABLES, ERROR_FOR_DIVISION_BY_ZERO,
# NO_ENGINE_SUBSTITUTION, NO_ZERO_IN_DATE, NO_ZERO_DATE, ONLY_FULL_GROUP_BY.
# Aquí quitamos sólo ONLY_FULL_GROUP_BY.

[mysqld]
sql_mode="STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION,NO_ZERO_IN_DATE,NO_ZERO_DATE"
