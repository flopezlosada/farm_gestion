{# ============================================================
 # Calendario interno (FullCalendar) — shell csa.
 # El JS calendar-settings.js busca #calendar-holder y pinta
 # el calendario con eventos de tareas, puestas, recogidas, etc.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Calendario{% endblock %}

{% block more_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/adesignscalendar/css/fullcalendar/fullcalendar.css') }}">
{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Calendario</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Día a día · Vista',
        'Calendario',
        'Eventos de la asociación: tareas, recogidas, puestas y reparto.'
    ) }}

    {% embed '_components/csa_card.html.twig' with { title: 'Mes en curso', accent: 'green' } %}
        {% block body %}
            <div id="calendar-holder"></div>
        {% endblock %}
    {% endembed %}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="{{ asset('bundles/fosjsrouting/js/router.js') }}"></script>
    <script src="{{ path('fos_js_routing_js', { callback: 'fos.Router.setData' }) }}"></script>
    <script type="text/javascript" src="{{ asset('bundles/adesignscalendar/js/fullcalendar/jquery.fullcalendar.min.js') }}"></script>
    <script type="text/javascript" src="{{ asset('bundles/adesignscalendar/js/calendar-settings.js') }}"></script>
{% endblock %}
