{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar {{ entity.username }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('user') }}">Usuarias</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('user_show', { id: entity.id }) }}">{{ entity.username }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Administración · Usuarias',
        'Editar ' ~ entity.username,
        'Identidad, permisos y vínculo con socix.'
    ) }}

    <form id="user-delete-form" method="post"
          action="{{ path('user_delete', { id: entity.id }) }}"
          style="display: none;">
        <input type="hidden" name="_method" value="DELETE">
    </form>

    {{ form_start(edit_form, { action: path('user_update', { id: entity.id }), method: 'PUT', attr: { class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Cuenta', subtitle: 'Datos básicos. La contraseña la cambia la propia usuaria con el enlace de recuperación en /login/forgot.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.username, 'Usuaria') }}
                        {{ csa.field(edit_form.email, 'Email') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Permisos' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.roles, 'Roles', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Vínculo con socix' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.partner, 'Socix vinculadx', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-user-delete').showModal()">Eliminar</button>
            {{ csa.confirm_dialog('confirm-user-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'user-delete-form',
            }) }}
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('user_show', { id: entity.id }) }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Guardar cambios</button>
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}
