{# ============================================================
 # Ficha del voluntario de acogida — mismo lenguaje visual que la ficha de socix
 # (reusa partner_card_styles: hero + avatar + chips + tarjetas + mini-stats).
 # Datos + cesta de reparto + historial de estancias.
 # ============================================================ #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set status_tone = { 'confirmed': 'activo', 'requested': 'warn', 'cancelled': 'mute' } %}
{% set status_label = { 'confirmed': 'Confirmada', 'requested': 'Solicitada', 'cancelled': 'Cancelada' } %}

{% set parts = helper.name|split(' ')|filter(p => p is not empty) %}
{% set initials = (parts|first|first|upper) ~ (parts|length > 1 ? parts|last|first|upper : '') %}
{% set avatar_palette = ['sage', 'ochre', 'terra', 'ink'] %}
{% set avatar_tone = avatar_palette[(helper.id|default(0)) % 4] %}

{% block title %}{{ helper.name }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('helper_index') }}">Albergue</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ helper.name }}</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
{% include '_components/partner_card_styles.html.twig' %}
<style>
/* Lista de estancias — tokens .prt locales (estamos dentro de .prt). */
.hst { display: flex; flex-direction: column; gap: 8px; }
.hst-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 11px 14px; border: 1px solid var(--prt-line); border-radius: 7px; background: var(--prt-bg); }
.hst-row--cancelled { opacity: 0.55; }
.hst-row__dates { font-family: 'Fraunces', serif; font-weight: 600; font-size: 14px; color: var(--prt-ink); letter-spacing: -0.005em; }
.hst-row__meta { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; margin-top: 4px; font-size: 12px; color: var(--prt-ink-faint); }
.hst-row__actions { display: flex; align-items: center; gap: 6px; white-space: nowrap; }
.hst-empty { padding: 26px 14px; text-align: center; color: var(--prt-ink-faint); font-style: italic; font-size: 13px; background: var(--prt-bg); border: 1px dashed var(--prt-line-2); border-radius: 7px; }
</style>
{% endblock %}

{% block csa_main %}
{# Form oculto del borrado del voluntario (lo dispara el modal de confirmación). #}
{% if is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
    <form id="helper-delete-form" method="post" action="{{ path('helper_delete', { id: helper.id }) }}" style="display: none;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ helper.id) }}">
    </form>
{% endif %}

<div class="prt">

    {# ============ HERO ============ #}
    <header class="prt-hero">
        <span class="prt-avatar prt-avatar--{{ avatar_tone }}" aria-hidden="true">{{ initials }}</span>

        <div>
            <h1 class="prt-hero__title">{{ helper.name }}</h1>
            <div class="prt-hero__meta">
                <span class="prt-chip prt-chip--mute">{{ helper.source.name }}</span>
                {% if helper.basketActive %}
                    <span class="prt-chip prt-chip--activo"><span class="dot"></span>Cesta activa</span>
                {% else %}
                    <span class="prt-chip prt-chip--baja"><span class="dot"></span>Sin cesta</span>
                {% endif %}
                {% if helper.country %}<span class="sep">·</span><span>{{ helper.country }}</span>{% endif %}
            </div>
        </div>

        <div class="prt-hero__actions">
            {% if is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
                {{ csa.btn('Editar', { variant: 'secondary', href: path('helper_edit', { id: helper.id }), icon: 'fa-pencil' }) }}
                <button type="button" class="csa-btn csa-btn--danger-soft" onclick="document.getElementById('confirm-helper-delete').showModal()">
                    <i class="fa fa-trash"></i><span>Borrar</span>
                </button>
            {% endif %}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('helper_index') }) }}
        </div>
    </header>

    {% if is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
        {{ csa.confirm_dialog('confirm-helper-delete', {
            variant: 'danger',
            title: 'Borrar voluntario',
            body: 'Se borrará «' ~ helper.name ~ '». No se puede deshacer.',
            confirm_label: 'Borrar',
            external_form_id: 'helper-delete-form',
        }) }}
    {% endif %}

    <div class="prt-cols">
        {# ============ Datos ============ #}
        <section class="prt-card">
            <div class="prt-card__head"><h2 class="prt-card__title"><span class="accent"></span>Datos</h2></div>
            <div class="prt-card__body">
                <dl class="prt-defs">
                    <div class="prt-defs__row"><dt class="prt-defs__label">Email</dt><dd class="prt-defs__value{{ helper.email ? '' : ' prt-defs__value--muted' }}">{{ helper.email ? ('<a href="mailto:' ~ helper.email ~ '">' ~ helper.email ~ '</a>')|raw : '—' }}</dd></div>
                    <div class="prt-defs__row"><dt class="prt-defs__label">Teléfono</dt><dd class="prt-defs__value{{ helper.phone ? '' : ' prt-defs__value--muted' }}">{{ helper.phone ?: '—' }}</dd></div>
                    <div class="prt-defs__row"><dt class="prt-defs__label">Idiomas</dt><dd class="prt-defs__value{{ helper.languages ? '' : ' prt-defs__value--muted' }}">{{ helper.languages ?: '—' }}</dd></div>
                    <div class="prt-defs__row"><dt class="prt-defs__label">Nacimiento</dt><dd class="prt-defs__value{{ helper.birthDate ? '' : ' prt-defs__value--muted' }}">{{ helper.birthDate ? helper.birthDate|date('d/m/Y') : '—' }}</dd></div>
                    <div class="prt-defs__row prt-defs__row--full"><dt class="prt-defs__label">Contacto de emergencia</dt><dd class="prt-defs__value{{ helper.emergencyContact ? '' : ' prt-defs__value--muted' }}">{{ helper.emergencyContact ?: '—' }}</dd></div>
                    {% if helper.studies or helper.university %}
                        <div class="prt-defs__row"><dt class="prt-defs__label">Estudios</dt><dd class="prt-defs__value">{{ helper.studies ?: '—' }}</dd></div>
                        <div class="prt-defs__row"><dt class="prt-defs__label">Universidad</dt><dd class="prt-defs__value">{{ helper.university ?: '—' }}</dd></div>
                    {% endif %}
                    {% if helper.notes %}
                        <div class="prt-defs__row prt-defs__row--full"><dt class="prt-defs__label">Notas</dt><dd class="prt-defs__value">{{ helper.notes|nl2br }}</dd></div>
                    {% endif %}
                </dl>
            </div>
        </section>

        {# ============ Cesta de reparto ============ #}
        <section class="prt-card{{ helper.basketActive ? '' : ' prt-card--ink' }}">
            <div class="prt-card__head">
                <h2 class="prt-card__title"><span class="accent"></span>Cesta de reparto</h2>
                {% if helper.basketActive %}
                    {{ csa.btn('Calendario', { variant: 'ghost', size: 'sm', href: path('helper_basket_calendar', { id: helper.id }), icon: 'fa-calendar' }) }}
                {% endif %}
            </div>
            <div class="prt-card__body">
                {% if helper.basketActive %}
                    <div class="prt-basket__name">Activa durante su estancia</div>
                    <div class="prt-basket__sub">Para saltar una semana concreta, usa el calendario de recogida.</div>
                    <div class="prt-mini">
                        <div class="prt-mini__cell"><div class="prt-mini__label">Nodo de recogida</div><div class="prt-mini__value">{{ helper.basketNode ? helper.basketNode.name : 'Torremocha' }}</div></div>
                        <div class="prt-mini__cell"><div class="prt-mini__label">Cestas de verdura</div><div class="prt-mini__value">{{ helper.basketVegBaskets }}</div></div>
                        <div class="prt-mini__cell"><div class="prt-mini__label">Docenas de huevos</div><div class="prt-mini__value">{{ helper.basketEggDozens == helper.basketEggDozens|round ? helper.basketEggDozens|number_format(0) : helper.basketEggDozens|number_format(1, ',', '.') }}</div></div>
                    </div>
                {% else %}
                    <div class="prt-mini__value--muted">Este voluntario no se lleva cesta de reparto. Actívala desde «Editar».</div>
                {% endif %}
            </div>
        </section>
    </div>

    {# ============ Estancias ============ #}
    <section class="prt-card">
        <div class="prt-card__head">
            <h2 class="prt-card__title"><span class="accent"></span>Estancias</h2>
            {% if is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
                {{ csa.btn('Nueva estancia', { variant: 'primary', size: 'sm', href: path('stay_new', { helperId: helper.id }), icon: 'fa-plus' }) }}
            {% endif %}
        </div>
        <div class="prt-card__body">
            {% if stays|length > 0 %}
                <div class="hst">
                    {% for stay in stays %}
                        <div class="hst-row{{ stay.status == 'cancelled' ? ' hst-row--cancelled' : '' }}">
                            <div>
                                <div class="hst-row__dates">{{ stay.arrivalDate|date('d/m/Y') }} → {{ stay.departureDate|date('d/m/Y') }}{{ stay.departureConfirmed ? '' : ' (estimada)' }}</div>
                                <div class="hst-row__meta">
                                    <span class="prt-chip prt-chip--{{ status_tone[stay.status] ?? 'mute' }}">{{ status_label[stay.status] ?? stay.status }}</span>
                                    {% if stay.internshipDetail %}
                                        <span class="prt-chip prt-chip--{{ stay.internshipDetail.reportDelivered ? 'activo' : 'warn' }}">{{ stay.internshipDetail.reportDelivered ? 'Informe entregado' : 'Informe pendiente' }}</span>
                                    {% endif %}
                                    {% if stay.notes %}· {{ stay.notes|length > 80 ? stay.notes|slice(0, 80) ~ '…' : stay.notes }}{% endif %}
                                </div>
                            </div>
                            {% if is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
                                <div class="hst-row__actions">
                                    {{ csa.btn('Prácticas', { variant: 'ghost', size: 'sm', href: path('stay_internship', { id: stay.id }), icon: 'fa-graduation-cap' }) }}
                                    {{ csa.btn('Editar', { variant: 'ghost', size: 'sm', href: path('stay_edit', { id: stay.id }), icon: 'fa-pencil' }) }}
                                    <form method="post" action="{{ path('stay_delete', { id: stay.id }) }}" onsubmit="return confirm('¿Borrar esta estancia?');" style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stay.id) }}">
                                        <button type="submit" class="csa-btn csa-btn--ghost csa-btn--sm"><i class="fa fa-trash"></i><span>Borrar</span></button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="hst-empty">Aún no hay estancias registradas.</div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
