{# ============================================================
 # Detalle de tipo de trabajo cultural — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Tipo · {{ entity.title }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalwork') }}">Trabajos culturales</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalworktype') }}">Tipos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ entity.title }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'culturalworktype-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-wrench"></i>
            </span>
            <div>
                <h1>{{ entity.title }}</h1>
                {% if entity.created %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Creado el {{ entity.created|format_date('long', locale='es') }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-culturalworktype-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-culturalworktype-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'culturalworktype-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('culturalworktype_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('culturalworktype') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos', accent: 'plum' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Nombre del tipo</dt>
                    <dd class="csa-defs__value">{{ entity.title }}</dd>
                </div>
                {% if entity.created %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Creado</dt>
                        <dd class="csa-defs__value">{{ entity.created|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if entity.updated %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Actualizado</dt>
                        <dd class="csa-defs__value">{{ entity.updated|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
