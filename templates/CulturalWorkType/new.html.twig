{# ============================================================
 # Nuevo tipo de trabajo cultural — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo tipo de trabajo cultural{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalwork') }}">Trabajos culturales</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalworktype') }}">Tipos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Nuevo tipo de trabajo cultural',
        'Añade una etiqueta nueva al catálogo de trabajos.'
    ) }}

    {{ form_start(form, {
        'action': path('culturalworktype_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Nombre del tipo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.title, 'Nombre', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('culturalworktype') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear tipo',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}
