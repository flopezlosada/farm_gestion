{# ============================================================
 # Nueva puesta de huevos — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva puesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('lay') }}">Puestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Puesta',
        'Nueva puesta de huevos',
        'Anota la fecha de recogida, el lote y la cantidad. La semana se calcula automáticamente.'
    ) }}

    {{ form_start(form, {
        'action': path('lay_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos de la puesta', subtitle: 'Fecha, lote y cantidad.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.lay_date, 'Fecha de puesta') }}
                        {{ csa.field(form.amount, 'Cantidad') }}
                        {{ csa.field(form.batch, 'Lote', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('lay') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear puesta',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
