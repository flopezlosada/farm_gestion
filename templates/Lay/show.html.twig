{# ============================================================
 # Detalle de una puesta de huevos — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Puesta · {{ entity.laydate|format_date('medium', locale='es') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('lay') }}">Puestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ entity.laydate|format_date('medium', locale='es') }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'lay-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-egg"></i>
            </span>
            <div>
                <h1>Puesta del {{ entity.laydate|format_date('long', locale='es') }}</h1>
                {% if entity.batch %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Lote {{ entity.batch.getNameBatchLay }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-lay-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-lay-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'lay-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('lay_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('lay') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos de la puesta', accent: 'ochre' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha de puesta</dt>
                    <dd class="csa-defs__value">{{ entity.laydate|format_date('long', locale='es') }}</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Cantidad</dt>
                    <dd class="csa-defs__value">{{ entity.amount }} huevos</dd>
                </div>
                {% if entity.batch %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Lote</dt>
                        <dd class="csa-defs__value">
                            <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch.getNameBatchLay }}</a>
                        </dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Semana del año</dt>
                    <dd class="csa-defs__value">{{ entity.week }}</dd>
                </div>
                {% if entity.created %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Creado</dt>
                        <dd class="csa-defs__value">{{ entity.created|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if entity.updated %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Actualizado</dt>
                        <dd class="csa-defs__value">{{ entity.updated|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
