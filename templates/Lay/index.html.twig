{# ============================================================
 # Listado de puestas de huevos (Lay).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Puestas de huevos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Puestas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Gallinas',
        'Puestas de huevos',
        'Registro diario de huevos recogidos por lote. La cantidad y la fecha alimentan las estadísticas semanales.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nueva puesta', { variant: 'primary', href: path('lay_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Lote</th>
                    <th class="csa-table__col-tight">Cantidad</th>
                    <th class="csa-table__col-tight">Semana</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            {% if entity.laydate %}
                                <a class="csa-table__primary" href="{{ path('lay_show', { id: entity.id }) }}">{{ entity.laydate|format_date('medium', locale='es') }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>
                            {% if entity.batch %}{{ entity.batch.getNameBatchLay }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">{{ entity.amount }}</td>
                        <td class="csa-table__col-tight">{{ entity.week }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('lay_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('lay_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay puestas registradas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
