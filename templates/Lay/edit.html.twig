{# ============================================================
 # Editar puesta de huevos — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar puesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('lay') }}">Puestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('lay_show', { id: entity.id }) }}">{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Puesta',
        'Editar puesta',
        'Corrige la fecha, el lote o la cantidad. La semana se recalcula automáticamente al guardar.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'lay-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('lay_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos de la puesta', subtitle: 'Fecha, lote y cantidad.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.lay_date, 'Fecha de puesta', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(edit_form.amount, 'Cantidad') }}
                        {{ csa.field(edit_form.batch, 'Lote', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="submit" form="lay-delete-form" class="csa-btn csa-btn--ghost"
                            onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                        Eliminar puesta
                    </button>
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('lay_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
