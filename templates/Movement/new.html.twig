{# ============================================================
 # Nuevo movimiento de lote — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo movimiento{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('movement') }}">Movimientos</a>
    {% if batch %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('batch_show', { id: batch.id }) }}">{{ batch }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo movimiento</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Gallinas',
        'Nuevo movimiento',
        batch ? ('Lote ' ~ batch ~ '. Indica la fecha del cambio y el sector destino.') : 'Indica la fecha del cambio y el sector destino.'
    ) }}

    {{ form_start(form, {
        'action': path('movement_create', { batch_id: batch.id }),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos del movimiento', subtitle: 'Fecha y sector destino.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.date, 'Fecha', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.sector, 'Sector al que se dirige') }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {% if batch %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('batch_show', { id: batch.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('movement') }) }}
                    {% endif %}
                    {{ form_widget(form.submit, {
                        label: 'Crear movimiento',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
