{# ============================================================
 # Detalle de un movimiento — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Movimiento #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('movement') }}">Movimientos</a>
    {% if entity.batch %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'movement-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-exchange"></i>
            </span>
            <div>
                <h1>Movimiento del {{ entity.date|format_date('long', locale='es') }}</h1>
                {% if entity.batch %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Lote {{ entity.batch }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="submit" form="movement-delete-form" class="csa-btn csa-btn--ghost"
                    onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                Eliminar
            </button>
            {{ csa.btn('Editar', { variant: 'secondary', href: path('movement_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {% if entity.batch %}
                {{ csa.btn('Volver al lote', { variant: 'ghost', href: path('batch_show', { id: entity.batch.id }) }) }}
            {% else %}
                {{ csa.btn('Volver', { variant: 'ghost', href: path('movement') }) }}
            {% endif %}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos del movimiento', accent: 'sky' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha</dt>
                    <dd class="csa-defs__value">{{ entity.date|format_date('long', locale='es') }}</dd>
                </div>
                {% if entity.sector %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Sector destino</dt>
                        <dd class="csa-defs__value">{{ entity.sector }}</dd>
                    </div>
                {% endif %}
                {% if entity.batch %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Lote</dt>
                        <dd class="csa-defs__value">
                            <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
                        </dd>
                    </div>
                {% endif %}
                {% if entity.amount %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Días en el sector</dt>
                        <dd class="csa-defs__value">{{ entity.amount }} días</dd>
                    </div>
                {% endif %}
                {% if entity.created %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Creado</dt>
                        <dd class="csa-defs__value">{{ entity.created|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
