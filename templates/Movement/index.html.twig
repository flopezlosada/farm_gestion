{# ============================================================
 # Listado de movimientos de lotes de gallinas (Movement).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Movimientos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Movimientos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Gallinas',
        'Movimientos de lote',
        'Cambios de sector de cada lote de gallinas. Cada movimiento marca cuándo el lote pasa al sector indicado.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Id</th>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Lote</th>
                    <th>Sector</th>
                    <th class="csa-table__col-tight">Días</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <a class="csa-table__primary" href="{{ path('movement_show', { id: entity.id }) }}">{{ entity.id }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.date %}{{ entity.date|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td>
                            {% if entity.batch %}
                                <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>{% if entity.sector %}{{ entity.sector }}{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">{% if entity.amount %}{{ entity.amount }}{% else %}—{% endif %}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('movement_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('movement_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay movimientos registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
