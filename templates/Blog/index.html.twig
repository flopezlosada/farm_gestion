{# ============================================================
 # Listado de noticias del blog (admin).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Noticias del blog{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Blog</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Blog',
        'Noticias',
        'Entradas publicadas en el blog público de la asociación.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nueva noticia', { variant: 'primary', href: path('blog_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Título</th>
                    <th class="csa-table__col-tight">Creada</th>
                    <th>Slug</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('blog_edit', { id: entity.id }) }}">{{ entity.title }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.created %}{{ entity.created|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td>{{ entity.slug }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('blog_show', { slug: entity.slug }) }}" title="Ver pública" aria-label="Ver pública" target="_blank" rel="noopener"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('blog_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay noticias.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
