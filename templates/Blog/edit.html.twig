{# ============================================================
 # Editar noticia del blog — shell csa.
 # Lado derecho: aside con render(controller) que pinta el panel
 # de medios (Blog/edition.html.twig).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar noticia · {{ entity.title }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('blog') }}">Blog</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ entity.title }}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Blog',
        'Editar ' ~ entity.title,
        'Categoría, título, imagen de portada y contenido.'
    ) }}

    {{ form_start(edit_form, {
        action: path('blog_update', { id: entity.id }),
        method: 'put',
        attr: { role: 'form', class: 'admin-form', 'data-place': 'out-modal', enctype: 'multipart/form-data' }
    }) }}

        <div class="csa-content-aside">

            <div class="csa-stack-lg">

                {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Categoría, título e imagen de portada.' } %}
                    {% block body %}
                        {% import '_macros/csa.html.twig' as csa %}
                        <div class="csa-form-grid">
                            {{ csa.field(edit_form.category, 'Categoría') }}
                            {{ csa.field(edit_form.title, 'Título') }}
                            {{ csa.field(edit_form.file, 'Imagen de portada', { full: true, hint: 'opcional · sustituye la actual' }) }}
                        </div>
                    {% endblock %}
                {% endembed %}

                {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Contenido', subtitle: 'Texto enriquecido con TinyMCE.' } %}
                    {% block body %}
                        {% import '_macros/csa.html.twig' as csa %}
                        <div class="csa-form-grid">
                            {{ csa.field(edit_form.content, 'Contenido', { full: true, attr: { class: 'tinymce', 'data-theme': 'advanced' } }) }}
                        </div>
                    {% endblock %}
                {% endembed %}

            </div>

            <aside class="admin-assets">
                {{ render(controller('App\\Controller\\BlogController::edition', { id: entity.id, object_class: entity.getClass|lower })) }}
            </aside>

        </div>

        <div class="csa-row-between" style="margin-top: var(--csa-sp-6); padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
            <div></div>
            <div class="csa-row">
                {{ csa.btn('Cancelar', { variant: 'ghost', href: path('blog') }) }}
                {{ form_widget(edit_form.submit, {
                    label: 'Guardar cambios',
                    attr: { class: 'csa-btn csa-btn--primary' }
                }) }}
            </div>
        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    <script src="{{ asset('bundles/app/js/jquery-modal/jquery.modal.min.js') }}"></script>
{% endblock %}
