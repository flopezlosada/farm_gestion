{% extends 'base_blog.html.twig' %}

{% block container %}

    <div class="row p-3">
        <div class="col-lg-11">

            {% block listing_header %}
                {% set effective_category = (category is defined and category) ? category : (post is defined and post and post.category ? post.category : null) %}
                {% if effective_category and effective_category.id == 4 %}
                    <header class="mb-4">
                        <h1 class="mb-2">
                            <span style="color: rgb(248, 177, 51)">Nuestras</span>
                            <span style="color: #138504">recetas</span>
                        </h1>
                        <h4 class="text-muted">
                            Ideas sencillas para sacar partido a las verduras de la cesta, compartidas por nuestrxs socixs.
                        </h4>
                        <p class="mt-3">
                            Aquí encontrarás recetas pensadas para cocinar de temporada, aprovechar cada hoja y descubrir nuevas formas de comer lo que la huerta nos da.
                            <br>
                            Si tienes una receta que quieras compartir con la comunidad, escríbenos y la publicamos.
                        </p>
                    </header>
                {% elseif effective_category and category is defined %}
                    <header class="mb-4">
                        <h1 class="mb-2">
                            <span style="color: rgb(248, 177, 51)">Categoría:</span>
                            <span style="color: #138504">{{ effective_category.name }}</span>
                        </h1>
                        <h4 class="text-muted">Todas las entradas publicadas en {{ effective_category.name }}.</h4>
                    </header>
                {% else %}
                    <header class="mb-4">
                        <h1 class="mb-2">
                            <span style="color: rgb(248, 177, 51)">Bienvenidos</span>
                            <span style="color: #138504">a nuestro blog</span>
                        </h1>
                        <h4 class="text-muted">
                            Si quieres venir a conocernos o participar en una jornada como voluntario no dudes en contactarnos y hacernos una visita.
                        </h4>
                        <p class="mt-3">
                            En este espacio puedes mantenerte al día de todo lo que ocurre dentro de nuestra asociación, también tenemos un sitio dedicado a las recetas que nos aportan los socios para poder hacer un buen uso de nuestra cesta.
                            <br>
                            Esperamos verte pronto por la huerta o en el local.
                        </p>
                    </header>
                {% endif %}
            {% endblock %}

            <div class="card border-1 bg-light">
                <div class="card-body p-3">
                    {% block post_main %}
                        {% for post in entities %}
                            <div class="blog-item">
                                {% include 'Blog/post_main.html.twig' with { extend: 0 } %}
                            </div>
                        {% endfor %}
                    {% endblock %}

                    {% if entities is defined %}
                        <div class="pagination justify-content-center mb-4">
                            {{ knp_pagination_render(entities) }}
                        </div>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>

{% endblock %}
