<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}CSA Vega de Jarama{% endblock %}</title>

    {% block analytics %}
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-SW7KHJSBGQ"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){ dataLayer.push(arguments); }
            gtag('js', new Date());
            gtag('config', 'G-SW7KHJSBGQ');
        </script>
    {% endblock %}

    {% block stylesheets %}
        <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans&family=Nunito:wght@600;700;800&display=swap" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
        <link href="{{ asset('bundles/app/frontend/lib/flaticon/font/flaticon.css') }}" rel="stylesheet">
        <link href="{{ asset('bundles/app/frontend/lib/owlcarousel/assets/owl.carousel.min.css') }}" rel="stylesheet">
        <link href="{{ asset('bundles/app/frontend/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css') }}" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/lightgallery@2.7.2/css/lightgallery.css" rel="stylesheet">
        <link href="{{ asset('bundles/app/frontend/css/style.css') }}" rel="stylesheet">
        <style>
            /* ---- Menú principal: hover / abierto / activo ----
               El tema pinta hover, .show y .active con un bloque naranja
               sólido (style.css:~9768) y texto blanco al abrir (~4436). Lo
               anulamos: el único indicador es el COLOR ámbar (el activo, además,
               en negrita). Sin subrayado ni relleno. Por defecto, blanco. */
            .navbar-dark .navbar-nav .nav-link:hover,
            .navbar-dark .navbar-nav .nav-link:focus,
            .navbar-dark .navbar-nav .nav-item.show > .nav-link,
            .navbar-dark .navbar-nav .nav-link.active {
                color: rgb(248, 177, 51);
                background: transparent;
                box-shadow: none;
            }
            .navbar-dark .navbar-nav .nav-link.active { font-weight: 700; }

            /* Menú más bajo: el tema usa padding vertical de 30px
               (style.css:~9786), demasiado alto. */
            .navbar-dark .navbar-nav .nav-link {
                padding-top: 15px;
                padding-bottom: 15px;
            }

            /* ---- Submenús: prolongación oscura del menú (no una tarjeta
               blanca que parece de otra página). Flush (margin-top 0) para no
               dejar un hueco que rompa el hover al ir hacia el submenú. ---- */
            .navbar-dark .navbar-nav .dropdown-menu {
                background: #181818;
                border: none;
                border-radius: 0 0 10px 10px;
                box-shadow: 0 14px 30px rgba(0, 0, 0, .35);
                padding: 6px;
                margin-top: 0;
                min-width: 13rem;
            }
            .navbar-dark .navbar-nav .dropdown-item {
                padding: 10px 14px;
                border-radius: 7px;
                color: #F2F2F4;
                font-size: 16px;
                font-weight: 600;
                transition: background .15s ease, color .15s ease;
            }
            .navbar-dark .navbar-nav .dropdown-item:hover,
            .navbar-dark .navbar-nav .dropdown-item:focus {
                background: rgba(255, 255, 255, .07);
                color: rgb(248, 177, 51);
            }
            .navbar-dark .navbar-nav .dropdown-item.active {
                background: rgba(255, 255, 255, .07);
                color: rgb(248, 177, 51);
                font-weight: 700;
            }
        </style>
    {% endblock %}
</head>

<body>

    {% block topbar %}
        <div class="container-fluid">
            <div class="row bg-secondary py-2 px-lg-5">
                <div class="col-lg-6 text-center text-lg-left mb-2 mb-lg-0">
                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        {# ROLE_ADMIN incluye ROLE_PARTNER por jerarquía, así que no
                         # podemos usar el rol para distinguir; chequeamos si user
                         # tiene un Partner vinculado realmente. #}
                        {% set has_gestion = is_granted('ROLE_ADMIN') or is_granted('ROLE_GESTION_GRANJA') or is_granted('ROLE_GESTION_SOCIXS') or is_granted('ROLE_GESTION_REPARTO') or is_granted('ROLE_BLOG') %}
                        {% set is_partner = app.user.partner is defined and app.user.partner %}
                        {% if is_partner %}
                            <a class="text-white px-2" href="{{ path('panel') }}"><i class="fa fa-user-circle mr-1"></i>Mi panel</a>
                        {% endif %}
                        {% if has_gestion %}
                            <a class="text-white px-2" href="{{ path('dashboard') }}"><i class="fa fa-cog mr-1"></i>Gestión</a>
                        {% endif %}
                        <a class="text-white px-2" href="{{ path('app_logout') }}"><i class="fa fa-sign-out-alt mr-1"></i>Salir</a>
                    {% else %}
                        <a class="text-white px-2" href="{{ path('app_login') }}"><i class="fa fa-user mr-1"></i>Acceso socixs</a>
                    {% endif %}
                </div>
                <div class="col-lg-6 text-center text-lg-right">
                    <div class="d-inline-flex align-items-center">
                        <a class="text-white px-3" target="_blank" href="https://www.facebook.com/CSA.Vega.de.Jarama/?locale=es_ES"><i class="fab fa-facebook-f"></i></a>
                        <a class="text-white px-3" target="_blank" href="https://twitter.com/csavegadejarama"><i class="fab fa-twitter"></i></a>
                        <a class="text-white px-3" target="_blank" href="https://masto.es/@csavegadejarama"><i class="fab fa-mastodon"></i></a>
                        <a class="text-white px-3" target="_blank" href="https://www.instagram.com/csavegadejarama/?hl=es"><i class="fab fa-instagram"></i></a>
                        <a class="text-white px-3" target="_blank" href="https://www.youtube.com/channel/UCBi4lm55t6X3lqaql2tG8xg"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <div class="row py-3 px-lg-5">
                <div class="col-lg-4">
                    <a href="{{ path('homepage') }}" class="navbar-brand d-none d-lg-block">
                        <h1 class="m-0 display-5 text-capitalize"><span style="color: rgb(151, 181, 57)">CSA</span>Vega de Jarama</h1>
                    </a>
                </div>
                <div class="col-lg-8 text-center text-lg-right">
                    <div class="d-inline-flex align-items-center">
                        <div class="d-inline-flex flex-column text-center pr-2">
                            <h6>Mantente al día</h6>
                            <p class="m-0">Visita nuestra agenda</p>
                        </div>
                        <div class="d-inline-flex flex-column text-center px-3 border-right">
                            <a href="{{ path('asambleas') }}">
                                <img src="{{ asset('bundles/app/img/calendario.png') }}" width="50" height="50" alt="Agenda de eventos">
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endblock %}

    {% block navbar %}
        {# Ruta actual para resaltar la sección abierta en el menú. #}
        {% set _route = app.request.attributes.get('_route') %}
        <div class="container-fluid p-0">
            <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-lg-5">
                <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between px-3" id="navbarCollapse">
                    <div class="navbar-nav mr-auto py-0">
                        <a href="{{ path('socios') }}" class="nav-item nav-link{{ _route == 'socios' ? ' active' }}"><strong>Hazte socix</strong></a>
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle{{ _route in ['huerta', 'nuestroFuturo'] ? ' active' }}" data-toggle="dropdown">Huerta</a>
                            <div class="dropdown-menu">
                                <a href="{{ path('huerta') }}" class="dropdown-item{{ _route == 'huerta' ? ' active' }}">La huerta</a>
                                <a href="{{ path('nuestroFuturo') }}" class="dropdown-item{{ _route == 'nuestroFuturo' ? ' active' }}">Nuestro futuro</a>
                            </div>
                        </div>
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link dropdown-toggle{{ _route == 'voluntariado' ? ' active' }}" data-toggle="dropdown">Creando CSA</a>
                            <div class="dropdown-menu">
                                <a href="{{ path('voluntariado') }}" class="dropdown-item{{ _route == 'voluntariado' ? ' active' }}">Voluntariado y comisiones</a>
                            </div>
                        </div>
                        <a href="{{ path('somos') }}" class="nav-item nav-link{{ _route == 'somos' ? ' active' }}">Quiénes somos</a>
                        <a href="{{ path('asambleas') }}" class="nav-item nav-link{{ _route in ['asambleas', 'evento_show'] ? ' active' }}">Agenda</a>
                        <a href="{{ path('frontend_blog') }}" class="nav-item nav-link{{ _route in ['frontend_blog', 'blog_show'] ? ' active' }}">Blog</a>
                        <a href="{{ path('blog_category_show', { id: 4 }) }}" class="nav-item nav-link{{ _route == 'blog_category_show' ? ' active' }}">Recetas</a>
                    </div>
                </div>
            </nav>
        </div>
    {% endblock %}

    {% block content %}{% endblock %}

    {% block footer %}
        <div class="container-fluid bg-dark text-white mt-5 py-5 px-sm-3 px-md-5">
            <div class="row pt-5">
                <div class="col-lg-4 col-md-12 mb-5">
                    <h1 class="mb-3 display-5 text-capitalize text-white"><span class="text-primary">CSA</span>Vega de Jarama</h1>
                </div>
                <div class="col-lg-8 col-md-12">
                    <div class="row">
                        <div class="col-md-4 mb-5">
                            <h5 class="text-primary mb-4">Contacto</h5>
                            <a id="mapa" class="fa fa-map-marker-alt mr-2" href="https://www.google.es/maps/@40.8339838,-3.4956325,150m/data=!3m1!1e3"> Torremocha de Jarama 28189, Madrid</a>
                            <p>Dirección: Calle Olivar, 13</p>
                            <p><i class="fa fa-envelope mr-2"></i>csa@csavegadejarama.org</p>
                            <div class="d-flex justify-content-start mt-4">
                                <a class="btn btn-outline-light rounded-circle text-center mr-2 px-0" style="width: 36px; height: 36px;" href="https://www.facebook.com/CSA.Vega.de.Jarama/?locale=es_ES"><i class="fab fa-facebook-f"></i></a>
                                <a class="btn btn-outline-light rounded-circle text-center mr-2 px-0" style="width: 36px; height: 36px;" href="https://twitter.com/csavegadejarama"><i class="fab fa-twitter"></i></a>
                                <a class="btn btn-outline-light rounded-circle text-center mr-2 px-0" style="width: 36px; height: 36px;" href="https://masto.es/@csavegadejarama"><i class="fab fa-mastodon"></i></a>
                                <a class="btn btn-outline-light rounded-circle text-center mr-2 px-0" style="width: 36px; height: 36px;" href="https://www.instagram.com/csavegadejarama/?hl=es"><i class="fab fa-instagram"></i></a>
                                <a class="btn btn-outline-light rounded-circle text-center mr-2 px-0" style="width: 36px; height: 36px;" href="https://www.youtube.com/channel/UCBi4lm55t6X3lqaql2tG8xg"><i class="fab fa-youtube"></i></a>
                            </div>
                        </div>
                        <div class="col-md-4 mb-5">
                            {{ render(controller('App\\Controller\\GestionController::contactWidget')) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid text-white py-4 px-sm-3 px-md-5" style="background: #111111;">
            <div class="row">
                <div class="col-md-6 text-center text-md-left mb-3 mb-md-0">
                    <p class="m-0 text-white">&copy; <a class="text-white font-weight-bold" href="{{ path('homepage') }}">CSA Vega de Jarama</a></p>
                </div>
            </div>
        </div>

        <a href="#" class="btn btn-lg btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>
    {% endblock %}

    {% block javascripts %}
        <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset('bundles/app/frontend/lib/easing/easing.min.js') }}"></script>
        <script src="{{ asset('bundles/app/frontend/lib/owlcarousel/owl.carousel.min.js') }}"></script>
        <script src="{{ asset('bundles/app/frontend/lib/tempusdominus/js/moment.min.js') }}"></script>
        <script src="{{ asset('bundles/app/frontend/lib/tempusdominus/js/moment-timezone.min.js') }}"></script>
        <script src="{{ asset('bundles/app/frontend/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js') }}"></script>
        <script src="https://cdn.jsdelivr.net/npm/lightgallery@2.7.2/lightgallery.umd.min.js"></script>
        <script src="{{ asset('bundles/app/frontend/js/main.js') }}"></script>
    {% endblock %}

</body>
</html>
