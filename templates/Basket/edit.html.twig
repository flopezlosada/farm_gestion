{# ============================================================
 # Editar cesta semanal — shell csa.
 # Sólo se edita la nota (TinyMCE). El controller redirecciona
 # al detalle de Production tras guardar.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar cesta #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('basket') }}">Cestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('basket_show', { id: entity.id }) }}">#{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cestas',
        'Editar cesta del ' ~ entity.date|format_date('long', locale='es'),
        'Edita las notas asociadas a la cesta semanal.'
    ) }}

    {{ form_start(edit_form, {
        'action': path('basket_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Notas', subtitle: 'Apuntes sobre el contenido de esta cesta.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.note, 'Notas', { full: true, attr: { class: 'tinymce', 'data-theme': 'advanced' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Volver al detalle de la cesta', { variant: 'ghost', href: path('production_show_basket_detail', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
