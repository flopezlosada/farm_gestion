{# ============================================================
 # Detalle de una cesta semanal — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cesta #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('basket') }}">Cestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'basket-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-shopping-basket"></i>
            </span>
            <div>
                <h1>Cesta del {{ entity.date|format_date('long', locale='es') }}</h1>
                <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                    Semana {{ entity.week }}{% if entity.amount %} · {{ entity.amount }} unidades{% endif %}
                </div>
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-delete-basket-{{ entity.id }}').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-delete-basket-' ~ entity.id, {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar esta cesta',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'basket-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('basket_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('basket') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos de la cesta', accent: 'green' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha</dt>
                    <dd class="csa-defs__value">{{ entity.date|format_date('long', locale='es') }}</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Semana del año</dt>
                    <dd class="csa-defs__value">{{ entity.week }}</dd>
                </div>
                {% if entity.amount %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Cantidad</dt>
                        <dd class="csa-defs__value">{{ entity.amount }}</dd>
                    </div>
                {% endif %}
                {% if entity.note %}
                    <div class="csa-defs__row csa-defs__row--full">
                        <dt class="csa-defs__label">Notas</dt>
                        <dd class="csa-defs__value">{{ entity.note|raw }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
