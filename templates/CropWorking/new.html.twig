{# ============================================================
 # Nuevo cultivo (CropWorking) — migrado al shell csa.
 # ============================================================
 # Si llega con crop_id en la URL, el controller pre-rellena el
 # entity.crop antes de renderizar — el dropdown aparece con el
 # cultivo ya seleccionado.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo cultivo{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking') }}">Cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cultivo',
        'Nuevo cultivo',
        'Abre un ciclo de cultivo nuevo. Después podrás registrar siembras, sectores y producciones.'
    ) }}

    {{ form_start(form, {
        'action': path('cropworking_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {# ---- 1. Identidad ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Cultivo y descripción del ciclo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.crop, 'Cultivo') }}
                        {{ csa.field(form.name, 'Descripción', { hint: 'p. ej. "Acelga 2026"' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 2. Producción ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Producción', subtitle: 'Superficie, estimación y marco de plantación.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.surface, 'Superficie de cultivo', { hint: 'm²' }) }}
                        {{ csa.field(form.estimated_production, 'Producción estimada', { hint: 'kg' }) }}
                        {{ csa.field(form.planting_pattern, 'Marco de plantación', { hint: 'cm x cm', full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 3. Observaciones ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Observaciones', subtitle: 'Información libre sobre el cultivo.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Observaciones', hint: 'opcional', full: true } %}
                        {% block body %}
                            {{ form_widget(form.content, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            {# ---- Footer de acciones ---- #}
            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('cropworking') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear cultivo',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
