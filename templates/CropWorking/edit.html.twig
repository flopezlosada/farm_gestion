{# ============================================================
 # Editar cultivo (CropWorking) — migrado al shell csa.
 # ============================================================
 # form_theme 'form_div_layout.html.twig' evita que Bootstrap 3
 # inyecte clases en los widgets. El campo `content` conserva
 # la clase `tinymce` para que tinymce_init() lo enganche.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar cultivo · {{ entity }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking') }}">Cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking_show', { id: entity.id }) }}">{{ entity }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cultivo',
        'Editar ' ~ entity,
        'Actualiza los datos del cultivo. Los cambios afectan a registros futuros, no a los históricos.'
    ) }}

    {# El delete_form va fuera del edit_form (HTML no permite forms anidados).
     # El botón visible "Eliminar cultivo" se sitúa dentro del footer del edit_form
     # y se asocia al delete_form vía el atributo HTML5 form="...". #}
    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'cropworking-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('cropworking_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {# ---- 1. Identidad ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Cómo se identifica el ciclo del cultivo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.name, 'Descripción', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 2. Producción ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Producción', subtitle: 'Superficie, estimación y marco de plantación.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.surface, 'Superficie de cultivo', { hint: 'm²' }) }}
                        {{ csa.field(edit_form.estimated_production, 'Producción estimada', { hint: 'kg' }) }}
                        {{ csa.field(edit_form.planting_pattern, 'Marco de plantación', { hint: 'cm x cm', full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 3. Observaciones ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Observaciones', subtitle: 'Información libre sobre el cultivo.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Observaciones', hint: 'opcional', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.content, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            {# ---- Footer de acciones ---- #}
            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button
                        type="submit"
                        form="cropworking-delete-form"
                        class="csa-btn csa-btn--ghost"
                        onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');"
                    >Eliminar cultivo</button>
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('cropworking_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
