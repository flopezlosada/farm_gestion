{# ============================================================
 # Listado de cultivos (CropWorking) — migrado al shell csa.
 # ============================================================
 # findActive() en el repo solo trae los cultivos en producción
 # (finish=0). No se muestra columna de estado porque todos los
 # listados están activos por definición.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cultivos en producción{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span>Granja</span>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cultivos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Cultivos en producción',
        'Ciclos de cultivo activos. Producción estimada vs producción real, sectores asignados y trabajos culturales.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Cultivo</th>
                    <th class="csa-table__col-tight">Superficie</th>
                    <th class="csa-table__col-tight">Estimada</th>
                    <th class="csa-table__col-tight">Producción real</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <div class="csa-table__id-cell">
                                <span class="csa-table__id-marker"><i class="fa fa-leaf"></i></span>
                                <div>
                                    <a class="csa-table__primary" href="{{ path('cropworking_show', { id: entity.id }) }}">
                                        {{ entity.name }}
                                    </a>
                                    <div class="csa-table__sub">
                                        {{ entity.getCrop }}
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.surface %}
                                {{ entity.surface }} m²
                            {% else %}
                                <span class="csa-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.estimatedproduction %}
                                {{ entity.estimatedproduction }} kg
                            {% else %}
                                <span class="csa-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.getTotalProduction %}
                                <strong>{{ entity.getTotalProduction }}</strong> kg
                            {% else %}
                                <span class="csa-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('cropworking_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('cropworking_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay cultivos en producción.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
