{# ============================================================
 # Añadir sector a un cultivo (CropWorking) — migrado al shell csa.
 # ============================================================
 # Selección encadenada: el cambio en zone dispara una petición
 # AJAX a select_sector que rellena el dropdown de sectores. Los
 # IDs #form_zone y #form_sector dependen del patrón Symfony con
 # el form llamado "form".
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Añadir sector · {{ crop_working }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking') }}">Cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking_show', { id: crop_working.id }) }}">{{ crop_working }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Añadir sector</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cultivo · ' ~ crop_working,
        'Añadir sector de producción',
        'Selecciona primero la zona y luego el sector donde se implanta el cultivo.'
    ) }}

    {{ form_start(form, {
        'action': path('cropworking_added_sector', { id: crop_working.id }),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {# ---- 1. Sector ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Zona y sector', subtitle: 'El sector se filtra automáticamente al elegir zona.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.zone, 'Zona') }}
                        {{ csa.field(form.sector, 'Sector') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- Footer ---- #}
            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('cropworking_show', { id: crop_working.id }) }) }}
                    {{ form_widget(form.submit, {
                        label: 'Añadir sector',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        $(function () {
            $('#form_sector').html('');
            $('#form_sector').prop('required', true);
            $('#form_zone').change(function () {
                var data = { zone_id: $(this).val() };
                $.ajax({
                    type: 'post',
                    url: '{{ path("select_sector") }}',
                    data: data,
                    success: function (data) {
                        $('#form_sector').html(data);
                    }
                });
            });
        });
    </script>
{% endblock %}
