{# ============================================================
 # Listado de clientxs (Purchaser) — compradorxs de productos.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Clientxs{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Clientxs</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Ventas',
        'Clientxs',
        'Personas a las que se les vende productos (sobre todo huevos). Si compran con frecuencia, se anota la cadencia.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevx clientx', { variant: 'primary', href: path('purchaser_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th class="csa-table__col-tight">¿Regular?</th>
                    <th class="csa-table__col-tight">Frecuencia</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('purchaser_show', { id: entity.id }) }}">{{ entity.name }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.regular == 1 %}Sí{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.regular == 1 %}cada {{ entity.getOftenBuyingEggs }} días{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('purchaser_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('purchaser_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay clientxs registradxs.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
