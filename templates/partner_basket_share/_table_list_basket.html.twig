{# ============================================================
 # Sub-tabla del reparto semanal por tipo de cesta — partial.
 # Recibe: entity (lista de basket), accent (color del card),
 # type (label), basket_share_id (1-5 según modalidad).
 # ============================================================ #}

{%- set count = 0 -%}
{%- if basket_share_id == 4 %}{% set count = basket_old_half_basket_partners_amount / 2 %}
{%- elseif basket_share_id == 1 %}{% set count = basket_weekly_partners_amount %}
{%- elseif basket_share_id == 2 %}{% set count = basket_biweekly_partners_amount %}
{%- elseif basket_share_id == 3 %}{% set count = basket_monthly_partners_amount %}
{%- elseif basket_share_id == 5 %}{% set count = basket_only_egg_partners_amount %}
{%- endif %}

{% embed '_components/csa_card.html.twig' with { title: 'Cestas ' ~ type ~ ' · ' ~ count, accent: accent } %}
    {% block body %}
        <div class="csa-table-wrap">
            <table class="csa-table">
                <thead>
                    <tr>
                        <th>Localidad</th>
                        <th>Nombre</th>
                        {% if basket_share_id != 4 %}
                            <th class="csa-table__col-tight">Cestas</th>
                        {% endif %}
                        <th class="csa-table__col-tight">Huevos</th>
                        <th>Estado</th>
                        <th>Cambios</th>
                    </tr>
                </thead>
                <tbody>
                {% if basket_share_id == 4 %}
                    {# Compartidas: dos filas correlativas con el mismo
                       color de fondo (randColor) para indicar la pareja. #}
                    {% for basket in entity %}
                        {% if not basket.partner.isListed %}
                            {{ basket.partner.setIsListed(1) }}
                            {% set color = randColor(true) %}
                            <tr style="background-color: {{ color }};">
                                <td>{{ basket.partner.weeklyBasketGroup.name }}</td>
                                <td>
                                    <a href="{{ path('partner_show', { id: basket.partner.id }) }}">{{ basket.partner }}</a>
                                </td>
                                <td class="csa-table__col-tight">{{ basket.partner.getActiveBasket.eggAmount ?: 'Sin huevos' }}</td>
                                <td>{{ basket.partner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                                <td>
                                    {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 1 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">No la recoge</a>
                                    {% elseif basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 2 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">Al final sí recoge</a>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr style="background-color: {{ color }};">
                                {{ basket.partner.sharePartner.setIsListed(1) }}
                                <td>{{ basket.partner.sharePartner.weeklyBasketGroup.name }}</td>
                                <td>
                                    <a href="{{ path('partner_show', { id: basket.partner.sharePartner.id }) }}">{{ basket.partner.sharePartner }}</a>
                                </td>
                                <td class="csa-table__col-tight">{{ basket.partner.getActiveBasket.eggAmount ?: 'Sin huevos' }}</td>
                                <td>{{ basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                                <td>
                                    {% if basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus.id == 1 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: basket.partner.sharePartner.getCurrentBasket.id }) }}">No la recoge</a>
                                    {% elseif basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus.id == 2 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: basket.partner.sharePartner.getCurrentBasket.id }) }}">Al final sí recoge</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endif %}
                    {% else %}
                        <tr><td colspan="5" class="csa-muted" style="text-align: center;">Sin cestas compartidas.</td></tr>
                    {% endfor %}
                {% else %}
                    {% for basket in entity %}
                        <tr>
                            <td>{{ basket.partner.weeklyBasketGroup.name }}</td>
                            <td>
                                <a href="{{ path('partner_show', { id: basket.partner.id }) }}">{{ basket.partner }}</a>
                            </td>
                            <td class="csa-table__col-tight">{{ basket.partner.getActiveBasket.amount }}</td>
                            <td class="csa-table__col-tight">
                                {{ basket.partner.getActiveBasket.eggAmount ?: 'Sin huevos' }}
                                {% if basket.partner.getActiveBasket.eggPeriod %}
                                    ({{ basket.partner.getActiveBasket.eggPeriod }})
                                {% endif %}
                            </td>
                            <td>{{ basket.partner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                            <td>
                                {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 1 %}
                                    <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">No la recoge</a>
                                {% elseif basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 2 %}
                                    <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">Al final sí recoge</a>
                                {% endif %}

                                {% if basket_share_id == 2 %}
                                    {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 1 %}
                                        <br><a href="{{ path('partner_basket_monthly_change_week', { weekly_basket_id: basket.partner.getCurrentBasket.id }) }}"
                                               onclick="return confirm('Esta acción no se puede deshacer. ¿Estás segurx?');">
                                            Cambiar a otra semana
                                        </a>
                                    {% endif %}
                                {% elseif basket_share_id == 3 %}
                                    {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id == 1 %}
                                        <br><a href="{{ path('partner_basket_monthly_change_week', { weekly_basket_id: basket.partner.getCurrentBasket.id }) }}"
                                               onclick="return confirm('Esta acción no se puede deshacer. ¿Estás segurx?');">
                                            La recoge la semana siguiente
                                        </a>
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="csa-muted" style="text-align: center;">Sin cestas {{ type }}.</td></tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
    {% endblock %}
{% endembed %}
