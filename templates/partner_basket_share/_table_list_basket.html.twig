<div class="row">
    <div class="col-lg-12">
        <div class="panel {{ class }}">
            <div class="panel-heading">
                Listado de cestas {{ type }}.
                {% if basket_share_id==4 %}
                    {{ basket_old_half_basket_partners_amount/2 }}
                {% elseif basket_share_id==1 %}
                    {{ basket_weekly_partners_amount }}
                {% elseif basket_share_id==2 %}
                    {{ basket_biweekly_partners_amount }}
                {% elseif basket_share_id==3 %}
                    {{ basket_monthly_partners_amount }}
                {% elseif basket_share_id==5 %}
                    {{ basket_only_egg_partners_amount }}
                {% endif %}
                cestas
            </div>
            <div class="panel-body">
                <div class="table-responsive">
                    <table id="table_list"
                           class="table table-striped table-bordered table-hover dataTable no-footer"
                           aria-describedby="dataTables-example_info">
                        <thead>
                        <tr>
                            <th>Localidad</th>
                            <th>Nombre</th>
                            {% if basket_share_id!=4 %}
                            <th>Cantidad de cestas</th>
                            {% endif %}
                            <th>Huevos</th>
                            <th>Qué va a hacer con la cesta</th>
                            <th>Cambios</th>
                        </tr>
                        </thead>
                        <tfoot>
                        <tr role="row">
                        </tr>
                        </tfoot>
                        <tbody>
                        {% if basket_share_id==4 %}
                            {% for basket in entity %}


                                {% if not basket.partner.isListed %}
                                    {{ basket.partner.setIsListed(1) }}
                                    {% set color=randColor(true) %}
                                    <tr style="background-color: {{ color }}">
                                        <td>{{ basket.partner.weeklyBasketGroup.name }}</td>
                                        <td>
                                            <a
                                                    href="{{ path('partner_show', {'id': basket.partner.id}) }}">{{ basket.partner }}</a>
                                        </td>
                                        <td>{{ basket.partner.getActiveBasket.eggAmount?:'Sin huevos' }}</td>
                                        <td>{{ basket.partner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                                        <td>
                                            {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==1 %}
                                                <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 2, 'weekly_basket_id': basket.partner.getCurrentBasket.id}) }}">
                                                    No la recoge</a>
                                            {% elseif basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==2 %}
                                                <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 1, 'weekly_basket_id': basket.partner.getCurrentBasket.id}) }}">Al
                                                    final sí recoge</a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    <tr style="background-color: {{ color }}">
                                        {{ basket.partner.sharePartner.setIsListed(1) }}
                                        <td>{{ basket.partner.sharePartner.weeklyBasketGroup.name }}</td>
                                        <td>
                                            <a
                                                    href="{{ path('partner_show', {'id': basket.partner.sharePartner.id}) }}">{{ basket.partner.sharePartner }}</a>
                                        </td>
                                        <td>{{ basket.partner.getActiveBasket.eggAmount?:'Sin huevos' }}</td>
                                        <td>{{ basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                                        <td>
                                            {% if basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus.id==1 %}
                                                <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 2, 'weekly_basket_id': basket.partner.sharePartner.getCurrentBasket.id}) }}">
                                                    No la recoge</a>
                                            {% elseif basket.partner.sharePartner.getCurrentBasket.getWeeklyBasketStatus.id==2 %}
                                                <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 1, 'weekly_basket_id': basket.partner.sharePartner.getCurrentBasket.id}) }}">Al
                                                    final sí recoge</a>
                                            {% endif %}
                                        </td>
                                    </tr>

                                {% endif %}
                            {% endfor %}
                        {% else %}
                            {% for basket in entity %}

                                <tr>
                                    <td>{{ basket.partner.weeklyBasketGroup.name }}</td>
                                    <td>
                                        <a href="{{ path('partner_show', {'id': basket.partner.id}) }}">{{ basket.partner }}</a>
                                    </td>
                                    <td>{{ basket.partner.getActiveBasket.amount }}</td>
                                    <td>{{ basket.partner.getActiveBasket.eggAmount?:'Sin huevos' }}
                                        {% if basket.partner.getActiveBasket.eggPeriod %}
                                            ({{ basket.partner.getActiveBasket.eggPeriod }})
                                        {% endif %}
                                    </td>

                                    <td>{{ basket.partner.getCurrentBasket.getWeeklyBasketStatus }}</td>
                                    <td>

                                        {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==1 %}
                                            <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 2, 'weekly_basket_id': basket.partner.getCurrentBasket.id}) }}">
                                                No la recoge</a>
                                        {% elseif basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==2 %}
                                            <a href="{{ path('partner_basket_weekly_change_status', {'weekly_basket_status_id': 1, 'weekly_basket_id': basket.partner.getCurrentBasket.id}) }}">Al
                                                final sí recoge</a>
                                        {% endif %}

                                        {% if basket_share_id==2 %}
                                            {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==1 %}
                                                <br><a
                                                    href="{{ path('partner_basket_monthly_change_week', {'weekly_basket_id':  basket.partner.getCurrentBasket.id}) }}"
                                                    onclick="return confirm('Esta acción no se puede deshacer, si luego quiere recogerla esta semana no va a poder, ¿estás segura/o?');">
                                                Se quiere cambiar de semana al otro turno
                                            </a>
                                            {% endif %}
                                        {% elseif basket_share_id==3 %}
                                            {% if basket.partner.getCurrentBasket.getWeeklyBasketStatus.id==1 %}
                                                <br><a
                                                    href="{{ path('partner_basket_monthly_change_week', {'weekly_basket_id':  basket.partner.getCurrentBasket.id}) }}"
                                                    onclick="return confirm('Esta acción no se puede deshacer, si luego quiere recogerla esta semana no va a poder, ¿estás segura/o?');">La
                                                quiere recoger la semana que viene</a>
                                            {% endif %}
                                        {% elseif basket_share_id==4 %}

                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                        </tbody>
                    </table>

                </div>
            </div>
        </div>
    </div>
</div>