{% import '_macros/csa.html.twig' as csa %}
{# ============================================================
 # Sub-tabla del reparto semanal por tipo de cesta — partial.
 # Recibe: entity (lista de basket), accent (color del card),
 # type (label), basket_share_id (1-5 según modalidad).
 # ============================================================ #}

{%- set count = 0 -%}
{%- if basket_share_id == 4 %}{% set count = basket_old_half_basket_partners_amount / 2 %}
{%- elseif basket_share_id == 1 %}{% set count = basket_weekly_partners_amount %}
{%- elseif basket_share_id == 2 %}{% set count = basket_biweekly_partners_amount %}
{%- elseif basket_share_id == 3 %}{% set count = basket_monthly_partners_amount %}
{%- elseif basket_share_id == 5 %}{% set count = basket_only_egg_partners_amount %}
{%- endif %}

{% embed '_components/csa_card.html.twig' with { title: 'Cestas ' ~ type ~ ' · ' ~ count, accent: accent } %}
    {% block body %}
        {% import '_macros/csa.html.twig' as csa %}
        <div class="csa-table-wrap">
            <table class="csa-table">
                <thead>
                    <tr>
                        <th>Localidad</th>
                        <th>Nombre</th>
                        {% if basket_share_id != 4 %}
                            <th class="csa-table__col-tight">Cestas</th>
                        {% endif %}
                        <th class="csa-table__col-tight">Huevos</th>
                        <th>Estado</th>
                        <th>Cambios</th>
                    </tr>
                </thead>
                <tbody>
                {% if basket_share_id == 4 %}
                    {# Compartidas: dos filas correlativas con el mismo
                       color de fondo (randColor) para indicar la pareja. #}
                    {% for basket in entity %}
                        {% if not basket.partner.isListed %}
                            {{ basket.partner.setIsListed(1) }}
                            {% set active = basket.partner.getActiveBasket %}
                            {% set current = basket.partner.getCurrentBasket %}
                            {% set share = basket.partner.sharePartner %}
                            {% set share_current = share ? share.getCurrentBasket : null %}
                            {% set color = randColor(true) %}
                            <tr style="background-color: {{ color }};">
                                <td>{{ basket.partner.weeklyBasketGroup.name ?? '—' }}</td>
                                <td>
                                    <a href="{{ path('partner_show', { id: basket.partner.id }) }}">{{ basket.partner }}</a>
                                </td>
                                <td class="csa-table__col-tight">{{ active.eggAmount|default('Sin huevos') ?: 'Sin huevos' }}</td>
                                <td>{{ current ? current.getWeeklyBasketStatus : '—' }}</td>
                                <td>
                                    {% if current and current.getWeeklyBasketStatus.id == 1 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: current.id }) }}">No la recoge</a>
                                    {% elseif current and current.getWeeklyBasketStatus.id == 2 %}
                                        <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: current.id }) }}">Al final sí recoge</a>
                                    {% endif %}
                                </td>
                            </tr>
                            {% if share %}
                                <tr style="background-color: {{ color }};">
                                    {{ share.setIsListed(1) }}
                                    <td>{{ share.weeklyBasketGroup.name ?? '—' }}</td>
                                    <td>
                                        <a href="{{ path('partner_show', { id: share.id }) }}">{{ share }}</a>
                                    </td>
                                    <td class="csa-table__col-tight">{{ active.eggAmount|default('Sin huevos') ?: 'Sin huevos' }}</td>
                                    <td>{{ share_current ? share_current.getWeeklyBasketStatus : '—' }}</td>
                                    <td>
                                        {% if share_current and share_current.getWeeklyBasketStatus.id == 1 %}
                                            <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: share_current.id }) }}">No la recoge</a>
                                        {% elseif share_current and share_current.getWeeklyBasketStatus.id == 2 %}
                                            <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: share_current.id }) }}">Al final sí recoge</a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endif %}
                        {% endif %}
                    {% else %}
                        <tr><td colspan="5" class="csa-muted" style="text-align: center;">Sin cestas compartidas.</td></tr>
                    {% endfor %}
                {% else %}
                    {% for basket in entity %}
                        {% set active = basket.partner.getActiveBasket %}
                        {% set current = basket.partner.getCurrentBasket %}
                        <tr>
                            <td>{{ basket.partner.weeklyBasketGroup.name ?? '—' }}</td>
                            <td>
                                <a href="{{ path('partner_show', { id: basket.partner.id }) }}">{{ basket.partner }}</a>
                            </td>
                            <td class="csa-table__col-tight">{{ active.amount ?? '—' }}</td>
                            <td class="csa-table__col-tight">
                                {{ active.eggAmount|default('Sin huevos') ?: 'Sin huevos' }}
                                {% if active and active.eggPeriod %}
                                    ({{ active.eggPeriod }})
                                {% endif %}
                            </td>
                            <td>{{ current ? current.getWeeklyBasketStatus : '—' }}</td>
                            <td>
                                {% if current and current.getWeeklyBasketStatus.id == 1 %}
                                    <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 2, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">No la recoge</a>
                                {% elseif current and current.getWeeklyBasketStatus.id == 2 %}
                                    <a href="{{ path('partner_basket_weekly_change_status', { weekly_basket_status_id: 1, weekly_basket_id: basket.partner.getCurrentBasket.id }) }}">Al final sí recoge</a>
                                {% endif %}

                                {% if basket_share_id == 2 %}
                                    {% if current and current.getWeeklyBasketStatus.id == 1 %}
                                        <br><button type="button"
                                                onclick="document.getElementById('confirm-table-list-basket-biweekly-{{ current.id }}').showModal()">Cambiar a otra semana</button>
{{ csa.confirm_dialog('confirm-table-list-basket-biweekly-' ~ current.id, {
    variant: 'warning',
    eyebrow: 'Acción definitiva',
    title: 'Cambiar a otra semana',
    body: 'Esta acción no se puede deshacer. El cambio se aplicará al listado.',
    confirm_label: 'Cambiar de semana',
    confirm_href: path('partner_basket_monthly_change_week', { weekly_basket_id: basket.partner.getCurrentBasket.id }),
}) }}
                                    {% endif %}
                                {% elseif basket_share_id == 3 %}
                                    {% if current and current.getWeeklyBasketStatus.id == 1 %}
                                        <br><button type="button"
                                                onclick="document.getElementById('confirm-table-list-basket-monthly-{{ current.id }}').showModal()">La recoge la semana siguiente</button>
{{ csa.confirm_dialog('confirm-table-list-basket-monthly-' ~ current.id, {
    variant: 'warning',
    eyebrow: 'Acción definitiva',
    title: 'Pasar a la semana siguiente',
    body: 'Esta acción no se puede deshacer. La cesta se moverá a la semana siguiente.',
    confirm_label: 'Cambiar',
    confirm_href: path('partner_basket_monthly_change_week', { weekly_basket_id: basket.partner.getCurrentBasket.id }),
}) }}
                                    {% endif %}
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="6" class="csa-muted" style="text-align: center;">Sin cestas {{ type }}.</td></tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
    {% endblock %}
{% endembed %}
