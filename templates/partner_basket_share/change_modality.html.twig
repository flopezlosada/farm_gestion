{# ============================================================
 # Cambio de modalidad de cesta CON histórico — shell csa.
 # A diferencia de edit (corrección en sitio), parte el histórico:
 # cierra la cesta vigente y abre una nueva con efecto desde la
 # fecha efectiva, emitiendo un evento BASKET_CHANGE.
 # Misma lógica condicional JS que new/edit.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Cambiar la cesta · {{ partner_basket_share.partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner_basket_share.partner.id }) }}">{{ partner_basket_share.partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cambiar la cesta</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cesta',
        'Cambiar la cesta',
        'Para ' ~ partner_basket_share.partner ~ '. Se conserva el histórico: la cesta actual se cierra la víspera de la fecha efectiva y se abre una nueva.'
    ) }}

    {# ---- Contexto: qué cesta tiene HOY la persona (read-only) ---- #}
    <div class="csa-form-narrow csa-stack-lg" style="margin-bottom: var(--csa-sp-5);">
        {% embed '_components/csa_card.html.twig' with { title: 'Cesta actual', subtitle: 'Lo que recibe ahora. Se cerrará la víspera de la fecha efectiva.', accent: 'ochre', icon: 'fa-shopping-basket' } %}
            {% import '_macros/csa.html.twig' as csa %}
            {% block body %}
                <div class="csa-row" style="flex-wrap: wrap; gap: var(--csa-sp-2);">
                    {{ csa.badge(partner_basket_share.basketShare ~ ' ×' ~ partner_basket_share.amount, 'green', { no_dot: true }) }}
                    {% if partner_basket_share.eggAmount %}
                        {{ csa.badge('Huevos: ' ~ partner_basket_share.eggAmount ~ (partner_basket_share.eggPeriod ? ' · ' ~ partner_basket_share.eggPeriod : ''), 'sky', { no_dot: true }) }}
                    {% else %}
                        {{ csa.badge('Sin huevos', 'neutral', { no_dot: true }) }}
                    {% endif %}
                    {% if partner_basket_share.basketShare.id == 2 and partner_basket_share.deliveryGroup %}
                        {{ csa.badge('Turno ' ~ partner_basket_share.deliveryGroup, 'plum', { no_dot: true }) }}
                    {% endif %}
                    {% if partner_basket_share.startDate %}
                        {{ csa.badge('Desde ' ~ partner_basket_share.startDate|date('d/m/Y'), 'neutral', { no_dot: true }) }}
                    {% endif %}
                </div>
            {% endblock %}
        {% endembed %}
    </div>

    {{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow', 'data-csa-dropdowns': '1' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Nueva cesta', subtitle: 'Periodicidad y opciones de la cesta a partir del cambio.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.basket_share, 'Tipo de cesta', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad de cestas', { hint: 'normalmente 1' }) }}
                    </div>
                    <label class="csa-toggle" style="margin-top: var(--csa-sp-4);">
                        {{ form_widget(form.isFreeBasket, { attr: { class: 'csa-toggle__input' } }) }}
                        <span class="csa-toggle__track"><span class="csa-toggle__thumb"></span></span>
                        <span class="csa-toggle__text">Cesta gratuita <small>Donada o solidaria · se factura a 0&nbsp;€</small></span>
                    </label>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Huevos', subtitle: 'Cantidad y frecuencia (sólo si la cesta incluye huevos).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.egg_amount, 'Cantidad de huevos', { full: true }) }}
                        <div id="egg_period" class="csa-field--full hidden">
                            {{ csa.field(form.egg_period, 'Frecuencia de huevos', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Cuándo entra en vigor', subtitle: 'Fecha efectiva del cambio, día concreto del mes y turno de viernes si procede.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.start_date, 'Fecha efectiva del cambio', { full: true, hint: 'La cesta actual se cierra el día anterior a esta fecha.', attr: { class: 'csa-input datepicker' } }) }}
                        <div id="day_month_order" class="csa-field--full hidden">
                            {{ csa.field(form.dayMonthOrder, 'Día del mes', { full: true }) }}
                        </div>
                        {% if node_is_biweekly %}
                            {# El punto reparte quincenalmente por sí mismo: el turno lo fija
                               el nodo, no se elige. Mostramos sus fechas como información. #}
                            <div class="csa-field--full">
                                {{ csa.callout(
                                    'Recoge en ' ~ node_name ~ (node_dates_label
                                        ? ' · ' ~ node_dates_label
                                        : '') ~ ' El turno lo fija el punto de recogida; aquí no se elige.',
                                    'info', 'map-marker'
                                ) }}
                                <div hidden>{{ form_row(form.deliveryGroup) }}</div>
                            </div>
                        {% else %}
                            <div id="delivery_group" class="csa-field--full hidden">
                                {{ csa.field(form.deliveryGroup, 'Turno de viernes (quincenal)', { full: true }) }}
                            </div>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}

            <div style="display: none;">
                {{ form_row(form.partner) }}
            </div>

            {{ csa.callout(
                'Al aplicar: la cesta actual se cierra la víspera de la fecha efectiva y se abre la nueva. Las entregas futuras ya generadas a partir de esa fecha se borran y se regeneran con la nueva cesta.',
                'warning',
                'exchange'
            ) }}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('partner_show', { id: partner_basket_share.partner.id }) }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Aplicar cambio de cesta</button>
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });

        // Cambia el valor de un <select> por código y avisa al dropdown enhanced
        // (assets/js/csa-dropdown.js escucha 'change' para refrescar su etiqueta).
        function setSelectValue(selector, value) {
            var el = document.querySelector(selector);
            if (el && el.value !== String(value)) {
                el.value = value;
                el.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }

        function syncConditionals() {
            var basketShare = $('#partner_basket_share_basket_share').val();
            var eggPeriod = $('#partner_basket_share_egg_period').val();
            var showDayMonth = (basketShare == 3) || (eggPeriod == 3);
            var showEggPeriod = (basketShare == 5);
            var showDeliveryGroup = (basketShare == 2);

            $('#day_month_order').toggleClass('hidden', !showDayMonth);
            $('#egg_period').toggleClass('hidden', !showEggPeriod);
            $('#delivery_group').toggleClass('hidden', !showDeliveryGroup);
            if (!showDayMonth) setSelectValue('#partner_basket_share_dayMonthOrder', '0');
            if (!showEggPeriod) setSelectValue('#partner_basket_share_egg_period', '0');
            if (!showDeliveryGroup) setSelectValue('#partner_basket_share_deliveryGroup', '');
        }

        $('#partner_basket_share_basket_share').change(syncConditionals);
        $('#partner_basket_share_egg_period').change(syncConditionals);
        syncConditionals();
    </script>
{% endblock %}
