{# ============================================================
 # Vista semanal del reparto de cestas — shell csa.
 # Renderiza 5 sub-tablas (semanales/quincenales/compartidas/
 # mensuales/sólo huevos) via _table_list_basket.html.twig.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Reparto semanal{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Reparto semanal</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Reparto semanal de cestas',
        'Listado de cestas que toca repartir esta semana, agrupado por modalidad.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            <a href="{{ path('regenerate_weekly_list', { weekly_basket_id: basket.id }) }}"
               class="csa-btn csa-btn--ghost"
               onclick="return confirm('Esto regenerará el listado y se perderán los cambios manuales. ¿Continuar?');">
                <i class="fa fa-refresh"></i> Regenerar listado
            </a>
            {{ csa.btn('Generar PDF', { variant: 'primary', href: path('generate_pdf_basket_weekly', { basket_id: basket.id, alternative_order: true }), icon: 'fa-file-pdf-o' }) }}
        </div>
    </div>

    <div class="csa-stack-lg">
        {{ include('partner_basket_share/_table_list_basket.html.twig', { entity: weekly_partners,         accent: 'sky',        type: 'semanales',                                  basket_share_id: 1 }) }}
        {{ include('partner_basket_share/_table_list_basket.html.twig', { entity: biweekly_partners,       accent: 'green',      type: 'quincenales',                                basket_share_id: 2 }) }}
        {{ include('partner_basket_share/_table_list_basket.html.twig', { entity: old_half_basket_partners, accent: 'terracotta', type: 'semanales compartidas (antigua media cesta)', basket_share_id: 4 }) }}
        {{ include('partner_basket_share/_table_list_basket.html.twig', { entity: monthly_partners,        accent: 'ochre',      type: 'mensuales',                                  basket_share_id: 3 }) }}
        {{ include('partner_basket_share/_table_list_basket.html.twig', { entity: only_egg_partners,       accent: 'plum',       type: 'sólo huevos',                                basket_share_id: 5 }) }}
    </div>

{% endblock %}
