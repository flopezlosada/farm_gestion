{# ============================================================
 # Detalle de PartnerBasketShare (cesta asignada a socix).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cesta #{{ partner_basket_share.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    {% if partner_basket_share.partner %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('partner_show', { id: partner_basket_share.partner.id }) }}">{{ partner_basket_share.partner }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cesta #{{ partner_basket_share.id }}</span>
{% endblock %}

{% block csa_main %}

    <form id="pbs-delete-form" method="post"
          action="{{ path('partner_basket_share_delete', { id: partner_basket_share.id }) }}"
          style="display: none;">
        <input type="hidden" name="_method" value="DELETE">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ partner_basket_share.id) }}">
    </form>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-shopping-basket"></i>
            </span>
            <div>
                <h1>Cesta #{{ partner_basket_share.id }}</h1>
                {% if partner_basket_share.partner %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        {{ partner_basket_share.partner }}
                        {% if partner_basket_share.basketShare %} · {{ partner_basket_share.basketShare }}{% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-pbs-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-pbs-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'pbs-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('partner_basket_share_edit', { id: partner_basket_share.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('partner_basket_share_index') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos de la cesta', accent: 'green' } %}
        {% block body %}
            <dl class="csa-defs">
                {% if partner_basket_share.partner %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Socix</dt>
                        <dd class="csa-defs__value">
                            <a href="{{ path('partner_show', { id: partner_basket_share.partner.id }) }}">{{ partner_basket_share.partner }}</a>
                        </dd>
                    </div>
                {% endif %}
                {% if partner_basket_share.basketShare %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Tipo de cesta</dt>
                        <dd class="csa-defs__value">{{ partner_basket_share.basketShare }}</dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Inicio</dt>
                    <dd class="csa-defs__value">
                        {% if partner_basket_share.startDate %}{{ partner_basket_share.startDate|format_date('long', locale='es') }}{% else %}—{% endif %}
                    </dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fin</dt>
                    <dd class="csa-defs__value">
                        {% if partner_basket_share.endDate %}{{ partner_basket_share.endDate|format_date('long', locale='es') }}{% else %}—{% endif %}
                    </dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Precio mensual</dt>
                    <dd class="csa-defs__value">{{ partner_basket_share.monthPrice }} €</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Estado</dt>
                    <dd class="csa-defs__value">
                        {% if partner_basket_share.isActive %}
                            <span class="csa-badge csa-badge--green">Activa</span>
                        {% else %}
                            <span class="csa-badge csa-badge--neutral">Cerrada</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
