{# ============================================================
 # CORREGIR ERRATA de una cesta — shell csa.
 # Edición EN SITIO: machaca los datos de la PBS sin partir el
 # histórico ni emitir evento BASKET_CHANGE. SÓLO para arreglar
 # datos mal tecleados. Para un cambio real de la cesta (el socio
 # pasa a otra modalidad/huevos/etc.) usar change_modality, que
 # conserva histórico y avisará a contabilidad.
 # Misma lógica condicional JS que new.html.twig.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Corregir errata · {{ partner_basket_share.partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner_basket_share.partner.id }) }}">{{ partner_basket_share.partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Corregir errata</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cesta',
        'Corregir errata (sin histórico)',
        'Para ' ~ partner_basket_share.partner ~ '. Sólo para arreglar datos mal introducidos.'
    ) }}

    {{ csa.callout(
        'Esto corrige datos en sitio: NO deja histórico y NO avisa a contabilidad. Si el socio realmente cambia de cesta (modalidad, huevos, cantidad, grupo) usa «Cambiar la cesta», que conserva el histórico.',
        'warning',
        'exclamation-triangle'
    ) }}

    {{ form_start(form, { attr: { id: 'pbs-errata-form', role: 'form', class: 'csa-form-narrow', 'data-csa-dropdowns': '1' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Tipo de cesta', subtitle: 'Periodicidad y opciones.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.basket_share, 'Tipo de cesta', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad de cestas', { hint: 'normalmente 1' }) }}
                    </div>
                    <label class="csa-toggle" style="margin-top: var(--csa-sp-4);">
                        {{ form_widget(form.isFreeBasket, { attr: { class: 'csa-toggle__input' } }) }}
                        <span class="csa-toggle__track"><span class="csa-toggle__thumb"></span></span>
                        <span class="csa-toggle__text">Cesta gratuita <small>Donada o solidaria · se factura a 0&nbsp;€</small></span>
                    </label>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Huevos', subtitle: 'Cantidad y frecuencia (sólo si la cesta incluye huevos).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.egg_amount, 'Cantidad de huevos', { full: true }) }}
                        <div id="egg_period" class="csa-field--full hidden">
                            {{ csa.field(form.egg_period, 'Frecuencia de huevos', { full: true }) }}
                        </div>
                        <div id="egg_day_month_order" class="csa-field--full hidden">
                            {{ csa.field(form.eggDayMonthOrder, 'En qué cesta del mes recibe los huevos', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Calendario', subtitle: 'Cuándo empieza y, según la modalidad, qué viernes recoge la cesta.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.start_date, 'Fecha de inicio', { full: true, attr: { class: 'csa-input datepicker' } }) }}
                        <div id="day_month_order" class="csa-field--full hidden">
                            {{ csa.field(form.dayMonthOrder, 'Qué viernes del mes recoge la cesta', { full: true }) }}
                        </div>
                        {% if node_is_biweekly|default(false) %}
                            {# El punto reparte quincenalmente por sí mismo: el turno lo fija
                               el nodo, no se elige. Mostramos sus fechas como información. #}
                            <div class="csa-field--full">
                                {{ csa.callout(
                                    'Recoge en ' ~ (node_name|default('')) ~ (node_dates_label|default(false)
                                        ? ' · ' ~ node_dates_label
                                        : '') ~ ' El turno lo fija el punto de recogida; aquí no se elige.',
                                    'info', 'map-marker'
                                ) }}
                                <div hidden>{{ form_row(form.deliveryGroup) }}</div>
                            </div>
                        {% else %}
                            <div id="delivery_group" class="csa-field--full hidden">
                                {{ csa.field(form.deliveryGroup, 'Turno de viernes (quincenal A/B)', { full: true }) }}
                            </div>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}

            <div style="display: none;">
                {{ form_row(form.partner) }}
            </div>

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('partner_show', { id: partner_basket_share.partner.id }) }) }}
                    <button type="button" class="csa-btn csa-btn--primary"
                            onclick="document.getElementById('confirm-pbs-errata').showModal()">Corregir errata</button>
                    {{ csa.confirm_dialog('confirm-pbs-errata', {
                        variant: 'warning',
                        eyebrow: 'Corrección sin histórico',
                        title: '¿Corregir la cesta en sitio?',
                        body: 'Se machacan los datos sin dejar histórico ni avisar a contabilidad. Hazlo solo si es una errata. Si el socio cambia de cesta de verdad, cancela y usa «Cambiar la cesta».',
                        confirm_label: 'Sí, corregir errata',
                        external_form_id: 'pbs-errata-form',
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });

        // Verdura y huevos son dos calendarios independientes:
        //  - day_month_order  = qué entrega del mes lleva la CESTA (sólo cesta mensual).
        //  - egg_period       = frecuencia de los HUEVOS (sólo si recibe huevos).
        //  - eggDayMonthOrder = en cuál de las cestas del socio viajan los huevos.
        //    Sólo aplica con huevos MENSUALES y cesta NO mensual; en la cesta
        //    mensual los huevos van con la única cesta (el resolver lo ignora).
        var eggOrderSelect = document.getElementById('partner_basket_share_eggDayMonthOrder');
        var eggOrderOptions = eggOrderSelect ? Array.prototype.slice.call(eggOrderSelect.options) : [];

        // Cuántas cestas al mes ofrece cada modalidad: no proponer "3ª/4ª cesta" a
        // quien no las tiene. Quincenal=2 cubre el caso normal (deuda consciente: el
        // mes de 5 viernes con 3ª cesta quincenal es un borde raro).
        function maxCestasForModality(basketShare) {
            return (basketShare == 2) ? 2 : 4;
        }

        // Reconstruye las opciones del select reusando las originales (sin duplicar
        // textos) y avisa al csa-dropdown con un 'change' para que refresque.
        function limitEggOptions(max) {
            if (!eggOrderSelect) return;
            var current = eggOrderSelect.value;
            eggOrderSelect.innerHTML = '';
            eggOrderOptions.forEach(function (opt) {
                if (opt.value === '' || parseInt(opt.value, 10) <= max) {
                    eggOrderSelect.appendChild(opt);
                }
            });
            var stillThere = Array.prototype.some.call(eggOrderSelect.options, function (o) { return o.value === current; });
            eggOrderSelect.value = stillThere ? current : '';
            eggOrderSelect.dispatchEvent(new Event('change', { bubbles: true }));
        }

        function syncConditionals() {
            var basketShare = $('#partner_basket_share_basket_share').val();
            var hasEggs = $('#partner_basket_share_egg_amount').val() !== '';
            var eggPeriod = $('#partner_basket_share_egg_period').val();

            var showCestaDayMonth = (basketShare == 3);
            var showEggPeriod = hasEggs;
            var showEggDayMonth = hasEggs && (eggPeriod == 3) && (basketShare != 3);
            // El turno A/B sólo es de las quincenales (normal y compartida).
            var showDeliveryGroup = (basketShare == 2 || basketShare == 6);

            $('#day_month_order').toggleClass('hidden', !showCestaDayMonth);
            $('#egg_period').toggleClass('hidden', !showEggPeriod);
            $('#egg_day_month_order').toggleClass('hidden', !showEggDayMonth);
            $('#delivery_group').toggleClass('hidden', !showDeliveryGroup);

            if (showEggDayMonth) {
                limitEggOptions(maxCestasForModality(basketShare));
            }
        }

        $('#partner_basket_share_basket_share').change(syncConditionals);
        $('#partner_basket_share_egg_amount').change(syncConditionals);
        $('#partner_basket_share_egg_period').change(syncConditionals);
        syncConditionals();
    </script>
{% endblock %}
