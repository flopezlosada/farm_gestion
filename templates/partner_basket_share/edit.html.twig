{# ============================================================
 # CORREGIR ERRATA de una cesta — shell csa.
 # Edición EN SITIO: machaca los datos de la PBS sin partir el
 # histórico ni emitir evento BASKET_CHANGE. SÓLO para arreglar
 # datos mal tecleados. Para un cambio real de la cesta (el socio
 # pasa a otra modalidad/huevos/etc.) usar change_modality, que
 # conserva histórico y avisará a contabilidad.
 # Misma lógica condicional JS que new.html.twig.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Corregir errata · {{ partner_basket_share.partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner_basket_share.partner.id }) }}">{{ partner_basket_share.partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Corregir errata</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cesta',
        'Corregir errata (sin histórico)',
        'Para ' ~ partner_basket_share.partner ~ '. Sólo para arreglar datos mal introducidos.'
    ) }}

    {{ csa.callout(
        'Esto corrige datos en sitio: NO deja histórico y NO avisa a contabilidad. Si el socio realmente cambia de cesta (modalidad, huevos, cantidad, grupo) usa «Cambiar la cesta», que conserva el histórico.',
        'warning',
        'exclamation-triangle'
    ) }}

    {{ form_start(form, { attr: { id: 'pbs-errata-form', role: 'form', class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Tipo de cesta', subtitle: 'Periodicidad y opciones.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.basket_share, 'Tipo de cesta', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad de cestas', { hint: 'normalmente 1' }) }}
                        {{ csa.field(form.isFreeBasket, '¿Es cesta gratuita?') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Huevos', subtitle: 'Cantidad y frecuencia (sólo si la cesta incluye huevos).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.egg_amount, 'Cantidad de huevos', { full: true }) }}
                        <div id="egg_period" class="csa-field--full hidden">
                            {{ csa.field(form.egg_period, 'Frecuencia de huevos', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Calendario', subtitle: 'Fecha de inicio, día concreto del mes y grupo de reparto si procede.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.start_date, 'Fecha de inicio', { full: true, attr: { class: 'csa-input datepicker' } }) }}
                        <div id="day_month_order" class="csa-field--full hidden">
                            {{ csa.field(form.dayMonthOrder, 'Día del mes', { full: true }) }}
                        </div>
                        {{ csa.field(form.deliveryGroup, 'Grupo de reparto', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div style="display: none;">
                {{ form_row(form.partner) }}
            </div>

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('partner_show', { id: partner_basket_share.partner.id }) }) }}
                    <button type="button" class="csa-btn csa-btn--primary"
                            onclick="document.getElementById('confirm-pbs-errata').showModal()">Corregir errata</button>
                    {{ csa.confirm_dialog('confirm-pbs-errata', {
                        variant: 'warning',
                        eyebrow: 'Corrección sin histórico',
                        title: '¿Corregir la cesta en sitio?',
                        body: 'Se machacan los datos sin dejar histórico ni avisar a contabilidad. Hazlo solo si es una errata. Si el socio cambia de cesta de verdad, cancela y usa «Cambiar la cesta».',
                        confirm_label: 'Sí, corregir errata',
                        external_form_id: 'pbs-errata-form',
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });

        function syncConditionals() {
            var basketShare = $('#partner_basket_share_basket_share').val();
            var eggPeriod = $('#partner_basket_share_egg_period').val();
            var showDayMonth = (basketShare == 3) || (eggPeriod == 3);
            var showEggPeriod = (basketShare == 5);

            $('#day_month_order').toggleClass('hidden', !showDayMonth);
            $('#egg_period').toggleClass('hidden', !showEggPeriod);
            if (!showDayMonth) $('#partner_basket_share_dayMonthOrder').val(0);
            if (!showEggPeriod) $('#partner_basket_share_egg_period').val(0);
        }

        $('#partner_basket_share_basket_share').change(syncConditionals);
        $('#partner_basket_share_egg_period').change(syncConditionals);
        syncConditionals();
    </script>
{% endblock %}
