{# ============================================================
 # Listado de cestas filtrado por status — shell csa.
 # Renderizado por partner_basket_share_list_status. La pantalla
 # operativa principal del bloque socios.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cestas activas{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cestas activas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cestas',
        'Cestas activas',
        'Total actual: ' ~ total_basket ~ ' cestas.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {# "Nueva cesta" retirado: las cestas se crean desde la ficha del
               socix ("añadir cesta"), único camino que pasa por reconcile. #}
            {{ csa.btn('Historial', { variant: 'ghost', href: path('partner_basket_share_index'), icon: 'fa-history' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Socix</th>
                    <th>Tipo de cesta</th>
                    <th class="csa-table__col-tight">Inicio</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for basket in baskets %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('partner_show', { id: basket.partner.id }) }}">{{ basket.partner }}</a>
                        </td>
                        <td>
                            {{ basket.basketShare }}
                            {% if basket.eggAmount %}
                                · {{ basket.eggAmount|lower }} de huevos
                            {% endif %}
                        </td>
                        {# startDate puede ser NULL (fechas perdidas del import):
                         # format_date(null) pintaría la fecha de HOY. #}
                        <td class="csa-table__col-tight">{{ basket.startDate ? basket.startDate|format_date('long', locale='es') : 'Sin fecha' }}</td>
                        <td class="csa-table__actions">
                            {% if is_granted('ROLE_GESTION_SOCIXS_EDIT') %}
                            <a href="{{ path('partner_basket_share_edit', { id: basket.id }) }}" title="Corregir errata (sin histórico)" aria-label="Corregir errata"><i class="fa fa-pencil"></i></a>
                            {# Directo al formulario de finalizar: él pide la fecha y
                             # confirma — el diálogo intermedio era redundante. #}
                            <a href="{{ path('partner_basket_share_finalize', { id: basket.id }) }}"
                               title="Finalizar cesta (elegir fecha de fin)" aria-label="Finalizar cesta"><i class="fa fa-calendar-times-o"></i></a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay cestas activas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
