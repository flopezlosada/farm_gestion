{% extends 'layout_list.html.twig' %}

{% block title %}Partner index{% endblock %}

{% block main %}
    <div class="row">
        <div class="col-lg-12">
            <h1 class="page-header">Listado de cestas activas </h1>
        </div>
        <!-- /.col-lg-12 -->
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                <h4>Número de cestas actuales: {{ total_basket }}</h4>
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table id="table_list"
                               class="table table-striped table-bordered table-hover dataTable no-footer"
                               aria-describedby="dataTables-example_info">
                            <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Tipo de cesta</th>
                                <th>Fecha de inicio</th>

                                {#<th>Producción año {{ year }}</th>#}
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tfoot>
                            <tr role="row">
                            </tr>
                            </tfoot>
                            <tbody>
                            {% for basket in baskets %}
                                <tr>
                                    <td>
                                        <a href="{{ path('partner_show', {'id': basket.partner.id}) }}">{{ basket.partner }}</a>
                                    </td>
                                    <td>{{ basket.basketShare }}
                                        {% if basket.eggAmount %}
                                            con {{ basket.eggAmount|lower}} de huevos
                                        {% endif %}
                                    </td>
                                    <td>{{ basket.startDate|localizeddate('long','none') }}</td>
                                    <td><a href="{{ path('partner_basket_share_finalize', {'id': basket.id}) }}">Finalizar
                                            cesta</a><br/>
                                        <a href="{{ path('partner_basket_share_edit', {'id': basket.id}) }}">Cambiar
                                            tipo de cesta</a>
                                    </td>

                                </tr>
                            {% endfor %}

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>


{% endblock %}
 {% block specific_js %}
     <script>
         $(document).ready(function () {
             $('#table_list').DataTable({
                 "lengthMenu": [10, 25, 50, 75, 100],
                 "pageLength": 50,
                 "language": {
                     "lengthMenu": "Muestra_MENU_ registros por página",
                     "zeroRecords": "No se encuentra",
                     "info": "Mostrando página _PAGE_ of _PAGES_",
                     "infoEmpty": "No hay registros para la consulta",
                     "infoFiltered": "(seleccionado de _MAX_ registros totales)"
                 }
             });
         });
     </script>
 {% endblock %}