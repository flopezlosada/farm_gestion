{% extends 'layout_crud.html.twig' %}

{% block title %}Añadir cesta{% endblock %}

{% block main %}
    <h1>Crear nueva cesta para {{ partner }}</h1>
    <div class="panel panel-default">
        {{ form_start(form) }}
        <div class="panel-body">
            <div class="row">
                <div class="col-lg-6">
                    <div class="form-group">
                        {{ form_errors(form.basket_share) }}
                        <label>{{ form_label(form.basket_share) }}</label>
                        {{ form_widget(form.basket_share,{'attr':{'class':'form-control','placeholder':''}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_errors(form.egg_amount) }}
                        <label>{{ form_label(form.egg_amount) }}{{ form_help(form.egg_amount) }}</label>
                        {{ form_widget(form.egg_amount,{'attr':{'placeholder':''}}) }}
                    </div>

                        <div class="form-group hidden" id="egg_period">
                            {{ form_errors(form.egg_period) }}
                            <label>{{ form_label(form.egg_period) }}</label>
                            {{ form_widget(form.egg_period,{'attr':{'placeholder':'','class':'form-control'}}) }}
                        </div>

                    <div class="form-group">
                        {{ form_errors(form.start_date) }}
                        <label>{{ form_label(form.start_date) }}{{ form_help(form.start_date) }}</label>
                        {{ form_widget(form.start_date,{'attr':{'placeholder':''}}) }}

                    </div>
                    <div class="hidden">
                        <div class="form-group">
                            {{ form_errors(form.partner) }}
                            <label>{{ form_label(form.partner) }}</label>
                            {{ form_widget(form.partner,{'attr':{'placeholder':'','class':'form-control'}}) }}
                        </div>
                    </div>
                    <div class="form-group hidden" id="day_month_order">
                        {{ form_errors(form.dayMonthOrder) }}
                        <label>{{ form_label(form.dayMonthOrder) }}</label>
                        {{ form_widget(form.dayMonthOrder,{'attr':{'placeholder':''}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_errors(form.isFreeBasket) }}
                        <label>{{ form_label(form.isFreeBasket) }}{{ form_help(form.isFreeBasket) }}</label>
                        {{ form_widget(form.isFreeBasket,{'attr':{'placeholder':''}}) }}
                    </div>
                    <div class="form-group">
                        {{ form_errors(form.amount) }}
                        <label>{{ form_label(form.amount) }}{{ form_help(form.amount) }}</label>
                        {{ form_widget(form.amount,{'attr':{'placeholder':''}}) }}
                    </div>
                </div>
            </div>
            {{ form_widget(form) }}
            {{ include('partner_basket_share/_form.html.twig', {'button_label': 'Añadir'}) }}


            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
{% block specific_js %}
    <script>
        $('.datepicker').pickadate({
            formatSubmit: 'yyyy-mm-dd',
            onStart: function () {
                this.set('min',new Date())
            }
        })
    </script>
    <script>
        $('#partner_basket_share_basket_share').change(function () {
            if ($(this).val() == 3) {
                $('#day_month_order').hide('slow');
                $('#day_month_order').removeClass('hidden');
                $('#day_month_order').show('slow');
            }
            else {
                $('#day_month_order').hide('slow');
                $('#partner_basket_share_dayMonthOrder').val(0);
            }
        });

        if ($('#partner_basket_share_basket_share').val() == 3) {
            $('#day_month_order').hide('slow');
            $('#day_month_order').removeClass('hidden');
            $('#day_month_order').show('slow');
        }
        else {
            $('#partner_basket_share_dayMonthOrder').val(0);
        }

        $('#partner_basket_share_basket_share').change(function () {
            if ($(this).val() == 5) {
                $('#egg_period').hide('slow');
                $('#egg_period').removeClass('hidden');
                $('#egg_period').show('slow');
            }
            else {
                $('#egg_period').hide('slow');
                $('#partner_basket_share_egg_period').val(0);
            }
        });

        if ($('#partner_basket_share_basket_share').val() == 5) {
            $('#egg_period').hide('slow');
            $('#egg_period').removeClass('hidden');
            $('#egg_period').show('slow');
        }
        else {
            $('#partner_basket_share_egg_period').val(0);
        }

        $('#partner_basket_share_egg_period').change(function () {
            if ($(this).val() == 3) {
                $('#day_month_order').hide('slow');
                $('#day_month_order').removeClass('hidden');
                $('#day_month_order').show('slow');
            }
            else {
                $('#day_month_order').hide('slow');
                $('#partner_basket_share_dayMonthOrder').val(0);
            }
        });

        if ($('#partner_basket_share_egg_period').val() == 3) {
            $('#day_month_order').hide('slow');
            $('#day_month_order').removeClass('hidden');
            $('#day_month_order').show('slow');
        }
    </script>
{% endblock %}