{# ============================================================
 # Nueva cesta para una socix — shell csa.
 # Los campos day_month_order y egg_period son visibles
 # condicionalmente vía JS según basket_share / egg_period.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva cesta · {{ partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner.id }) }}">{{ partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva cesta</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Cesta',
        'Nueva cesta para ' ~ partner,
        'Tipo de cesta, huevos, frecuencia y fecha de inicio.'
    ) }}

    {{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Tipo de cesta', subtitle: 'Periodicidad y opciones.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.basket_share, 'Tipo de cesta', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad de cestas', { hint: 'normalmente 1' }) }}
                        {{ csa.field(form.isFreeBasket, '¿Es cesta gratuita?') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Huevos', subtitle: 'Cantidad y frecuencia (sólo si la cesta incluye huevos).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.egg_amount, 'Cantidad de huevos', { full: true }) }}
                        <div id="egg_period" class="csa-field--full hidden">
                            {{ csa.field(form.egg_period, 'Frecuencia de huevos', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Calendario', subtitle: 'Fecha de inicio y día concreto del mes si procede.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.start_date, 'Fecha de inicio', { full: true, attr: { class: 'csa-input datepicker' } }) }}
                        <div id="day_month_order" class="csa-field--full hidden">
                            {{ csa.field(form.dayMonthOrder, 'Día del mes', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            <div style="display: none;">
                {{ form_row(form.partner) }}
            </div>

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('partner_show', { id: partner.id }) }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Añadir cesta</button>
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });

        // Lógica condicional heredada del legacy: mostrar day_month_order
        // y egg_period según el tipo de cesta / frecuencia de huevos.
        function syncConditionals() {
            var basketShare = $('#partner_basket_share_basket_share').val();
            var eggPeriod = $('#partner_basket_share_egg_period').val();
            var showDayMonth = (basketShare == 3) || (eggPeriod == 3);
            var showEggPeriod = (basketShare == 5);

            $('#day_month_order').toggleClass('hidden', !showDayMonth);
            $('#egg_period').toggleClass('hidden', !showEggPeriod);
            if (!showDayMonth) $('#partner_basket_share_dayMonthOrder').val(0);
            if (!showEggPeriod) $('#partner_basket_share_egg_period').val(0);
        }

        $('#partner_basket_share_basket_share').change(syncConditionals);
        $('#partner_basket_share_egg_period').change(syncConditionals);
        syncConditionals();
    </script>
{% endblock %}
