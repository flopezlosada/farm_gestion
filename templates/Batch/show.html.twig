{# ============================================================
 # Detalle de lote — migrado al shell csa.
 # ============================================================
 # El contenido interno (panel verde + tabs + tablas + JS de
 # gráficas) sigue en su forma legacy y se migrará a csa-card /
 # csa-table en commits separados, uno por bloque.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Lote #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('batch') }}">Lotes</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block more_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/app/css/morris/morris.css') }}"/>
{% endblock %}

{% block csa_main -%}

    {# Cabecera nueva — estilo csa. El h1 legacy y sus wrappers row/col-lg-12 se han retirado. #}
    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-egg"></i>
            </span>
            <div>
                <div class="csa-row" style="gap: var(--csa-sp-3); margin-bottom: var(--csa-sp-2);">
                    {% if entity.batchStatus.id == 1 %}
                        {{ csa.badge('Activo · ' ~ entity.product, 'green') }}
                    {% elseif entity.batchStatus.id == 2 %}
                        {{ csa.badge('Finalizado', 'neutral') }}
                    {% endif %}
                    <span class="csa-muted" style="font-size: var(--csa-fs-sm);">
                        ID #L-{{ '%03d'|format(entity.id) }}
                    </span>
                    {% if entity.purchaseDate %}
                        <span class="csa-muted" style="font-size: var(--csa-fs-sm);">·</span>
                        <span class="csa-muted" style="font-size: var(--csa-fs-sm);">{{ entity.purchaseDate|date('Y-m-d') }}</span>
                    {% endif %}
                </div>
                <h1>Lote #{{ entity.id }}</h1>
                <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                    {{ entity.product }} · {{ entity.amount }} animales
                </div>
            </div>
        </div>
        <div class="csa-row">
            {% if entity.getProduct.getId in [2, 3] %}
                {{ csa.btn('Ver estadísticas', { variant: 'ghost', href: path('batch_analyses', { product_id: entity.product.id }), icon: 'fa-bar-chart' }) }}
            {% elseif entity.getProduct.getId == 6 %}
                {{ csa.btn('Análisis comparativo', { variant: 'ghost', href: path('hens_analyses'), icon: 'fa-bar-chart' }) }}
            {% endif %}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('batch_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver al listado', { variant: 'ghost', href: path('batch') }) }}
        </div>
    </div>

    {# ===== Contenido legacy: tabs, gráficas, tablas (sin panel verde wrapper) ===== #}
                    <ul class="csa-tabs">
                        <li class="csa-tabs__item active">
                            <a class="csa-tabs__link" href="#home" data-toggle="tab">General</a>
                        </li>
                        <li class="csa-tabs__item">
                            <a class="csa-tabs__link" href="#consum" data-toggle="tab">Consumo</a>
                        </li>
                        <li class="csa-tabs__item">
                            <a class="csa-tabs__link" href="#animals" data-toggle="tab">Animales</a>
                        </li>
                        {% if entity.getProduct.getId in [6] %}
                            <li class="csa-tabs__item">
                                <a class="csa-tabs__link" href="#movements" data-toggle="tab">Movimientos</a>
                            </li>
                        {% endif %}
                    </ul>
                    <div class="tab-content">
                        <div id="home" class="tab-pane fade active in ">
                            <h4>Resumen del lote</h4>

                            <div class="col-lg-8">
                                <p>
                                    <strong>Animal: </strong>{{ entity.getProduct }}<br/>
                                    <strong>Fecha de
                                        compra:</strong> {{ entity.getPurchaseDate|format_date('long', locale='es') }}
                                    <br/>
                                    {% if  entity.receiptdate %}
                                        <strong>Fecha de
                                            recepción:</strong> {{ entity.receiptdate|format_date('long', locale='es') }}
                                        <br/>
                                    {% endif %}
                                    <strong>Días de vida en la compra: </strong> {{ entity.getDaysOfLife }}<br/>
                                    <strong>Edad a día de hoy: </strong> {{ entity.getBatchAge }} dias
                                    ({{ (entity.getBatchAge/30)|number_format(1) }} meses)<br/>
                                    <strong>Tiempo en producción: </strong> {{ entity.getProductionTime }} dias
                                    ({{ (entity.getProductionTime/30)|number_format(1) }} meses)<br/>
                                    {% if entity.batchStatus.getId==2 %}
                                        <strong>Fecha de
                                            finalización:</strong> {{ entity.finalizationDate|format_date('long', locale='es') }}
                                        <br/>
                                    {% endif %}
                                    <strong>Precio de compra del lote: </strong> {{ entity.getPrice }}€<br/>
                                    <strong>Número de animales: </strong>{{ entity.amount }}<br/>
                                    {% if  entity.totalcost %}
                                        <strong>Coste total del lote:</strong> {{ entity.totalcost }} €<br/>
                                    {% endif %}

                                <p><strong>Total de pienso consumido:</strong> {{ entity.getfeedamount }} kg
                                <ul>
                                    <li><strong>Consumo medio diario por
                                            animal: </strong> {{ average_consumption|number_format(0) }} g
                                    </li>
                                    {% if entity.getProduct.getId in [2,3] %}
                                        <li><strong>Índice de conversión del
                                                lote: </strong> {{ entity.getFeedConversion|number_format(2) }} kg de
                                            comida
                                            por cada kg en canal
                                        </li>
                                    {% elseif entity.getProduct.getId in [6] %}
                                        <li><strong>Total de huevos puestos:</strong> {{ entity.getTotalLayEggs }}</li>
                                        <li><strong>Coste por huevo del
                                                lote:</strong> {{ entity.getEggCost|number_format(2) }} € por huevo
                                            ({{ 12*entity.getEggCost|number_format(2) }} € por docena)
                                        </li>
                                        <li><strong>Producción de
                                                equilibrio:</strong> {{ entity.getBalaceProduction(dozen_price)|number_format(2) }}
                                            huevos
                                        </li>
                                    {% endif %}
                                </ul>
                                </p>

                                {% if  entity.totalincome %}
                                    <strong>Ingresos:</strong>{{ entity.totalincome }} €
                                    <ul>
                                        <li><em>Ventas</em>: {{ entity.getIncomeFormDestination(1) }} €</li>
                                        <li><em>Regalos</em>: {{ entity.getIncomeFormDestination(2) }} €</li>
                                        <li><em>Sueldo</em>: {{ entity.getIncomeFormDestination(3) }} €</li>
                                    </ul>
                                {% endif %}
                                {% if  entity.totalprofit %}
                                    {% if entity.getProduct.getId in [6] %}
                                        <strong>Beneficios:</strong> {{ entity.totalprofit + 3.5*entity.getTotalLayEggs/12 }} €
                                        <br/>
                                    {% else %}
                                        <strong>Beneficios:</strong> {{ entity.totalprofit }} €<br/>
                                    {% endif %}
                                {% endif %}
                                {% if  entity.balanceprice %}
                                    <strong>Precio de equilibrio:</strong> {{ entity.balanceprice }} €/kg<br/>
                                    {% if entity.getTotalWeightGifted %}
                                        <strong>Precio de equilibrio incluyendo
                                            regalos:</strong> {{ entity.getBalancePriceWithGifts }} €/kg<br/>
                                    {% endif %}
                                {% endif %}
                                <strong>Notas: </strong>{{ entity.note }}
                                </p>
                            </div>
                            {% if is_granted('ROLE_COOP') %}
                                <div class="col-lg-4">
                                    <div class="well">
                                        <h4>Acciones</h4>
                                        {% if entity.getBatchStatus.getId==1 %}
                                            <p><a href="{{ path("sack_new",{'batch_id':entity.getId}) }}">
                                                    <button class="btn btn-outline btn-default" type="button">Añadir
                                                        saco de
                                                        pienso o grano
                                                    </button>
                                                </a></p>
                                            <p><a href="{{ path('batch_edit', { 'id': entity.id }) }}">
                                                    <button class="btn btn-outline btn-success" type="button">Editar
                                                        lote
                                                    </button>
                                                </a>
                                                {% if entity.getProduct.getId in [6] %}
                                                    <a href="{{ path('movement_new', {'batch_id': entity.id}) }}">
                                                        <button class="btn btn-outline btn-primary" type="button">Mover
                                                            lote
                                                        </button>
                                                    </a>
                                                {% endif %}
                                            </p>

                                            <p>
                                            {% if entity.canClose %}
                                                <a href="{{ path('batch_close', { 'id': entity.id }) }}">
                                                    <button class="btn btn-outline btn-danger" type="button">Finalizar
                                                        lote
                                                    </button>
                                                </a>
                                            {% else %}
                                                <div class="alert alert-danger">
                                                    No se puede finalizar un lote hasta que todos sus animales hayan
                                                    sido
                                                    clasificados
                                                </div>
                                            {% endif %}
                                            </p>
                                        {% else %}
                                            <div class="alert alert-warning">
                                                El lote está finalizado, no se puede realizar ninguna acción salvo
                                                reactivarlo.
                                            </div>
                                            <p><a href="{{ path('batch_reactivate', { 'id': entity.id }) }}">
                                                    <button class="btn btn-outline btn-warning" type="button">Reactivar
                                                        lote
                                                    </button>
                                                </a></p>
                                        {% endif %}

                                    </div>
                                </div>
                            {% endif %}
                            <div class="col-lg-12">


                                {% if entity.getProduct.getId in [2,3] %}

                                {% elseif entity.getProduct.getId in [6] %}
                                    <h4>Gráficas</h4>
                                    {#<div id="layweekchart" style="position: relative;height: 250px;"></div>#}
                                    <div id="container" style="width:100%; height:400px;"></div>
                                    <div id="container2" style="width:100%; height:400px;"></div>
                                    <div id="container3" style="width:100%; height:600px;"></div>
                                    <h4>Resumen de consumos</h4>
                                    <div class="table-responsive">
                                        <table id="table_list"
                                               class="table table-striped table-bordered table-hover dataTable no-footer "
                                               aria-describedby="dataTables-example_info">
                                            <thead>
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Ingresos</th>
                                                <th>Gastos</th>
                                                <th>Beneficios</th>
                                                <th>Pienso (Kg)</th>
                                                <th>Grano (Kg)</th>
                                                <th>Relación pienso/grano</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% for data in incoming_expenses %}
                                                <tr>
                                                    <td>{{ data[0].month }} - {{ data[0].year_date }}</td>
                                                    <td>{{ (data[1].total/3)|round(2) }} €</td>
                                                    <td>{{ data[0].total }}</td>
                                                    <td>{{ (data[1].total/3)|round(2) - data[0].total }} €</td>
                                                    <td>{{ data[3] }}</td>
                                                    <td>{{ data[2] }}</td>
                                                    <td>{{ (data[3]*100/(data[3]+data[2]))|round(0) }} /
                                                        {{ (data[2]*100/(data[3]+data[2]))|round(0) }}</td>
                                                </tr>

                                            {% endfor %}

                                            </tbody>
                                        </table>
                                    </div>


                                    <h4>Resumen de consumos relativos a la fecha de entrada</h4>
                                    <div class="table-responsive">
                                        <table id="table_list"
                                               class="table table-striped table-bordered table-hover dataTable no-footer "
                                               aria-describedby="dataTables-example_info">
                                            <thead>
                                            <tr>
                                                <th>Fecha</th>
                                                <th>Ingresos</th>
                                                <th>Gastos</th>
                                                <th>Beneficios</th>
                                                <th>Beneficio acumulado</th>
                                                <th>Huevos acumulados</th>
                                                <th>Pienso (Kg)</th>
                                                <th>Grano (Kg)</th>
                                                <th>Relación pienso/grano</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% set accumulate=0 %}
                                            {% set accumulate_eggs=0 %}
                                            {% for data in  relative_incoming_expenses %}

                                                <tr>
                                                    <td>Día {{ 1+loop.index0*days }} al {{ loop.index*days }}</td>
                                                    <td>{{ (data[0].total/3)|round(2) }} € | {{ (data[0].total) }} huevos</td>
                                                    <td>{{ data[1].total }}</td>
                                                    <td>{{ (data[0].total/3)|round(2) - data[1].total }} €</td>
                                                    {%  set accumulate= accumulate+(data[0].total/3)|round(2) - data[1].total %}
                                                    {%  set accumulate_eggs= accumulate_eggs+data[0].total %}
                                                    <td>{{ accumulate }} €</td>
                                                    <td>{{ accumulate_eggs }}</td>
                                                    <td>{{ data[3] }}</td>
                                                    <td>{{ data[2] }}</td>
                                                    <td>{% if  (data[3]+data[2])>0%}
                                                        {{ (data[3]*100/(data[3]+data[2]))|round(0) }} /
                                                        {{ (data[2]*100/(data[3]+data[2]))|round(0) }}
                                                    {% else %}
                                                        NULL
                                                        {% endif %}
                                                    </td>
                                                </tr>

                                            {% endfor %}

                                            </tbody>
                                        </table>
                                    </div>

                                {% endif %}
                            </div>

                        </div>
                        <div id="consum" class="tab-pane fade">

                            <h4>Consumo de grano y pienso</h4>

                            <p><strong>Total de pienso consumido:</strong> {{ entity.getfeedamount }} kg
                            <ul>
                                <li><strong>Consumo medio diario por
                                        animal: </strong> {{ average_consumption|number_format(0) }} g
                                </li>
                                {% if entity.getProduct.getId in [2,3] %}
                                    <li><strong>Índice de conversión del
                                            lote: </strong> {{ entity.getFeedConversion|number_format(2) }} kg de
                                        comida
                                        por cada kg en canal
                                    </li>
                                {% elseif entity.getProduct.getId in [6] %}
                                    <li><strong>Total de huevos puestos:</strong> {{ entity.getTotalLayEggs }}</li>
                                    <li><strong>Coste por huevo del
                                            lote:</strong> {{ entity.getEggCost|number_format(2) }} € por huevo
                                        ({{ 12*entity.getEggCost|number_format(2) }} € por docena)
                                    </li>
                                    <li><strong>Producción de
                                            equilibrio:</strong> {{ entity.getBalaceProduction(dozen_price)|number_format(2) }}
                                        huevos
                                    </li>
                                {% endif %}
                            </ul>
                            </p>
                            <ul>
                                {% for sack in entity.getSacks %}
                                    <li>{{ sack.getDate|format_date('short', locale='es') }} - {{ sack.getWeight }}
                                        kg
                                        de {{ sack.getProduct }} - {{ sack.getTotalPrice }} € <a
                                                href="{{ path('sack_fast_delete', {'id': sack.getId}) }}">Quitar</a>
                                    </li>
                                {% else %}
                                    <li>No se ha asignado ningún saco</li>
                                {% endfor %}
                            </ul>
                        </div>
                        <div id="animals" class="tab-pane fade">


                            <h4>Animales del lote</h4>

                            <div class="table-responsive">
                                <table id="table_list"
                                       class="table table-striped table-bordered table-hover dataTable no-footer"
                                       aria-describedby="dataTables-example_info">
                                    <thead>
                                    <tr>
                                        <th>Orden</th>
                                        <th>Estado</th>
                                        <th>Destino</th>
                                        <th>Fecha de sacrifio/muerte</th>
                                        <th>Peso en vivo (kg)</th>
                                        <th>Peso de canal (kg)</th>
                                        <th>Precio de venta (€/kg)</th>
                                        <th>Notas</th>
                                        <th>Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for fowl in entity.fowls %}
                                        <tr>
                                            <td>{{ loop.index }}</td>
                                            <td>{{ fowl.fowlstatus }}</a></td>
                                            <td>{{ fowl.fowldestination }}</a></td>
                                            <td>{% if fowl.putdowndate %}{{ fowl.putdowndate|format_date('long', locale='es') }}{% endif %}</td>
                                            <td>{{ fowl.putdownweight }}</td>
                                            <td>{{ fowl.carcassweight }}</td>
                                            <td>{{ fowl.saleprice }}</td>
                                            <td>{{ fowl.note }}</td>
                                            <td>
                                                <ul class="list-unstyled">
                                                    {% if entity.getBatchStatus.getId==1 %}
                                                        <li>
                                                            <a href="{{ path('fowl_edit', { 'id': fowl.id }) }}">editar</a>
                                                        </li>
                                                    {% endif %}
                                                </ul>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div id="movements" class="tab-pane fade">
                            <h4>Movimientos del lote</h4>

                            <table id="table_list"
                                   class="table table-striped table-bordered table-hover dataTable no-footer"
                                   aria-describedby="dataTables-example_info">
                                <thead>
                                <tr>
                                    <th>Sector</th>
                                    <th>Fecha inicio</th>
                                    <th>Tiempo estancia</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for movement in movements %}
                                    <tr>
                                        <td>{{ movement.sector }}</td>
                                        <td>{{ movement.date|format_date('long', locale='es') }}</td>
                                        <td>{% if movement.amount %}{{ movement.amount|abs }} días{% else %}Activo actualmente{% endif %}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    </div>
{% endblock %}


{% block more_js %}
    {{ parent() }}
    <script src="{{ asset('bundles/app/js/morris/raphael-min.js') }}"></script>
    <script src="{{ asset('bundles/app/js/morris/morris.min.js') }}"></script>
    <script src="https://code.highcharts.com/highcharts.src.js"></script>
    <script>
        /* new Morris.Line({
         // ID of the element in which to draw the chart.
         element: 'layweekchart',
         // Chart data records -- each entry in this array corresponds to a point on
         // the chart.
         data: [
        {#{% for week in week_lay %}#}
         {#{#}
         {#average: {{ (week.total/week.days)|number_format(2,'.',',') }},#}
         {#week: '{{ week.year_date }}-{{ week.week }}',#}
         {#value: {{ week.total }},#}
         {#},#}
        {#{%  endfor %}#}
         ],
         // The name of the data record attribute that contains x-values.
         xkey: 'week',
         // A list of names of data record attributes that contain y-values.
         ykeys: ['value', 'average'],
         // Labels for the ykeys -- will be displayed when you hover over the
         // chart.
         labels: ['Huevos', "Media Semanal"],
         hideHover: true,

         });*/

        $(function () {
            var myChart = Highcharts.chart('container', {
                chart: {
                    type: 'spline',
                    zoomType: 'x'
                },
                title: {
                    text: 'Evolución puesta semanal'
                },

                subtitle: {
                    text: 'Lote {{ entity.id }}'
                },

                yAxis: {
                    title: {
                        text: 'Puesta semanal'
                    }
                },
                tooltip: {
                    shared: true
                },
                legend: {
                    layout: 'vertical',
                    align: 'right',
                    verticalAlign: 'middle'
                },
                xAxis: {
                    title: {
                        text: 'Semana'
                    },
                    categories: [
                        {% for high_week in highchart_week_lay %}
                        '{{ high_week.week }} - {{ high_week.year_date }}',
                        {% endfor %}
                    ]
                },
                plotOptions: {
                    series: {
                        label: {
                            connectorAllowed: false
                        }

                    }
                },

                series: [{
                    name: 'Puesta',
                    color: Highcharts.getOptions().colors[5],
                    data: [
                        {% for high_week in highchart_week_lay %}
                        {{ high_week.total }},
                        {% endfor %}
                    ]
                }, {
                    name: 'Media semanal',
                    color: Highcharts.getOptions().colors[2],
                    data: [
                        {% for high_week in highchart_week_lay %}
                        {{ (high_week.total/high_week.days) |number_format(2,'.',',') }},
                        {% endfor %}
                    ]
                }]


            });


            var myChart2 = Highcharts.chart('container2', {
                chart: {
                    zoomType: 'xy'
                },
                title: {
                    text: 'Evolución puesta mensual'
                },
                subtitle: {
                    text: 'Lote {{ entity.id }}'
                },
                xAxis: {
                    type: 'category',
                    categories: [
                        {% for lay in month_lay %}
                        '{{ lay.month }} - {{ lay.year_date }}',
                        {% endfor %}
                    ],
                    crosshair: true,
                    labels: {
                        rotation: -90,
                        style: {
                            fontSize: '13px',
                            fontFamily: 'Verdana, sans-serif'
                        }
                    }
                },
                yAxis: [{
                    min: 0,
                    title: {
                        text: 'Puesta mensual',
                        style: {
                            color: Highcharts.getOptions().colors[1]
                        }
                    }

                }, {
                    title: {
                        text: 'Acumulado',
                        style: {
                            color: Highcharts.getOptions().colors[1]
                        }
                    },
                    labels: {
                        format: '{value}',
                        style: {
                            color: Highcharts.getOptions().colors[1]
                        }
                    },
                    opposite: true
                }
                ],
                legend: {
                    layout: 'horizontal',
                    align: 'left',
                    x: 120,
                    verticalAlign: 'top',
                    y: 50,
                    floating: true,
                    backgroundColor: (Highcharts.theme && Highcharts.theme.legendBackgroundColor) || '#FFFFFF'

                },
                tooltip: {
                    //pointFormat: 'Puesta: <b>{point.y:.0f} </b>',
                    shared: true
                },
                series: [{
                    name: 'Puesta',
                    type: 'column',
                    color: Highcharts.getOptions().colors[4],

                    data: [
                        {% for lay in month_lay %}
                        ['{{ lay.month }} - {{ lay.year_date }}', {{ lay.total }}],
                        {% endfor %}
                    ],
                    style: {
                        color: Highcharts.getOptions().colors[1]
                    },
                    dataLabels: {
                        enabled: true,
                        rotation: -90,
                        color: '#000000',
                        align: 'right',
                        format: '{point.y:.0f}', // one decimal
                        y: 10, // 10 pixels down from the top
                        style: {
                            fontSize: '13px',
                            fontFamily: 'Verdana, sans-serif',
                            textOutline: 0,
                        }
                    }
                }, {
                    name: 'Acumulada',
                    yAxis: 1,
                    type: 'spline',
                    color: Highcharts.getOptions().colors[3],
                    marker: {
                        lineWidth: 2,
                        lineColor: Highcharts.getOptions().colors[3],
                        fillColor: 'white'
                    },
                    data: [
                        {% set cumulative_lay=0 %}
                        {% for lay in month_lay %}
                        {% set cumulative_lay=cumulative_lay+lay.total %}
                        {{ cumulative_lay }},
                        {% endfor %}
                    ]
                }]
            });

            var myChart3 = Highcharts.chart('container3', {
                chart: {
                    zoomType: 'xy'
                },
                title: {
                    text: 'Evolución gastos e ingresos'
                },
                subtitle: {
                    text: 'Lote {{ entity.id }}'
                },
                xAxis: {

                    type: 'category',
                    categories: [

                        {% for data in incoming_expenses %}
                        '{{ data[0].month }} - {{ data[0].year_date }}',
                        {% endfor %}
                    ],
                    crosshair: true,
                    labels: {
                        rotation: -90,
                        style: {
                            fontSize: '13px',
