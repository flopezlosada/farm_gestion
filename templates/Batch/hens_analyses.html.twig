{# ============================================================
 # Comparativo de puesta de gallinas por lotes — shell csa.
 # 3 gráficas Highcharts: semanal, mensual, semanal con zoom.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Comparativo de puesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('batch') }}">Lotes</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Comparativo de puesta</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Gallinas',
        'Comparativo de puesta',
        'Producción de huevos por lote: semanal, mensual y semanal con zoom.'
    ) }}

    <div class="csa-stack-lg">
        {% embed '_components/csa_card.html.twig' with { title: 'Puesta semanal por lotes', accent: 'sky' } %}
            {% block body %}
                <div id="container" style="width: 100%; height: 400px;"></div>
            {% endblock %}
        {% endembed %}

        {% embed '_components/csa_card.html.twig' with { title: 'Puesta mensual por lotes', accent: 'ochre' } %}
            {% block body %}
                <div id="container2" style="width: 100%; height: 400px;"></div>
            {% endblock %}
        {% endembed %}

        {% embed '_components/csa_card.html.twig' with { title: 'Puesta semanal (con zoom)', accent: 'plum' } %}
            {% block body %}
                <div id="container3" style="width: 100%; height: 400px;"></div>
            {% endblock %}
        {% endembed %}
    </div>

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script>
        (function () {
            Highcharts.chart('container', {
                title: { text: 'Puesta semanal por lotes' },
                subtitle: { text: '' },
                yAxis: { title: { text: 'Puesta semanal' } },
                xAxis: { title: { text: 'Tiempo en producción' }, visible: true },
                legend: { layout: 'vertical', align: 'right', verticalAlign: 'middle' },
                plotOptions: { series: { label: { connectorAllowed: false } } },
                tooltip: { shared: false },
                series: [
                    {% for array_batch in batchs_week_lay %}
                        {
                            name: 'Lote {{ array_batch[1].id }}',
                            type: 'spline',
                            {% if array_batch[1].id < 11 %}visible: false,{% endif %}
                            data: [
                                {% for lay in array_batch[0] %}
                                    ['{{ lay.week }}-{{ lay.year_date }}', {{ lay.total }}],
                                {% endfor %}
                            ]
                        },
                    {% endfor %}
                ],
                responsive: {
                    rules: [{
                        condition: { maxWidth: 500 },
                        chartOptions: {
                            legend: { layout: 'horizontal', align: 'center', verticalAlign: 'bottom' }
                        }
                    }]
                }
            });

            Highcharts.chart('container2', {
                chart: { type: 'column' },
                title: { text: 'Puesta mensual por lotes' },
                subtitle: { text: '' },
                xAxis: { categories: [], crosshair: true, visible: false },
                yAxis: { min: 0, title: { text: 'Puesta mensual' } },
                tooltip: { shared: true },
                plotOptions: { column: { pointPadding: 0.2, borderWidth: 0 } },
                series: [
                    {% for array_month_batch in batchs_month_lay %}
                        {
                            name: 'Lote {{ array_month_batch[1].id }}',
                            {% if array_month_batch[1].id < 11 %}visible: false,{% endif %}
                            data: [
                                {% for lay in array_month_batch[0] %}{{ lay.total }},{% endfor %}
                            ]
                        },
                    {% endfor %}
                ]
            });

            Highcharts.chart('container3', {
                chart: { zoomType: 'x', panning: true, panKey: 'shift' },
                title: { text: 'Puesta semanal por lotes' },
                subtitle: { text: '' },
                yAxis: { title: { text: 'Puesta semanal' } },
                xAxis: { title: { text: 'Tiempo en producción' }, visible: true },
                legend: { layout: 'vertical', align: 'right', verticalAlign: 'middle' },
                plotOptions: { series: { label: { connectorAllowed: false } } },
                tooltip: { shared: false },
                series: [
                    {% for batch in graph_lay_weeks %}
                        {
                            name: '{{ loop.index }}',
                            type: 'spline',
                            data: [{% for lay in batch %}{{ lay }},{% endfor %}]
                        },
                    {% endfor %}
                ],
                responsive: {
                    rules: [{
                        condition: { maxWidth: 500 },
                        chartOptions: {
                            legend: { layout: 'horizontal', align: 'center', verticalAlign: 'bottom' }
                        }
                    }]
                }
            });
        })();
    </script>
{% endblock %}
