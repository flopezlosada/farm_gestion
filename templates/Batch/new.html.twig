{# ============================================================
 # Nuevo lote de animales — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo lote{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('batch') }}">Lotes</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Lotes',
        'Nuevo lote de animales',
        'Fechas, precio, cantidad y tipo de animal.'
    ) }}

    {{ form_start(form, {
        action: path('batch_create'),
        method: 'post',
        attr: { role: 'form', class: 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Fechas', subtitle: 'Compra y recepción.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.purchase_date, 'Fecha de compra', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.receipt_date, 'Fecha de recepción', { attr: { class: 'csa-input datepicker2' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Lote', subtitle: 'Tipo de animal, cantidad y datos económicos.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.product, 'Tipo de animal', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad de animales') }}
                        {{ csa.field(form.days_of_life, 'Días de vida en recepción') }}
                        {{ csa.field(form.weight, 'Peso aproximado (g)') }}
                        {{ csa.field(form.price, 'Precio del lote (€)') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Notas', subtitle: 'Información adicional sobre el lote.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.note, 'Notas', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('batch') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear lote',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
