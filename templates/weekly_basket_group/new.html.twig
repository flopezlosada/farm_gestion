{# ============================================================
 # Nuevo grupo de recogida — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo grupo de recogida{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('weekly_basket_group_index') }}">Grupos de recogida</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Nuevo grupo de recogida',
        'Nombre y color identificativo.'
    ) }}

    {{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Nombre y color del grupo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.name, 'Nombre', { full: true }) }}
                        {{ csa.field(form.color, 'Color') }}
                        {{ csa.field(form.node, 'Nodo de reparto', { hint: 'opcional' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('weekly_basket_group_index') }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Crear grupo</button>
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}
