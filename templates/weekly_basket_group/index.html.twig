{% extends 'layout_list.html.twig' %}

{% block title %}Listado de grupos de recogida{% endblock %}

{% block main %}
    <h1>Grupos de recogida</h1>

    <div class="panel panel-default">
        <div class="panel-heading">
            Grupos de recogida
        </div>
        <div class="panel-body">
            <div class="table-responsive">
                <table id="table_list" class="table table-striped table-bordered table-hover dataTable no-footer"
                       aria-describedby="dataTables-example_info">
                    <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Color</th>
                        <th>actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for weekly_basket_group in weekly_basket_groups %}
                        <tr>
                            <td>{{ weekly_basket_group.id }}</td>
                            <td>{{ weekly_basket_group.name }}</td>
                            <td style="background-color: {{ weekly_basket_group.color }}"></td>
                            <td>
                                {#<a href="{{ path('weekly_basket_group_show', {'id': weekly_basket_group.id}) }}">Mostrar</a>#}
                                <a href="{{ path('weekly_basket_group_edit', {'id': weekly_basket_group.id}) }}">Editar</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">no records found</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <a href="{{ path('weekly_basket_group_new') }}">Añadir grupo</a>
{% endblock %}
{% block specific_js %}
    <script>
        $(document).ready(function() {
            $('#table_list').DataTable({
                "lengthMenu": [10, 25,50 ],
                "pageLength": 25,
                "language": {
                    "lengthMenu": "Muestra_MENU_ registros por página",
                    "zeroRecords": "No se encuentra",
                    "info": "Mostrando página _PAGE_ of _PAGES_",
                    "infoEmpty": "No hay registros para la consulta",
                    "infoFiltered": "(seleccionado de _MAX_ registros totales)"
                }
            });
        } );
    </script>
{% endblock %}