{# ============================================================
 # Listado de grupos de recogida (WeeklyBasketGroup).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Grupos de recogida{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Grupos de recogida</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Grupos de recogida',
        'Agrupaciones de socixs por punto y día de recogida. El color identifica el grupo en el calendario semanal.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo grupo', { variant: 'primary', href: path('weekly_basket_group_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Color</th>
                    <th>Nombre</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for group in weekly_basket_groups %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <span style="display: inline-block; width: 24px; height: 24px; border-radius: var(--csa-radius-sm); background: {{ group.color }}; border: 1px solid var(--csa-rule);"></span>
                        </td>
                        <td>
                            <a class="csa-table__primary" href="{{ path('weekly_basket_group_edit', { id: group.id }) }}">{{ group.name }}</a>
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('weekly_basket_group_edit', { id: group.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay grupos de recogida.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
