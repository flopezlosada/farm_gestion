{# ============================================================
 # Resumen analítico de la recogida de residuos — shell csa.
 #
 # Renderiza dos gráficos Highcharts (anual con drilldown mensual,
 # comparativa semanal). CompostCollectionPoint/show.html.twig
 # hereda de esta plantilla y solo sobreescribe el título/crumbs.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}{% block resume_title %}Resumen de la recogida de residuos{% endblock %}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostcollection') }}">Recogida de compost</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{% block resume_crumb %}Resumen{% endblock %}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Compost · Recogida',
        block('resume_title'),
        'Kilos de residuo orgánico recogidos en los distintos puntos. Resumen anual con desglose mensual y comparativa semanal.'
    ) }}

    {% embed '_components/csa_card.html.twig' with { title: 'Resumen anual', accent: 'sky' } %}
        {% block body %}
            <div class="csa-table-wrap">
                <table class="csa-table">
                    <thead>
                        <tr>
                            <th>Año</th>
                            <th class="csa-table__col-tight">Kilos recogidos</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for key, amount in year_collections %}
                            <tr>
                                <td>{{ key }}</td>
                                <td class="csa-table__col-tight">{{ amount|number_format(0, ',', '.') }} kg</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="2" class="csa-muted" style="text-align: center;">Sin datos.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endblock %}
    {% endembed %}

    <div style="margin-top: var(--csa-sp-5);">
        {% embed '_components/csa_card.html.twig' with { title: 'Gráfico anual', accent: 'plum' } %}
            {% block body %}
                <div id="container" style="width:100%; height:400px;"></div>
            {% endblock %}
        {% endembed %}
    </div>

    <div style="margin-top: var(--csa-sp-5);">
        {% embed '_components/csa_card.html.twig' with { title: 'Comparativa semanal', accent: 'green' } %}
            {% block body %}
                <div id="container2" style="width:100%; height:400px;"></div>
            {% endblock %}
        {% endembed %}
    </div>

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script src="https://code.highcharts.com/modules/drilldown.js"></script>
    <script>
        (function () {
            Highcharts.chart('container', {
                chart: { type: 'column' },
                title: { text: 'Resumen recogidas anuales' },
                subtitle: { text: 'Restos orgánicos recogidos semanalmente' },
                yAxis: { title: { text: 'Kilogramos recogidos' } },
                xAxis: { type: 'category' },
                tooltip: {
                    headerFormat: '<span style="font-size:11px">{series.name}</span><br>',
                    pointFormat: '<span style="color:{point.color}">{point.name}</span>: <b>{point.y:.0f}</b> kg<br/>'
                },
                legend: { enabled: false },
                plotOptions: {
                    series: {
                        borderWidth: 0,
                        dataLabels: { enabled: true, format: '{point.y:.0f}' }
                    }
                },
                series: [{
                    name: 'Resumen anual',
                    colorByPoint: true,
                    data: [
                        {% for key, amount in year_collections %}
                            { name: '{{ key }}', y: {{ amount }}, drilldown: '{{ key }}' },
                        {% endfor %}
                    ]
                }],
                drilldown: {
                    series: [
                        {% for key, data in year_month_collections %}
                            {
                                name: '{{ key }}',
                                id: '{{ key }}',
                                data: [
                                    {% for month in data %}
                                        ['{{ month.month|month_names }}', {{ month.total }}],
                                    {% endfor %}
                                ]
                            },
                        {% endfor %}
                    ]
                }
            });

            Highcharts.chart('container2', {
                chart: { type: 'spline' },
                title: { text: 'Comparativa semanal de recogida de residuos' },
                subtitle: { text: 'Total semanal de todos los puntos de recogida' },
                yAxis: { title: { text: 'Kilogramos recogidos' } },
                xAxis: { categories: [{% for i in 0..52 %}{{ i }},{% endfor %}] },
                legend: { layout: 'vertical', align: 'right', verticalAlign: 'middle' },
                plotOptions: { series: { label: { connectorAllowed: false } } },
                series: [
                    {% for key, data in year_week_collections %}
                        {
                            name: '{{ key }}',
                            data: [
                                {% for week in data %}
                                    [{{ week.week }}, {{ week.total }}],
                                {% endfor %}
                            ]
                        },
                    {% endfor %}
                ]
            });
        })();
    </script>
{% endblock %}
