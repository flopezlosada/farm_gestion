{# ============================================================
 # Detalle de una recogida de compost — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Recogida #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostcollection') }}">Recogida de compost</a>
    {% if entity.compostCollectionPoint %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('compostcollectionpoint_show', { id: entity.compostCollectionPoint.id }) }}">{{ entity.compostCollectionPoint }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'compostcollection-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-recycle"></i>
            </span>
            <div>
                <h1>Recogida del {{ entity.collectDate|format_date('long', locale='es') }}</h1>
                {% if entity.compostCollectionPoint %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        En {{ entity.compostCollectionPoint }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-compostcollection-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-compostcollection-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'compostcollection-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('compostcollection_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('compostcollection') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos de la recogida', accent: 'green' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha</dt>
                    <dd class="csa-defs__value">{{ entity.collectDate|format_date('long', locale='es') }}</dd>
                </div>
                {% if entity.compostCollectionPoint %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Punto de recogida</dt>
                        <dd class="csa-defs__value">
                            <a href="{{ path('compostcollectionpoint_show', { id: entity.compostCollectionPoint.id }) }}">{{ entity.compostCollectionPoint }}</a>
                        </dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Kilos recogidos</dt>
                    <dd class="csa-defs__value">{{ entity.amount }} kg</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">% de impropios</dt>
                    <dd class="csa-defs__value">{{ entity.improperPercentage }} %</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Semana del año</dt>
                    <dd class="csa-defs__value">{{ entity.week }}</dd>
                </div>
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
