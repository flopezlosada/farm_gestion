{# ============================================================
 # Editar recogida de compost — shell csa.
 #
 # La plantilla legacy estaba vacía (solo el submit, sin campos).
 # Aquí se reproduce el form completo siguiendo el patrón del new.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar recogida #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostcollection') }}">Recogida de compost</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostcollection_show', { id: entity.id }) }}">#{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Compost · Recogida',
        'Editar recogida #' ~ entity.id,
        'Corrige fecha, punto, kilos o impropios.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'compostcollection-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('compostcollection_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos de la recogida', subtitle: 'Fecha, punto, kilos y calidad.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.collect_date, 'Fecha', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(edit_form.compost_collection_point, 'Punto de recogida') }}
                        {{ csa.field(edit_form.amount, 'Kilos recogidos') }}
                        {{ csa.field(edit_form.improper_percentage, '% de impropios', { hint: 'número de 0 a 100' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-compostcollection-delete').showModal()">
                        Eliminar recogida
                    </button>
            {{ csa.confirm_dialog('confirm-compostcollection-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'compostcollection-delete-form',
            }) }}
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('compostcollection_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
