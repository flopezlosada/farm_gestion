{# ============================================================
 # Albergue · Métricas por procedencia. UX funcional, pendiente
 # de rediseño.
 # ============================================================ #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Albergue · Métricas {{ stats.year }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('helper_index') }}">Albergue</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Métricas {{ stats.year }}</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
.met-table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid var(--csa-rule, #ebe7dd); border-radius: 10px; overflow: hidden; }
.met-table th, .met-table td { padding: 12px 16px; border-bottom: 1px solid var(--csa-rule, #f0ede5); font-size: 14px; text-align: left; }
.met-table th { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--csa-ink-faint, #8d8773); font-weight: 600; }
.met-table td.num, .met-table th.num { text-align: right; font-variant-numeric: tabular-nums; }
.met-table tr:last-child td { border-bottom: none; }
.met-table tfoot td { font-weight: 700; background: #faf8f3; border-top: 2px solid var(--csa-line-2, #d8d2c2); }
.met-empty { padding: 40px 18px; text-align: center; color: var(--csa-ink-faint, #8d8773); font-style: italic; background: #fff; border: 1px dashed var(--csa-line-2, #d8d2c2); border-radius: 8px; }
</style>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Albergue', 'Métricas por procedencia', 'De dónde llega la gente y cuánto se queda, por año.') }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div class="csa-row" style="align-items: center; gap: 10px;">
            {{ csa.btn('◂ ' ~ prev_year, { variant: 'ghost', href: path('albergue_stats', { year: prev_year }) }) }}
            <strong style="font-family: var(--csa-serif); font-size: 20px;">{{ stats.year }}</strong>
            {{ csa.btn(next_year ~ ' ▸', { variant: 'ghost', href: path('albergue_stats', { year: next_year }) }) }}
        </div>
        {{ csa.btn('Voluntarios', { variant: 'ghost', href: path('helper_index'), icon: 'fa-bed' }) }}
    </div>

    {% if stats.rows|length > 0 %}
        <table class="met-table">
            <thead>
                <tr>
                    <th>Procedencia</th>
                    <th class="num">Voluntarios</th>
                    <th class="num">Estancias</th>
                    <th class="num">Noches</th>
                </tr>
            </thead>
            <tbody>
                {% for row in stats.rows %}
                    <tr>
                        <td>{{ row.source.name }}</td>
                        <td class="num">{{ row.helpers }}</td>
                        <td class="num">{{ row.stays }}</td>
                        <td class="num">{{ row.nights }}</td>
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td>Total</td>
                    <td class="num">{{ stats.totals.helpers }}</td>
                    <td class="num">{{ stats.totals.stays }}</td>
                    <td class="num">{{ stats.totals.nights }}</td>
                </tr>
            </tfoot>
        </table>
        <p style="margin-top: 12px; font-size: 12px; color: var(--csa-ink-faint, #8d8773);">
            Voluntarios y estancias cuentan confirmadas y solicitadas (no canceladas); las noches, sólo confirmadas.
        </p>
    {% else %}
        <div class="met-empty">No hay estancias registradas en {{ stats.year }}.</div>
    {% endif %}
{% endblock %}
