{# ============================================================
 # Listado de proveedorxs (Provider).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Proveedorxs{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Proveedorxs</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Compras',
        'Proveedorxs',
        'Personas y empresas a las que se les compran productos o servicios.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevx proveedorx', { variant: 'primary', href: path('provider_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Contacto</th>
                    <th>Web</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('provider_show', { id: entity.id }) }}">{{ entity.name }}</a>
                        </td>
                        <td>{% if entity.contact %}{{ entity.contact }}{% else %}—{% endif %}</td>
                        <td>{% if entity.web %}{{ entity.web }}{% else %}—{% endif %}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('provider_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('provider_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay proveedorxs registradxs.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
