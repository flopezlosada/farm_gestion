{# ============================================================
 # Selector de familiar o socix con quien comparte cesta.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set is_family = type == 'add_family' %}

{% block title %}{{ is_family ? 'Selección de familiares' : 'Selección de cesta compartida' }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner.id }) }}">{{ partner.name }} {{ partner.surname }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ is_family ? 'Añadir familiar' : 'Cesta compartida' }}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Vínculos',
        is_family ? ('Familiares de ' ~ partner.name ~ ' ' ~ partner.surname) : ('Cesta compartida de ' ~ partner.name ~ ' ' ~ partner.surname),
        is_family
            ? 'Al pinchar en una socix se le añade como familiar de la socix actual. La familiar principal es la actual; la seleccionada queda relacionada con ella pero no es la principal.'
            : 'Al pinchar en una socix se establece con quién comparte la cesta semanal.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for people in partners %}
                    <tr>
                        <td>{{ people.name }} {{ people.surname }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('partner_show', { id: people.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path(type, { partner1_id: partner.id, partner2_id: people.id }) }}"
                               title="Asociar" aria-label="Asociar"
                               onclick="return confirm('¿Asociar a {{ people.name }} {{ people.surname }} con {{ partner.name }} {{ partner.surname }}?');">
                                <i class="fa fa-link"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="2" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay socixs disponibles para asociar.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
