{% extends 'layout_list.html.twig' %}

{% block title %} Indicar {{ type=='add_family'?'familiares':'con quién comparte cesta' }}

{% endblock %}

{% block main %}
    <div class="row">
        <div class="col-lg-12">
            <h1 class="page-header"> {{ type=='add_family'?'Selección de familiares':'Seleccionar con quién comparte cesta' }} </h1>
        </div>
        <!-- /.col-lg-12 -->
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    Socia/o: <a
                            href="{{ path('partner_show', {'id': partner.id}) }}"> {{ partner.name }} {{ partner.surname }}</a>
                </div>
                <div class="panel-body">
                    Al pinchar en una/un socia/o se le añadirá
                    como {{ type=='add_family'?'familiar':' con quien comparte cesta' }} a la/el socia/o actual.
                    {% if type=='add_family' %}
                        El familiar
                        principal es la socia actual. La socia que selecciones de la lista
                        estará relacionada con la actual pero no será la principal.
                    {% endif %}
                    <div class="table-responsive">
                        <table id="table_list"
                               class="table table-striped table-bordered table-hover dataTable no-footer"
                               aria-describedby="dataTables-example_info">
                            <thead>
                            <tr>
                                <th>Nombre</th>

                            </tr>
                            </thead>
                            <tfoot>
                            <tr role="row">
                            </tr>
                            </tfoot>
                            <tbody>

                            {% for people in partners %}
                                <tr>
                                    <td>
                                        {{ people.name }} {{ people.surname }} | <a
                                                href="{{ path('partner_show', {'id': people.id}) }}">Mostrar</a> | <a
                                                href="{{ path(type, {'partner1_id': partner.id, 'partner2_id': people.id}) }}">Asociar</a>

                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

