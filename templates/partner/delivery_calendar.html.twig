{# ============================================================
 # Calendario de recogida del socio (B').
 # Rejilla mensual (qué días recoge de un vistazo) + panel del día
 # seleccionado con sus acciones: editar componentes (verdura/huevos),
 # mover de día (cambio puntual) y no recoger.
 #
 # R1: en cestas compartidas el día y el contenido los marca la
 # alternancia con el otro hogar — no hay acciones.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set EGG = constant('App\\Entity\\BasketComponent::ID_EGGS') %}

{# Lista (solo lectura) de lo que lleva una entrega ese día. El contenido del día ya no
   se edita por componente: el modelo es "todo junto por día". Para cambiar un día se
   ARRASTRA en la rejilla (día→papelera = no recoge; día→día libre = mover). #}
{% macro components(selected, EGG) %}
    {% for it in selected.items|sort((a, b) => a.component.id - b.component.id) %}
        {% set is_egg = it.component.id == EGG %}
        <div class="rcal-comp">
            <span class="rcal-comp__ic {{ is_egg ? 'egg' : 'veg' }}"><i class="fa {{ is_egg ? 'fa-egg' : 'fa-leaf' }}"></i></span>
            <span class="rcal-comp__t">
                <span class="rcal-comp__name">{{ is_egg ? 'Huevos' : 'Cesta de verdura' }}</span>
                <span class="rcal-comp__sub">{{ it.amount + 0 }} {{ is_egg ? 'docena' : 'cesta' }}{{ (it.amount + 0) != 1 ? 's' }}</span>
            </span>
        </div>
    {% else %}
        <p class="csa-muted">Sin componentes.</p>
    {% endfor %}
{% endmacro %}

{% block title %}Calendario de recogida · {{ partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner.id }) }}">{{ partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Calendario de recogida</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
  .rcal{display:grid;grid-template-columns:1.4fr 1fr;gap:var(--csa-sp-5);align-items:start}
  .rcal.rcal-busy{opacity:.55;pointer-events:none;transition:opacity .1s}
  @media (max-width:880px){.rcal{grid-template-columns:1fr}}

  /* --- navegación de mes (botones circulares, sin el subrayado verde de :where(a):hover) --- */
  .rcal-monthnav{position:relative;display:flex;align-items:center;justify-content:center;gap:var(--csa-sp-4);margin-bottom:var(--csa-sp-5)}
  .rcal-resetform{position:absolute;right:0;margin:0}
  .rcal-month{font-family:var(--csa-serif);font-weight:500;font-size:18px;letter-spacing:-.02em;text-transform:capitalize;min-width:150px;text-align:center}
  .csa-app a.rcal-navbtn{width:36px;height:36px;border-radius:50%;border:1px solid var(--csa-border);background:var(--csa-surface);color:var(--csa-ink-soft);display:inline-grid;place-items:center;text-decoration:none;transition:.15s}
  .csa-app a.rcal-navbtn:hover{border-color:var(--csa-ink-soft);border-bottom-color:var(--csa-ink-soft);color:var(--csa-ink);background:var(--csa-surface-alt)}

  /* --- rejilla --- */
  .rcal-grid{background:var(--csa-surface);border:1px solid var(--csa-border);border-top:2px solid var(--csa-green);border-radius:var(--csa-radius,12px);padding:var(--csa-sp-4)}
  .rcal-dow{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:5px}
  .rcal-dow span{text-align:center;font-size:10px;font-weight:600;color:var(--csa-ink-muted);text-transform:uppercase;letter-spacing:.03em}
  .rcal-weeks{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
  .rcal-cell{height:44px;border-radius:8px;padding:5px 7px;border:1px solid transparent;display:flex;flex-direction:column;justify-content:space-between;text-decoration:none}
  .rcal-cell .n{font-size:12px;color:var(--csa-ink-soft);font-variant-numeric:tabular-nums;line-height:1}
  .rcal-cell.out .n{color:#d2d1cc}
  .rcal-cell.empty{background:var(--csa-surface-alt)}
  .rcal-cell.wknd.empty{background:#f0efec}
  .rcal-dots{display:flex;gap:3px;align-self:flex-end}
  .rcal-dot{width:7px;height:7px;border-radius:50%}
  .rcal-dot.veg{background:var(--csa-green)} .rcal-dot.egg{background:var(--csa-ochre)}
  a.rcal-pick{background:var(--csa-green-soft);border-color:#cfe0b4;transition:.12s}
  a.rcal-pick .n{color:var(--csa-green);font-weight:700}
  a.rcal-pick:hover{box-shadow:0 2px 6px rgba(74,124,58,.18)}
  a.rcal-skip{background:var(--csa-terracotta-soft);border-color:#f3c4a8}
  a.rcal-skip .n{color:var(--csa-terracotta);font-weight:700;text-decoration:line-through}
  a.rcal-skip .x{align-self:flex-end;font-size:10px;color:#b04e22}
  /* semana cerrada (excepción de cancelación): gris, no hay reparto para nadie */
  a.rcal-closed{background:#eceae6;border-color:#dcdad5;cursor:default}
  a.rcal-closed .n{color:#9b988f;font-weight:600}
  a.rcal-closed .x{align-self:flex-end;font-size:10px;color:#9b988f}
  .rcal-cell.sel.rcal-closed{outline-color:#9b988f}
  /* movida a otro día: su cesta está en otra fecha, no es "no recoge" */
  a.rcal-moved{background:var(--csa-sky-soft);border-color:var(--csa-sky)}
  a.rcal-moved .n{color:var(--csa-sky);font-weight:700}
  a.rcal-moved .x{align-self:flex-end;font-size:10px;color:var(--csa-sky)}
  .rcal-cell.sel{outline:2px solid var(--csa-green);outline-offset:1px}
  .rcal-cell.sel.rcal-skip{outline-color:var(--csa-terracotta)}
  .rcal-cell.sel.rcal-moved{outline-color:var(--csa-sky)}
  .rcal-legend{display:flex;gap:var(--csa-sp-4);margin-top:var(--csa-sp-4);padding-top:var(--csa-sp-3);border-top:1px solid var(--csa-border);font-size:12px;color:var(--csa-ink-soft);align-items:center;flex-wrap:wrap}
  .rcal-legend .d{width:9px;height:9px;border-radius:50%;display:inline-block;margin-right:5px}

  /* --- panel --- */
  .rcal-panel{background:var(--csa-surface);border:1px solid var(--csa-border);border-radius:var(--csa-radius,12px);overflow:hidden}
  .rcal-panel__hd{padding:var(--csa-sp-4) var(--csa-sp-4) var(--csa-sp-3);background:var(--csa-green-soft)}
  .rcal-panel__hd.is-skip{background:var(--csa-terracotta-soft)}
  .rcal-panel__day{font-family:var(--csa-serif);font-size:22px;font-weight:500;letter-spacing:-.02em;font-variant-numeric:lining-nums tabular-nums}
  .rcal-panel__where{font-size:13px;color:var(--csa-green);font-weight:500;margin-top:2px}
  .rcal-panel__hd.is-skip .rcal-panel__where{color:#b04e22}
  .rcal-panel__where i{margin-right:5px}
  .rcal-panel__bd{padding:var(--csa-sp-4)}
  .rcal-sect{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--csa-ink-muted);font-weight:600;margin-bottom:var(--csa-sp-3)}
  .rcal-empty-note{display:flex;align-items:center;gap:8px;background:var(--csa-terracotta-soft);color:#b04e22;font-size:12.5px;border-radius:9px;padding:9px 12px;margin-bottom:var(--csa-sp-4)}
  .rcal-move-wrap{margin-top:var(--csa-sp-5)}

  .rcal-comp{display:flex;align-items:center;gap:var(--csa-sp-3);padding:9px 0}
  .rcal-comp+.rcal-comp{border-top:1px solid var(--csa-border)}
  .rcal-comp__ic{width:34px;height:34px;border-radius:9px;display:grid;place-items:center;font-size:14px;flex-shrink:0}
  .rcal-comp__ic.veg{background:var(--csa-green-soft);color:var(--csa-green)}
  .rcal-comp__ic.egg{background:var(--csa-ochre-soft);color:var(--csa-ochre)}
  .rcal-comp.off .rcal-comp__ic{filter:grayscale(.6);opacity:.55}
  .rcal-comp__t{flex:1}
  .rcal-comp__name{font-weight:600;font-size:14px;display:block}
  .rcal-comp__sub{font-size:12px;color:var(--csa-ink-muted);display:block;margin-top:1px}
  .rcal-comp__sub.off{color:var(--csa-terracotta);font-weight:600}

  /* switch = botón submit del form de toggle */
  .rcal-sw{position:relative;width:40px;height:23px;flex-shrink:0;border:0;padding:0;background:none;cursor:pointer}
  .rcal-sw .track{position:absolute;inset:0;background:#d6d5d0;border-radius:12px;transition:.18s}
  .rcal-sw .thumb{position:absolute;top:2px;left:2px;width:19px;height:19px;background:#fff;border-radius:50%;transition:.18s;box-shadow:0 1px 2px rgba(0,0,0,.25)}
  .rcal-sw.on .track{background:var(--csa-green)}
  .rcal-sw.on .thumb{transform:translateX(17px)}

  /* selector de alcance del movimiento (mover todo / solo un componente) */
  .rcal-move-scope{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:var(--csa-sp-3)}
  .rcal-move-scope__lbl{font-size:12px;color:var(--csa-ink-muted)}
  .csa-app a.rcal-scope-btn{font-size:12px;padding:3px 10px;border-radius:999px;border:1px solid var(--csa-border);color:var(--csa-ink-soft);background:var(--csa-surface);text-decoration:none;text-transform:capitalize;transition:.12s}
  .csa-app a.rcal-scope-btn:hover{border-color:var(--csa-ink-soft);border-bottom-color:var(--csa-ink-soft);color:var(--csa-ink)}
  .csa-app a.rcal-scope-btn.on{background:var(--csa-green-soft);border-color:#cfe0b4;color:var(--csa-green);font-weight:600}
  .rcal-move-chips{display:flex;flex-wrap:wrap;gap:var(--csa-sp-2)}
  .rcal-move-chip{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--csa-sky);background:var(--csa-sky-soft);color:var(--csa-sky);border-radius:9px;padding:8px 13px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;text-transform:capitalize;transition:.12s}
  .rcal-move-chip:hover{background:#bcdaea}
  .rcal-move-chip i{font-size:11px}
  .rcal-hint{font-size:11px;color:var(--csa-ink-muted);margin-top:6px}

  .rcal-panel__ft{padding:var(--csa-sp-4);border-top:1px solid var(--csa-border);background:var(--csa-surface-alt)}
  .rcal-empty{padding:var(--csa-sp-6) var(--csa-sp-4);text-align:center;color:var(--csa-ink-muted);font-size:14px}

  /* --- columna izquierda (rejilla + papelera apiladas) --- */
  .rcal-left{display:flex;flex-direction:column;gap:var(--csa-sp-5)}

  /* --- arrastre --- */
  .csa-app a.rcal-grab,.rcal-grab{cursor:grab}
  .rcal-grab:active{cursor:grabbing}
  .rcal-dragging{opacity:.4}
  /* destino DISPONIBLE mientras se arrastra (pista suave) */
  .rcal-dragok{outline:2px dashed #cfe0b4;outline-offset:-2px;background:var(--csa-green-soft)}
  /* destino que se está SOBREVOLANDO ahora (pista fuerte) */
  .rcal-dropok{outline:2px solid var(--csa-green);outline-offset:-2px;background:#dcebc4}

  /* --- papelera --- */
  .rcal-tray{background:var(--csa-surface);border:1px dashed var(--csa-border);border-radius:var(--csa-radius,12px);padding:var(--csa-sp-4);transition:.12s}
  .rcal-tray__hd{display:flex;flex-direction:column;gap:2px;margin-bottom:var(--csa-sp-3)}
  .rcal-tray__title{font-size:13px;font-weight:600;color:var(--csa-terracotta)}
  .rcal-tray__title i{margin-right:6px}
  .rcal-tray__hint{font-size:11px;color:var(--csa-ink-muted)}
  .rcal-tray__body{display:flex;flex-wrap:wrap;gap:var(--csa-sp-2);min-height:46px;align-items:center}
  .rcal-tray__empty{font-size:12px;color:var(--csa-ink-muted);margin:0}
  .rcal-tray-card{display:inline-flex;align-items:center;gap:7px;background:var(--csa-terracotta-soft);border:1px solid #f3c4a8;border-radius:9px;padding:7px 11px;font-size:13px;color:#b04e22;font-weight:600;text-transform:capitalize}
  .rcal-tray-card__ic{font-size:11px}
</style>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Recogida',
        'Calendario de recogida',
        partner ~ (pickup_place ? ' · recoge en ' ~ pickup_place : '')
    ) }}

    <div class="rcal-monthnav">
        <a class="rcal-navbtn" href="{{ path('partner_delivery_calendar', { id: partner.id, year: prev.format('Y'), month: prev.format('n') }) }}"
           aria-label="Mes anterior" title="Mes anterior"><i class="fa fa-chevron-left"></i></a>
        <span class="rcal-month">{{ current|format_datetime('none', 'none', pattern='LLLL yyyy', locale='es') }}</span>
        <a class="rcal-navbtn" href="{{ path('partner_delivery_calendar', { id: partner.id, year: next.format('Y'), month: next.format('n') }) }}"
           aria-label="Mes siguiente" title="Mes siguiente"><i class="fa fa-chevron-right"></i></a>

        {# Reset del mes a su patrón: red de seguridad para estados enredados. Lo puede usar
           quien gestiona socixs (la página ya exige ROLE_GESTION_SOCIXS). No en compartidas (R1).
           Recarga normal (no AJAX): es una acción rara y conviene ver el mes limpio de cero. #}
        {% if partner.sharePartner is null %}
            <form id="rcal-reset-form" action="{{ path('partner_delivery_calendar_reset', { id: partner.id }) }}" method="post" class="rcal-resetform">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_reset_' ~ partner.id) }}">
                <input type="hidden" name="year" value="{{ current.format('Y') }}">
                <input type="hidden" name="month" value="{{ current.format('n') }}">
                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm"
                        onclick="document.getElementById('rcal-confirm-reset').showModal()">
                    <i class="fa fa-rotate-left"></i><span>Resetear el mes</span>
                </button>
            </form>
            {{ csa.confirm_dialog('rcal-confirm-reset', {
                variant: 'warning',
                eyebrow: 'Resetear mes',
                title: '¿Resetear el calendario de este mes?',
                body: 'Se deshacen los cambios puntuales (mover, no recoger, recuperar) de ' ~ (current|format_datetime('none', 'none', pattern='LLLL yyyy', locale='es')) ~ ' y las entregas vuelven a su patrón. Úsalo si algo quedó descuadrado.',
                confirm_label: 'Resetear',
                external_form_id: 'rcal-reset-form',
            }) }}
        {% endif %}
    </div>

    {% if partner.sharePartner %}
        {{ csa.callout('Esta cesta es compartida: su día y su contenido los marca la alternancia con el otro hogar, no se editan desde aquí.', 'info', 'info-circle') }}
    {% endif %}

    <div class="rcal">

        <div class="rcal-left">

        {# ===== REJILLA ===== #}
        <div class="rcal-grid" data-rcal-drop="grid">
            <div class="rcal-dow"><span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span></div>
            <div class="rcal-weeks">
                {% for week in weeks %}
                    {% for day in week %}
                        {% set slot = day.slot %}
                        {% set is_sel = slot and selected and slot.basket.id == selected.basket.id %}
                        {% set wknd = day.date.format('N') in [6, 7] %}
                        {% if slot and slot.closed|default(false) %}
                            {# Semana CERRADA (excepción de cancelación: festivo/vacaciones). No
                               hay reparto para nadie. Gris, no arrastrable ni editable; navegable
                               para que el panel explique el cierre. #}
                            <a href="{{ path('partner_delivery_calendar', { id: partner.id, year: slot.basket.date.format('Y'), month: slot.basket.date.format('n'), sel: slot.basket.id }) }}"
                               class="rcal-cell rcal-closed{{ is_sel ? ' sel' }}">
                                <span class="n">{{ day.date.format('j') }}</span>
                                <span class="x"><i class="fa fa-lock"></i></span>
                            </a>
                        {% elseif slot %}
                            {# Rojo si se le han quitado todos los componentes (no recoge nada).
                               Las "no recoge" (saltadas) ya NO llegan aquí: viven en la papelera
                               y su día sale libre. #}
                            {% set no_pickup = slot.items is empty %}
                            {# Arrastrable = entrega real, futura y no compartida (R1). Arrastrarla
                               a la papelera = no recoger esa semana. #}
                            {% set day_grab = not no_pickup and partner.sharePartner is null and slot.date > date('today') %}
                            {# Se navega al mes LÓGICO del Basket (su viernes-ciclo), que para las
                               entregas del mes coincide con el visible, pero para una que se cuela
                               por fecha física desde un mes vecino es donde el panel la resuelve. #}
                            <a href="{{ path('partner_delivery_calendar', { id: partner.id, year: slot.basket.date.format('Y'), month: slot.basket.date.format('n'), sel: slot.basket.id }) }}"
                               class="rcal-cell {{ no_pickup ? 'rcal-skip' : 'rcal-pick' }}{{ is_sel ? ' sel' }}{{ day_grab ? ' rcal-grab' }}"
                               {% if day_grab %}draggable="true" data-rcal-draggable data-rcal-kind="grid" data-rcal-skip-url="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: slot.basket.id }) }}" data-rcal-move-url="{{ path('partner_delivery_calendar_move', { id: partner.id, basketId: slot.basket.id }) }}"{% endif %}>
                                <span class="n">{{ day.date.format('j') }}</span>
                                {% if no_pickup %}
                                    <span class="x"><i class="fa fa-ban"></i></span>
                                {% else %}
                                    <span class="rcal-dots">
                                        {# Orden fijo por id de componente (verdura, huevos): si no,
                                           al quitar y re-añadir los puntitos se desordenan. #}
                                        {% for item in slot.items|sort((a, b) => a.component.id - b.component.id) %}
                                            <span class="rcal-dot {{ item.component.id == EGG ? 'egg' : 'veg' }}"></span>
                                        {% endfor %}
                                    </span>
                                {% endif %}
                            </a>
                        {% else %}
                            {# Celda libre. Si el nodo reparte ese día (dropBasketId), es
                               destino válido para soltar una entrega arrastrada (mover). #}
                            <div class="rcal-cell empty{{ not day.inMonth ? ' out' }}{{ wknd ? ' wknd' }}{{ day.dropBasketId ? ' rcal-droptarget' }}"
                                 {% if day.dropBasketId %}data-rcal-target data-rcal-to="{{ day.dropBasketId }}"{% endif %}>
                                <span class="n">{{ day.date.format('j') }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
            </div>
            <div class="rcal-legend">
                <span><span class="d" style="background: var(--csa-green);"></span>Verdura</span>
                <span><span class="d" style="background: var(--csa-ochre);"></span>Huevos</span>
            </div>
        </div>

        {# ===== PAPELERA (no recoge, recuperable) ===== #}
        {% if partner.sharePartner is null %}
        <div class="rcal-tray" data-rcal-drop="tray">
            <div class="rcal-tray__hd">
                <span class="rcal-tray__title"><i class="fa fa-inbox"></i> No recoge</span>
                <span class="rcal-tray__hint">Arrastra un día aquí para no recogerlo · o saca uno para recuperarlo</span>
            </div>
            <div class="rcal-tray__body">
                {% for t in tray %}
                    {% set t_grab = t.date > date('today') %}
                    <div class="rcal-tray-card{{ t_grab ? ' rcal-grab' }}"
                         {% if t_grab %}draggable="true" data-rcal-draggable data-rcal-kind="tray" data-rcal-skip-url="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: t.basket.id }) }}" data-rcal-recover-url="{{ path('partner_delivery_calendar_recover', { id: partner.id, basketId: t.basket.id }) }}"{% endif %}>
                        <span class="rcal-tray-card__ic"><i class="fa fa-ban"></i></span>
                        <span class="rcal-tray-card__d">{{ t.date|format_date(pattern='EEE d MMM', locale='es') }}</span>
                    </div>
                {% else %}
                    <p class="rcal-tray__empty">Nada aparcado este mes.</p>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        </div>{# /.rcal-left #}

        {# ===== PANEL DEL DÍA SELECCIONADO ===== #}
        <div class="rcal-panel">
            {% if selected %}
                {% set bid = selected.basket.id %}
                {# Vacío = sin componentes y no saltada explícitamente: no recoge nada. #}
                {% set is_empty = not selected.skipped and selected.items is empty %}

                <div class="rcal-panel__hd{{ (selected.skipped or is_empty) ? ' is-skip' }}">
                    <div class="rcal-panel__day">{{ selected.date|format_date('full', locale='es')|capitalize }}</div>
                    {% if pickup_place %}
                        <div class="rcal-panel__where"><i class="fa fa-map-marker"></i>Recoge en {{ pickup_place }}</div>
                    {% endif %}
                </div>

                {# Solo-lectura: compartidas (R1) y entregas pasadas. En semanas SIN
                   generar el contenido SÍ se edita: las acciones (no recoger / quitar
                   componente) se guardan como intents durables, no materializan nada. #}
                {% set readonly = partner.sharePartner is not null or not selected_editable %}

                {% if selected.closed|default(false) %}
                    {# Semana CERRADA por excepción de calendario (festivo/vacaciones): no hay
                       reparto para nadie. No editable — el cierre se gestiona desde Excepciones
                       de reparto, no aquí. #}
                    <div class="rcal-panel__bd">
                        <div class="rcal-sect"><i class="fa fa-lock"></i> Semana cerrada</div>
                        <p class="csa-muted">El {{ selected.date|format_date('long', locale='es') }} no hay reparto (excepción de calendario). No se recoge nada esa semana y no sale en el listado.</p>
                    </div>
                {% elseif selected.skipped %}
                    {# Saltada: no lleva nada esa semana; si es editable, se puede restaurar.
                       Una cesta movida que se marca "no recoge" también cae aquí. #}
                    <div class="rcal-panel__bd">
                        <div class="rcal-sect">Esta semana no recoge</div>
                        <p class="csa-muted">La entrega del {{ selected.date|format_date('long', locale='es') }} está marcada como NO recogida y no saldrá en el reparto.</p>
                    </div>
                    {% if selected_editable and partner.sharePartner is null %}
                        <div class="rcal-panel__ft">
                            <form action="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: bid }) }}" method="post" style="margin: 0;" data-rcal-ajax>
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_skip_' ~ partner.id) }}">
                                <input type="hidden" name="recover" value="1">
                                {{ csa.btn('Volver a recoger', { type: 'submit', variant: 'secondary', icon: 'fa-undo', block: true }) }}
                            </form>
                        </div>
                    {% endif %}
                {% else %}
                    {# Entrega activa. El contenido es de solo lectura: para cambiar el día se
                       ARRASTRA en la rejilla (a la papelera = no recoge; a un día libre = mover).
                       El botón de abajo es un atajo accesible para "no recoge". #}
                    <div class="rcal-panel__bd">
                        {% if is_empty and not readonly %}
                            <div class="rcal-empty-note"><i class="fa fa-ban"></i> Esta semana no recoge nada.</div>
                        {% endif %}
                        <div class="rcal-sect">Qué se lleva ese día</div>

                        {{ _self.components(selected, EGG) }}

                        {% if not readonly %}
                            <div class="rcal-hint" style="margin-top: var(--csa-sp-4);">
                                <i class="fa fa-arrows"></i> Arrastra este día en el calendario para moverlo a otra fecha o a "No recoge".
                            </div>
                        {% endif %}
                    </div>

                    {% if not readonly %}
                        <div class="rcal-panel__ft">
                            <form id="rcal-skip-form-{{ bid }}" action="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: bid }) }}" method="post" style="margin: 0;" data-rcal-ajax>
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_skip_' ~ partner.id) }}">
                                <button type="button" class="csa-btn csa-btn--danger-soft csa-btn--block"
                                        onclick="document.getElementById('rcal-confirm-skip-{{ bid }}').showModal()">
                                    <i class="fa fa-ban"></i><span>No recoge esta semana</span>
                                </button>
                            </form>
                            <div class="rcal-hint" style="text-align: center;">Queda fuera del reparto. Reversible.</div>
                            {{ csa.confirm_dialog('rcal-confirm-skip-' ~ bid, {
                                variant: 'warning',
                                eyebrow: 'No recoger',
                                title: '¿Marcar que no recoge esta semana?',
                                body: 'La entrega de ' ~ (selected.date|format_date('long', locale='es')) ~ ' no saldrá en el reparto. Podrás revertirlo desde aquí.',
                                confirm_label: 'No recoger',
                                external_form_id: 'rcal-skip-form-' ~ bid,
                            }) }}
                        </div>
                    {% elseif not partner.sharePartner %}
                        <div class="rcal-panel__ft">
                            <div class="rcal-hint" style="text-align: center;"><i class="fa fa-lock"></i> Se recoge hoy o ya pasó · solo lectura</div>
                        </div>
                    {% endif %}
                {% endif %}
            {% else %}
                <div class="rcal-empty">
                    <p>Este mes no tiene entregas para el socio.</p>
                    <p style="margin-top: var(--csa-sp-2); font-size: 12px;">Navega a otro mes con las flechas de arriba.</p>
                </div>
            {% endif %}
        </div>

    </div>

    {% if partner.sharePartner is null %}
    <script>
    (function () {
        const SKIP_CSRF = {{ csrf_token('calendar_skip_' ~ partner.id)|json_encode|raw }};
        const MOVE_CSRF = {{ csrf_token('calendar_move_' ~ partner.id)|json_encode|raw }};

        let dragged = null;

        function clearHighlights() {
            document.querySelectorAll('.rcal-dropok, .rcal-dragok').forEach(function (el) {
                el.classList.remove('rcal-dropok', 'rcal-dragok');
            });
        }

        // handlers: { <kind>: fn(card) }. La zona acepta una ficha si hay handler para su
        // tipo; al soltar, ejecuta el de ese tipo. Una misma celda acepta MOVER (ficha de
        // rejilla) y RECUPERAR (ficha de papelera).
        function wireDrop(el, handlers) {
            el.addEventListener('dragover', function (e) {
                if (!dragged || !handlers[dragged.dataset.rcalKind]) return;
                e.preventDefault();
                el.classList.add('rcal-dropok');
            });
            el.addEventListener('dragleave', function (e) {
                if (e.target === el) el.classList.remove('rcal-dropok');
            });
            el.addEventListener('drop', function (e) {
                if (!dragged || !handlers[dragged.dataset.rcalKind]) return;
                e.preventDefault();
                handlers[dragged.dataset.rcalKind](dragged);
            });
        }

        // (Re)vincula el DnD y la intercepción de forms sobre un nodo .rcal concreto. Se
        // llama al cargar y tras cada refresco AJAX (el .rcal se reemplaza entero).
        function bind(cal) {
            cal.addEventListener('dragstart', function (e) {
                const card = e.target.closest('[data-rcal-draggable]');
                if (!card) return;
                dragged = card;
                e.dataTransfer.effectAllowed = 'move';
                // setData es obligatorio en Firefox para que arranque el arrastre.
                e.dataTransfer.setData('text/plain', '');
                card.classList.add('rcal-dragging');
                // Destinos válidos: días libres del nodo. Para una ficha de rejilla, además
                // la papelera (no recoge).
                cal.querySelectorAll('[data-rcal-target]').forEach(function (el) { el.classList.add('rcal-dragok'); });
                if (card.dataset.rcalKind === 'grid') {
                    const tray = cal.querySelector('.rcal-tray');
                    if (tray) tray.classList.add('rcal-dragok');
                }
            });

            cal.addEventListener('dragend', function () {
                if (dragged) dragged.classList.remove('rcal-dragging');
                dragged = null;
                clearHighlights();
            });

            cal.querySelectorAll('[data-rcal-target]').forEach(function (cell) {
                wireDrop(cell, {
                    grid: function (card) { send(card.dataset.rcalMoveUrl, { to_basket_id: cell.dataset.rcalTo, _csrf_token: MOVE_CSRF }); },
                    tray: function (card) { send(card.dataset.rcalRecoverUrl, { to_basket_id: cell.dataset.rcalTo, _csrf_token: MOVE_CSRF }); },
                });
            });

            const tray = cal.querySelector('.rcal-tray');
            if (tray) {
                wireDrop(tray, {
                    grid: function (card) { send(card.dataset.rcalSkipUrl, { _csrf_token: SKIP_CSRF }); },
                });
            }

            // Forms del panel (no recoge / volver a recoger): también por AJAX. El botón del
            // diálogo de confirmación es un submit nativo (form="..."), así que su submit
            // burbujea hasta aquí.
            cal.addEventListener('submit', function (e) {
                const form = e.target.closest('form[data-rcal-ajax]');
                if (!form) return;
                e.preventDefault();
                const fields = {};
                new FormData(form).forEach(function (v, k) { fields[k] = v; });
                send(form.action, fields);
            });
        }

        // POST por AJAX y refresco EN SITIO del calendario (sin recargar la página). El
        // endpoint redirige al GET del calendario; seguimos el redirect, y del HTML resultante
        // reemplazamos solo .rcal (rejilla + papelera + panel) y los avisos flash. El servidor
        // sigue siendo la fuente de verdad. Si algo falla, recarga normal como respaldo.
        async function send(url, fields) {
            if (!url) return;
            const cal = document.querySelector('.rcal');
            if (!cal) return;
            cal.classList.add('rcal-busy');
            try {
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    body: new URLSearchParams(fields),
                });
                const doc = new DOMParser().parseFromString(await resp.text(), 'text/html');
                const fresh = doc.querySelector('.rcal');
                if (!fresh) { window.location.reload(); return; }
                const imported = document.importNode(fresh, true);
                cal.replaceWith(imported);
                bind(imported);

                // Avisos flash del shell (errores/confirmaciones): se refrescan en sitio.
                const content = document.querySelector('.csa-content');
                if (content) {
                    const old = content.querySelector('.csa-alerts');
                    if (old) old.remove();
                    const freshAlerts = doc.querySelector('.csa-alerts');
                    if (freshAlerts) content.insertBefore(document.importNode(freshAlerts, true), content.firstElementChild);
                }
            } catch (err) {
                window.location.reload();
            }
        }

        // Cierre de avisos flash inyectados por AJAX (el script del componente no se reejecuta).
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.csa-alert__close');
            if (btn) { const a = btn.closest('.csa-alert'); if (a) a.remove(); }
        });

        const root = document.querySelector('.rcal');
        if (root) bind(root);
    })();
    </script>
    {% endif %}

{% endblock %}
