{# ============================================================
 # Calendario de recogida del socio (B').
 # Rejilla mensual (qué días recoge de un vistazo) + panel del día
 # seleccionado con sus acciones: editar componentes (verdura/huevos),
 # mover de día (cambio puntual) y no recoger.
 #
 # R1: en cestas compartidas el día y el contenido los marca la
 # alternancia con el otro hogar — no hay acciones.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set EGG = constant('App\\Entity\\BasketComponent::ID_EGGS') %}

{# Chips de "mover a otra fecha": un botón por destino. Reusado por la cesta normal
   y por la que ya viene movida (cuyos destinos incluyen su día original = volver). #}
{% macro move_block(partner, bid, candidates, selected, move_component, current) %}
    {% set EGG = constant('App\\Entity\\BasketComponent::ID_EGGS') %}
    <div class="rcal-move-wrap">
        <div class="rcal-sect">Mover a otra fecha</div>
        {# Selector de alcance: solo si la entrega lleva 2+ componentes. Por defecto se
           mueve TODO; "solo verdura/huevos" recarga con los destinos de ese componente
           (caso SANTOS). Cada enlace es una navegación GET que recalcula candidatos. #}
        {% if selected.items|length >= 2 %}
            <div class="rcal-move-scope">
                <span class="rcal-move-scope__lbl">Mover:</span>
                <a href="{{ path('partner_delivery_calendar', { id: partner.id, year: current.format('Y'), month: current.format('n'), sel: bid, move_component: 0 }) }}"
                   class="rcal-scope-btn{{ move_component == 0 ? ' on' }}">todo</a>
                {% for it in selected.items|sort((a, b) => a.component.id - b.component.id) %}
                    <a href="{{ path('partner_delivery_calendar', { id: partner.id, year: current.format('Y'), month: current.format('n'), sel: bid, move_component: it.component.id }) }}"
                       class="rcal-scope-btn{{ move_component == it.component.id ? ' on' }}">solo {{ it.component.id == EGG ? 'huevos' : 'verdura' }}</a>
                {% endfor %}
            </div>
        {% endif %}
        {% if candidates is not empty %}
            <form action="{{ path('partner_delivery_calendar_move', { id: partner.id, basketId: bid }) }}" method="post" style="margin: 0;">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_move_' ~ partner.id) }}">
                {% if move_component != 0 %}<input type="hidden" name="component_id" value="{{ move_component }}">{% endif %}
                <div class="rcal-move-chips">
                    {% for cand in candidates %}
                        <button type="submit" name="to_basket_id" value="{{ cand.id }}" class="rcal-move-chip">
                            <i class="fa fa-arrow-right"></i>{{ cand.date|format_date(pattern='EEE d MMM', locale='es') }}
                        </button>
                    {% endfor %}
                </div>
            </form>
            <div class="rcal-hint">
                {% if move_component != 0 %}Se mueve solo ese componente al día elegido.
                {% else %}Se mueve toda la cesta al día elegido (solo días válidos para su nodo).{% endif %}
            </div>
        {% else %}
            <div class="rcal-hint">No hay días disponibles para mover {{ move_component != 0 ? 'ese componente' : 'la cesta' }} este mes.</div>
        {% endif %}
    </div>
{% endmacro %}

{# Lista de componentes de una entrega. En solo lectura pinta lo que lleva; editable,
   un interruptor por componente que el patrón permite (el switch solo aparece con 2+:
   con uno solo, quitarlo equivale a no recoger → se hace desde el botón de abajo).
   Reusado por la entrega normal y por la que viene movida (destino de un cambio). #}
{% macro components(partner, bid, selected, present_ids, EGG, readonly) %}
    {% if readonly %}
        {% for it in selected.items|sort((a, b) => a.component.id - b.component.id) %}
            {% set is_egg = it.component.id == EGG %}
            <div class="rcal-comp">
                <span class="rcal-comp__ic {{ is_egg ? 'egg' : 'veg' }}"><i class="fa {{ is_egg ? 'fa-egg' : 'fa-leaf' }}"></i></span>
                <span class="rcal-comp__t">
                    <span class="rcal-comp__name">{{ is_egg ? 'Huevos' : 'Cesta de verdura' }}</span>
                    <span class="rcal-comp__sub">{{ it.amount + 0 }} {{ is_egg ? 'docena' : 'cesta' }}{{ (it.amount + 0) != 1 ? 's' }}</span>
                </span>
            </div>
        {% else %}
            <p class="csa-muted">Sin componentes.</p>
        {% endfor %}
    {% else %}
        {# Universo de interruptores = lo que el patrón permite (available) + lo que la
           entrega lleva aunque el patrón no lo dé esa semana (p. ej. huevos que viajaron
           con una cesta movida a una semana sin huevo): así no desaparecen de la vista y
           se pueden quitar. En la entrega normal `extra` es vacío y `comps == available`. #}
        {% set avail_ids = [] %}
        {% for c in selected.available %}{% set avail_ids = avail_ids|merge([c.id]) %}{% endfor %}
        {% set extra = [] %}
        {% for it in selected.items|filter(it => it.component.id not in avail_ids) %}{% set extra = extra|merge([it.component]) %}{% endfor %}
        {% set comps = selected.available|merge(extra) %}
        {% set show_switches = comps|length >= 2 %}
        {% for comp in comps %}
            {% set on = comp.id in present_ids %}
            {% set is_egg = comp.id == EGG %}
            {% set amount = 0 %}
            {% for it in selected.items|filter(it => it.component.id == comp.id) %}{% set amount = it.amount + 0 %}{% endfor %}
            <div class="rcal-comp{{ on ? '' : ' off' }}">
                <span class="rcal-comp__ic {{ is_egg ? 'egg' : 'veg' }}"><i class="fa {{ is_egg ? 'fa-egg' : 'fa-leaf' }}"></i></span>
                <span class="rcal-comp__t">
                    <span class="rcal-comp__name">{{ is_egg ? 'Huevos' : 'Cesta de verdura' }}</span>
                    {% if on %}
                        <span class="rcal-comp__sub">{{ amount }} {{ is_egg ? 'docena' : 'cesta' }}{{ amount != 1 ? 's' }}</span>
                    {% else %}
                        <span class="rcal-comp__sub off">Esta semana no lo quiere</span>
                    {% endif %}
                </span>
                {% if show_switches %}
                    <form action="{{ path('partner_delivery_calendar_component', { id: partner.id, basketId: bid, componentId: comp.id }) }}" method="post" style="margin: 0;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_component_' ~ partner.id) }}">
                        <button type="submit" class="rcal-sw{{ on ? ' on' }}" aria-label="{{ on ? 'Quitar' : 'Añadir' }} {{ is_egg ? 'huevos' : 'verdura' }}">
                            <span class="track"></span><span class="thumb"></span>
                        </button>
                    </form>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}
{% endmacro %}

{% block title %}Calendario de recogida · {{ partner }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_show', { id: partner.id }) }}">{{ partner }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Calendario de recogida</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
  .rcal{display:grid;grid-template-columns:1.4fr 1fr;gap:var(--csa-sp-5);align-items:start}
  @media (max-width:880px){.rcal{grid-template-columns:1fr}}

  /* --- navegación de mes (botones circulares, sin el subrayado verde de :where(a):hover) --- */
  .rcal-monthnav{display:flex;align-items:center;justify-content:center;gap:var(--csa-sp-4);margin-bottom:var(--csa-sp-5)}
  .rcal-month{font-family:var(--csa-serif);font-weight:500;font-size:18px;letter-spacing:-.02em;text-transform:capitalize;min-width:150px;text-align:center}
  .csa-app a.rcal-navbtn{width:36px;height:36px;border-radius:50%;border:1px solid var(--csa-border);background:var(--csa-surface);color:var(--csa-ink-soft);display:inline-grid;place-items:center;text-decoration:none;transition:.15s}
  .csa-app a.rcal-navbtn:hover{border-color:var(--csa-ink-soft);border-bottom-color:var(--csa-ink-soft);color:var(--csa-ink);background:var(--csa-surface-alt)}

  /* --- rejilla --- */
  .rcal-grid{background:var(--csa-surface);border:1px solid var(--csa-border);border-top:2px solid var(--csa-green);border-radius:var(--csa-radius,12px);padding:var(--csa-sp-4)}
  .rcal-dow{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:5px}
  .rcal-dow span{text-align:center;font-size:10px;font-weight:600;color:var(--csa-ink-muted);text-transform:uppercase;letter-spacing:.03em}
  .rcal-weeks{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
  .rcal-cell{height:44px;border-radius:8px;padding:5px 7px;border:1px solid transparent;display:flex;flex-direction:column;justify-content:space-between;text-decoration:none}
  .rcal-cell .n{font-size:12px;color:var(--csa-ink-soft);font-variant-numeric:tabular-nums;line-height:1}
  .rcal-cell.out .n{color:#d2d1cc}
  .rcal-cell.empty{background:var(--csa-surface-alt)}
  .rcal-cell.wknd.empty{background:#f0efec}
  .rcal-dots{display:flex;gap:3px;align-self:flex-end}
  .rcal-dot{width:7px;height:7px;border-radius:50%}
  .rcal-dot.veg{background:var(--csa-green)} .rcal-dot.egg{background:var(--csa-ochre)}
  a.rcal-pick{background:var(--csa-green-soft);border-color:#cfe0b4;transition:.12s}
  a.rcal-pick .n{color:var(--csa-green);font-weight:700}
  a.rcal-pick:hover{box-shadow:0 2px 6px rgba(74,124,58,.18)}
  a.rcal-skip{background:var(--csa-terracotta-soft);border-color:#f3c4a8}
  a.rcal-skip .n{color:var(--csa-terracotta);font-weight:700;text-decoration:line-through}
  a.rcal-skip .x{align-self:flex-end;font-size:10px;color:#b04e22}
  /* movida a otro día: su cesta está en otra fecha, no es "no recoge" */
  a.rcal-moved{background:var(--csa-sky-soft);border-color:var(--csa-sky)}
  a.rcal-moved .n{color:var(--csa-sky);font-weight:700}
  a.rcal-moved .x{align-self:flex-end;font-size:10px;color:var(--csa-sky)}
  .rcal-cell.sel{outline:2px solid var(--csa-green);outline-offset:1px}
  .rcal-cell.sel.rcal-skip{outline-color:var(--csa-terracotta)}
  .rcal-cell.sel.rcal-moved{outline-color:var(--csa-sky)}
  .rcal-legend{display:flex;gap:var(--csa-sp-4);margin-top:var(--csa-sp-4);padding-top:var(--csa-sp-3);border-top:1px solid var(--csa-border);font-size:12px;color:var(--csa-ink-soft);align-items:center;flex-wrap:wrap}
  .rcal-legend .d{width:9px;height:9px;border-radius:50%;display:inline-block;margin-right:5px}

  /* --- panel --- */
  .rcal-panel{background:var(--csa-surface);border:1px solid var(--csa-border);border-radius:var(--csa-radius,12px);overflow:hidden}
  .rcal-panel__hd{padding:var(--csa-sp-4) var(--csa-sp-4) var(--csa-sp-3);background:var(--csa-green-soft)}
  .rcal-panel__hd.is-skip{background:var(--csa-terracotta-soft)}
  .rcal-panel__day{font-family:var(--csa-serif);font-size:22px;font-weight:500;letter-spacing:-.02em;font-variant-numeric:lining-nums tabular-nums}
  .rcal-panel__where{font-size:13px;color:var(--csa-green);font-weight:500;margin-top:2px}
  .rcal-panel__hd.is-skip .rcal-panel__where{color:#b04e22}
  .rcal-panel__where i{margin-right:5px}
  .rcal-panel__bd{padding:var(--csa-sp-4)}
  .rcal-sect{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--csa-ink-muted);font-weight:600;margin-bottom:var(--csa-sp-3)}
  .rcal-empty-note{display:flex;align-items:center;gap:8px;background:var(--csa-terracotta-soft);color:#b04e22;font-size:12.5px;border-radius:9px;padding:9px 12px;margin-bottom:var(--csa-sp-4)}
  .rcal-move-wrap{margin-top:var(--csa-sp-5)}

  .rcal-comp{display:flex;align-items:center;gap:var(--csa-sp-3);padding:9px 0}
  .rcal-comp+.rcal-comp{border-top:1px solid var(--csa-border)}
  .rcal-comp__ic{width:34px;height:34px;border-radius:9px;display:grid;place-items:center;font-size:14px;flex-shrink:0}
  .rcal-comp__ic.veg{background:var(--csa-green-soft);color:var(--csa-green)}
  .rcal-comp__ic.egg{background:var(--csa-ochre-soft);color:var(--csa-ochre)}
  .rcal-comp.off .rcal-comp__ic{filter:grayscale(.6);opacity:.55}
  .rcal-comp__t{flex:1}
  .rcal-comp__name{font-weight:600;font-size:14px;display:block}
  .rcal-comp__sub{font-size:12px;color:var(--csa-ink-muted);display:block;margin-top:1px}
  .rcal-comp__sub.off{color:var(--csa-terracotta);font-weight:600}

  /* switch = botón submit del form de toggle */
  .rcal-sw{position:relative;width:40px;height:23px;flex-shrink:0;border:0;padding:0;background:none;cursor:pointer}
  .rcal-sw .track{position:absolute;inset:0;background:#d6d5d0;border-radius:12px;transition:.18s}
  .rcal-sw .thumb{position:absolute;top:2px;left:2px;width:19px;height:19px;background:#fff;border-radius:50%;transition:.18s;box-shadow:0 1px 2px rgba(0,0,0,.25)}
  .rcal-sw.on .track{background:var(--csa-green)}
  .rcal-sw.on .thumb{transform:translateX(17px)}

  /* selector de alcance del movimiento (mover todo / solo un componente) */
  .rcal-move-scope{display:flex;flex-wrap:wrap;align-items:center;gap:6px;margin-bottom:var(--csa-sp-3)}
  .rcal-move-scope__lbl{font-size:12px;color:var(--csa-ink-muted)}
  .csa-app a.rcal-scope-btn{font-size:12px;padding:3px 10px;border-radius:999px;border:1px solid var(--csa-border);color:var(--csa-ink-soft);background:var(--csa-surface);text-decoration:none;text-transform:capitalize;transition:.12s}
  .csa-app a.rcal-scope-btn:hover{border-color:var(--csa-ink-soft);border-bottom-color:var(--csa-ink-soft);color:var(--csa-ink)}
  .csa-app a.rcal-scope-btn.on{background:var(--csa-green-soft);border-color:#cfe0b4;color:var(--csa-green);font-weight:600}
  .rcal-move-chips{display:flex;flex-wrap:wrap;gap:var(--csa-sp-2)}
  .rcal-move-chip{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--csa-sky);background:var(--csa-sky-soft);color:var(--csa-sky);border-radius:9px;padding:8px 13px;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;text-transform:capitalize;transition:.12s}
  .rcal-move-chip:hover{background:#bcdaea}
  .rcal-move-chip i{font-size:11px}
  .rcal-hint{font-size:11px;color:var(--csa-ink-muted);margin-top:6px}

  .rcal-panel__ft{padding:var(--csa-sp-4);border-top:1px solid var(--csa-border);background:var(--csa-surface-alt)}
  .rcal-empty{padding:var(--csa-sp-6) var(--csa-sp-4);text-align:center;color:var(--csa-ink-muted);font-size:14px}
</style>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Recogida',
        'Calendario de recogida',
        partner ~ (pickup_place ? ' · recoge en ' ~ pickup_place : '')
    ) }}

    <div class="rcal-monthnav">
        <a class="rcal-navbtn" href="{{ path('partner_delivery_calendar', { id: partner.id, year: prev.format('Y'), month: prev.format('n') }) }}"
           aria-label="Mes anterior" title="Mes anterior"><i class="fa fa-chevron-left"></i></a>
        <span class="rcal-month">{{ current|format_datetime('none', 'none', pattern='LLLL yyyy', locale='es') }}</span>
        <a class="rcal-navbtn" href="{{ path('partner_delivery_calendar', { id: partner.id, year: next.format('Y'), month: next.format('n') }) }}"
           aria-label="Mes siguiente" title="Mes siguiente"><i class="fa fa-chevron-right"></i></a>
    </div>

    {% if partner.sharePartner %}
        {{ csa.callout('Esta cesta es compartida: su día y su contenido los marca la alternancia con el otro hogar, no se editan desde aquí.', 'info', 'info-circle') }}
    {% endif %}

    <div class="rcal">

        {# ===== REJILLA ===== #}
        <div class="rcal-grid">
            <div class="rcal-dow"><span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span></div>
            <div class="rcal-weeks">
                {% for week in weeks %}
                    {% for day in week %}
                        {% set slot = day.slot %}
                        {% set moved_away = slot and (slot.moved_away ?? false) %}
                        {% set is_sel = slot and not moved_away and selected and slot.basket.id == selected.basket.id %}
                        {% set wknd = day.date.format('N') in [6, 7] %}
                        {% if slot and moved_away %}
                            {# Cesta movida a otro día: su cesta está en otra fecha. NO es
                               clicable (no hay nada que gestionar aquí); el azul + flecha
                               ya indican que es un día original. #}
                            <div class="rcal-cell rcal-moved" title="Su cesta está movida a otra fecha">
                                <span class="n">{{ day.date.format('j') }}</span>
                                <span class="x"><i class="fa fa-share"></i></span>
                            </div>
                        {% elseif slot %}
                            {# Rojo si está saltada O si se le han quitado todos los
                               componentes (no recoge nada esa semana). #}
                            {% set no_pickup = slot.skipped or slot.items is empty %}
                            {# Se navega al mes LÓGICO del Basket (su viernes-ciclo), que para las
                               entregas del mes coincide con el visible, pero para una que se cuela
                               por fecha física desde un mes vecino es donde el panel la resuelve. #}
                            <a href="{{ path('partner_delivery_calendar', { id: partner.id, year: slot.basket.date.format('Y'), month: slot.basket.date.format('n'), sel: slot.basket.id }) }}"
                               class="rcal-cell {{ no_pickup ? 'rcal-skip' : 'rcal-pick' }}{{ is_sel ? ' sel' }}">
                                <span class="n">{{ day.date.format('j') }}</span>
                                {% if no_pickup %}
                                    <span class="x"><i class="fa fa-ban"></i></span>
                                {% else %}
                                    <span class="rcal-dots">
                                        {# Orden fijo por id de componente (verdura, huevos): si no,
                                           al quitar y re-añadir los puntitos se desordenan. #}
                                        {% for item in slot.items|sort((a, b) => a.component.id - b.component.id) %}
                                            <span class="rcal-dot {{ item.component.id == EGG ? 'egg' : 'veg' }}"></span>
                                        {% endfor %}
                                    </span>
                                {% endif %}
                            </a>
                        {% else %}
                            <div class="rcal-cell empty{{ not day.inMonth ? ' out' }}{{ wknd ? ' wknd' }}">
                                <span class="n">{{ day.date.format('j') }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
            </div>
            <div class="rcal-legend">
                <span><span class="d" style="background: var(--csa-green);"></span>Verdura</span>
                <span><span class="d" style="background: var(--csa-ochre);"></span>Huevos</span>
                <span><span class="d" style="background: var(--csa-terracotta-soft); border: 1px solid #f3c4a8;"></span>No recoge</span>
                <span><span class="d" style="background: var(--csa-sky-soft); border: 1px solid var(--csa-sky);"></span>Movida a otro día</span>
            </div>
        </div>

        {# ===== PANEL DEL DÍA SELECCIONADO ===== #}
        <div class="rcal-panel">
            {% if selected %}
                {% set bid = selected.basket.id %}
                {# Ids de componentes presentes en la entrega, para decidir on/off.
                   OJO: lista (no mapa con claves enteras) — Twig `merge` reindexa las
                   claves enteras como array_merge y rompería el lookup por id. #}
                {% set present_ids = [] %}
                {% for it in selected.items %}{% set present_ids = present_ids|merge([it.component.id]) %}{% endfor %}
                {# Vacío = sin componentes y no saltada explícitamente: no recoge nada. #}
                {% set is_empty = not selected.skipped and selected.items is empty %}

                <div class="rcal-panel__hd{{ (selected.skipped or is_empty) ? ' is-skip' }}">
                    <div class="rcal-panel__day">{{ selected.date|format_date('full', locale='es')|capitalize }}</div>
                    {% if pickup_place %}
                        <div class="rcal-panel__where"><i class="fa fa-map-marker"></i>Recoge en {{ pickup_place }}</div>
                    {% endif %}
                </div>

                {# Solo-lectura: compartidas (R1) y entregas pasadas. #}
                {% set readonly = partner.sharePartner is not null or not selected_editable %}
                {# Contenido bloqueado: semana editable pero cuyo listado aún no está
                   generado. Se puede MOVER (solo guarda el shift), pero no editar
                   componentes ni "no recoger" (materializaría un WB suelto que
                   corrompería la generación posterior del listado). #}
                {% set content_locked = not readonly and not (selected.listed ?? true) %}

                {% if shift_role == 'origin' %}
                    {# Día vacío: su cesta se movió a otra fecha. Informativo — para
                       traerla de vuelta se mueve desde el día que la tiene ahora. #}
                    <div class="rcal-panel__bd">
                        <div class="rcal-sect">Esta semana no recoge</div>
                        <p class="csa-muted">La cesta de este día está movida al {{ shift.toBasket.date|format_date('long', locale='es') }}. Para traerla de vuelta, muévela desde ese día.</p>
                    </div>
                {% elseif selected.skipped %}
                    {# Saltada: no lleva nada esa semana; si es editable, se puede restaurar.
                       Una cesta movida que se marca "no recoge" también cae aquí. #}
                    <div class="rcal-panel__bd">
                        <div class="rcal-sect">Esta semana no recoge</div>
                        <p class="csa-muted">La entrega del {{ selected.date|format_date('long', locale='es') }} está marcada como NO recogida y no saldrá en el reparto.</p>
                    </div>
                    {% if selected_editable and partner.sharePartner is null %}
                        <div class="rcal-panel__ft">
                            <form action="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: bid }) }}" method="post" style="margin: 0;">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_skip_' ~ partner.id) }}">
                                {{ csa.btn('Volver a recoger', { type: 'submit', variant: 'secondary', icon: 'fa-undo', block: true }) }}
                            </form>
                        </div>
                    {% endif %}
                {% else %}
                    {# Entrega activa: normal o destino de un cambio (viene movida). Ambas se
                       editan igual (componentes + no recoge); el destino solo añade el aviso
                       de dónde viene y, entre los destinos de mover, su día original (= volver). #}
                    <div class="rcal-panel__bd">
                        {% if shift_role == 'destination' %}
                            <div class="rcal-sect">Cesta movida a este día</div>
                            <p class="csa-muted" style="margin-bottom: var(--csa-sp-3);">Viene movida del {{ shift.fromBasket.date|format_date('long', locale='es') }}.</p>
                        {% endif %}
                        {% if content_locked %}
                            <div class="rcal-empty-note" style="background: var(--csa-sky-soft); color: var(--csa-sky);"><i class="fa fa-info-circle"></i> Esta semana aún no está en el listado de reparto: su contenido no se puede editar hasta generarlo. Mover la cesta de día sí está disponible.</div>
                        {% elseif is_empty and not readonly %}
                            <div class="rcal-empty-note"><i class="fa fa-ban"></i> Ahora mismo no recoge nada esta semana. Activa algún componente o déjalo así.</div>
                        {% endif %}
                        <div class="rcal-sect">Qué se lleva ese día</div>

                        {{ _self.components(partner, bid, selected, present_ids, EGG, readonly or content_locked) }}

                        {% if can_move %}
                            {{ _self.move_block(partner, bid, move_candidates, selected, move_component, current) }}
                        {% endif %}
                    </div>

                    {% if not readonly and not content_locked %}
                        <div class="rcal-panel__ft">
                            <form id="rcal-skip-form-{{ bid }}" action="{{ path('partner_delivery_calendar_skip', { id: partner.id, basketId: bid }) }}" method="post" style="margin: 0;">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('calendar_skip_' ~ partner.id) }}">
                                <button type="button" class="csa-btn csa-btn--danger-soft csa-btn--block"
                                        onclick="document.getElementById('rcal-confirm-skip-{{ bid }}').showModal()">
                                    <i class="fa fa-ban"></i><span>No recoge esta semana</span>
                                </button>
                            </form>
                            <div class="rcal-hint" style="text-align: center;">Queda fuera del reparto. Reversible.</div>
                            {{ csa.confirm_dialog('rcal-confirm-skip-' ~ bid, {
                                variant: 'warning',
                                eyebrow: 'No recoger',
                                title: '¿Marcar que no recoge esta semana?',
                                body: 'La entrega de ' ~ (selected.date|format_date('long', locale='es')) ~ ' no saldrá en el reparto. Podrás revertirlo desde aquí.',
                                confirm_label: 'No recoger',
                                external_form_id: 'rcal-skip-form-' ~ bid,
                            }) }}
                        </div>
                    {% elseif not partner.sharePartner and not content_locked %}
                        <div class="rcal-panel__ft">
                            <div class="rcal-hint" style="text-align: center;"><i class="fa fa-lock"></i> Se recoge hoy o ya pasó · solo lectura</div>
                        </div>
                    {% endif %}
                {% endif %}
            {% else %}
                <div class="rcal-empty">
                    <p>Este mes no tiene entregas para el socio.</p>
                    <p style="margin-top: var(--csa-sp-2); font-size: 12px;">Navega a otro mes con las flechas de arriba.</p>
                </div>
            {% endif %}
        </div>

    </div>

{% endblock %}
