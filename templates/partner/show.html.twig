{# ============================================================
 # Ficha de socix (Partner) — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Ficha · {{ partner.name }} {{ partner.surname }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ partner.name }} {{ partner.surname }}</span>
{% endblock %}

{% block csa_main %}

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div style="margin-bottom: var(--csa-sp-4);">
            <p class="csa-callout csa-callout--info">
                <i class="csa-callout__icon fa fa-check-circle"></i>
                <span>{{ message }}</span>
            </p>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div style="margin-bottom: var(--csa-sp-4);">
            <p class="csa-callout csa-callout--warning">
                <i class="csa-callout__icon fa fa-exclamation-triangle"></i>
                <span>{{ message }}</span>
            </p>
        </div>
    {% endfor %}

    {# Cabecera con marker + nombre + status #}
    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-user"></i>
            </span>
            <div>
                <h1>{{ partner.name }} {{ partner.surname }}</h1>
                <div class="csa-row" style="gap: var(--csa-sp-2); margin-top: var(--csa-sp-2);">
                    {% set status_badge = {
                        'ACTIVO':  { label: 'Activx',  tone: 'green' },
                        'PAUSADO': { label: 'Pausadx', tone: 'ochre' },
                        'BAJA':    { label: 'De baja', tone: 'neutral' }
                    } %}
                    {% set sb = status_badge[partner.status]|default({ label: partner.status, tone: 'neutral' }) %}
                    <span class="csa-badge csa-badge--{{ sb.tone }}">{{ sb.label }}</span>
                    {% if partner.status == 'ACTIVO' %}
                        {% if partner.hasActiveBasket %}
                            <span class="csa-badge csa-badge--sky">{{ partner.getActiveBasket.basketShare }}</span>
                        {% else %}
                            <span class="csa-badge csa-badge--ochre">Sin cesta</span>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="csa-row">
            {{ csa.btn('Volver al listado', { variant: 'ghost', href: path('partner_index') }) }}
        </div>
    </div>

    <div class="csa-stack-lg">

        {# Acciones administrativas — arriba para que estén visibles sin
         # tener que scrollear hasta el fondo de la ficha. #}
        {% if app.user %}
            {% embed '_components/csa_card.html.twig' with { title: 'Acciones', accent: 'ochre' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-row" style="flex-wrap: wrap; gap: var(--csa-sp-3);">
                        <a href="{{ path('partner_edit', { id: partner.id }) }}" class="csa-btn csa-btn--primary csa-btn--sm">
                            <i class="fa fa-pencil"></i> Editar ficha
                        </a>
                        {# Acciones disponibles dependen del status del partner:
                         #   ACTIVO  → familia, cesta, Pausar, Dar de baja
                         #   PAUSADO → Reactivar, Dar de baja
                         #   BAJA    → Reactivar
                         # Usamos partner.status (string, fuente del Workflow) y NO
                         # partner.isActive (boolean que en el dump de prod puede estar
                         # desincronizado para socios antiguos). #}
                        {% if partner.status == 'ACTIVO' %}
                            {% if partner.getActiveBasket and partner.getActiveBasket.basketShare.id == 4 and partner.sharePartner is null %}
                                <a href="{{ path('family', { id: partner.id, type: 'add_share_partner' }) }}" class="csa-btn csa-btn--info-soft csa-btn--sm">
                                    <i class="fa fa-handshake-o"></i> ¿Comparte con?
                                </a>
                            {% endif %}
                            <a href="{{ path('family', { id: partner.id, type: 'add_family' }) }}" class="csa-btn csa-btn--ghost csa-btn--sm">
                                <i class="fa fa-users"></i> Añadir familiar
                            </a>
                            {% if not partner.hasActiveBasket %}
                                <a href="{{ path('partner_add_basket', { id: partner.id }) }}" class="csa-btn csa-btn--ghost csa-btn--sm">
                                    <i class="fa fa-shopping-basket"></i> Añadir cesta
                                </a>
                            {% endif %}
                            <button type="button"
                                    class="csa-btn csa-btn--ghost csa-btn--sm"
                                    onclick="document.getElementById('confirm-partner-show-1').showModal()"><i class="fa fa-pause"></i> Pausar</button>
                            {{ csa.confirm_dialog('confirm-partner-show-1', {
                                variant: 'warning',
                                eyebrow: 'Cambio reversible',
                                title: 'Pausar a este socix',
                                body: 'Dejará de recibir cesta pero seguirá siendo socix; podrás reactivarle más adelante.',
                                confirm_label: 'Pausar',
                                confirm_href: path('partner_pause', { id: partner.id }),
                            }) }}
                            <button type="button"
                                    class="csa-btn csa-btn--ghost csa-btn--sm"
                                    onclick="document.getElementById('confirm-partner-show-2').showModal()"><i class="fa fa-times"></i> Dar de baja</button>
                            {{ csa.confirm_dialog('confirm-partner-show-2', {
                                variant: 'danger',
                                eyebrow: 'Acción permanente',
                                title: 'Dar de baja a este socix',
                                body: 'Dejará de recibir cesta y se conservará el histórico.',
                                confirm_label: 'Dar de baja',
                                confirm_href: path('partner_demote', { id: partner.id }),
                            }) }}
                        {% elseif partner.status == 'PAUSADO' %}
                            <a href="{{ path('partner_promote', { id: partner.id }) }}"
                               class="csa-btn csa-btn--info-soft csa-btn--sm"
                               title="Salir de la pausa y volver a recibir cesta">
                                <i class="fa fa-play"></i> Reanudar
                            </a>
                            <button type="button"
                                    class="csa-btn csa-btn--ghost csa-btn--sm"
                                    onclick="document.getElementById('confirm-partner-show-2').showModal()"><i class="fa fa-times"></i> Dar de baja</button>
                            {{ csa.confirm_dialog('confirm-partner-show-2', {
                                variant: 'danger',
                                eyebrow: 'Acción permanente',
                                title: 'Dar de baja a este socix',
                                body: 'Dejará de recibir cesta y se conservará el histórico.',
                                confirm_label: 'Dar de baja',
                                confirm_href: path('partner_demote', { id: partner.id }),
                            }) }}
                        {% else %}
                            {# status == 'BAJA' — el socix se reincorpora después de una baja. #}
                            <a href="{{ path('partner_promote', { id: partner.id }) }}"
                               class="csa-btn csa-btn--info-soft csa-btn--sm"
                               title="Volver al alta tras una baja">
                                <i class="fa fa-undo"></i> Volver al alta
                            </a>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}
        {% endif %}

        {# Cuerpo en dos columnas: a la izquierda quién es la persona
         # (datos + familia), a la derecha qué cesta tiene. En móvil
         # las columnas se apilan automáticamente. #}
        <div class="csa-dashboard-pair" style="align-items: flex-start;">

            <div class="csa-stack-lg">

        {# Datos personales #}
        {% embed '_components/csa_card.html.twig' with { title: 'Datos personales', accent: 'sky' } %}
            {% block body %}
                <dl class="csa-defs">
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Nombre completo</dt>
                        <dd class="csa-defs__value">{{ partner.name }} {{ partner.surname }}</dd>
                    </div>
                    {% if partner.dNI %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">DNI</dt>
                            <dd class="csa-defs__value">{{ partner.dNI }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.celular %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Teléfono</dt>
                            <dd class="csa-defs__value">{{ partner.celular }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.email %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Email</dt>
                            <dd class="csa-defs__value"><a href="mailto:{{ partner.email }}">{{ partner.email }}</a></dd>
                        </div>
                    {% endif %}
                    {% if partner.address %}
                        <div class="csa-defs__row csa-defs__row--full">
                            <dt class="csa-defs__label">Dirección</dt>
                            <dd class="csa-defs__value">{{ partner.address }} — {{ partner.city }} ({{ partner.state }})</dd>
                        </div>
                    {% endif %}
                    {% if partner.inscriptionDate %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Fecha de inscripción</dt>
                            <dd class="csa-defs__value">{{ partner.inscriptionDate|format_date('long', locale='es') }}</dd>
                        </div>
                    {% endif %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">¿Consume cárnicos?</dt>
                        <dd class="csa-defs__value">{{ partner.eatMeat ? 'Sí' : 'No' }}</dd>
                    </div>
                    {% if partner.sharePayment %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Forma de pago</dt>
                            <dd class="csa-defs__value">{{ partner.sharePayment.name }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.weeklyBasketGroup %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Grupo de recogida</dt>
                            <dd class="csa-defs__value">{{ partner.weeklyBasketGroup }}</dd>
                        </div>
                    {% endif %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Ficha rellenada</dt>
                        <dd class="csa-defs__value">
                            {% if partner.hasFile %}
                                Sí · <a href="{{ asset('uploads/partner/images/' ~ partner.registrationFormImage) }}" target="_blank" rel="noopener">Ver imagen</a>
                            {% else %}
                                No
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            {% endblock %}
        {% endembed %}

        {# Familia #}
        {% embed '_components/csa_card.html.twig' with { title: 'Familiares', accent: 'plum' } %}
            {% block body %}
                {% import '_macros/csa.html.twig' as csa %}
                {% if partner.parent is null %}
                    <p>Es familiar principal{% if partner.relatives|length == 0 %}, sin familiares definidos.{% endif %}</p>
                    {% if partner.relatives|length > 0 %}
                        <ul class="csa-list">
                            {% for relative in partner.relatives %}
                                <li class="csa-list__item">
                                    <div class="csa-list__row">
                                        <span class="csa-list__body">
                                            <a class="csa-list__primary" href="{{ path('partner_show', { id: relative.id }) }}">{{ relative.name }} {{ relative.surname }}</a>
                                        </span>
                                        <button type="button"
                                           class="csa-btn csa-btn--ghost csa-btn--sm"
                                            onclick="document.getElementById('confirm-partner-show-relative-{{ relative.id }}').showModal()">Quitar</button>
{{ csa.confirm_dialog('confirm-partner-show-relative-' ~ relative.id, {
    variant: 'danger',
    eyebrow: 'Acción permanente',
    title: 'Quitar la relación familiar',
    body: 'La persona se desvinculará del socix. Podrás volver a añadirla.',
    confirm_label: 'Quitar',
    confirm_href: path('remove_family', { partner1_id: partner.id, partner2_id: relative.id }),
}) }}
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                {% else %}
                    <p>Es familiar relacionado con
                        <a href="{{ path('partner_show', { id: partner.parent.id }) }}">{{ partner.parent.name }} {{ partner.parent.surname }}</a>.
                    </p>
                {% endif %}

                {% if partner.getActiveBasket and partner.getActiveBasket.basketShare.id == 4 %}
                    {% if partner.sharePartner %}
                        <p style="margin-top: var(--csa-sp-4);">
                            <strong>Comparte cesta con:</strong>
                            <a href="{{ path('partner_show', { id: partner.sharePartner.id }) }}">{{ partner.sharePartner }}</a>
                            ·
                            <button type="button"
                                onclick="document.getElementById('confirm-partner-show-4').showModal()">quitar</button>
{{ csa.confirm_dialog('confirm-partner-show-4', {
    variant: 'danger',
    eyebrow: 'Acción permanente',
    title: 'Quitar la relación de cesta compartida',
    body: 'Ambos socixs dejarán de compartir la cesta. La cesta se mantiene.',
    confirm_label: 'Quitar',
    confirm_href: path('remove_share_partner', { partner1_id: partner.id, partner2_id: partner.sharePartner.id }),
}) }}
                        </p>
                    {% else %}
                        <p class="csa-callout csa-callout--warning" style="margin-top: var(--csa-sp-4);">
                            <i class="csa-callout__icon fa fa-exclamation-triangle"></i>
                            <span>Tiene cesta compartida pero no se ha definido con quién la comparte.</span>
                        </p>
                    {% endif %}
                {% endif %}
            {% endblock %}
        {% endembed %}

            </div>{# /col izquierda — Datos personales + Familiares #}

            <div class="csa-stack-lg">

        {# Cesta activa #}
        {% if partner.hasActiveBasket %}
            {% embed '_components/csa_card.html.twig' with { title: 'Cesta actual', accent: 'green' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <dl class="csa-defs">
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Tipo de cesta</dt>
                            <dd class="csa-defs__value">
                                {{ partner.getActiveBasket.basketShare }}
                                {% if partner.getActiveBasket.basketShare.id == 3 %}
                                    · {{ partner.getActiveBasket.dayMonthOrder }}º viernes
                                {% endif %}
                            </dd>
                        </div>
                        {% if partner.activeBasket.amount > 1 %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Cestas asociadas</dt>
                                <dd class="csa-defs__value">{{ partner.activeBasket.amount }}</dd>
                            </div>
                        {% endif %}
                        {% if partner.activeBasket.eggAmount %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Huevos</dt>
                                <dd class="csa-defs__value">
                                    {{ partner.activeBasket.eggAmount }}
                                    {% if partner.activeBasket.basketShare.id == 5 %}
                                        · {{ partner.activeBasket.eggPeriod }}
                                        {% if partner.activeBasket.eggPeriod.id is defined and partner.activeBasket.eggPeriod.id == 3 %}
                                            ({{ partner.getActiveBasket.dayMonthOrder }}º viernes)
                                        {% endif %}
                                    {% endif %}
                                </dd>
                            </div>
                        {% else %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Huevos</dt>
                                <dd class="csa-defs__value csa-muted">Sin huevos</dd>
                            </div>
                        {% endif %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Inicio</dt>
                            <dd class="csa-defs__value">{{ partner.getActiveBasket.startDate|format_date('long', locale='es') }}</dd>
                        </div>
                        {% if partner.getActiveBasket.endDate %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Fin</dt>
                                <dd class="csa-defs__value">{{ partner.getActiveBasket.endDate|format_date('long', locale='es') }}</dd>
                            </div>
                        {% endif %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Precio mensual</dt>
                            <dd class="csa-defs__value">
                                {% if partner.activeBasket.eggAmount %}
                                    {{ (partner.getActiveBasket.monthPrice + partner.activeBasket.eggMonthPrice)|number_format(2) }} €
                                {% else %}
                                    {{ partner.getActiveBasket.monthPrice }} €
                                {% endif %}
                            </dd>
                        </div>
                    </dl>

                    {% if app.user %}
                        <div class="csa-row" style="flex-wrap: wrap; gap: var(--csa-sp-2); margin-top: var(--csa-sp-5); padding-top: var(--csa-sp-4); border-top: 1px solid var(--csa-rule);">
                            <a href="{{ path('partner_basket_share_edit', { id: partner.getActiveBasket.id }) }}"
                               class="csa-btn csa-btn--secondary csa-btn--sm">
                                <i class="fa fa-pencil"></i> Cambiar tipo de cesta
                            </a>
                            <button type="button"
                               class="csa-btn csa-btn--ghost csa-btn--sm"
                                onclick="document.getElementById('confirm-partner-show-5').showModal()"><i class="fa fa-times"></i> Dar de baja la cesta</button>
{{ csa.confirm_dialog('confirm-partner-show-5', {
    variant: 'danger',
    eyebrow: 'Acción permanente',
    title: 'Dar de baja la cesta',
    body: 'El socix dejará de recibir cesta y se conservará el histórico.',
    confirm_label: 'Dar de baja la cesta',
    confirm_href: path('partner_basket_share_finalize', { id: partner.getActiveBasket.id }),
}) }}
                        </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {# Histórico de eventos de pertenencia. Siempre visible, aunque esté
         # vacío, para que se sepa que la sección existe. Vive dentro de la
         # col derecha junto a la cesta — su altura crece con los eventos. #}
        {% set event_labels = {
            'JOIN':                   { label: 'Alta',                      icon: 'fa-user-plus' },
            'LEAVE':                  { label: 'Baja',                      icon: 'fa-user-times' },
            'PAUSE':                  { label: 'Pausa',                     icon: 'fa-pause' },
            'RESUME':                 { label: 'Reanudación',               icon: 'fa-play' },
            'BASKET_START':           { label: 'Empieza cesta',             icon: 'fa-shopping-basket' },
            'BASKET_END':             { label: 'Termina cesta',             icon: 'fa-shopping-basket' },
            'BASKET_SKIP':            { label: 'No recoge la cesta',        icon: 'fa-ban' },
            'BASKET_UNSKIP':          { label: 'Vuelve a recoger la cesta', icon: 'fa-undo' },
            'GROUP_CHANGE_PERMANENT': { label: 'Cambio definitivo A/B',     icon: 'fa-exchange' },
            'WEEK_SWAP':              { label: 'Cambio puntual de viernes', icon: 'fa-calendar-times-o' },
            'NODE_CHANGE':            { label: 'Cambio de nodo',            icon: 'fa-map-marker' }
        } %}

        {% embed '_components/csa_card.html.twig' with { title: 'Histórico', accent: 'neutral' } %}
            {% block body %}
                {% if events|default([])|length == 0 %}
                    <p class="csa-muted" style="margin: 0;">
                        Aún no hay eventos registrados para este socix. Las próximas
                        transiciones (pausa, baja, cambios de cesta, cambios de grupo A/B)
                        irán dejando rastro aquí.
                    </p>
                {% else %}
                    <ul class="csa-timeline" style="list-style: none; margin: 0; padding: 0;">
                        {% for event in events %}
                            {% set meta = event_labels[event.type]|default({ label: event.type, icon: 'fa-circle' }) %}
                            {% set payload = event.payload|default({}) %}

                            {# Etiqueta específica para WEEK_SWAP cancelado: el feed
                             # conserva apply y cancel; el verbo cambia. #}
                            {% set label = meta.label %}
                            {% if event.type == 'WEEK_SWAP' and payload.cancelled|default(false) %}
                                {% set label = 'Cambio puntual cancelado' %}
                            {% endif %}

                            {# Actor legible:
                             #   partner:<id>  con id == partner actual → "autoservicio"
                             #   partner:<id>  con otro id              → "otro socix" (familiar, etc)
                             #   gestor:<id>                            → nombre del admin (resuelto en controller)
                             #   sistema / vacío                        → "sistema"
                             # Evitamos exponer ids crudos en la UI; identifican poco. #}
                            {% set actor_label = null %}
                            {% if event.actor %}
                                {% if event.actor == 'partner:' ~ partner.id %}
                                    {% set actor_label = 'autoservicio' %}
                                {% elseif event.actor starts with 'partner:' %}
                                    {% set actor_label = 'otro socix' %}
                                {% elseif event.actor starts with 'gestor:' %}
                                    {% set gestor_id = event.actor|slice(7) %}
                                    {% set gestor_name = gestor_names[gestor_id]|default(gestor_names[gestor_id|number_format(0,'','')]|default(null)) %}
                                    {% set actor_label = gestor_name ? 'responsable: ' ~ gestor_name : 'responsable: gestión' %}
                                {% elseif event.actor == 'system' or event.actor == 'sistema' %}
                                    {% set actor_label = 'sistema' %}
                                {% else %}
                                    {% set actor_label = event.actor %}
                                {% endif %}
                            {% endif %}

                            <li style="padding: var(--csa-sp-2) 0; border-bottom: 1px solid var(--csa-line);">
                                <div class="csa-row" style="gap: var(--csa-sp-3); align-items: baseline;">
                                    <i class="fa {{ meta.icon }} csa-muted"></i>
                                    <strong>{{ label }}</strong>
                                    <span class="csa-muted csa-small">{{ event.occurredAt|format_datetime('medium', 'short', locale='es') }}</span>
                                    {% if actor_label %}
                                        <span class="csa-muted csa-small">· {{ actor_label }}</span>
                                    {% endif %}
                                </div>

                                {# Detalle por tipo de evento: lo que importa al admin
                                 # cuando ojea el feed (a qué viernes pasó, de qué nodo
                                 # a qué nodo, etc.). #}
                                {% if event.type == 'WEEK_SWAP' and payload.from_date and payload.to_date %}
                                    <div class="csa-muted csa-small" style="margin-top: var(--csa-sp-1); padding-left: var(--csa-sp-5);">
                                        {{ payload.from_date|date('d/m/Y') }} → {{ payload.to_date|date('d/m/Y') }}
                                    </div>
                                {% elseif event.type == 'NODE_CHANGE' and payload.to_group_name %}
                                    <div class="csa-muted csa-small" style="margin-top: var(--csa-sp-1); padding-left: var(--csa-sp-5);">
                                        {% if payload.from_group_name %}{{ payload.from_group_name }} → {% endif %}{{ payload.to_group_name }}
                                    </div>
                                {% endif %}

                                {% if event.notes %}
                                    <div class="csa-muted csa-small" style="margin-top: var(--csa-sp-1); padding-left: var(--csa-sp-5);">
                                        {{ event.notes }}
                                    </div>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            {% endblock %}
        {% endembed %}

            </div>{# /col derecha — Cesta actual + Histórico #}

        </div>{# /csa-dashboard-pair #}

    </div>

{% endblock %}
