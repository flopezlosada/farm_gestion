{# ============================================================
 # Ficha de socix (Partner) — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Ficha · {{ partner.name }} {{ partner.surname }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ partner.name }} {{ partner.surname }}</span>
{% endblock %}

{% block csa_main %}

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div style="margin-bottom: var(--csa-sp-4);">
            <p class="csa-callout csa-callout--info">
                <i class="csa-callout__icon fa fa-check-circle"></i>
                <span>{{ message }}</span>
            </p>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div style="margin-bottom: var(--csa-sp-4);">
            <p class="csa-callout csa-callout--warning">
                <i class="csa-callout__icon fa fa-exclamation-triangle"></i>
                <span>{{ message }}</span>
            </p>
        </div>
    {% endfor %}

    {# Cabecera con marker + nombre + status #}
    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-user"></i>
            </span>
            <div>
                <h1>{{ partner.name }} {{ partner.surname }}</h1>
                <div class="csa-row" style="gap: var(--csa-sp-2); margin-top: var(--csa-sp-2);">
                    {% if partner.isActive == 1 %}
                        <span class="csa-badge csa-badge--green">Activx</span>
                        {% if partner.hasActiveBasket %}
                            <span class="csa-badge csa-badge--sky">{{ partner.getActiveBasket.basketShare }}</span>
                        {% else %}
                            <span class="csa-badge csa-badge--ochre">Sin cesta</span>
                        {% endif %}
                    {% else %}
                        <span class="csa-badge csa-badge--neutral">De baja</span>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="csa-row">
            {{ csa.btn('Volver al listado', { variant: 'ghost', href: path('partner_index') }) }}
        </div>
    </div>

    <div class="csa-stack-lg">

        {# Datos personales #}
        {% embed '_components/csa_card.html.twig' with { title: 'Datos personales', accent: 'sky' } %}
            {% block body %}
                <dl class="csa-defs">
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Nombre completo</dt>
                        <dd class="csa-defs__value">{{ partner.name }} {{ partner.surname }}</dd>
                    </div>
                    {% if partner.dNI %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">DNI</dt>
                            <dd class="csa-defs__value">{{ partner.dNI }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.celular %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Teléfono</dt>
                            <dd class="csa-defs__value">{{ partner.celular }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.email %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Email</dt>
                            <dd class="csa-defs__value"><a href="mailto:{{ partner.email }}">{{ partner.email }}</a></dd>
                        </div>
                    {% endif %}
                    {% if partner.address %}
                        <div class="csa-defs__row csa-defs__row--full">
                            <dt class="csa-defs__label">Dirección</dt>
                            <dd class="csa-defs__value">{{ partner.address }} — {{ partner.city }} ({{ partner.state }})</dd>
                        </div>
                    {% endif %}
                    {% if partner.inscriptionDate %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Fecha de inscripción</dt>
                            <dd class="csa-defs__value">{{ partner.inscriptionDate|format_date('long', locale='es') }}</dd>
                        </div>
                    {% endif %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">¿Consume cárnicos?</dt>
                        <dd class="csa-defs__value">{{ partner.eatMeat ? 'Sí' : 'No' }}</dd>
                    </div>
                    {% if partner.sharePayment %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Forma de pago</dt>
                            <dd class="csa-defs__value">{{ partner.sharePayment.name }}</dd>
                        </div>
                    {% endif %}
                    {% if partner.weeklyBasketGroup %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Grupo de recogida</dt>
                            <dd class="csa-defs__value">{{ partner.weeklyBasketGroup }}</dd>
                        </div>
                    {% endif %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Ficha rellenada</dt>
                        <dd class="csa-defs__value">
                            {% if partner.hasFile %}
                                Sí · <a href="{{ asset('uploads/partner/images/' ~ partner.registrationFormImage) }}" target="_blank" rel="noopener">Ver imagen</a>
                            {% else %}
                                No
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            {% endblock %}
        {% endembed %}

        {# Familia #}
        {% embed '_components/csa_card.html.twig' with { title: 'Familiares', accent: 'plum' } %}
            {% block body %}
                {% if partner.parent is null %}
                    <p>Es familiar principal{% if partner.relatives|length == 0 %}, sin familiares definidos.{% endif %}</p>
                    {% if partner.relatives|length > 0 %}
                        <ul class="csa-list">
                            {% for relative in partner.relatives %}
                                <li class="csa-list__item">
                                    <div class="csa-list__row">
                                        <span class="csa-list__body">
                                            <a class="csa-list__primary" href="{{ path('partner_show', { id: relative.id }) }}">{{ relative.name }} {{ relative.surname }}</a>
                                        </span>
                                        <a href="{{ path('remove_family', { partner1_id: partner.id, partner2_id: relative.id }) }}"
                                           class="csa-btn csa-btn--ghost csa-btn--sm"
                                           onclick="return confirm('¿Quitar la relación familiar?');">
                                            Quitar
                                        </a>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                {% else %}
                    <p>Es familiar relacionado con
                        <a href="{{ path('partner_show', { id: partner.parent.id }) }}">{{ partner.parent.name }} {{ partner.parent.surname }}</a>.
                    </p>
                {% endif %}

                {% if partner.getActiveBasket and partner.getActiveBasket.basketShare.id == 4 %}
                    {% if partner.sharePartner %}
                        <p style="margin-top: var(--csa-sp-4);">
                            <strong>Comparte cesta con:</strong>
                            <a href="{{ path('partner_show', { id: partner.sharePartner.id }) }}">{{ partner.sharePartner }}</a>
                            ·
                            <a href="{{ path('remove_share_partner', { partner1_id: partner.id, partner2_id: partner.sharePartner.id }) }}"
                               onclick="return confirm('¿Quitar la relación?');">
                                quitar
                            </a>
                        </p>
                    {% else %}
                        <p class="csa-callout csa-callout--warning" style="margin-top: var(--csa-sp-4);">
                            <i class="csa-callout__icon fa fa-exclamation-triangle"></i>
                            <span>Tiene cesta compartida pero no se ha definido con quién la comparte.</span>
                        </p>
                    {% endif %}
                {% endif %}
            {% endblock %}
        {% endembed %}

        {# Cesta activa #}
        {% if partner.hasActiveBasket %}
            {% embed '_components/csa_card.html.twig' with { title: 'Cesta actual', accent: 'green' } %}
                {% block body %}
                    <dl class="csa-defs">
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Tipo de cesta</dt>
                            <dd class="csa-defs__value">
                                {{ partner.getActiveBasket.basketShare }}
                                {% if partner.getActiveBasket.basketShare.id == 3 %}
                                    · {{ partner.getActiveBasket.dayMonthOrder }}º viernes
                                {% endif %}
                            </dd>
                        </div>
                        {% if partner.activeBasket.amount > 1 %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Cestas asociadas</dt>
                                <dd class="csa-defs__value">{{ partner.activeBasket.amount }}</dd>
                            </div>
                        {% endif %}
                        {% if partner.activeBasket.eggAmount %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Huevos</dt>
                                <dd class="csa-defs__value">
                                    {{ partner.activeBasket.eggAmount }}
                                    {% if partner.activeBasket.basketShare.id == 5 %}
                                        · {{ partner.activeBasket.eggPeriod }}
                                        {% if partner.activeBasket.eggPeriod.id is defined and partner.activeBasket.eggPeriod.id == 3 %}
                                            ({{ partner.getActiveBasket.dayMonthOrder }}º viernes)
                                        {% endif %}
                                    {% endif %}
                                </dd>
                            </div>
                        {% else %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Huevos</dt>
                                <dd class="csa-defs__value csa-muted">Sin huevos</dd>
                            </div>
                        {% endif %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Inicio</dt>
                            <dd class="csa-defs__value">{{ partner.getActiveBasket.startDate|format_date('long', locale='es') }}</dd>
                        </div>
                        {% if partner.getActiveBasket.endDate %}
                            <div class="csa-defs__row">
                                <dt class="csa-defs__label">Fin</dt>
                                <dd class="csa-defs__value">{{ partner.getActiveBasket.endDate|format_date('long', locale='es') }}</dd>
                            </div>
                        {% endif %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Precio mensual</dt>
                            <dd class="csa-defs__value">
                                {% if partner.activeBasket.eggAmount %}
                                    {{ (partner.getActiveBasket.monthPrice + partner.activeBasket.eggMonthPrice)|number_format(2) }} €
                                {% else %}
                                    {{ partner.getActiveBasket.monthPrice }} €
                                {% endif %}
                            </dd>
                        </div>
                    </dl>

                    {% if is_granted('ROLE_COOP') %}
                        <div class="csa-row" style="flex-wrap: wrap; gap: var(--csa-sp-2); margin-top: var(--csa-sp-5); padding-top: var(--csa-sp-4); border-top: 1px solid var(--csa-rule);">
                            <a href="{{ path('partner_basket_share_edit', { id: partner.getActiveBasket.id }) }}"
                               class="csa-btn csa-btn--secondary csa-btn--sm">
                                <i class="fa fa-pencil"></i> Cambiar tipo de cesta
                            </a>
                            <a href="{{ path('partner_basket_share_finalize', { id: partner.getActiveBasket.id }) }}"
                               class="csa-btn csa-btn--ghost csa-btn--sm"
                               onclick="return confirm('¿Dar de baja esta cesta?');">
                                <i class="fa fa-times"></i> Dar de baja la cesta
                            </a>
                        </div>
                    {% endif %}
                {% endblock %}
            {% endembed %}
        {% endif %}

        {# Acciones administrativas #}
        {% if is_granted('ROLE_COOP') %}
            {% embed '_components/csa_card.html.twig' with { title: 'Acciones', accent: 'ochre' } %}
                {% block body %}
                    <div class="csa-row" style="flex-wrap: wrap; gap: var(--csa-sp-3);">
                        <a href="{{ path('partner_edit', { id: partner.id }) }}" class="csa-btn csa-btn--primary csa-btn--sm">
                            <i class="fa fa-pencil"></i> Editar ficha
                        </a>
                        {% if partner.isActive == 1 %}
                            {% if partner.getActiveBasket and partner.getActiveBasket.basketShare.id == 4 and partner.sharePartner is null %}
                                <a href="{{ path('family', { id: partner.id, type: 'add_share_partner' }) }}" class="csa-btn csa-btn--secondary csa-btn--sm">
                                    <i class="fa fa-handshake-o"></i> ¿Comparte con?
                                </a>
                            {% endif %}
                            <a href="{{ path('family', { id: partner.id, type: 'add_family' }) }}" class="csa-btn csa-btn--ghost csa-btn--sm">
                                <i class="fa fa-users"></i> Añadir familiar
                            </a>
                            {% if not partner.hasActiveBasket %}
                                <a href="{{ path('partner_add_basket', { id: partner.id }) }}" class="csa-btn csa-btn--ghost csa-btn--sm">
                                    <i class="fa fa-shopping-basket"></i> Añadir cesta
                                </a>
                            {% endif %}
                            <a href="{{ path('partner_demote', { id: partner.id }) }}"
                               class="csa-btn csa-btn--ghost csa-btn--sm"
                               onclick="return confirm('¿Dar de baja a estx socix?');">
                                <i class="fa fa-times"></i> Dar de baja
                            </a>
                        {% else %}
                            <a href="{{ path('partner_promote', { id: partner.id }) }}"
                               class="csa-btn csa-btn--secondary csa-btn--sm">
                                <i class="fa fa-check"></i> Activar
                            </a>
                        {% endif %}
                    </div>
                {% endblock %}
            {% endembed %}
        {% endif %}

    </div>

{% endblock %}
