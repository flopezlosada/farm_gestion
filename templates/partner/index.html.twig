{# ============================================================
 # Listado de socixs (Partner).
 #
 # El controller pasa `title` y `type` (1=activos, otro valor=todos).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}{{ title|default('Socixs') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ title|default('Socixs') }}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Listado',
        title|default('Socixs'),
        'Personas asociadas a la cooperativa.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Evolución', { variant: 'ghost', href: path('partner_evolution'), icon: 'fa-line-chart' }) }}
            {{ csa.btn('Nuevx socix', { variant: 'primary', href: path('partner_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th class="csa-table__col-tight">Teléfono</th>
                    <th class="csa-table__col-tight">Fecha de alta</th>
                    <th>Email</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for partner in partners %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('partner_show', { id: partner.id }) }}">{{ partner.name }} {{ partner.surname }}</a>
                        </td>
                        <td class="csa-table__col-tight">{% if partner.celular %}{{ partner.celular }}{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">
                            {% if partner.inscriptionDate %}{{ partner.inscriptionDate|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td>{% if partner.email %}{{ partner.email }}{% else %}—{% endif %}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('partner_show', { id: partner.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('partner_edit', { id: partner.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                            {% if type == 1 %}
                                <a href="{{ path('partner_add_basket', { id: partner.id }) }}" title="Añadir cesta" aria-label="Añadir cesta"><i class="fa fa-shopping-basket"></i></a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay socixs registradxs.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
