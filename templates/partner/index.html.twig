{# ============================================================
 # Listado de socixs (Partner) — rediseño al estilo del reparto v2.
 #
 # El controller pasa:
 #   - pagination       Knp PaginationInterface de Partner
 #   - title            cabecera de la página
 #   - type             (legacy) 1=activos sin cesta, 2=baja
 #   - status_filter    ACTIVO / PAUSADO / BAJA / null (Todxs)
 #   - statuses         array de estados conocidos
 #   - status_counts    ['ALL'=>N, 'ACTIVO'=>N, ...]
 #   - filters          ['status', 'modalities', 'cesta', 'node', 'wbg', 'q']
 #   - modalities_all   BasketShare[] para el popover de modalidad
 #   - nodes_all        Node[] para el popover de nodo
 #   - wbgs_all         WeeklyBasketGroup[] para el popover de WBG
 #
 # Funcionalidad: el form GET de filtros recarga la página con los
 # criterios; las acciones masivas viven en un form POST separado.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set status_chip = {
    'ACTIVO':  { label: 'Activx',  cls: 'activo'  },
    'PAUSADO': { label: 'Pausadx', cls: 'pausado' },
    'BAJA':    { label: 'De baja', cls: 'baja'    }
} %}
{% set status_tab = {
    'ACTIVO':  'Activxs',
    'PAUSADO': 'Pausadxs',
    'BAJA':    'De baja'
} %}

{# Etiquetas de modalidad — mismas que en el reparto. #}
{% set mod_labels = {
    1: 'Semanal',
    2: 'Quincenal',
    3: 'Mensual',
    4: 'Compartida',
    5: 'Solo huevos'
} %}

{% block title %}{{ title|default('Socixs') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ title|default('Socixs') }}</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
{% include 'partner/_listing_styles.html.twig' %}
{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        // Listado de socixs — JS local.
        //   1. Cuenta seleccionados y muestra/oculta bulk bar.
        //   2. Toggle de popovers de filtro (click fuera = cerrar).
        //   3. Auto-submit del form GET al cambiar cualquier filtro.
        (function () {
            // ---------- popovers ----------
            document.querySelectorAll('[data-pop-trigger]').forEach(function (btn) {
                btn.addEventListener('click', function (ev) {
                    ev.stopPropagation();
                    var id = btn.getAttribute('data-pop-trigger');
                    var pop = document.getElementById(id);
                    if (!pop) return;
                    var isOpen = !pop.hidden;
                    // cerrar todos primero
                    document.querySelectorAll('.prl-pop').forEach(function (p) { p.hidden = true; });
                    pop.hidden = isOpen;
                });
            });
            document.addEventListener('click', function (ev) {
                document.querySelectorAll('.prl-pop').forEach(function (pop) {
                    if (pop.hidden) return;
                    if (pop.contains(ev.target)) return;
                    var triggerId = pop.id;
                    var trigger = document.querySelector('[data-pop-trigger="' + triggerId + '"]');
                    if (trigger && trigger.contains(ev.target)) return;
                    pop.hidden = true;
                });
            });

            // ---------- auto-submit del form GET ----------
            var filterForm = document.getElementById('prl-filter-form');
            if (filterForm) {
                filterForm.querySelectorAll('input[type="checkbox"], input[type="radio"], select').forEach(function (el) {
                    el.addEventListener('change', function () {
                        // Al cambiar el nodo, el wbg queda huérfano si era de
                        // otro nodo. Forzamos "Cualquier grupo" antes de
                        // submit para evitar listados vacíos por desajuste.
                        if (el.name === 'node') {
                            var wbgReset = filterForm.querySelector('input[name="wbg"][value=""]');
                            if (wbgReset) wbgReset.checked = true;
                        }
                        filterForm.submit();
                    });
                });

                // Búsqueda por texto: auto-envío con debounce (~350ms) al
                // dejar de teclear, para no obligar a pulsar Enter. Sigue
                // siendo server-side (busca en toda la base, no sólo la
                // página visible), por eso recarga en vez de filtrar en
                // cliente como el listado de reparto.
                var searchInput = filterForm.querySelector('input[name="q"]');
                if (searchInput) {
                    var debounce = null;
                    searchInput.addEventListener('input', function () {
                        clearTimeout(debounce);
                        debounce = setTimeout(function () { filterForm.submit(); }, 350);
                    });
                    // Como el submit recarga la página, el foco se pierde.
                    // Si veníamos de una búsqueda, devolvemos el foco al
                    // campo con el cursor al final para seguir escribiendo.
                    if (searchInput.value) {
                        searchInput.focus();
                        var end = searchInput.value.length;
                        searchInput.setSelectionRange(end, end);
                    }
                }
            }

            // ---------- bulk bar ----------
            var bulkForm = document.querySelector('form[data-prl-bulk]');
            if (!bulkForm) return;
            var checks = Array.prototype.slice.call(bulkForm.querySelectorAll('input[data-partner-check]'));
            var counter = document.getElementById('prl-selected-counter');
            var bar = document.getElementById('prl-bulkbar');
            var buttons = Array.prototype.slice.call(bulkForm.querySelectorAll('[data-bulk-button]'));
            var selectAll = document.getElementById('prl-select-all');
            var clearAll = document.getElementById('prl-clear');

            function refreshBulk() {
                var n = 0;
                checks.forEach(function (c) { if (c.checked) n += 1; });
                if (counter) counter.textContent = n;
                buttons.forEach(function (b) { b.disabled = n === 0; });
                if (bar) bar.classList.toggle('is-active', n > 0);
            }
            checks.forEach(function (c) { c.addEventListener('change', refreshBulk); });
            if (selectAll) selectAll.addEventListener('click', function () {
                checks.forEach(function (c) { c.checked = true; });
                refreshBulk();
            });
            if (clearAll) clearAll.addEventListener('click', function () {
                checks.forEach(function (c) { c.checked = false; });
                refreshBulk();
            });
            refreshBulk();
        }());
    </script>
{% endblock %}

{% block csa_main %}

{# Qué acciones masivas tienen sentido en la pestaña actual. Sólo se
 # ofrecen en pestañas mono-estado (en "Todxs" se mezclarían estados
 # y aplicar una transición a quien no la admite es confuso). #}
{% set bulk_leave  = status_filter == 'ACTIVO' or status_filter == 'PAUSADO' %}
{% set bulk_pause  = status_filter == 'ACTIVO' %}
{% set bulk_resume = status_filter == 'PAUSADO' %}
{% set bulk_rejoin = status_filter == 'BAJA' %}
{% set bulk_any    = bulk_leave or bulk_pause or bulk_resume or bulk_rejoin %}

{% set avatar_palette = ['sage', 'ochre', 'terra', 'ink'] %}

{# El form GET de filtros lleva el status actual para no perderlo al
 # marcar/desmarcar otros filtros; cuando entras en una tab "Todxs"
 # mando status=ALL para forzar el bypass del default ACTIVO. #}
{% set status_param = status_filter ?: 'ALL' %}

{# Conteo de filtros activos (excluyendo status y q) para el badge "Filtros". #}
{% set active_filters_count = (filters.modalities|length) + (filters.cesta ? 1 : 0) + (filters.eggs ? 1 : 0) + (filters.node ? 1 : 0) + (filters.wbg ? 1 : 0) + (filters.needs_review ? 1 : 0) %}

<div class="prl">

    {{ csa.page_header(
        'Socixs · Listado',
        title|default('Socixs'),
        'Personas asociadas a la cooperativa.'
    ) }}

    {# ============ STAT STRIP ============ #}
    <div class="prl-stats">
        <a class="prl-stat prl-stat--active" href="{{ path('partner_index', { status: 'ACTIVO' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.ACTIVO ?? 0 }}</div>
            <div class="l">activxs</div>
        </a>
        <a class="prl-stat prl-stat--paused" href="{{ path('partner_index', { status: 'PAUSADO' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.PAUSADO ?? 0 }}</div>
            <div class="l">pausadxs</div>
        </a>
        <a class="prl-stat prl-stat--leave" href="{{ path('partner_index', { status: 'BAJA' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.BAJA ?? 0 }}</div>
            <div class="l">de baja</div>
        </a>
        <a class="prl-stat" href="{{ path('partner_index', { status: 'ALL' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.ALL ?? 0 }}</div>
            <div class="l">en total</div>
        </a>
        {# Acceso a los socixs importados del histórico de prod pendientes de
           validar. Solo aparece si los hay; destacado en ámbar (atención). #}
        {% if needs_review_count > 0 %}
        <a class="prl-stat" href="{{ path('partner_index', { status: 'ALL', needs_review: 1 }) }}"
           style="text-decoration: none; box-shadow: inset 0 0 0 2px var(--csa-warning, #c89a3a);">
            <div class="v">{{ needs_review_count }}</div>
            <div class="l">por confirmar</div>
        </a>
        {% endif %}
    </div>

    {# ============ TABS por estado ============ #}
    <nav class="prl-tabs" role="tablist">
        {% for s in statuses %}
            <a href="{{ path('partner_index', { status: s }) }}"
               class="{{ status_filter == s ? 'active' : '' }}">
                {{ status_tab[s] }} <span class="count">{{ status_counts[s] ?? 0 }}</span>
            </a>
        {% endfor %}
        <a href="{{ path('partner_index', { status: 'ALL' }) }}"
           class="{{ status_filter is null ? 'active' : '' }}">
            Todxs <span class="count">{{ status_counts.ALL ?? 0 }}</span>
        </a>
    </nav>

    {# ============ FORM GET de filtros ============ #}
    <form method="get" action="{{ path('partner_index') }}" id="prl-filter-form">
        <input type="hidden" name="status" value="{{ status_param }}">

        <div class="prl-toolbar">
            <div class="prl-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
                <input type="search" name="q" value="{{ filters.q }}" placeholder="Buscar por nombre, email, teléfono…" autocomplete="off">
            </div>

            {# Popover MODALIDAD #}
            <div class="prl-filt-wrap">
                <button type="button" class="prl-filt {{ filters.modalities|length > 0 ? 'has' : '' }}" data-pop-trigger="pop-mod">
                    Modalidad
                    {% if filters.modalities|length > 0 %}<span class="badge">{{ filters.modalities|length }}</span>{% endif %}
                    <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="prl-pop" id="pop-mod" hidden>
                    {% for m in modalities_all %}
                        <label class="mod-{{ m.id }}">
                            <input type="checkbox" name="modality[]" value="{{ m.id }}"
                                   {% if m.id in filters.modalities %}checked{% endif %}>
                            <span class="dot"></span>
                            {{ mod_labels[m.id] ?? m.name }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {# Popover CESTA SÍ/NO #}
            <div class="prl-filt-wrap">
                <button type="button" class="prl-filt {{ filters.cesta ? 'has' : '' }}" data-pop-trigger="pop-cesta">
                    Cesta
                    {% if filters.cesta %}<span class="badge">{{ filters.cesta == 'yes' ? 'sí' : 'no' }}</span>{% endif %}
                    <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="prl-pop" id="pop-cesta" hidden>
                    <label><input type="radio" name="cesta" value="" {% if not filters.cesta %}checked{% endif %}> Todxs (con o sin cesta)</label>
                    <label><input type="radio" name="cesta" value="yes" {% if filters.cesta == 'yes' %}checked{% endif %}> Con cesta activa</label>
                    <label><input type="radio" name="cesta" value="no"  {% if filters.cesta == 'no' %}checked{% endif %}> Sin cesta activa</label>
                </div>
            </div>

            {# Popover HUEVOS SÍ/NO #}
            <div class="prl-filt-wrap">
                <button type="button" class="prl-filt {{ filters.eggs ? 'has' : '' }}" data-pop-trigger="pop-eggs">
                    Huevos
                    {% if filters.eggs %}<span class="badge">{{ filters.eggs == 'yes' ? 'sí' : 'no' }}</span>{% endif %}
                    <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="prl-pop" id="pop-eggs" hidden>
                    <label><input type="radio" name="eggs" value="" {% if not filters.eggs %}checked{% endif %}> Todxs (con o sin huevos)</label>
                    <label><input type="radio" name="eggs" value="yes" {% if filters.eggs == 'yes' %}checked{% endif %}> Con huevos</label>
                    <label><input type="radio" name="eggs" value="no"  {% if filters.eggs == 'no' %}checked{% endif %}> Sin huevos</label>
                </div>
            </div>

            {# Toggle POR CONFIRMAR — filtro binario (todos / solo pendientes) sobre
             # los socixs importados del histórico de prod. Va dentro del form, así
             # que el JS lo auto-reenvía al cambiar y se preserva con los demás
             # filtros. Sin marcar no viaja en el GET → desaparece el filtro solo.
             # Solo se ofrece si hay pendientes. #}
            {% if needs_review_count > 0 %}
                <label class="prl-filt prl-filt--review {{ filters.needs_review ? 'has' : '' }}" style="display: inline-flex; align-items: center; gap: 8px; cursor: pointer; white-space: nowrap; margin: 0;">
                    <span class="csa-toggle">
                        <input type="checkbox" class="csa-toggle__input" name="needs_review" value="1" {{ filters.needs_review ? 'checked' }}>
                        <span class="csa-toggle__track"><span class="csa-toggle__thumb"></span></span>
                    </span>
                    Por confirmar ({{ needs_review_count }})
                </label>
            {% endif %}

            {# Popover NODO #}
            {% if nodes_all|length > 1 %}
                <div class="prl-filt-wrap">
                    <button type="button" class="prl-filt {{ filters.node ? 'has' : '' }}" data-pop-trigger="pop-node">
                        Nodo
                        {% if filters.node %}<span class="badge">1</span>{% endif %}
                        <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                    </button>
                    <div class="prl-pop" id="pop-node" hidden>
                        <label><input type="radio" name="node" value="" {% if not filters.node %}checked{% endif %}> Cualquier nodo</label>
                        {% for n in nodes_all %}
                            <label><input type="radio" name="node" value="{{ n.id }}" {% if filters.node == n.id %}checked{% endif %}> {{ n.name }}</label>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Popover GRUPO DE RECOGIDA — depende del nodo seleccionado.
             # Si hay nodo activo, sólo se ofrecen los WBG de ese nodo. #}
            {% if wbgs_all|length > 0 or filters.node %}
                {% set scoped_node = filters.node ? (nodes_all|filter(n => n.id == filters.node)|first) : null %}
                <div class="prl-filt-wrap">
                    <button type="button" class="prl-filt {{ filters.wbg ? 'has' : '' }}" data-pop-trigger="pop-wbg">
                        Grupo
                        {% if filters.wbg %}<span class="badge">1</span>{% endif %}
                        <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                    </button>
                    <div class="prl-pop" id="pop-wbg" hidden>
                        {% if scoped_node %}
                            <div class="prl-pop__scope">Grupos de <b>{{ scoped_node.name }}</b></div>
                        {% endif %}
                        <label><input type="radio" name="wbg" value="" {% if not filters.wbg %}checked{% endif %}> Cualquier grupo</label>
                        {% if wbgs_all|length == 0 %}
                            <div class="prl-pop__empty">Este nodo no tiene grupos definidos.</div>
                        {% else %}
                            {% for g in wbgs_all %}
                                <label><input type="radio" name="wbg" value="{{ g.id }}" {% if filters.wbg == g.id %}checked{% endif %}> {{ g.name }}</label>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {% if active_filters_count > 0 or filters.q %}
                <a class="prl-filt prl-filt--clear" href="{{ path('partner_index', { status: status_param }) }}" title="Limpiar todos los filtros">
                    <i class="fa fa-times-circle" aria-hidden="true"></i> Limpiar filtros
                </a>
            {% endif %}

            <span class="prl-filt-divider"></span>

            <div class="counters">
                <b>{{ pagination|length }}</b> de <b>{{ pagination.getTotalItemCount }}</b> socix{{ pagination.getTotalItemCount == 1 ? '' : 's' }}
            </div>
            <div class="spacer"></div>
            <a href="{{ path('partner_evolution') }}" class="prl-btn">
                <i class="fa fa-line-chart"></i> Evolución
            </a>
            <a href="{{ path('partner_new') }}" class="prl-btn prl-btn--primary">
                <i class="fa fa-plus"></i> Nuevx socix
            </a>
        </div>

        {# noscript fallback: con JS desactivado el form GET no autosubmit;
         # ofrecemos un botón aplicar al menos visible en ese caso. #}
        <noscript>
            <div style="margin-bottom: 14px;">
                <button type="submit" class="prl-btn prl-btn--primary">Aplicar filtros</button>
            </div>
        </noscript>
    </form>

    {# ============ FORM POST de bulk transition ============ #}
    <form method="post" action="{{ path('partner_bulk_transition') }}" data-prl-bulk>
        <input type="hidden" name="_token" value="{{ csrf_token('partner_bulk_transition') }}">

        {% if bulk_any %}
            <div id="prl-bulkbar" class="prl-bulkbar">
                <span class="prl-bulkbar__counter"><b id="prl-selected-counter">0</b> seleccionadxs</span>
                <button type="button" id="prl-select-all" class="prl-btn prl-btn--sm">
                    <i class="fa fa-check-square-o"></i> Marcar página
                </button>
                <button type="button" id="prl-clear" class="prl-btn prl-btn--sm">
                    <i class="fa fa-square-o"></i> Quitar selección
                </button>
                <span class="spacer"></span>
                {% if bulk_resume %}
                    <button type="submit" name="transition" value="resume" class="prl-btn prl-btn--primary prl-btn--sm" data-bulk-button>
                        <i class="fa fa-play"></i> Reactivar
                    </button>
                {% endif %}
                {% if bulk_rejoin %}
                    <button type="submit" name="transition" value="rejoin" class="prl-btn prl-btn--primary prl-btn--sm" data-bulk-button>
                        <i class="fa fa-undo"></i> Reactivar
                    </button>
                {% endif %}
                {% if bulk_pause %}
                    <button type="submit" name="transition" value="pause" class="prl-btn prl-btn--warn prl-btn--sm" data-bulk-button>
                        <i class="fa fa-pause"></i> Pausar
                    </button>
                {% endif %}
                {% if bulk_leave %}
                    <button type="submit" name="transition" value="leave" class="prl-btn prl-btn--danger prl-btn--sm" data-bulk-button>
                        <i class="fa fa-user-times"></i> Dar de baja
                    </button>
                {% endif %}
            </div>
        {% endif %}

        <div class="prl-table-wrap">
            {% if pagination|length == 0 %}
                <div class="prl-empty">
                    {% if active_filters_count > 0 or filters.q %}
                        No hay socixs que cumplan los filtros aplicados.
                    {% else %}
                        Aún no hay socixs registradxs{% if status_filter %} con estado {{ status_chip[status_filter].label|lower }}{% endif %}.
                    {% endif %}
                </div>
            {% else %}
                <table class="prl-table">
                    <thead>
                        <tr>
                            {% if bulk_any %}<th class="check"><span class="sr-only">Selección</span></th>{% endif %}
                            <th>Socix</th>
                            {% if status_filter is null %}<th class="tight">Estado</th>{% endif %}
                            <th class="tight">Cesta</th>
                            <th class="tight">Huevos</th>
                            <th class="tight">Recogida</th>
                            <th class="tight">Teléfono</th>
                            <th class="tight">Alta</th>
                            <th class="actions"><span class="sr-only">Acciones</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for partner in pagination %}
                            {% set initials = (partner.name|first|upper) ~ (partner.surname|first|default('')|upper) %}
                            {% set avatar_tone = partner.status == 'BAJA' ? 'muted' : avatar_palette[(partner.id|default(0)) % 4] %}
                            {% set sc = status_chip[partner.status]|default({ label: partner.status, cls: 'baja' }) %}
                            {% set ab = partner.hasActiveBasket ? partner.getActiveBasket : null %}
                            {% set bs_id = ab ? ab.basketShare.id : null %}
                            <tr>
                                {% if bulk_any %}
                                    <td class="check">
                                        <input type="checkbox" name="partner_ids[]" value="{{ partner.id }}"
                                               data-partner-check
                                               aria-label="Seleccionar {{ partner.name }} {{ partner.surname }}">
                                    </td>
                                {% endif %}
                                <td>
                                    <div class="prl-person">
                                        <span class="prl-person__avatar prl-person__avatar--{{ avatar_tone }}" aria-hidden="true">{{ initials }}</span>
                                        <div class="prl-person__body">
                                            <a class="prl-person__name" href="{{ path('partner_show', { id: partner.id }) }}">
                                                {{ partner.name }} {{ partner.surname }}
                                            </a>
                                            {% if partner.displayName %}
                                                <span class="prl-person__meta prl-person__meta--alias" title="Nombre en el listado de reparto">↳ {{ partner.displayName }}</span>
                                            {% endif %}
                                            {% if partner.email %}
                                                <span class="prl-person__meta">{{ partner.email }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                {% if status_filter is null %}
                                    <td class="tight">
                                        <span class="prl-chip prl-chip--{{ sc.cls }}"><span class="dot"></span>{{ sc.label }}</span>
                                    </td>
                                {% endif %}
                                <td class="tight">
                                    {% if ab %}
                                        <span class="prl-chip prl-chip--mod-{{ bs_id }}">
                                            {% if bs_id != 4 %}<span class="dot"></span>{% endif %}
                                            {{ mod_labels[bs_id] ?? ab.basketShare.name }}
                                        </span>
                                    {% elseif partner.parent %}
                                        <span class="prl-cell-muted">vía familiar</span>
                                    {% else %}
                                        <span class="prl-cell-muted">sin cesta</span>
                                    {% endif %}
                                </td>
                                <td class="tight">
                                    {# Huevos de la cesta activa (mismas clases que Recogida
                                     # para no duplicar CSS: línea fuerte + sublínea gris). #}
                                    {% if ab and ab.eggAmount %}
                                        <div class="prl-pickup__name">{{ ab.eggAmount.name }}</div>
                                        {% if ab.eggPeriod %}<div class="prl-pickup__node">{{ ab.eggPeriod.name }}</div>{% endif %}
                                    {% else %}
                                        <span class="prl-cell-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="tight">
                                    {% if partner.weeklyBasketGroup %}
                                        <div class="prl-pickup__name">{{ partner.weeklyBasketGroup.name }}</div>
                                        {% if partner.weeklyBasketGroup.node %}
                                            <div class="prl-pickup__node">{{ partner.weeklyBasketGroup.node.name }}</div>
                                        {% endif %}
                                    {% else %}
                                        <span class="prl-cell-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="tight">{{ partner.celular ?: '—' }}</td>
                                <td class="tight">
                                    {% if partner.inscriptionDate %}{{ partner.inscriptionDate|date('d/m/Y') }}{% else %}—{% endif %}
                                </td>
                                <td class="actions">
                                    <a href="{{ path('partner_show', { id: partner.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                                    <a href="{{ path('partner_edit', { id: partner.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                                    {% if type == 1 %}
                                        <a href="{{ path('partner_add_basket', { id: partner.id }) }}" title="Añadir cesta" aria-label="Añadir cesta"><i class="fa fa-shopping-basket"></i></a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        {% if pagination.getPageCount > 1 %}
            <div class="prl-pagination">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </form>

</div>
{% endblock %}
