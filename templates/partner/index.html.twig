{# ============================================================
 # Listado de socixs (Partner) — rediseño al estilo del reparto v2.
 #
 # El controller pasa:
 #   - pagination       Knp PaginationInterface de Partner
 #   - title            cabecera de la página
 #   - type             (legacy) 1=activos sin cesta, 2=baja
 #   - status_filter    ACTIVO / PAUSADO / BAJA / null (Todxs)
 #   - statuses         array de estados conocidos
 #   - status_counts    ['ALL'=>N, 'ACTIVO'=>N, ...]
 #   - filters          ['status', 'modalities', 'cesta', 'node', 'wbg', 'q']
 #   - modalities_all   BasketShare[] para el popover de modalidad
 #   - nodes_all        Node[] para el popover de nodo
 #   - wbgs_all         WeeklyBasketGroup[] para el popover de WBG
 #
 # Funcionalidad: el form GET de filtros recarga la página con los
 # criterios; las acciones masivas viven en un form POST separado.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set status_chip = {
    'ACTIVO':  { label: 'Activx',  cls: 'activo'  },
    'PAUSADO': { label: 'Pausadx', cls: 'pausado' },
    'BAJA':    { label: 'De baja', cls: 'baja'    }
} %}
{% set status_tab = {
    'ACTIVO':  'Activxs',
    'PAUSADO': 'Pausadxs',
    'BAJA':    'De baja'
} %}

{# Etiquetas de modalidad — mismas que en el reparto. #}
{% set mod_labels = {
    1: 'Semanal',
    2: 'Quincenal',
    3: 'Mensual',
    4: 'Compartida',
    5: 'Solo huevos'
} %}

{% block title %}{{ title|default('Socixs') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ title|default('Socixs') }}</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
/* ============================================================
 * Listado de socixs — tokens locales (--prl-*).
 * Paleta hermana de --dlv-* (reparto v2) y --prt-* (ficha).
 * ============================================================ */
.prl {
    --prl-line: #ebe7dd;
    --prl-line-2: #d8d2c2;
    --prl-ink: #1d1c17;
    --prl-ink-soft: #5a564a;
    --prl-ink-faint: #8d8773;
    --prl-sage: #5b7a4c;
    --prl-sage-d: #2f4426;
    --prl-sage-l: #eaf0e2;
    --prl-ochre: #c89a3a;
    --prl-ochre-d: #8c6919;
    --prl-ochre-l: #faf1d8;
    --prl-terra: #b45d3a;
    --prl-terra-d: #7d3a1f;
    --prl-terra-l: #fae6dc;
    --prl-bg: #fbfaf6;
    --prl-surface: #ffffff;
    /* Forzar Inter como base del bloque para blindar la cascada frente a
     * Bootstrap 3 (que se carga antes y mete Helvetica/Arial en algunos
     * elementos heredados). */
    font-family: 'Inter', sans-serif;
    font-variant-numeric: tabular-nums;
}

/* ---------- stat strip (4 cards) ---------- */
.prl-stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
    margin-bottom: 18px;
}
.prl-stat {
    background: var(--prl-surface); border: 1px solid var(--prl-line);
    border-radius: 8px; padding: 14px 18px;
    display: flex; flex-direction: column; gap: 5px;
}
.prl-stat .v {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 28px;
    letter-spacing: -0.02em; line-height: 1; color: var(--prl-ink);
}
.prl-stat .l {
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--prl-ink-faint); font-weight: 500;
}
.prl-stat--active   .v { color: var(--prl-sage-d); }
.prl-stat--paused   .v { color: var(--prl-ochre-d); }
.prl-stat--leave    .v { color: var(--prl-terra-d); }

/* ---------- tabs estilo dlv-nodes ---------- */
.prl-tabs {
    display: flex; border-bottom: 2px solid var(--prl-ink);
    margin-bottom: 18px; flex-wrap: wrap;
}
.prl-tabs a {
    background: transparent; padding: 12px 22px 10px;
    cursor: pointer; color: var(--prl-ink-soft);
    border-radius: 6px 6px 0 0; margin-bottom: -2px;
    text-decoration: none; transition: 0.15s;
    display: flex; align-items: center; gap: 8px;
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 15px;
    letter-spacing: -0.005em;
}
.prl-tabs a:hover { color: var(--prl-ink); background: var(--prl-surface); }
.prl-tabs a.active {
    background: var(--prl-ink); color: #fff;
    border-bottom: 2px solid var(--prl-ink);
}
.prl-tabs a .count {
    font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 600;
    padding: 2px 7px; border-radius: 999px;
    background: var(--prl-line); color: var(--prl-ink-soft);
    letter-spacing: 0.02em;
}
.prl-tabs a.active .count { background: rgba(255,255,255,0.18); color: #fff; }

/* ---------- toolbar (search + filtros + cta) ---------- */
.prl-toolbar {
    display: flex; align-items: center; gap: 8px; margin-bottom: 14px;
    flex-wrap: wrap;
}
.prl-search { position: relative; flex: 1; min-width: 200px; max-width: 320px; }
.prl-search input {
    width: 100%; padding: 8px 12px 8px 34px;
    border: 1px solid var(--prl-line); background: var(--prl-surface);
    border-radius: 6px; font-size: 13px; color: var(--prl-ink);
    font-family: inherit;
}
.prl-search input:focus {
    outline: none; border-color: var(--prl-sage);
    box-shadow: 0 0 0 3px var(--prl-sage-l);
}
.prl-search svg {
    position: absolute; left: 11px; top: 50%; transform: translateY(-50%);
    color: var(--prl-ink-faint);
}

/* botones de filtro estilo dlv-toolbar */
.prl-filt-wrap { position: relative; }
.prl-filt {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 7px 12px; border: 1px solid var(--prl-line);
    background: var(--prl-surface); border-radius: 6px;
    cursor: pointer; font-size: 12px; font-weight: 500;
    color: var(--prl-ink-soft); font-family: inherit;
}
.prl-filt:hover { color: var(--prl-ink); border-color: var(--prl-line-2); }
.prl-filt.has {
    background: var(--prl-sage-l); color: var(--prl-ink);
    border-color: var(--prl-sage);
}
.prl-filt .badge {
    display: inline-grid; place-items: center;
    min-width: 18px; height: 16px; padding: 0 4px;
    background: var(--prl-sage-d); color: #fff;
    border-radius: 3px; font-size: 10px; font-weight: 600;
}
.prl-filt .chev { color: var(--prl-ink-faint); }
.prl-filt-divider { width: 1px; height: 22px; background: var(--prl-line); margin: 0 2px; }

/* Acción "borrar filtros" — color terracota suave para distinguirla
 * del resto de filtros (que son acumulativos). */
.prl-filt.prl-filt--clear {
    background: var(--prl-terra-l); border-color: var(--prl-terra);
    color: var(--prl-terra-d); font-weight: 600;
}
.prl-filt.prl-filt--clear:hover {
    background: var(--prl-terra); border-color: var(--prl-terra-d); color: #fff;
}
.prl-filt.prl-filt--clear .fa { color: inherit; }

.prl-pop {
    position: absolute; top: calc(100% + 5px); left: 0; z-index: 30;
    background: var(--prl-surface); border: 1px solid var(--prl-line-2);
    border-radius: 7px; padding: 6px; min-width: 200px; max-width: 280px;
    box-shadow: 0 8px 24px rgba(40,36,24,0.12);
    display: flex; flex-direction: column; gap: 2px;
    max-height: 320px; overflow-y: auto;
}
.prl-pop[hidden] { display: none; }
.prl-pop label {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 9px; border-radius: 4px;
    font-size: 12.5px; color: var(--prl-ink); cursor: pointer;
}
.prl-pop label:hover { background: var(--prl-sage-l); }
.prl-pop input { accent-color: var(--prl-sage-d); }

/* dot de modalidad dentro del popover (mismas reglas que el reparto) */
.prl-pop .dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.prl-pop .mod-1 .dot { background: var(--prl-sage); }
.prl-pop .mod-2 .dot { background: var(--prl-ochre); }
.prl-pop .mod-3 .dot { background: var(--prl-terra); }
.prl-pop .mod-4 .dot { background: transparent; border: 1px dashed var(--prl-sage); width: 7px; height: 7px; }
.prl-pop .mod-5 .dot { background: var(--prl-ochre-l); border: 1px solid var(--prl-ochre); }
.prl-pop hr {
    border: 0; border-top: 1px solid var(--prl-line); margin: 4px 0;
}
.prl-pop .reset {
    text-align: left; padding: 7px 9px; font-size: 11.5px;
    color: var(--prl-ink-faint); cursor: pointer; background: transparent;
    border: 0; border-radius: 4px; font-family: inherit;
}
.prl-pop .reset:hover { color: var(--prl-terra-d); background: var(--prl-terra-l); }

/* Encabezado del popover de WBG cuando el listado está acotado por nodo,
 * para que el usuario sepa por qué sólo ve algunos grupos. */
.prl-pop__scope {
    padding: 6px 9px 4px; font-size: 10.5px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--prl-ink-faint); font-weight: 600;
    border-bottom: 1px solid var(--prl-line); margin-bottom: 3px;
}
.prl-pop__scope b { color: var(--prl-ink); font-weight: 700; letter-spacing: 0; text-transform: none; }
.prl-pop__empty {
    padding: 12px 9px; font-size: 12px; font-style: italic;
    color: var(--prl-ink-faint); text-align: center;
}

.prl-toolbar .spacer { flex: 1; }
.prl-toolbar .counters {
    font-size: 12px; color: var(--prl-ink-soft); font-variant-numeric: tabular-nums;
}
.prl-toolbar .counters b { color: var(--prl-ink); font-weight: 600; }

.prl-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 6px; border: 1px solid var(--prl-line);
    background: var(--prl-surface); color: var(--prl-ink);
    font-size: 12.5px; font-weight: 500; text-decoration: none;
    cursor: pointer; transition: 0.12s ease; font-family: inherit;
}
.prl-btn:hover { border-color: var(--prl-line-2); background: var(--prl-bg); color: var(--prl-ink); }
.prl-btn .fa { font-size: 11px; color: var(--prl-ink-faint); }
.prl-btn:hover .fa { color: var(--prl-ink); }
.prl-btn--primary {
    background: var(--prl-sage-d); border-color: var(--prl-sage-d); color: #fff;
}
.prl-btn--primary:hover { background: #233619; border-color: #233619; color: #fff; }
.prl-btn--primary .fa, .prl-btn--primary:hover .fa { color: rgba(255,255,255,0.85); }
.prl-btn--warn .fa { color: var(--prl-ochre-d); }
.prl-btn--warn:hover { background: var(--prl-ochre-l); border-color: var(--prl-ochre); }
.prl-btn--danger .fa { color: var(--prl-terra-d); }
.prl-btn--danger:hover { background: var(--prl-terra-l); border-color: var(--prl-terra); }
.prl-btn--sm { padding: 6px 11px; font-size: 12px; }
.prl-btn[disabled] { opacity: 0.45; cursor: not-allowed; }

/* ---------- bulk bar ---------- */
.prl-bulkbar {
    display: flex; align-items: center; gap: 10px;
    padding: 0 14px; border-radius: 7px;
    background: var(--prl-sage-l); border: 1px solid var(--prl-sage);
    color: var(--prl-sage-d); flex-wrap: wrap;
    opacity: 0; max-height: 0; overflow: hidden; margin-bottom: 0;
    transition: opacity 0.2s ease, max-height 0.25s ease, padding 0.2s ease, margin-bottom 0.2s ease;
}
.prl-bulkbar.is-active {
    opacity: 1; max-height: 80px;
    padding-top: 10px; padding-bottom: 10px;
    margin-bottom: 14px;
}
.prl-bulkbar__counter {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 15px;
    letter-spacing: -0.005em;
}
.prl-bulkbar .prl-btn { border-color: rgba(91,122,76,0.3); background: rgba(255,255,255,0.6); }
.prl-bulkbar .prl-btn:hover { background: #fff; }
.prl-bulkbar .spacer { flex: 1; }

/* ---------- tabla ---------- */
.prl-table-wrap {
    background: var(--prl-surface); border: 1px solid var(--prl-line);
    border-radius: 8px; overflow: hidden;
}
.prl-table { width: 100%; border-collapse: collapse; }
.prl-table thead th {
    text-align: left; padding: 10px 14px;
    font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--prl-ink-faint); font-weight: 600;
    background: var(--prl-bg); border-bottom: 1px solid var(--prl-line);
    white-space: nowrap;
}
.prl-table tbody td {
    padding: 11px 14px; font-size: 12.5px; color: var(--prl-ink);
    border-bottom: 1px solid var(--prl-line); vertical-align: middle;
}
.prl-table tbody tr:last-child td { border-bottom: 0; }
.prl-table tbody tr:hover td { background: var(--prl-sage-l); }
.prl-table .tight { white-space: nowrap; width: 1%; }
.prl-table th.tight { padding-left: 10px; padding-right: 10px; }
.prl-table .actions { text-align: right; white-space: nowrap; width: 1%; }
.prl-table .actions a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: 5px;
    color: var(--prl-ink-faint); text-decoration: none;
    transition: 0.12s ease;
}
.prl-table .actions a:hover { background: var(--prl-bg); color: var(--prl-sage-d); }
.prl-table .actions a + a { margin-left: 2px; }

/* nombre con avatar mini + email/teléfono debajo */
.prl-person { display: flex; align-items: center; gap: 10px; min-width: 0; }
.prl-person__avatar {
    width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0;
    display: grid; place-items: center;
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 11.5px;
    color: var(--prl-surface); background: var(--prl-sage-d);
    letter-spacing: -0.01em;
}
.prl-person__avatar--ochre { background: var(--prl-ochre-d); }
.prl-person__avatar--terra { background: var(--prl-terra-d); }
.prl-person__avatar--ink   { background: var(--prl-ink); }
.prl-person__avatar--muted { background: var(--prl-line-2); color: var(--prl-ink-soft); }
.prl-person__body { min-width: 0; }
.prl-person__name {
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px;
    color: var(--prl-ink); text-decoration: none; letter-spacing: -0.005em;
    display: block; line-height: 1.2;
}
.prl-person__name:hover { color: var(--prl-sage-d); }
.prl-person__meta {
    display: block; font-family: 'Inter', sans-serif;
    font-size: 11px; color: var(--prl-ink-faint); margin-top: 1px;
    line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 260px;
}
.prl-person__meta--alias { color: var(--prl-sage-d); font-weight: 500; }

/* recogida: WBG arriba, Nodo abajo */
.prl-pickup__name {
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 13px;
    color: var(--prl-ink); letter-spacing: -0.005em; line-height: 1.2;
}
.prl-pickup__node {
    font-family: 'Inter', sans-serif; font-size: 10.5px;
    color: var(--prl-ink-faint); letter-spacing: 0.04em;
    text-transform: uppercase; margin-top: 1px;
}
.prl-cell-muted { color: var(--prl-ink-faint); font-style: italic; font-size: 12px; }

/* chips */
.prl-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 9px 4px; border-radius: 4px;
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; line-height: 1.2; white-space: nowrap;
}
.prl-chip .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.prl-chip--activo  { background: var(--prl-sage-l);  color: var(--prl-sage-d); }
.prl-chip--activo .dot { background: var(--prl-sage); }
.prl-chip--pausado { background: var(--prl-ochre-l); color: var(--prl-ochre-d); }
.prl-chip--pausado .dot { background: var(--prl-ochre); }
.prl-chip--baja    { background: #f0eee7; color: var(--prl-ink-soft); }
.prl-chip--baja .dot { background: var(--prl-ink-faint); }
.prl-chip--mod-1   { background: var(--prl-sage-l);  color: var(--prl-sage-d); }
.prl-chip--mod-1 .dot { background: var(--prl-sage); }
.prl-chip--mod-2   { background: var(--prl-ochre-l); color: var(--prl-ochre-d); }
.prl-chip--mod-2 .dot { background: var(--prl-ochre); }
.prl-chip--mod-3   { background: var(--prl-terra-l); color: var(--prl-terra-d); }
.prl-chip--mod-3 .dot { background: var(--prl-terra); }
.prl-chip--mod-4   { background: transparent; color: var(--prl-sage-d); border: 1px dashed var(--prl-sage); }
.prl-chip--mod-4 .dot { background: var(--prl-sage); }
.prl-chip--mod-5   { background: #fff2d6; color: var(--prl-ochre-d); }
.prl-chip--mod-5 .dot { background: var(--prl-ochre); }

/* checkbox tight */
.prl-table .check { width: 32px; padding-right: 0; }
.prl-table .check input[type="checkbox"] { accent-color: var(--prl-sage-d); cursor: pointer; }

/* empty */
.prl-empty {
    padding: 56px 18px; text-align: center;
    color: var(--prl-ink-faint); font-size: 13.5px; font-style: italic;
    background: var(--prl-bg);
}

/* paginación Knp — overrides estéticos del default sliding */
.prl-pagination { margin-top: 14px; display: flex; justify-content: center; }
.prl-pagination .pagination {
    display: inline-flex; gap: 4px; padding: 0; margin: 0; list-style: none;
}
.prl-pagination .pagination li a,
.prl-pagination .pagination li span {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 34px; height: 34px; padding: 0 10px;
    border: 1px solid var(--prl-line); border-radius: 6px;
    background: var(--prl-surface); color: var(--prl-ink-soft);
    font-size: 12.5px; font-weight: 500; text-decoration: none;
    font-variant-numeric: tabular-nums;
}
.prl-pagination .pagination li a:hover {
    border-color: var(--prl-line-2); background: var(--prl-bg); color: var(--prl-ink);
}
.prl-pagination .pagination li.current span {
    background: var(--prl-ink); border-color: var(--prl-ink); color: #fff;
}
.prl-pagination .pagination li.disabled span {
    color: var(--prl-line-2); background: var(--prl-bg);
}

/* responsive */
@media (max-width: 900px) {
    .prl-stats { grid-template-columns: repeat(2, 1fr); }
    .prl-person__meta { max-width: 160px; }
}
</style>
{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        // Listado de socixs — JS local.
        //   1. Cuenta seleccionados y muestra/oculta bulk bar.
        //   2. Toggle de popovers de filtro (click fuera = cerrar).
        //   3. Auto-submit del form GET al cambiar cualquier filtro.
        (function () {
            // ---------- popovers ----------
            document.querySelectorAll('[data-pop-trigger]').forEach(function (btn) {
                btn.addEventListener('click', function (ev) {
                    ev.stopPropagation();
                    var id = btn.getAttribute('data-pop-trigger');
                    var pop = document.getElementById(id);
                    if (!pop) return;
                    var isOpen = !pop.hidden;
                    // cerrar todos primero
                    document.querySelectorAll('.prl-pop').forEach(function (p) { p.hidden = true; });
                    pop.hidden = isOpen;
                });
            });
            document.addEventListener('click', function (ev) {
                document.querySelectorAll('.prl-pop').forEach(function (pop) {
                    if (pop.hidden) return;
                    if (pop.contains(ev.target)) return;
                    var triggerId = pop.id;
                    var trigger = document.querySelector('[data-pop-trigger="' + triggerId + '"]');
                    if (trigger && trigger.contains(ev.target)) return;
                    pop.hidden = true;
                });
            });

            // ---------- auto-submit del form GET ----------
            var filterForm = document.getElementById('prl-filter-form');
            if (filterForm) {
                filterForm.querySelectorAll('input[type="checkbox"], input[type="radio"], select').forEach(function (el) {
                    el.addEventListener('change', function () {
                        // Al cambiar el nodo, el wbg queda huérfano si era de
                        // otro nodo. Forzamos "Cualquier grupo" antes de
                        // submit para evitar listados vacíos por desajuste.
                        if (el.name === 'node') {
                            var wbgReset = filterForm.querySelector('input[name="wbg"][value=""]');
                            if (wbgReset) wbgReset.checked = true;
                        }
                        filterForm.submit();
                    });
                });

                // Búsqueda por texto: auto-envío con debounce (~350ms) al
                // dejar de teclear, para no obligar a pulsar Enter. Sigue
                // siendo server-side (busca en toda la base, no sólo la
                // página visible), por eso recarga en vez de filtrar en
                // cliente como el listado de reparto.
                var searchInput = filterForm.querySelector('input[name="q"]');
                if (searchInput) {
                    var debounce = null;
                    searchInput.addEventListener('input', function () {
                        clearTimeout(debounce);
                        debounce = setTimeout(function () { filterForm.submit(); }, 350);
                    });
                    // Como el submit recarga la página, el foco se pierde.
                    // Si veníamos de una búsqueda, devolvemos el foco al
                    // campo con el cursor al final para seguir escribiendo.
                    if (searchInput.value) {
                        searchInput.focus();
                        var end = searchInput.value.length;
                        searchInput.setSelectionRange(end, end);
                    }
                }
            }

            // ---------- bulk bar ----------
            var bulkForm = document.querySelector('form[data-prl-bulk]');
            if (!bulkForm) return;
            var checks = Array.prototype.slice.call(bulkForm.querySelectorAll('input[data-partner-check]'));
            var counter = document.getElementById('prl-selected-counter');
            var bar = document.getElementById('prl-bulkbar');
            var buttons = Array.prototype.slice.call(bulkForm.querySelectorAll('[data-bulk-button]'));
            var selectAll = document.getElementById('prl-select-all');
            var clearAll = document.getElementById('prl-clear');

            function refreshBulk() {
                var n = 0;
                checks.forEach(function (c) { if (c.checked) n += 1; });
                if (counter) counter.textContent = n;
                buttons.forEach(function (b) { b.disabled = n === 0; });
                if (bar) bar.classList.toggle('is-active', n > 0);
            }
            checks.forEach(function (c) { c.addEventListener('change', refreshBulk); });
            if (selectAll) selectAll.addEventListener('click', function () {
                checks.forEach(function (c) { c.checked = true; });
                refreshBulk();
            });
            if (clearAll) clearAll.addEventListener('click', function () {
                checks.forEach(function (c) { c.checked = false; });
                refreshBulk();
            });
            refreshBulk();
        }());
    </script>
{% endblock %}

{% block csa_main %}

{# Qué acciones masivas tienen sentido en la pestaña actual. Sólo se
 # ofrecen en pestañas mono-estado (en "Todxs" se mezclarían estados
 # y aplicar una transición a quien no la admite es confuso). #}
{% set bulk_leave  = status_filter == 'ACTIVO' or status_filter == 'PAUSADO' %}
{% set bulk_pause  = status_filter == 'ACTIVO' %}
{% set bulk_resume = status_filter == 'PAUSADO' %}
{% set bulk_rejoin = status_filter == 'BAJA' %}
{% set bulk_any    = bulk_leave or bulk_pause or bulk_resume or bulk_rejoin %}

{% set avatar_palette = ['sage', 'ochre', 'terra', 'ink'] %}

{# El form GET de filtros lleva el status actual para no perderlo al
 # marcar/desmarcar otros filtros; cuando entras en una tab "Todxs"
 # mando status=ALL para forzar el bypass del default ACTIVO. #}
{% set status_param = status_filter ?: 'ALL' %}

{# Conteo de filtros activos (excluyendo status y q) para el badge "Filtros". #}
{% set active_filters_count = (filters.modalities|length) + (filters.cesta ? 1 : 0) + (filters.node ? 1 : 0) + (filters.wbg ? 1 : 0) %}

<div class="prl">

    {{ csa.page_header(
        'Socixs · Listado',
        title|default('Socixs'),
        'Personas asociadas a la cooperativa.'
    ) }}

    {# ============ STAT STRIP ============ #}
    <div class="prl-stats">
        <a class="prl-stat prl-stat--active" href="{{ path('partner_index', { status: 'ACTIVO' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.ACTIVO ?? 0 }}</div>
            <div class="l">activxs</div>
        </a>
        <a class="prl-stat prl-stat--paused" href="{{ path('partner_index', { status: 'PAUSADO' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.PAUSADO ?? 0 }}</div>
            <div class="l">pausadxs</div>
        </a>
        <a class="prl-stat prl-stat--leave" href="{{ path('partner_index', { status: 'BAJA' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.BAJA ?? 0 }}</div>
            <div class="l">de baja</div>
        </a>
        <a class="prl-stat" href="{{ path('partner_index', { status: 'ALL' }) }}" style="text-decoration: none;">
            <div class="v">{{ status_counts.ALL ?? 0 }}</div>
            <div class="l">en total</div>
        </a>
    </div>

    {# ============ TABS por estado ============ #}
    <nav class="prl-tabs" role="tablist">
        {% for s in statuses %}
            <a href="{{ path('partner_index', { status: s }) }}"
               class="{{ status_filter == s ? 'active' : '' }}">
                {{ status_tab[s] }} <span class="count">{{ status_counts[s] ?? 0 }}</span>
            </a>
        {% endfor %}
        <a href="{{ path('partner_index', { status: 'ALL' }) }}"
           class="{{ status_filter is null ? 'active' : '' }}">
            Todxs <span class="count">{{ status_counts.ALL ?? 0 }}</span>
        </a>
    </nav>

    {# ============ FORM GET de filtros ============ #}
    <form method="get" action="{{ path('partner_index') }}" id="prl-filter-form">
        <input type="hidden" name="status" value="{{ status_param }}">

        <div class="prl-toolbar">
            <div class="prl-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3-3"/></svg>
                <input type="search" name="q" value="{{ filters.q }}" placeholder="Buscar por nombre, email, teléfono…" autocomplete="off">
            </div>

            {# Popover MODALIDAD #}
            <div class="prl-filt-wrap">
                <button type="button" class="prl-filt {{ filters.modalities|length > 0 ? 'has' : '' }}" data-pop-trigger="pop-mod">
                    Modalidad
                    {% if filters.modalities|length > 0 %}<span class="badge">{{ filters.modalities|length }}</span>{% endif %}
                    <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="prl-pop" id="pop-mod" hidden>
                    {% for m in modalities_all %}
                        <label class="mod-{{ m.id }}">
                            <input type="checkbox" name="modality[]" value="{{ m.id }}"
                                   {% if m.id in filters.modalities %}checked{% endif %}>
                            <span class="dot"></span>
                            {{ mod_labels[m.id] ?? m.name }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {# Popover CESTA SÍ/NO #}
            <div class="prl-filt-wrap">
                <button type="button" class="prl-filt {{ filters.cesta ? 'has' : '' }}" data-pop-trigger="pop-cesta">
                    Cesta
                    {% if filters.cesta %}<span class="badge">{{ filters.cesta == 'yes' ? 'sí' : 'no' }}</span>{% endif %}
                    <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="prl-pop" id="pop-cesta" hidden>
                    <label><input type="radio" name="cesta" value="" {% if not filters.cesta %}checked{% endif %}> Todxs (con o sin cesta)</label>
                    <label><input type="radio" name="cesta" value="yes" {% if filters.cesta == 'yes' %}checked{% endif %}> Con cesta activa</label>
                    <label><input type="radio" name="cesta" value="no"  {% if filters.cesta == 'no' %}checked{% endif %}> Sin cesta activa</label>
                </div>
            </div>

            {# Popover NODO #}
            {% if nodes_all|length > 1 %}
                <div class="prl-filt-wrap">
                    <button type="button" class="prl-filt {{ filters.node ? 'has' : '' }}" data-pop-trigger="pop-node">
                        Nodo
                        {% if filters.node %}<span class="badge">1</span>{% endif %}
                        <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                    </button>
                    <div class="prl-pop" id="pop-node" hidden>
                        <label><input type="radio" name="node" value="" {% if not filters.node %}checked{% endif %}> Cualquier nodo</label>
                        {% for n in nodes_all %}
                            <label><input type="radio" name="node" value="{{ n.id }}" {% if filters.node == n.id %}checked{% endif %}> {{ n.name }}</label>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Popover GRUPO DE RECOGIDA — depende del nodo seleccionado.
             # Si hay nodo activo, sólo se ofrecen los WBG de ese nodo. #}
            {% if wbgs_all|length > 0 or filters.node %}
                {% set scoped_node = filters.node ? (nodes_all|filter(n => n.id == filters.node)|first) : null %}
                <div class="prl-filt-wrap">
                    <button type="button" class="prl-filt {{ filters.wbg ? 'has' : '' }}" data-pop-trigger="pop-wbg">
                        Grupo
                        {% if filters.wbg %}<span class="badge">1</span>{% endif %}
                        <svg class="chev" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                    </button>
                    <div class="prl-pop" id="pop-wbg" hidden>
                        {% if scoped_node %}
                            <div class="prl-pop__scope">Grupos de <b>{{ scoped_node.name }}</b></div>
                        {% endif %}
                        <label><input type="radio" name="wbg" value="" {% if not filters.wbg %}checked{% endif %}> Cualquier grupo</label>
                        {% if wbgs_all|length == 0 %}
                            <div class="prl-pop__empty">Este nodo no tiene grupos definidos.</div>
                        {% else %}
                            {% for g in wbgs_all %}
                                <label><input type="radio" name="wbg" value="{{ g.id }}" {% if filters.wbg == g.id %}checked{% endif %}> {{ g.name }}</label>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {% if active_filters_count > 0 or filters.q %}
                <a class="prl-filt prl-filt--clear" href="{{ path('partner_index', { status: status_param }) }}" title="Limpiar todos los filtros">
                    <i class="fa fa-times-circle" aria-hidden="true"></i> Limpiar filtros
                </a>
            {% endif %}

            <span class="prl-filt-divider"></span>

            <div class="counters">
                <b>{{ pagination|length }}</b> de <b>{{ pagination.getTotalItemCount }}</b> socix{{ pagination.getTotalItemCount == 1 ? '' : 's' }}
            </div>
            <div class="spacer"></div>
            <a href="{{ path('partner_evolution') }}" class="prl-btn">
                <i class="fa fa-line-chart"></i> Evolución
            </a>
            <a href="{{ path('partner_new') }}" class="prl-btn prl-btn--primary">
                <i class="fa fa-plus"></i> Nuevx socix
            </a>
        </div>

        {# noscript fallback: con JS desactivado el form GET no autosubmit;
         # ofrecemos un botón aplicar al menos visible en ese caso. #}
        <noscript>
            <div style="margin-bottom: 14px;">
                <button type="submit" class="prl-btn prl-btn--primary">Aplicar filtros</button>
            </div>
        </noscript>
    </form>

    {# ============ FORM POST de bulk transition ============ #}
    <form method="post" action="{{ path('partner_bulk_transition') }}" data-prl-bulk>
        <input type="hidden" name="_token" value="{{ csrf_token('partner_bulk_transition') }}">

        {% if bulk_any %}
            <div id="prl-bulkbar" class="prl-bulkbar">
                <span class="prl-bulkbar__counter"><b id="prl-selected-counter">0</b> seleccionadxs</span>
                <button type="button" id="prl-select-all" class="prl-btn prl-btn--sm">
                    <i class="fa fa-check-square-o"></i> Marcar página
                </button>
                <button type="button" id="prl-clear" class="prl-btn prl-btn--sm">
                    <i class="fa fa-square-o"></i> Quitar selección
                </button>
                <span class="spacer"></span>
                {% if bulk_resume %}
                    <button type="submit" name="transition" value="resume" class="prl-btn prl-btn--primary prl-btn--sm" data-bulk-button>
                        <i class="fa fa-play"></i> Reactivar
                    </button>
                {% endif %}
                {% if bulk_rejoin %}
                    <button type="submit" name="transition" value="rejoin" class="prl-btn prl-btn--primary prl-btn--sm" data-bulk-button>
                        <i class="fa fa-undo"></i> Reactivar
                    </button>
                {% endif %}
                {% if bulk_pause %}
                    <button type="submit" name="transition" value="pause" class="prl-btn prl-btn--warn prl-btn--sm" data-bulk-button>
                        <i class="fa fa-pause"></i> Pausar
                    </button>
                {% endif %}
                {% if bulk_leave %}
                    <button type="submit" name="transition" value="leave" class="prl-btn prl-btn--danger prl-btn--sm" data-bulk-button>
                        <i class="fa fa-user-times"></i> Dar de baja
                    </button>
                {% endif %}
            </div>
        {% endif %}

        <div class="prl-table-wrap">
            {% if pagination|length == 0 %}
                <div class="prl-empty">
                    {% if active_filters_count > 0 or filters.q %}
                        No hay socixs que cumplan los filtros aplicados.
                    {% else %}
                        Aún no hay socixs registradxs{% if status_filter %} con estado {{ status_chip[status_filter].label|lower }}{% endif %}.
                    {% endif %}
                </div>
            {% else %}
                <table class="prl-table">
                    <thead>
                        <tr>
                            {% if bulk_any %}<th class="check"><span class="sr-only">Selección</span></th>{% endif %}
                            <th>Socix</th>
                            {% if status_filter is null %}<th class="tight">Estado</th>{% endif %}
                            <th class="tight">Cesta</th>
                            <th class="tight">Recogida</th>
                            <th class="tight">Teléfono</th>
                            <th class="tight">Alta</th>
                            <th class="actions"><span class="sr-only">Acciones</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for partner in pagination %}
                            {% set initials = (partner.name|first|upper) ~ (partner.surname|first|default('')|upper) %}
                            {% set avatar_tone = partner.status == 'BAJA' ? 'muted' : avatar_palette[(partner.id|default(0)) % 4] %}
                            {% set sc = status_chip[partner.status]|default({ label: partner.status, cls: 'baja' }) %}
                            {% set ab = partner.hasActiveBasket ? partner.getActiveBasket : null %}
                            {% set bs_id = ab ? ab.basketShare.id : null %}
                            <tr>
                                {% if bulk_any %}
                                    <td class="check">
                                        <input type="checkbox" name="partner_ids[]" value="{{ partner.id }}"
                                               data-partner-check
                                               aria-label="Seleccionar {{ partner.name }} {{ partner.surname }}">
                                    </td>
                                {% endif %}
                                <td>
                                    <div class="prl-person">
                                        <span class="prl-person__avatar prl-person__avatar--{{ avatar_tone }}" aria-hidden="true">{{ initials }}</span>
                                        <div class="prl-person__body">
                                            <a class="prl-person__name" href="{{ path('partner_show', { id: partner.id }) }}">
                                                {{ partner.name }} {{ partner.surname }}
                                            </a>
                                            {% if partner.displayName %}
                                                <span class="prl-person__meta prl-person__meta--alias" title="Nombre en el listado de reparto">↳ {{ partner.displayName }}</span>
                                            {% endif %}
                                            {% if partner.email %}
                                                <span class="prl-person__meta">{{ partner.email }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                {% if status_filter is null %}
                                    <td class="tight">
                                        <span class="prl-chip prl-chip--{{ sc.cls }}"><span class="dot"></span>{{ sc.label }}</span>
                                    </td>
                                {% endif %}
                                <td class="tight">
                                    {% if ab %}
                                        <span class="prl-chip prl-chip--mod-{{ bs_id }}">
                                            {% if bs_id != 4 %}<span class="dot"></span>{% endif %}
                                            {{ mod_labels[bs_id] ?? ab.basketShare.name }}
                                        </span>
                                    {% elseif partner.parent %}
                                        <span class="prl-cell-muted">vía familiar</span>
                                    {% else %}
                                        <span class="prl-cell-muted">sin cesta</span>
                                    {% endif %}
                                </td>
                                <td class="tight">
                                    {% if partner.weeklyBasketGroup %}
                                        <div class="prl-pickup__name">{{ partner.weeklyBasketGroup.name }}</div>
                                        {% if partner.weeklyBasketGroup.node %}
                                            <div class="prl-pickup__node">{{ partner.weeklyBasketGroup.node.name }}</div>
                                        {% endif %}
                                    {% else %}
                                        <span class="prl-cell-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="tight">{{ partner.celular ?: '—' }}</td>
                                <td class="tight">
                                    {% if partner.inscriptionDate %}{{ partner.inscriptionDate|date('d/m/Y') }}{% else %}—{% endif %}
                                </td>
                                <td class="actions">
                                    <a href="{{ path('partner_show', { id: partner.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                                    <a href="{{ path('partner_edit', { id: partner.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                                    {% if type == 1 %}
                                        <a href="{{ path('partner_add_basket', { id: partner.id }) }}" title="Añadir cesta" aria-label="Añadir cesta"><i class="fa fa-shopping-basket"></i></a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        {% if pagination.getPageCount > 1 %}
            <div class="prl-pagination">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </form>

</div>
{% endblock %}
