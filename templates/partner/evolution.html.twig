{# ============================================================
 # Evolución del número de socixs — shell csa.
 # Gráfico Highcharts con datos por mes.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Evolución de socixs{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('partner_index') }}">Socixs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Evolución</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Estadísticas',
        'Evolución del número de socixs',
        'Variación mensual del total de socias y socios.'
    ) }}

    {% embed '_components/csa_card.html.twig' with { title: 'Gráfico', accent: 'green' } %}
        {% block body %}
            <div id="container" style="width: 100%; height: 400px;"></div>
        {% endblock %}
    {% endembed %}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="https://code.highcharts.com/highcharts.js"></script>
    <script>
        (function () {
            Highcharts.chart('container', {
                chart: { type: 'spline', zoomType: 'x' },
                title: { text: 'Evolución número de socixs' },
                yAxis: { title: { text: 'Número de socixs' } },
                tooltip: { shared: true },
                legend: { layout: 'vertical', align: 'right', verticalAlign: 'middle' },
                xAxis: {
                    title: { text: 'meses' },
                    categories: [
                        {% for amount in amount_partners %}
                            '{{ amount[0][0].date|date("m/d/Y") }}',
                        {% endfor %}
                    ]
                },
                plotOptions: { series: { label: { connectorAllowed: false } } },
                series: [{
                    name: 'Nº de socixs',
                    color: Highcharts.getOptions().colors[5],
                    data: [
                        {% for amount in amount_partners %}
                            {{ amount[1] }},
                        {% endfor %}
                    ]
                }]
            });
        })();
    </script>
{% endblock %}
