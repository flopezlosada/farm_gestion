{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Nueva encuesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('survey_index') }}">Encuestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Encuestas',
        'Nueva encuesta',
        'Crea la encuesta y sus preguntas. Nace en borrador: podrás revisarla antes de abrirla a lxs socixs.'
    ) }}

    {% include 'survey/_form.html.twig' with { submit_label: 'Crear encuesta' } %}

{% endblock %}
