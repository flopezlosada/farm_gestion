{# ============================================================
 # Form de encuesta en una sola pantalla: cabecera + colección
 # dinámica de preguntas, y dentro de cada pregunta una colección
 # dinámica de opciones (single/multiple). Dos niveles de
 # prototipo: __question__ (preguntas) y __option__ (opciones).
 #
 # Los campos se pintan con los macros locales `question_fields`
 # y `option_row`, reutilizados tanto por los elementos ya
 # presentes (edición) como por los prototipos, para que todo
 # luzca la estética csa sin duplicar markup.
 # ============================================================ #}
{% import '_macros/csa.html.twig' as csa %}
{% import _self as svf %}
{% form_theme form 'form_div_layout.html.twig' %}

{% macro option_row(o) %}
    {% import '_macros/csa.html.twig' as csa %}
    <div class="sv-option-row">
        {{ form_widget(o.label, { attr: { class: 'csa-input' } }) }}
        <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm sv-remove-option" aria-label="Quitar opción">×</button>
    </div>
{% endmacro %}

{% macro question_fields(q) %}
    {% import '_macros/csa.html.twig' as csa %}
    {% import _self as svf %}
    <div class="csa-form-grid">
        {{ csa.field(q.text, 'Pregunta', { full: true }) }}
        {{ csa.field(q.type, 'Tipo') }}
        <div class="csa-field">
            <div class="csa-field__label-row">
                <label class="csa-field__label" for="{{ q.required.vars.id }}">Obligatoria</label>
            </div>
            <label class="sv-check">{{ form_widget(q.required) }} <span>Hay que responderla</span></label>
        </div>

        {# Opciones: solo aplican a single/multiple. El JS muestra/oculta este
         # bloque según el tipo elegido. #}
        <div class="csa-field csa-field--full sv-options-field">
            <div class="csa-field__label-row">
                <label class="csa-field__label">Opciones</label>
            </div>
            <div class="sv-options-list"
                 data-prototype="{{ svf.option_row(q.options.vars.prototype)|e('html_attr') }}"
                 data-index="{{ q.options|length }}">
                {% for option in q.options %}
                    {{ svf.option_row(option) }}
                {% endfor %}
            </div>
            <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm sv-add-option" style="margin-top: var(--csa-sp-2);">+ Añadir opción</button>
        </div>
    </div>
{% endmacro %}

{{ form_start(form, { attr: { class: 'csa-form-narrow', 'data-csa-dropdowns': '1' } }) }}

    <div class="csa-stack-lg">

        {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Encuesta', subtitle: 'Título y, si quieres, una descripción y fecha de cierre orientativa.' } %}
            {% block body %}
                {% import '_macros/csa.html.twig' as csa %}
                <div class="csa-form-grid">
                    {{ csa.field(form.title, 'Título', { full: true }) }}
                    {{ csa.field(form.description, 'Descripción', { full: true }) }}
                    {{ csa.field(form.closesAt, 'Fecha de cierre (informativa)') }}
                </div>
            {% endblock %}
        {% endembed %}

        {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Preguntas', subtitle: 'Añade tantas como necesites. En opción única/múltiple, escribe cada opción en su campo.' } %}
            {% block body %}
                {% import 'survey/_form.html.twig' as svf %}
                {% import '_macros/csa.html.twig' as csa %}
                <div id="sv-questions"
                     data-prototype="{{ svf.question_fields(form.questions.vars.prototype)|e('html_attr') }}"
                     data-index="{{ form.questions|length }}">
                    {% for question in form.questions %}
                        <div class="sv-q">
                            {{ svf.question_fields(question) }}
                            <button type="button" class="csa-btn csa-btn--ghost sv-q-remove">Quitar pregunta</button>
                        </div>
                    {% endfor %}
                </div>

                <button type="button" id="sv-add-question" class="csa-btn csa-btn--ghost" style="margin-top: var(--csa-sp-4);">
                    + Añadir pregunta
                </button>
            {% endblock %}
        {% endembed %}

        <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
            <div></div>
            <div class="csa-row">
                {{ csa.btn('Cancelar', { variant: 'ghost', href: path('survey_index') }) }}
                <button type="submit" class="csa-btn csa-btn--primary">{{ submit_label|default('Guardar') }}</button>
            </div>
        </div>

    </div>

    {{ form_rest(form) }}
{{ form_end(form, { render_rest: false }) }}

<style>
    .sv-q { border: 1px solid var(--csa-rule); border-radius: 8px; padding: var(--csa-sp-4); margin-bottom: var(--csa-sp-4); background: #fff; }
    .sv-check { display: inline-flex; align-items: center; gap: var(--csa-sp-2); font-weight: 400; }
    .sv-check input { width: auto; height: auto; }
    .sv-options-list { display: flex; flex-direction: column; gap: var(--csa-sp-2); }
    .sv-option-row { display: flex; align-items: center; gap: var(--csa-sp-2); }
    .sv-option-row .csa-input { flex: 1; }
    .sv-remove-option { line-height: 1; padding: 0 var(--csa-sp-3); }
</style>

<script>
(function () {
    var wrap = document.getElementById('sv-questions');
    if (!wrap) { return; }
    var TYPES_WITH_OPTIONS = ['single', 'multiple'];

    // Muestra/oculta el bloque de opciones de una pregunta según su tipo.
    function syncOptions(item) {
        var typeSelect = item.querySelector('select');
        var optField = item.querySelector('.sv-options-field');
        if (!typeSelect || !optField) { return; }
        var show = TYPES_WITH_OPTIONS.indexOf(typeSelect.value) !== -1;
        optField.style.display = show ? '' : 'none';
    }

    // Enlaza el botón "quitar" de una fila de opción.
    function bindOption(row) {
        var remove = row.querySelector('.sv-remove-option');
        if (remove) { remove.addEventListener('click', function () { row.parentNode.removeChild(row); }); }
    }

    // Enlaza una pregunta entera: cambio de tipo, quitar pregunta, y la
    // sub-colección de opciones (filas existentes + botón añadir).
    function bindQuestion(item) {
        var typeSelect = item.querySelector('select');
        if (typeSelect) { typeSelect.addEventListener('change', function () { syncOptions(item); }); }

        var removeQ = item.querySelector('.sv-q-remove');
        if (removeQ) { removeQ.addEventListener('click', function () { item.parentNode.removeChild(item); }); }

        var list = item.querySelector('.sv-options-list');
        if (list) {
            Array.prototype.forEach.call(list.querySelectorAll('.sv-option-row'), bindOption);
        }

        var addOption = item.querySelector('.sv-add-option');
        if (addOption && list) {
            addOption.addEventListener('click', function () {
                // El índice de opción solo crece, nunca se reutiliza.
                var idx = parseInt(list.dataset.index, 10);
                var html = list.dataset.prototype.replace(/__option__/g, idx);
                var tmp = document.createElement('div');
                tmp.innerHTML = html;
                var row = tmp.firstElementChild;
                list.appendChild(row);
                list.dataset.index = idx + 1;
                bindOption(row);
            });
        }

        syncOptions(item);
    }

    // Preguntas ya presentes al cargar (caso edición).
    Array.prototype.forEach.call(wrap.querySelectorAll('.sv-q'), bindQuestion);

    document.getElementById('sv-add-question').addEventListener('click', function () {
        // El índice de pregunta solo crece, nunca se reutiliza, para no colisionar nombres.
        var index = parseInt(wrap.dataset.index, 10);
        var html = wrap.dataset.prototype.replace(/__question__/g, index);
        var item = document.createElement('div');
        item.className = 'sv-q';
        item.innerHTML = html + '<button type="button" class="csa-btn csa-btn--ghost sv-q-remove">Quitar pregunta</button>';
        wrap.appendChild(item);
        wrap.dataset.index = index + 1;
        bindQuestion(item);

        // El <select> de tipo de la pregunta recién añadida aún es nativo:
        // pásalo por el enhancer csa para que luzca como el resto.
        if (window.csaEnhanceDropdowns) { window.csaEnhanceDropdowns(); }
    });
})();
</script>
