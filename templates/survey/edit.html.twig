{# ============================================================
 # Editar encuesta (sólo en borrador) — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Editar encuesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('survey_index') }}">Encuestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ survey.title }}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Encuestas',
        'Editar encuesta',
        'Sólo se puede editar en borrador. Al abrirla queda congelada para no invalidar respuestas.'
    ) }}

    {% include 'survey/_form.html.twig' with { submit_label: 'Guardar cambios' } %}

{% endblock %}
