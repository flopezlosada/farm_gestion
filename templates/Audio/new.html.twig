{# ============================================================
 # Modal de creación de audio adjunto a una entidad polimórfica
 # (object_class + foreign_key). Se carga vía jQuery Modal AJAX
 # desde Blog/edition. Mantiene el script ajaxForm para que el
 # submit no recargue la página padre.
 # ============================================================ #}

{% extends 'Default/layout_admin.html.twig' %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block admin_content -%}
    <div class="csa-modal-card" style="max-width: 480px;">
        <header style="display: flex; align-items: center; gap: var(--csa-sp-3); margin-bottom: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 44px; height: 44px; font-size: 18px; border-radius: var(--csa-radius-md);">
                <i class="fa fa-music"></i>
            </span>
            <h3 style="font-family: var(--csa-serif); font-weight: 500; margin: 0;">Añadir audio</h3>
        </header>

        {{ form_start(form, { attr: {
            class: 'admin-form on-modal',
            'data-place': 'on-modal',
            id: 'form_' ~ object_class ~ '_' ~ entity.getClass|lower ~ '_' ~ foreign_key,
            enctype: 'multipart/form-data'
        } }) }}

            <div class="csa-form-grid">
                <div class="csa-field csa-field--full">
                    <label class="csa-field__label" for="{{ form.title.vars.id }}">Título</label>
                    {{ form_widget(form.title, { attr: { class: 'csa-input' } }) }}
                </div>
                <div class="csa-field csa-field--full">
                    <label class="csa-field__label" for="{{ form.file.vars.id }}">Archivo de audio</label>
                    {{ form_widget(form.file) }}
                </div>
            </div>

            <div style="margin-top: var(--csa-sp-5);">
                {{ form_widget(form.button, { label: 'Subir audio', attr: { class: 'csa-btn csa-btn--primary' } }) }}
            </div>

            {{ form_rest(form) }}
        {{ form_end(form, { render_rest: false }) }}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript" src="{{ asset('bundles/app/assets/jquery.form.min.js') }}"></script>
    <script src="{{ asset('bundles/app/js/scripts/admin.js') }}"></script>
    <script>
        $(document).ready(function () {
            $('#{{ 'form_' ~ object_class ~ '_' ~ entity.getClass|lower ~ '_' ~ foreign_key }}').ajaxForm({
                success: function () {
                    $('.jquery-modal').hide();
                    $('.modal').hide();
                },
                target: '#edition_aside_medias'
            });
        });
    </script>
{% endblock %}
