{% extends 'base_front.html.twig' %}

{% block title %}Nuestro futuro · CSA Vega de Jarama{% endblock %}

{% block content %}


    <div class="container py-3"> 
        <div class="row pt-0">
            <div class="col-lg-7 pb-0 pb-lg-0 px-3 px-lg-5">
                <div class="mb-5">
                <h2 class="d-flex flex-column text-left mb-4">Nuevos retos</h2>
                   <img class="img-fluid w-50 float-left mr-4 mb-3" style="width: 300px; height: 400px;" src="{{ asset('bundles/app/img/girasol.JPG') }}" alt="Image">
                    <h4 class="mb-3 ">En la actualidad trabajamos para:</h4>
					<ul>
			<li>Seguir compostando el residuo orgánico de la comarca en una ubicación favorable.</li>
			<li>Introducir de nuevo las gallinas de la forma más integrada posible, sin dejar de renunciar al valor
			ecológico que la forma de vida de este animal produce en el lugar en el que habita.</li>
			<li>Diseñar los espacios de trabajo como lugares compatibles con la formación y la educación.</li>
			<li>Adquirir una nave que sirva como almacén, lugar de trabajo, reparto de cestas y como espacio
				para las tareas de gestión y comunitarias de nuestra asociación.</li>
			<li>Consolidar los tres puestos de trabajo agrícolas y uno más para realizar tareas de
		administración.</li>		
                <ul>
				</div>
            </div>
            <div class="col-lg-4 mt-5 mt-lg-4">
                <div class="mb-2 text" align="center">
                    <img src="{{ asset('bundles/app/img/barricadas.jpg') }}" style="width: 400px; height: 300px;"  alt="" >
                </div>
                  <div class="mb-2 text" align="center">
                    <img src="{{ asset('bundles/app/img/jornada_huerta.JPG') }}" style="width: 400px; height: 300px;"  alt="" >
                </div>
            </div>
        </div>
    </div>
	
	    <div class="container py-0">
