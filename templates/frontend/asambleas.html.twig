{% extends 'base_front.html.twig' %}

{% block title %}Agenda · CSA Vega de Jarama{% endblock %}

{% block content %}

    <style>
        /* Agenda pública (prefijo ag-). Paleta de la web: verde #138504,
           ámbar rgb(248,177,51), papel cálido #faf7f0 / borde #e4ddcd. */
        .ag-wrap { max-width: 880px; margin: 0 auto; }

        /* ---- Cabecera ligera (es una agenda, no una landing) ----
           Alineada a la izquierda para cuadrar con el logo, el menú y las
           tarjetas; centrada descuadraba dentro de la propia columna. */
        .ag-head {
            margin-bottom: 2.4rem;
            padding-bottom: 1.4rem;
            border-bottom: 2px solid #e4ddcd;
        }
        .ag-head__kicker {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: .14em;
            font-size: .78rem;
            color: rgb(248, 177, 51);
            margin-bottom: .5rem;
        }
        .ag-head__title {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            color: #138504;
            font-size: 2.4rem;
            line-height: 1.1;
            margin: 0 0 .6rem;
        }
        .ag-head__lead {
            max-width: 68ch;
            margin: 0;
            color: #5b5347;
            font-size: 1.08rem;
            line-height: 1.55;
        }

        /* ---- Encabezado de mes ---- */
        .ag-month {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 1.15rem;
            color: #138504;
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2.4rem 0 1.2rem;
        }
        .ag-month::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #e4ddcd;
        }

        /* ---- Item de agenda: chip de fecha + cuerpo + cartel ---- */
        .ag-item {
            display: flex;
            gap: 1.4rem;
            align-items: stretch;
            background: #fff;
            border: 1px solid #e4ddcd;
            border-radius: 14px;
            padding: 1.2rem 1.4rem;
            margin-bottom: 1rem;
            transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
        }
        .ag-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(60, 50, 30, .14);
            border-color: rgb(248, 177, 51);
        }

        /* Chip de fecha tipo calendario */
        .ag-date {
            flex: 0 0 64px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            border-radius: 12px;
            background: #faf7f0;
            border: 1px solid #e4ddcd;
            padding: .5rem 0;
            line-height: 1;
        }
        .ag-date__dow {
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: rgb(248, 177, 51);
        }
        .ag-date__day {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 1.9rem;
            color: #138504;
            margin: .15rem 0;
        }
        .ag-date__mon {
            font-family: 'Nunito', sans-serif;
            font-weight: 700;
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #5b5347;
        }

        .ag-item__body { flex: 1; min-width: 0; }
        .ag-item__meta {
            font-size: .82rem;
            font-weight: 700;
            color: rgb(248, 177, 51);
            text-transform: uppercase;
            letter-spacing: .04em;
            margin-bottom: .35rem;
        }
        .ag-item__title {
            font-family: 'Nunito', sans-serif;
            font-weight: 800;
            font-size: 1.35rem;
            line-height: 1.2;
            margin: 0 0 .5rem;
        }
        .ag-item__title a { color: #138504; }
        .ag-item__title a:hover { color: rgb(151, 181, 57); text-decoration: none; }
        .ag-item__excerpt {
            color: #5b5347;
            margin: 0 0 .7rem;
            line-height: 1.55;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .ag-item__more { font-weight: 800; color: rgb(248, 177, 51); }
        .ag-item__more:hover { color: #138504; text-decoration: none; }

        /* Cartel: miniatura secundaria, no protagonista */
        .ag-item__media {
            flex: 0 0 150px;
            align-self: stretch;
            border-radius: 12px;
            overflow: hidden;
            background: #f1ece0;
        }
        .ag-item__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

        .ag-empty {
            background: #fff;
            border: 1px dashed #e4ddcd;
            border-radius: 14px;
            padding: 3rem 2rem;
            text-align: center;
            color: #5b5347;
        }

        @media (max-width: 700px) {
            .ag-head__title { font-size: 2rem; }
            .ag-item { flex-wrap: wrap; }
            .ag-item__media { flex-basis: 100%; max-height: 180px; order: 3; }
        }
    </style>

    <div class="container py-5">
        <div class="ag-wrap">

            {# ---------- Cabecera ligera ---------- #}
            <header class="ag-head">
                <p class="ag-head__kicker">CSA Vega de Jarama</p>
                <h1 class="ag-head__title">Nuestra agenda</h1>
                <p class="ag-head__lead">
                    Asambleas, jornadas de voluntariado y actividades de la asociación.
                    Estas son nuestras próximas citas — ¡asiste y participa!
                </p>
            </header>

            {# ---------- Agenda agrupada por mes ----------
             # Sin namespace(): el separador de mes se emite cuando el mes
             # del evento difiere del anterior (events viene ordenado por
             # fecha ascendente desde findUpcoming). #}
            {% for event in events %}
                {% set prev = loop.first ? null : events[loop.index0 - 1] %}
                {% if loop.first or event.beginAt|date('Y-m') != prev.beginAt|date('Y-m') %}
                    <h2 class="ag-month">{{ event.beginAt|format_datetime(pattern="MMMM 'de' yyyy", locale='es')|capitalize }}</h2>
                {% endif %}

                <article class="ag-item">
                    <div class="ag-date">
                        <span class="ag-date__dow">{{ event.beginAt|format_datetime(pattern="EEE", locale='es')|replace({'.': ''}) }}</span>
                        <span class="ag-date__day">{{ event.beginAt|date('j') }}</span>
                        <span class="ag-date__mon">{{ event.beginAt|format_datetime(pattern="MMM", locale='es')|replace({'.': ''}) }}</span>
                    </div>

                    <div class="ag-item__body">
                        {% if event.beginAt|date('H:i') != '00:00' or (event.endAt and event.endAt|date('Y-m-d') != event.beginAt|date('Y-m-d')) %}
                            <div class="ag-item__meta">
                                {%- if event.beginAt|date('H:i') != '00:00' %}{{ event.beginAt|date('H:i') }} h{% endif -%}
                                {%- if event.endAt and event.endAt|date('Y-m-d') != event.beginAt|date('Y-m-d') %}
                                    {% if event.beginAt|date('H:i') != '00:00' %} · {% endif %}hasta el {{ event.endAt|format_datetime(pattern="d 'de' MMMM", locale='es') }}
                                {%- endif -%}
                            </div>
                        {% endif %}
                        <h3 class="ag-item__title">
                            <a href="{{ path('evento_show', { id: event.id }) }}">{{ event.title }}</a>
                        </h3>
                        <p class="ag-item__excerpt">{{ event.content|striptags|u.truncate(160, '…') }}</p>
                        <a class="ag-item__more" href="{{ path('evento_show', { id: event.id }) }}">
                            Ver detalles <i class="fa fa-angle-right"></i>
                        </a>
                    </div>

                    {% if event.image and event.isImage %}
                        <a class="ag-item__media" href="{{ path('evento_show', { id: event.id }) }}">
                            <img src="{{ asset(event.webPath) }}" alt="{{ event.title }}">
                        </a>
                    {% endif %}
                </article>
            {% else %}
                <div class="ag-empty">
                    <h5 class="mb-2">Ahora mismo no hay citas anunciadas</h5>
                    <p class="m-0">Pronto publicaremos nuevas. Mientras tanto, puedes pasarte por el <a href="{{ path('frontend_blog') }}">blog</a>.</p>
                </div>
            {% endfor %}

        </div>
    </div>

{% endblock %}
