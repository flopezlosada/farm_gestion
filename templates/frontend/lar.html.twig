{% extends 'base_front.html.twig' %}

{% block title %}LAR · Laboratorio Agroecológico Rural · CSA Vega de Jarama{% endblock %}

{% block content %}

    {# ---------- Cabecera ---------- #}
    <div class="container py-5">
        <div class="row py-4">
            <div class="col-12 text-center mb-4">
                <h1 class="display-4 mb-3"><span style="color: rgb(248, 177, 51)">LAR</span> <span style="color: #138504">Laboratorio Agroecológico Rural</span></h1>
                <h5 class="text-muted">Espacio de convivencia, encuentro, construcción y transferencia de conocimiento agroecológico.</h5>
            </div>
        </div>

        {# ---------- Descripción + coordinación ---------- #}
        <div class="row">
            <div class="col-lg-8 px-3 px-lg-5">
                {{ page.intro|raw }}
            </div>
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="bg-light p-4 rounded">
                    <h5 class="mb-3" style="color: #138504">Coordinación del LAR</h5>
                    {% if page.coordName %}<p class="mb-1"><i class="fa fa-user mr-2"></i>{{ page.coordName }}</p>{% endif %}
                    {% if page.coordPhone %}<p class="mb-1"><i class="fa fa-phone mr-2"></i>{{ page.coordPhone }}</p>{% endif %}
                    {% if page.coordEmail %}<p class="mb-0"><i class="fa fa-envelope mr-2"></i><a href="mailto:{{ page.coordEmail }}">{{ page.coordEmail }}</a></p>{% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ---------- Proyectos en marcha ---------- #}
    {% if active is not empty %}
        <div class="container-fluid bg-light py-5 px-sm-3 px-md-5">
            <div class="container">
                <h1 class="display-4 mb-4"><span style="color: rgb(248, 177, 51)">Proyectos</span> <span style="color: #138504">en marcha</span></h1>
                <div class="row">
                    {% for project in active %}
                        {% set cover = covers[project.id]|default(null) %}
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="bg-white border rounded h-100 d-flex flex-column overflow-hidden">
                                <a href="{{ path('lar_public_project', { slug: project.slug }) }}" class="d-block position-relative">
                                    {% if cover %}
                                        <img src="{{ asset(cover.webPath) }}" alt="{{ project.title }}" style="width: 100%; height: 200px; object-fit: cover;">
                                    {% else %}
                                        <div style="height: 200px; display: flex; align-items: center; justify-content: center; background: #e8f3e4;">
                                            <i class="fa fa-leaf" style="font-size: 2.5rem; color: #8bbf7f;"></i>
                                        </div>
                                    {% endif %}
                                    <span class="badge badge-success" style="position: absolute; top: 12px; left: 12px; font-size: 90%;">{{ project.typeLabel }}</span>
                                </a>
                                <div class="p-4 d-flex flex-column flex-grow-1">
                                    <h4 class="mb-2" style="color: #138504">{{ project.title }}</h4>
                                    <p class="text-muted flex-grow-1">{{ project.summary }}</p>
                                    <a href="{{ path('lar_public_project', { slug: project.slug }) }}" class="btn btn-outline-success mt-2 align-self-start">Ver más</a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {# ---------- Proyectos anteriores (memoria) ---------- #}
    {% if finished is not empty %}
        <div class="container py-5">
            <h3 class="mb-4 text-muted">Proyectos anteriores</h3>
            <div class="row">
                {% for project in finished %}
                    <div class="col-md-6 col-lg-4 mb-3">
                        <div class="border rounded h-100 p-3">
                            <span class="badge badge-secondary mb-2">{{ project.typeLabel }}</span>
                            <h5 class="mb-1"><a href="{{ path('lar_public_project', { slug: project.slug }) }}" class="text-dark">{{ project.title }}</a></h5>
                            <p class="text-muted small mb-0">{{ project.summary }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# ---------- Oferta formativa ---------- #}
    <div class="container py-5">
        <h1 class="display-4 mb-4"><span style="color: rgb(248, 177, 51)">Formación</span> <span style="color: #138504">e inmersión pedagógica</span></h1>
        <div class="row">
            {% for offer in page.offers %}
                {% if offer.title or offer.body %}
                    <div class="col-md-4 mb-4">
                        <div class="border rounded h-100 p-4">
                            <h5 style="color: #138504">{{ offer.title }}</h5>
                            {% if offer.hours %}<p class="text-muted mb-2"><strong>{{ offer.hours }}</strong></p>{% endif %}
                            <p class="small mb-0">{{ offer.body }}</p>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        <p class="text-muted small mt-2">Las tarifas se adaptan a cada grupo y colectivo, basadas en la economía de la solidaridad y la generosidad. Hay becas para colectivos socialmente vulnerabilizados. Escríbenos y lo acordamos.</p>
    </div>

    {# ---------- Formulario de petición de información ---------- #}
    <div class="container-fluid bg-light py-5 px-sm-3 px-md-5" id="pide-informacion">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <h1 class="display-4 mb-3 text-center"><span style="color: rgb(248, 177, 51)">Pide</span> <span style="color: #138504">información</span></h1>
                    <p class="text-center text-muted mb-4">¿Quieres organizar una visita pedagógica o una estancia de inmersión? Cuéntanos y la coordinación del LAR te responderá.</p>

                    {% for label, messages in app.flashes(['notice', 'error']) %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'notice' ? 'success' : 'danger' }}">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}

                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">{{ form_widget(form.name) }}</div>
                            <div class="col-md-6 mb-3">{{ form_widget(form.email) }}</div>
                            <div class="col-md-6 mb-3">{{ form_widget(form.phone) }}</div>
                            <div class="col-md-6 mb-3">{{ form_widget(form.requestType) }}</div>
                            <div class="col-md-6 mb-3">{{ form_widget(form.groupSize) }}</div>
                            <div class="col-md-6 mb-3">{{ form_widget(form.preferredDates) }}</div>
                            <div class="col-12 mb-3">{{ form_widget(form.body) }}</div>
                        </div>
                        {{ form_widget(form.submit) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>

{% endblock %}
