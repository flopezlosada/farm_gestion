{# ============================================================
 # Nuevx agraciadx — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevx agraciadx{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('recipient') }}">Agraciadxs</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevx</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Regalos',
        'Nuevx agraciadx',
        'Nombre y, si recibe con frecuencia, la cadencia en días entre regalos.'
    ) }}

    {{ form_start(form, {
        'action': path('recipient_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos', subtitle: 'Identidad y cadencia.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.name, 'Nombre', { full: true }) }}
                        {{ csa.field(form.regular, '¿Recibe con frecuencia?') }}
                        {{ csa.field(form.often_buying_eggs, 'Frecuencia en días', { hint: 'sólo si es regular' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('recipient') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear agraciadx',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}
