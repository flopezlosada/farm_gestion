{# ============================================================
 # Panel de control — versión rediseñada (shell csa)
 # ============================================================
 # Mantiene los datos y queries del controller original; sólo
 # cambia la presentación. Patrón coherente con Batch index/show.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Panel de control{% endblock %}

{% block more_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/app/css/morris/morris.css') }}"/>
{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="{{ asset('bundles/app/js/morris/raphael-min.js') }}"></script>
    <script src="{{ asset('bundles/app/js/morris/morris.min.js') }}"></script>
    <script>
        $(function() {
            if (typeof Morris === 'undefined' || !document.getElementById('layweekchart')) {
                return;
            }
            new Morris.Line({
                element: 'layweekchart',
                data: [
                    {% for week in week_lay %}
                    {
                        average: {{ (week.total*(active_hen_batch|length)/week.days)|number_format(2,'.',',') }},
                        week: '{{ week.year_date }}-{{ week.week }}',
                        value: {{ week.total }}
                    }{% if not loop.last %},{% endif %}
                    {% endfor %}
                ],
                xkey: 'week',
                ykeys: ['value', 'average'],
                labels: ['Huevos', 'Media semanal'],
                hideHover: true
            });
        });
    </script>
{% endblock %}

{% block csa_crumbs %}
    <span class="csa-topbar__crumb-active">Inicio</span>
{% endblock %}

{% block csa_main %}

    {% if app.user %}

        {%- set hour = 'now'|date('G') -%}
        {%- set greeting = hour < 14 ? 'Buenos días' : (hour < 21 ? 'Buenas tardes' : 'Buenas noches') -%}
        {%- set lay_week = render(controller('App\\Controller\\DefaultController::layWeek'))|trim -%}
        {%- set production_year = render(controller('App\\Controller\\DefaultController::totalProductionYear'))|trim -%}

        {{ csa.page_header(
            'Panel de control · ' ~ 'now'|date('Y'),
            greeting ~ ', ' ~ app.user.userIdentifier ~ '.',
            'Esto es lo que pasa hoy en la granja.'
        ) }}

        {# ===== KPIs ===== #}
        <div class="csa-kpi-row" style="margin-bottom: var(--csa-sp-10);">
            {{ csa.kpi(
                'Puesta semanal',
                lay_week,
                'huevos',
                lay_week == '0' ? 'Aún sin registrar →' : (total_lay_eggs ~ ' acumulado en ' ~ 'now'|date('Y')),
                null,
                'ochre',
                'fa-egg'
            ) }}
            {{ csa.kpi(
                'Producidos · año',
                production_year|number_format(0, ',', '.'),
                'kg',
                'verduras y hortalizas',
                null,
                'green',
                'fa-leaf'
            ) }}
            {{ csa.kpi(
                'Cultivos en producción',
                render(controller('App\\Controller\\DefaultController::totalCropWorking')),
                null,
                'sectores activos ahora',
                null,
                'sky',
                'fa-seedling'
            ) }}
            {{ csa.kpi(
                'Residuo · año',
                render(controller('App\\Controller\\DefaultController::totalCompost')),
                't',
                'compostaje recogido',
                null,
                'terracotta',
                'fa-recycle'
            ) }}
        </div>

        <div class="csa-dashboard-grid">

            <div class="csa-stack-lg">

                {# ===== Lotes activos: dos cards en paralelo ===== #}
                <div class="csa-dashboard-pair">

                    {# --- Gallinas --- #}
                    {% embed '_components/csa_card.html.twig' with {
                        title: 'Lotes de gallinas',
                        subtitle: active_hen_batch|length ~ ' activos · puesta semanal'
                    } %}
                        {% block body %}
                            {% if active_hen_batch|length > 0 %}
                                <ul class="csa-list">
                                    {% for batch in active_hen_batch %}
                                        <li class="csa-list__item">
                                            <a class="csa-list__link" href="{{ path('batch_show', {'id': batch.id}) }}">
                                                <span class="csa-list__icon csa-list__icon--ochre">
                                                    <i class="fa fa-egg" aria-hidden="true"></i>
                                                </span>
                                                <div class="csa-list__body">
                                                    <div class="csa-list__primary">Lote #{{ batch.id }}</div>
                                                    <div class="csa-list__secondary">
                                                        {{ batch.amount }} {{ batch.product|lower }}
                                                        {%- if batch.purchaseDate %} · desde {{ batch.purchaseDate|date('d-m-Y') }}{% endif %}
                                                    </div>
                                                </div>
                                                <div class="csa-list__metric csa-list__metric--ochre">
                                                    <span class="csa-list__metric-value">{{ batch.weekLay }}</span>
                                                    <span class="csa-list__metric-unit">/ sem</span>
                                                </div>
                                                <i class="csa-list__chevron fa fa-chevron-right" aria-hidden="true"></i>
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="csa-muted">No hay lotes de gallinas activos.</p>
                            {% endif %}
                        {% endblock %}
                    {% endembed %}

                    {# --- Pollos --- #}
                    {% embed '_components/csa_card.html.twig' with {
                        title: 'Lotes de pollos',
                        subtitle: active_chicken_batch|length ~ ' activos · cría para carne'
                    } %}
                        {% block body %}
                            {% if active_chicken_batch|length > 0 %}
                                <ul class="csa-list">
                                    {% for batch in active_chicken_batch %}
                                        <li class="csa-list__item">
                                            <a class="csa-list__link" href="{{ path('batch_show', {'id': batch.id}) }}">
                                                <span class="csa-list__icon csa-list__icon--terracotta">
                                                    <i class="fa fa-feather" aria-hidden="true"></i>
                                                </span>
                                                <div class="csa-list__body">
                                                    <div class="csa-list__primary">Lote #{{ batch.id }}</div>
                                                    <div class="csa-list__secondary">
                                                        {{ batch.product|lower }}
                                                        {%- if batch.purchaseDate %} · desde {{ batch.purchaseDate|date('d-m-Y') }}{% endif %}
                                                    </div>
                                                </div>
                                                <div class="csa-list__metric csa-list__metric--terracotta">
                                                    <span class="csa-list__metric-value">{{ batch.amount }}</span>
                                                    <span class="csa-list__metric-unit">animales</span>
                                                </div>
                                                <i class="csa-list__chevron fa fa-chevron-right" aria-hidden="true"></i>
                                            </a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p class="csa-muted">No hay lotes de pollos activos.</p>
                            {% endif %}
                        {% endblock %}
                    {% endembed %}

                </div>

                {# ===== Gráfica de evolución ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Evolución de la puesta semanal',
                    subtitle: 'Últimas 10 semanas.'
                } %}
                    {% block body %}
                        <div id="layweekchart" style="position: relative; height: 260px;"></div>
                    {% endblock %}
                {% endembed %}

            </div>

            <aside class="csa-stack-lg">

                {# ===== Resumen del año ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Resumen ' ~ 'now'|date('Y'),
                    subtitle: 'al ' ~ ('now'|format_date('long', locale='es'))
                } %}
                    {% block body %}
                        <ul class="csa-list">
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_eggs') }}">
                                    <span class="csa-list__icon csa-list__icon--ochre">
                                        <i class="fa fa-egg" aria-hidden="true"></i>
                                    </span>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Huevos puestos</div>
                                    </div>
                                    <div class="csa-list__metric csa-list__metric--ochre">
                                        <span class="csa-list__metric-value">{{ total_lay_eggs|number_format(0, ',', '.') }}</span>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_user_collect', {'user_id': app.user.id}) }}">
                                    <span class="csa-list__icon csa-list__icon--terracotta">
                                        <i class="fa fa-drumstick-bite" aria-hidden="true"></i>
                                    </span>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg de pollo</div>
                                    </div>
                                    <div class="csa-list__metric csa-list__metric--terracotta">
                                        <span class="csa-list__metric-value">{{ total_chicken|number_format(0, ',', '.') }}</span>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <span class="csa-list__icon csa-list__icon--green">
                                        <i class="fa fa-leaf" aria-hidden="true"></i>
                                    </span>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg de verduras</div>
                                    </div>
                                    <div class="csa-list__metric csa-list__metric--green">
                                        <span class="csa-list__metric-value">{{ render(controller('App\\Controller\\DefaultController::totalProductionYear'))|trim|number_format(0, ',', '.') }}</span>
                                        <span class="csa-list__metric-unit">kg</span>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <span class="csa-list__icon csa-list__icon--ochre">
                                        <i class="fa fa-wheat-awn" aria-hidden="true"></i>
                                    </span>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg de trigo</div>
                                    </div>
                                    <div class="csa-list__metric csa-list__metric--ochre">
                                        <span class="csa-list__metric-value">{{ wheat_year|number_format(0, ',', '.') }}</span>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <span class="csa-list__icon csa-list__icon--sky">
                                        <i class="fa fa-bolt" aria-hidden="true"></i>
                                    </span>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg pienso pollos</div>
                                    </div>
                                    <div class="csa-list__metric csa-list__metric--sky">
                                        <span class="csa-list__metric-value">{{ broiler_feed_year|number_format(0, ',', '.') }}</span>
                                    </div>
                                </a>
                            </li>
                        </ul>
                    {% endblock %}
                {% endembed %}

            </aside>

        </div>

    {% elseif is_granted('ROLE_COMPOST') %}

        {{ csa.page_header(
            'Compostaje',
            'Panel'
        ) }}

        <div class="csa-kpi-row">
            {{ csa.kpi(
                'Residuo recogido',
                render(controller('App\\Controller\\DefaultController::totalCompost')),
                't',
                null, null, 'plum'
            ) }}
        </div>

    {% endif %}

{% endblock %}
