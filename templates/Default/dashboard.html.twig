{# ============================================================
 # Panel de control — versión rediseñada (shell csa)
 # ============================================================
 # Mantiene los datos y queries del controller original; sólo
 # cambia la presentación. Patrón coherente con Batch index/show.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Panel de control{% endblock %}

{% block more_css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/app/css/morris/morris.css') }}"/>
{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script src="{{ asset('bundles/app/js/morris/raphael-min.js') }}"></script>
    <script src="{{ asset('bundles/app/js/morris/morris.min.js') }}"></script>
    <script>
        $(function() {
            if (typeof Morris === 'undefined' || !document.getElementById('layweekchart')) {
                return;
            }
            new Morris.Line({
                element: 'layweekchart',
                data: [
                    {% for week in week_lay %}
                    {
                        average: {{ (week.total*(active_hen_batch|length)/week.days)|number_format(2,'.',',') }},
                        week: '{{ week.year_date }}-{{ week.week }}',
                        value: {{ week.total }}
                    }{% if not loop.last %},{% endif %}
                    {% endfor %}
                ],
                xkey: 'week',
                ykeys: ['value', 'average'],
                labels: ['Huevos', 'Media semanal'],
                hideHover: true
            });
        });
    </script>
{% endblock %}

{% block csa_crumbs %}
    <span class="csa-topbar__crumb-active">Inicio</span>
{% endblock %}

{% block csa_main %}

    {% if is_granted('ROLE_GUEST') %}

        {{ csa.page_header(
            'Día a día · Resumen',
            'Panel de control',
            'Estado general de la cooperativa.'
        ) }}

        {# ===== KPIs ===== #}
        <div class="csa-kpi-row" style="margin-bottom: var(--csa-sp-7);">
            {{ csa.kpi(
                'Puesta semanal',
                render(controller('App\\Controller\\DefaultController::layWeek')),
                'huevos',
                null, null, 'sky'
            ) }}
            {{ csa.kpi(
                'Producción del año',
                render(controller('App\\Controller\\DefaultController::totalProductionYear'))|round,
                'kg',
                null, null, 'green'
            ) }}
            {{ csa.kpi(
                'Cultivos activos',
                render(controller('App\\Controller\\DefaultController::totalCropWorking')),
                null,
                null, null, 'green'
            ) }}
            {{ csa.kpi(
                'Residuo recogido',
                render(controller('App\\Controller\\DefaultController::totalCompost')),
                't',
                null, null, 'plum'
            ) }}
        </div>

        <div style="display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: var(--csa-sp-6); align-items: flex-start;">

            <div class="csa-stack-lg">

                {# ===== Lotes de gallinas activos ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Lotes de gallinas activos',
                    subtitle: 'Puesta de la semana en curso.'
                } %}
                    {% block body %}
                        {% if active_hen_batch|length > 0 %}
                            <ul class="csa-list">
                                {% for batch in active_hen_batch %}
                                    <li class="csa-list__item">
                                        <a class="csa-list__link" href="{{ path('batch_show', {'id': batch.id}) }}">
                                            <i class="csa-list__icon fa fa-egg"></i>
                                            <div class="csa-list__body">
                                                <div class="csa-list__primary">Lote #{{ batch.id }}</div>
                                                <div class="csa-list__secondary">
                                                    {{ batch.getWeekLay }} huevos esta semana
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="csa-muted">No hay lotes de gallinas activos.</p>
                        {% endif %}
                    {% endblock %}
                {% endembed %}

                {# ===== Lotes de pollos activos ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Lotes de pollos activos',
                    subtitle: 'Animales en cría.'
                } %}
                    {% block body %}
                        {% if active_chicken_batch|length > 0 %}
                            <ul class="csa-list">
                                {% for batch in active_chicken_batch %}
                                    <li class="csa-list__item">
                                        <a class="csa-list__link" href="{{ path('batch_show', {'id': batch.id}) }}">
                                            <i class="csa-list__icon fa fa-paw"></i>
                                            <div class="csa-list__body">
                                                <div class="csa-list__primary">Lote #{{ batch.id }}</div>
                                                <div class="csa-list__secondary">
                                                    {{ batch.amount }} animales
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="csa-muted">No hay lotes de pollos activos.</p>
                        {% endif %}
                    {% endblock %}
                {% endembed %}

                {# ===== Gráfica de evolución ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Evolución de la puesta semanal'
                } %}
                    {% block body %}
                        <div id="layweekchart" style="position: relative; height: 250px;"></div>
                    {% endblock %}
                {% endembed %}

            </div>

            <aside class="csa-stack-lg">

                {# ===== Resumen del año ===== #}
                {% embed '_components/csa_card.html.twig' with {
                    title: 'Resumen del año ' ~ 'now'|date('Y')
                } %}
                    {% block body %}
                        <ul class="csa-list">
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_eggs') }}">
                                    <i class="csa-list__icon fa fa-egg"></i>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Huevos puestos</div>
                                        <div class="csa-list__secondary">{{ total_lay_eggs }}</div>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_user_collect', {'user_id': app.user.id}) }}">
                                    <i class="csa-list__icon fa fa-paw"></i>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg de pollo</div>
                                        <div class="csa-list__secondary">{{ total_chicken }}</div>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <i class="csa-list__icon fa fa-leaf"></i>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Kg de verduras</div>
                                        <div class="csa-list__secondary">{{ render(controller('App\\Controller\\DefaultController::totalProductionYear')) }}</div>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <i class="csa-list__icon fa fa-cubes"></i>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Trigo</div>
                                        <div class="csa-list__secondary">{{ wheat_year }} kg</div>
                                    </div>
                                </a>
                            </li>
                            <li class="csa-list__item">
                                <a class="csa-list__link" href="{{ path('statistic_feed') }}">
                                    <i class="csa-list__icon fa fa-bolt"></i>
                                    <div class="csa-list__body">
                                        <div class="csa-list__primary">Pienso de pollos</div>
                                        <div class="csa-list__secondary">{{ broiler_feed_year }} kg</div>
                                    </div>
                                </a>
                            </li>
                        </ul>
                    {% endblock %}
                {% endembed %}

            </aside>

        </div>

    {% elseif is_granted('ROLE_COMPOST') %}

        {{ csa.page_header(
            'Compostaje',
            'Panel'
        ) }}

        <div class="csa-kpi-row">
            {{ csa.kpi(
                'Residuo recogido',
                render(controller('App\\Controller\\DefaultController::totalCompost')),
                't',
                null, null, 'plum'
            ) }}
        </div>

    {% endif %}

{% endblock %}
