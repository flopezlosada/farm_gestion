{# ============================================================
 # Editar nota de tarea — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar nota #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    {% if entity.task %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('task_show', { id: entity.task.id }) }}">{{ entity.task }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('tasknote_show', { id: entity.id }) }}">Nota #{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Tareas · Notas',
        'Editar nota #' ~ entity.id,
        entity.task ? ('Para la tarea: ' ~ entity.task) : 'Corrige el contenido de la nota.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'tasknote-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('tasknote_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Contenido', subtitle: 'Texto enriquecido (negritas, listas, enlaces).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.content, 'Contenido', { full: true, attr: { class: 'tinymce', 'data-theme': 'advanced' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="submit" form="tasknote-delete-form" class="csa-btn csa-btn--ghost"
                            onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                        Eliminar nota
                    </button>
                </div>
                <div class="csa-row">
                    {% if entity.task %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('task_show', { id: entity.task.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('tasknote_show', { id: entity.id }) }) }}
                    {% endif %}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
