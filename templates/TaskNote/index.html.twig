{# ============================================================
 # Listado de notas de tareas (TaskNote).
 #
 # En la práctica las notas se acceden desde Task/show. Esta vista
 # global existe pero es secundaria.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Notas de tareas{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Notas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Tareas · Notas',
        'Notas de tareas',
        'Comentarios o anotaciones añadidos a las tareas.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Id</th>
                    <th>Contenido</th>
                    <th class="csa-table__col-tight">Creado</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <a class="csa-table__primary" href="{{ path('tasknote_show', { id: entity.id }) }}">#{{ entity.id }}</a>
                        </td>
                        <td>{{ entity.content|striptags|slice(0, 140) }}{% if entity.content|striptags|length > 140 %}…{% endif %}</td>
                        <td class="csa-table__col-tight">
                            {% if entity.created %}{{ entity.created|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('tasknote_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('tasknote_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay notas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
