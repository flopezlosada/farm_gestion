{# ============================================================
 # Nueva nota de tarea — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva nota{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    {% if entity.task %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('task_show', { id: entity.task.id }) }}">{{ entity.task }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva nota</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Tareas · Notas',
        'Nueva nota',
        entity.task ? ('Para la tarea: ' ~ entity.task) : 'Añade un comentario o anotación a la tarea.'
    ) }}

    {{ form_start(form, {
        'action': path('tasknote_create', { task_id: entity.getTask.id }),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Contenido', subtitle: 'Texto enriquecido (negritas, listas, enlaces).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.content, 'Contenido', { full: true, attr: { class: 'tinymce', 'data-theme': 'advanced' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {% if entity.task %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('task_show', { id: entity.task.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('task') }) }}
                    {% endif %}
                    {{ form_widget(form.submit, {
                        label: 'Crear nota',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
