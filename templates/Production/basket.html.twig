{# ============================================================
 # Cestas semanales — tarjetas en dos columnas.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cestas semanales {{ year }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span>Granja</span>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cestas {{ year }}</span>
{% endblock %}

{% block csa_main %}

    {% set total_year = render(controller('App\\Controller\\DefaultController::totalProductionYear', { year: year }))|round %}

    {{ csa.page_header(
        'Granja · Huerta · ' ~ year,
        'Cestas semanales',
        total_year ~ ' kg recogidos · ' ~ baskets|length ~ ' semana' ~ (baskets|length != 1 ? 's' : '') ~ ' con cosecha'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6);">
        <form method="get" action="{{ path('production_show_basket', { year: year }) }}" class="csa-row" style="gap: var(--csa-sp-2);">
            <label for="basket-year" class="csa-muted">Ver año:</label>
            <select id="basket-year" class="csa-input" style="width: auto;"
                    onchange="window.location.href='{{ path('production_show_basket', { year: 'YEAR' })|raw }}'.replace('YEAR', this.value)">
                {% set years = year in years_available ? years_available : [year]|merge(years_available) %}
                {% for y in years %}
                    <option value="{{ y }}" {% if y == year %}selected{% endif %}>{{ y }}</option>
                {% endfor %}
            </select>
        </form>
        <div class="csa-row">
            {{ csa.btn('Registrar cosecha', { variant: 'primary', href: path('production_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    {% if baskets|length > 0 %}

        <ul class="csa-baskets">
            {% for week, basket in baskets %}

                {% set total = 0 %}
                {% for production in basket %}{% set total = total + production.amount %}{% endfor %}

                {% set sorted = basket|sort((a, b) => b.amount <=> a.amount) %}
                {% set top = sorted|slice(0, 3) %}
                {% set extras = basket|length - top|length %}

                {# Temporada → color sutil + icono decorativo #}
                {% if week >= 10 and week <= 22 %}
                    {% set season = 'spring' %}{% set season_icon = 'fa-leaf' %}
                {% elseif week >= 23 and week <= 39 %}
                    {% set season = 'summer' %}{% set season_icon = 'fa-sun-o' %}
                {% elseif week >= 40 and week <= 50 %}
                    {% set season = 'autumn' %}{% set season_icon = 'fa-pagelines' %}
                {% else %}
                    {% set season = 'winter' %}{% set season_icon = 'fa-snowflake-o' %}
                {% endif %}

                <li class="csa-baskets__item">
                    <a href="{{ path('production_show_basket_detail', { id: basket[0].getBasket.id }) }}"
                       class="csa-baskets__card csa-baskets__card--{{ season }}">

                        <i class="csa-baskets__season fa {{ season_icon }}" aria-hidden="true"></i>

                        <header class="csa-baskets__head">
                            <span class="csa-baskets__num">{{ week }}</span>
                            <div class="csa-baskets__when">
                                <div class="csa-baskets__week-label">Semana {{ week }}</div>
                                <div class="csa-baskets__date">{{ getDateFromWeek(year, week) }}</div>
                            </div>
                        </header>

                        <div class="csa-baskets__weight">
                            <span class="csa-baskets__weight-num">{{ total|number_format(0, ',', '.') }}</span>
                            <span class="csa-baskets__weight-unit">kg recogidos</span>
                        </div>

                        <p class="csa-baskets__cultivos">
                            {%- for production in top -%}
                                {{ production.cropworking ? production.cropworking.getName : '?' }}{% if not loop.last or extras > 0 %} · {% endif %}
                            {%- endfor -%}
                            {% if extras > 0 %}
                                <span class="csa-baskets__extras">y {{ extras }} más</span>
                            {% endif %}
                        </p>

                        <footer class="csa-baskets__foot">
                            <span class="csa-baskets__count">{{ basket|length }} cosechas</span>
                            <span class="csa-baskets__cta">
                                Abrir
                                <i class="fa fa-arrow-right" aria-hidden="true"></i>
                            </span>
                        </footer>

                    </a>
                </li>

            {% endfor %}
        </ul>

    {% else %}
        <div class="csa-baskets-empty">
            Sin cosechas registradas en {{ year }}.
        </div>
    {% endif %}

{% endblock %}
