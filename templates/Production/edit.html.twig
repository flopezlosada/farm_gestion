{# ============================================================
 # Editar producción/cosecha (Production) — shell csa.
 # ============================================================
 # El controller convierte production_date a YYYY-MM-DD antes
 # de renderizar y vuelve a DateTime tras el submit.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar cosecha · {{ entity.cropWorking }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('production_show_basket') }}">Cestas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    {% if entity.basket %}
        <a href="{{ path('production_show_basket_detail', { id: entity.basket.id }) }}">Semana {{ entity.basket.week }}</a>
        <span class="csa-topbar__crumbs-sep">/</span>
    {% endif %}
    <span class="csa-topbar__crumb-active">Editar cosecha</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cosecha',
        'Editar cosecha',
        'Actualiza la fecha o la cantidad. La cesta de la semana se recalcula al guardar.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'production-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('production_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Cosecha', subtitle: 'Cultivo, fecha y cantidad recogida.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.crop_working, 'Cultivo', { full: true }) }}
                        {{ csa.field(edit_form.production_date, 'Fecha de cosecha', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(edit_form.amount, 'Cantidad', { hint: 'kg' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Anotaciones', subtitle: 'Observaciones libres sobre la cosecha.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Anotaciones', hint: 'opcional', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.note, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="submit" form="production-delete-form" class="csa-btn csa-btn--ghost"
                            onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                        Eliminar cosecha
                    </button>
                </div>
                <div class="csa-row">
                    {% if entity.basket %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('production_show_basket_detail', { id: entity.basket.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('production_show_basket') }) }}
                    {% endif %}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    <script>
        document.querySelectorAll('.datepicker')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
