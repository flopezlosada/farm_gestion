{# ============================================================
 # Editar siembra/plantación (SeedWork) — migrado al shell csa.
 # ============================================================
 # El controller convierte estimatedDate/realDate a YYYY-MM-DD
 # antes de renderizar para que el input date nativo lo acepte.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar siembra · {{ entity.cropWorking }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking') }}">Cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    {% if entity.cropWorking %}
        <a href="{{ path('cropworking_show', { id: entity.cropWorking.id }) }}">{{ entity.cropWorking }}</a>
        <span class="csa-topbar__crumbs-sep">/</span>
    {% endif %}
    <span class="csa-topbar__crumb-active">Editar siembra</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Siembra',
        'Editar siembra',
        'Actualiza los datos del registro de siembra/plantación.'
    ) }}

    {# delete_form oculto fuera del edit_form para no anidar #}
    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'seedwork-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('seedwork_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Tipo de siembra y cultivo asociado.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.seed_work_type, 'Tipo') }}
                        {{ csa.field(edit_form.crop_working, 'Cultivo') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Fechas', subtitle: 'Cuándo se previó y cuándo se hizo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.estimated_date, 'Fecha prevista', { attr: { class: 'csa-input datepicker2' } }) }}
                        {{ csa.field(edit_form.real_date, 'Fecha real', { attr: { class: 'csa-input datepicker' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Cantidades y ubicación', subtitle: 'Plantas, bandejas, superficie y sector.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.plant, 'Número de plantas') }}
                        {{ csa.field(edit_form.tray, 'Número de bandejas') }}
                        {{ csa.field(edit_form.surface, 'Superficie', { hint: 'm²' }) }}
                        {{ csa.field(edit_form.sector, 'Sector') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '4', title: 'Observaciones', subtitle: 'Información libre sobre la siembra.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Observaciones', hint: 'opcional', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.content, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-seedwork-delete').showModal()">
                        Eliminar siembra
                    </button>
            {{ csa.confirm_dialog('confirm-seedwork-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'seedwork-delete-form',
            }) }}
                </div>
                <div class="csa-row">
                    {% if entity.cropWorking %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('cropworking_show', { id: entity.cropWorking.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('seedwork') }) }}
                    {% endif %}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
