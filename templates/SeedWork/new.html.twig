{# ============================================================
 # Nueva siembra/plantación (SeedWork) — migrado al shell csa.
 # ============================================================
 # El crop_working viene preseleccionado desde la URL. Las fechas
 # se renderizan como <input type="date"> nativo (mismo formato
 # YYYY-MM-DD que ya manejaba el controller).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva siembra · {{ crop_working }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking') }}">Cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('cropworking_show', { id: crop_working.id }) }}">{{ crop_working }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva siembra</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cultivo · ' ~ crop_working,
        'Registrar siembra/plantación',
        'Anota una siembra en semillero, siembra directa o plantación dentro del ciclo del cultivo.'
    ) }}

    {{ form_start(form, {
        'action': path('seedwork_create', { crop_working_id: crop_working.id }),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {# ---- 1. Tipo y cultivo ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Tipo de siembra y cultivo asociado.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.seed_work_type, 'Tipo') }}
                        {{ csa.field(form.crop_working, 'Cultivo') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 2. Fechas ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Fechas', subtitle: 'Cuándo se previó y cuándo se hizo.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.estimated_date, 'Fecha prevista', { attr: { class: 'csa-input datepicker2' } }) }}
                        {{ csa.field(form.real_date, 'Fecha real', { attr: { class: 'csa-input datepicker' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 3. Cantidades y ubicación ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Cantidades y ubicación', subtitle: 'Plantas, bandejas, superficie y sector.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.plant, 'Número de plantas') }}
                        {{ csa.field(form.tray, 'Número de bandejas') }}
                        {{ csa.field(form.surface, 'Superficie', { hint: 'm²' }) }}
                        {{ csa.field(form.sector, 'Sector') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# ---- 4. Observaciones ---- #}
            {% embed '_components/csa_form_section.html.twig' with { num: '4', title: 'Observaciones', subtitle: 'Información libre sobre la siembra.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Observaciones', hint: 'opcional', full: true } %}
                        {% block body %}
                            {{ form_widget(form.content, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('cropworking_show', { id: crop_working.id }) }) }}
                    {{ form_widget(form.submit, {
                        label: 'Registrar siembra',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    {# Convertimos los inputs con clase datepicker* a <input type="date">
     # nativo. El FormType es TextType y el controller lo trata como
     # string YYYY-MM-DD (mismo formato que el date picker nativo emite). #}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
