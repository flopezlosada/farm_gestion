{# ============================================================
 # Listado de siembras (SeedWork) — migrado al shell csa.
 # ============================================================
 # Vista global de todas las siembras/plantaciones registradas
 # en el sistema. El alta se hace desde un CropWorking concreto
 # (ahí sí tiene contexto), no desde aquí.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Siembras / plantaciones{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span>Granja</span>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Siembras</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Siembras / plantaciones',
        'Histórico de siembras y plantaciones en todos los ciclos. Para añadir una nueva, abre el cultivo correspondiente.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Cultivo</th>
                    <th class="csa-table__col-tight">Fecha real</th>
                    <th class="csa-table__col-tight">Fecha prevista</th>
                    <th class="csa-table__col-tight">Plantas</th>
                    <th class="csa-table__col-tight">Bandejas</th>
                    <th class="csa-table__col-tight">Superficie</th>
                    <th class="csa-table__col-tight">Sector</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>{{ entity.seedWorkType }}</td>
                        <td>
                            {% if entity.cropWorking %}
                                <a href="{{ path('cropworking_show', { id: entity.cropWorking.id }) }}">{{ entity.cropWorking }}</a>
                            {% else %}
                                <span class="csa-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.realDate %}{{ entity.realDate|format_date('medium', locale='es') }}{% else %}<span class="csa-muted">—</span>{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.estimatedDate %}{{ entity.estimatedDate|format_date('medium', locale='es') }}{% else %}<span class="csa-muted">—</span>{% endif %}
                        </td>
                        <td class="csa-table__col-tight">{{ entity.plant ?: '—' }}</td>
                        <td class="csa-table__col-tight">{{ entity.tray ?: '—' }}</td>
                        <td class="csa-table__col-tight">{% if entity.surface %}{{ entity.surface }} m²{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.sector ?: '—' }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('seedwork_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay siembras registradas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
