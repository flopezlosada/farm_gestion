{# ============================================================
 # Nuevo evento — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo evento{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('event') }}">Eventos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Eventos',
        'Nuevo evento',
        'Título, descripción y rango de fechas.'
    ) }}

    {{ form_start(form, {
        'action': path('event_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Título y descripción.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.title, 'Título', { full: true }) }}
                        {{ csa.field(form.content, 'Descripción', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Fechas', subtitle: 'Cuándo empieza y termina el evento.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.start_date, 'Fecha de inicio', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.end_date, 'Fecha de fin', { hint: 'opcional', attr: { class: 'csa-input datepicker2' } }) }}
                        {{ csa.field(form.all_day_event, '¿Todo el día?', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('event') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear evento',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
