{# ============================================================
 # Listado de eventos públicos (Event).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Eventos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Eventos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Eventos',
        'Eventos',
        'Citas y actos visibles en el calendario del sitio.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo evento', { variant: 'primary', href: path('event_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Título</th>
                    <th class="csa-table__col-tight">Inicio</th>
                    <th class="csa-table__col-tight">Fin</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('event_show', { id: entity.id }) }}">{{ entity.title }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.startdate %}{{ entity.startdate|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.enddate %}{{ entity.enddate|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('event_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('event_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay eventos registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
