{# ============================================================
 # Detalle de una pila de compost — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Pila #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostcollection') }}">Recogida de compost</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('compostpile') }}">Pilas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'compostpile-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-cubes"></i>
            </span>
            <div>
                <h1>Pila #{{ entity.id }}</h1>
                <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                    {% if entity.endDate %}
                        Cerrada el {{ entity.endDate|format_date('long', locale='es') }}
                    {% else %}
                        Activa desde el {{ entity.startDate|format_date('long', locale='es') }}
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="csa-row">
            <button type="submit" form="compostpile-delete-form" class="csa-btn csa-btn--ghost"
                    onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                Eliminar
            </button>
            {{ csa.btn('Editar', { variant: 'secondary', href: path('compostpile_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('compostpile') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos de la pila', accent: 'green' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha de inicio</dt>
                    <dd class="csa-defs__value">{{ entity.startDate|format_date('long', locale='es') }}</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha de cierre</dt>
                    <dd class="csa-defs__value">
                        {% if entity.endDate %}
                            {{ entity.endDate|format_date('long', locale='es') }}
                        {% else %}
                            <span class="csa-badge csa-badge--green">Pila activa</span>
                        {% endif %}
                    </dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Total acumulado</dt>
                    <dd class="csa-defs__value">{{ entity.getAmount|default(0) }} kg</dd>
                </div>
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
