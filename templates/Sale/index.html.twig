{# ============================================================
 # Listado de ventas (Sale).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Ventas{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Ventas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Ventas',
        'Ventas',
        'Registro de productos vendidos a clientxs. Cada venta indica si está pagada o pendiente de cobro.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nueva venta', { variant: 'primary', href: path('sale_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Clientx</th>
                    <th>Producto</th>
                    <th class="csa-table__col-tight">Cantidad</th>
                    <th class="csa-table__col-tight">Total</th>
                    <th class="csa-table__col-tight">¿Pagada?</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <a class="csa-table__primary" href="{{ path('sale_show', { id: entity.id }) }}">{{ entity.getSaleDate|format_date('medium', locale='es') }}</a>
                        </td>
                        <td>
                            {% if entity.getPurchaser %}
                                <a href="{{ path('purchaser_show', { id: entity.getPurchaser.id }) }}">{{ entity.Purchaser }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>{% if entity.getProduct %}<a href="{{ path('product_show', { id: entity.getProduct.id }) }}">{{ entity.Product }}</a>{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.amount }}{% if entity.Unity %} {{ entity.Unity }}{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.totalprice }} €</td>
                        <td class="csa-table__col-tight">
                            {% if entity.paid %}
                                <span class="csa-badge csa-badge--green">Sí</span>
                            {% else %}
                                <span class="csa-badge csa-badge--terracotta">No</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('sale_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('sale_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay ventas registradas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
