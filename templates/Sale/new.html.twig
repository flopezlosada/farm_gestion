{# ============================================================
 # Nueva venta — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva venta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('sale') }}">Ventas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Ventas',
        'Nueva venta',
        'Anota la fecha, a quién se vende y el producto. El precio total se calcula al guardar.'
    ) }}

    {{ form_start(form, {
        'action': path('sale_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Cuándo y a quién', subtitle: 'Fecha y clientx.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.sale_date, 'Fecha de venta', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.purchaser, 'Clientx') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Qué y cuánto', subtitle: 'Producto, cantidad y precio unitario.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.product, 'Producto vendido', { full: true }) }}
                        {{ csa.field(form.amount, 'Cantidad') }}
                        {{ csa.field(form.unity, 'Unidades') }}
                        {{ csa.field(form.single_price, 'Precio por unidad (€)', { hint: 'se multiplica por la cantidad' }) }}
                        {{ csa.field(form.paid, '¿Pagada?') }}
                        {{ csa.field(form.note, 'Notas', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('sale') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear venta',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
