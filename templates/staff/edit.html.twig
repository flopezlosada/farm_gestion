{# Editar trabajador — shell csa. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Editar {{ worker.name }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_show', { id: worker.id }) }}">{{ worker.name }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Personal', 'Editar trabajador', worker.name) }}

    {{ include('staff/_form.html.twig', { submit_label: 'Guardar cambios', cancel_path: path('staff_show', { id: worker.id }) }) }}
{% endblock %}
