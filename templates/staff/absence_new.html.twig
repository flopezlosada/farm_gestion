{# Registrar ausencia (vacaciones/baja/permiso) — supervisor. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Registrar ausencia · {{ worker.name }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_show', { id: worker.id }) }}">{{ worker.name }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Ausencia</span>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Personal · ' ~ worker.name, 'Registrar ausencia', 'Vacaciones, baja o permiso. Queda aprobada directamente.') }}

    {% form_theme form 'form_div_layout.html.twig' %}
    {{ form_start(form, { attr: { class: 'csa-form-narrow' } }) }}
        <div class="csa-stack-lg">
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Ausencia', subtitle: 'Tipo y fechas (ambos días incluidos).' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.type, 'Tipo') }}
                        {{ csa.field(form.startDate, 'Desde') }}
                        {{ csa.field(form.endDate, 'Hasta') }}
                        {{ csa.field(form.note, 'Comentario', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('staff_show', { id: worker.id }) }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Registrar ausencia</button>
                </div>
            </div>
        </div>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}
