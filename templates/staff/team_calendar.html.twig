{# Calendario del equipo: ausencias de todos los trabajadores en el mes. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Personal · Calendario del equipo{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Calendario del equipo</span>
{% endblock %}

{% block more_css %}
    {{ parent() }}
    <style>
        .tm-nav { display: flex; align-items: center; gap: var(--csa-sp-3); margin-bottom: var(--csa-sp-4); }
        .tm-nav__title { font-size: var(--csa-fs-lg); font-weight: 600; text-transform: capitalize; min-width: 11rem; text-align: center; }
        .tm-wrap { overflow-x: auto; border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-lg); background: var(--csa-surface); }
        .tm { border-collapse: collapse; }
        .tm th, .tm td { text-align: center; font-size: .72rem; padding: 0; font-variant-numeric: tabular-nums; }
        .tm__name { text-align: left; padding: .5rem .8rem; white-space: nowrap; position: sticky; left: 0; background: var(--csa-surface); font-weight: 500; min-width: 9rem; z-index: 1; border-right: 1px solid var(--csa-rule); }
        .tm__dh { padding: .3rem 0; color: var(--csa-ink-muted); width: 1.7rem; line-height: 1.2; }
        .tm__dh small { display: block; font-size: .6rem; }
        .tm__dh--today { color: var(--csa-ink); font-weight: 700; }
        .tm__cell { height: 1.9rem; border-left: 1px solid var(--csa-rule-soft); }
        .tm__dh--we, .tm__cell--we   { background: var(--csa-bg); }
        .tm__dh--hol, .tm__cell--hol { background: var(--csa-plum-soft); }
        .tm__cell--vac  { background: var(--csa-green-soft); }
        .tm__cell--per  { background: var(--csa-sky-soft); }
        .tm__cell--baja { background: var(--csa-terracotta-soft); }
        .tm__cell--other{ background: var(--csa-bg); }
        .tm__cell--pending { opacity: .45; }
        .tm-legend { display: flex; flex-wrap: wrap; gap: var(--csa-sp-2) var(--csa-sp-4); margin-top: var(--csa-sp-4); font-size: .8rem; color: var(--csa-ink-soft); }
        .tm-legend span { display: inline-flex; align-items: center; gap: .4rem; }
        .tm-legend i { width: .9rem; height: .9rem; border-radius: 3px; display: inline-block; }
        .tm-sw--vac{background:var(--csa-green-soft)} .tm-sw--per{background:var(--csa-sky-soft)} .tm-sw--baja{background:var(--csa-terracotta-soft)} .tm-sw--hol{background:var(--csa-plum-soft)}
    </style>
{% endblock %}

{% block csa_main %}
    {% set month_names = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'] %}
    {% set wdl = ['L','M','X','J','V','S','D'] %}
    {% set tcls = { vacation: 'tm__cell--vac', permit: 'tm__cell--per', sick_leave: 'tm__cell--baja' } %}

    {{ csa.page_header('Personal', 'Calendario del equipo', 'Vacaciones y ausencias de todo el equipo en el mes. Para ver solapes y planificar.') }}

    <div class="tm-nav">
        {{ csa.btn('', { variant: 'ghost', icon: 'fa-chevron-left', href: path('staff_team_calendar', { year: prev|date('Y'), month: prev|date('n') }) }) }}
        <div class="tm-nav__title">{{ month_names[(month_label|date('n')) - 1] }} {{ month_label|date('Y') }}</div>
        {{ csa.btn('', { variant: 'ghost', icon: 'fa-chevron-right', href: path('staff_team_calendar', { year: next|date('Y'), month: next|date('n') }) }) }}
    </div>

    <div class="tm-wrap">
        <table class="tm">
            <thead>
                <tr>
                    <th class="tm__name">Trabajador</th>
                    {% for d in days %}
                        <th class="tm__dh{{ d.weekend ? ' tm__dh--we' : '' }}{{ d.holiday ? ' tm__dh--hol' : '' }}{{ d.today ? ' tm__dh--today' : '' }}"
                            {% if d.holiday %}title="{{ d.holiday }}"{% endif %}>
                            {{ d.day }}<small>{{ wdl[(d.ymd|date('N')) - 1] }}</small>
                        </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    <tr>
                        <td class="tm__name">{{ row.worker.name }}</td>
                        {% for d in days %}
                            {% set a = row.days[d.ymd] ?? null %}
                            {% set cls = 'tm__cell' %}
                            {% if a %}
                                {% set cls = cls ~ ' ' ~ (tcls[a.type]|default('tm__cell--other')) ~ (a.status == 'approved' ? '' : ' tm__cell--pending') %}
                            {% elseif d.holiday %}{% set cls = cls ~ ' tm__cell--hol' %}
                            {% elseif d.weekend %}{% set cls = cls ~ ' tm__cell--we' %}{% endif %}
                            <td class="{{ cls }}"{% if a %} title="{{ row.worker.name }}: {{ a.status == 'approved' ? 'aprobada' : 'pendiente' }}"{% endif %}></td>
                        {% endfor %}
                    </tr>
                {% else %}
                    <tr><td class="tm__name" colspan="{{ days|length + 1 }}" style="text-align:center;color:var(--csa-ink-muted);padding:var(--csa-sp-6);">No hay trabajadores activos.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="tm-legend">
        <span><i class="tm-sw--vac"></i> Vacaciones</span>
        <span><i class="tm-sw--per"></i> Permiso</span>
        <span><i class="tm-sw--baja"></i> Baja</span>
        <span><i class="tm-sw--hol"></i> Festivos</span>
        <span style="color:var(--csa-ink-muted);">· pálido = pendiente · sólido = aprobada</span>
    </div>
{% endblock %}
