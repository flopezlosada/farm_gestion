{# Estilos del calendario mensual (supervisor y trabajador). #}
<style>
    .cal-nav { display:flex; align-items:center; gap:1rem; margin-bottom:1rem; }
    .cal-nav__title { font-size:1.2rem; font-weight:700; text-transform:capitalize; min-width:200px; text-align:center; }
    .cal-grid { width:100%; border-collapse:collapse; table-layout:fixed; background:var(--csa-surface); border:1px solid var(--csa-rule); border-radius:var(--csa-radius-lg); overflow:hidden; }
    .cal-grid th { font-size:.75rem; text-transform:uppercase; letter-spacing:.03em; color:var(--csa-ink-muted); padding:.5rem; border-bottom:1px solid var(--csa-rule-soft); text-align:center; }
    .cal-cell { height:84px; vertical-align:top; border:1px solid var(--csa-rule-soft); padding:0; }
    .cal-cell a, .cal-cell span.cal-day-wrap { display:block; height:100%; padding:.4rem .5rem; text-decoration:none; color:inherit; }
    .cal-cell a:hover { background:var(--csa-surface-alt); }
    .cal-cell--out { background:var(--csa-surface-alt); color:var(--csa-ink-muted); }
    .cal-cell--weekend { background:var(--csa-surface-alt); }
    .cal-cell--today { outline:2px solid var(--csa-green); outline-offset:-2px; }
    .cal-num { font-size:.85rem; font-weight:600; }
    .cal-span { margin-top:.4rem; font-size:.8rem; color:var(--csa-ink-soft); font-variant-numeric:tabular-nums; }
    .cal-total { margin-top:.15rem; font-size:.95rem; font-weight:700; color:var(--csa-green); font-variant-numeric:tabular-nums; }
    .cal-badge { margin-top:.5rem; display:inline-block; font-size:.72rem; font-weight:600; border-radius:var(--csa-radius-sm); padding:.1rem .4rem; }
    .cal-badge--gap { background:var(--csa-ochre-soft); color:var(--csa-amber); }
    .cal-badge--abs { background:var(--csa-sky-soft); color:var(--csa-sky); }
    .cal-badge--warn { background:var(--csa-terracotta-soft); color:#9b1c1c; }
    .cal-badge--holiday { background:var(--csa-plum-soft); color:var(--csa-plum); }

    /* Móvil: el grid de 7 columnas es estrecho; celdas más bajas, números más
       pequeños y se oculta la franja horaria (se conserva el total). */
    @media (max-width: 560px) {
        .cal-nav__title { min-width:0; font-size:1.05rem; }
        .cal-cell { height:60px; }
        .cal-cell a, .cal-cell span.cal-day-wrap { padding:.25rem .3rem; }
        .cal-grid th { padding:.3rem .1rem; font-size:.62rem; }
        .cal-num { font-size:.75rem; }
        .cal-span { display:none; }
        .cal-total { font-size:.8rem; }
        .cal-badge { font-size:.6rem; padding:.05rem .25rem; }
    }
</style>
