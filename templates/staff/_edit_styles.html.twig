{# Estilos compartidos del registro de jornada y sus controles de edición
 # (ficha y vista de día). #}
<style>
    .stf-reg { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: visible; }
    .stf-day { border-bottom: 1px solid #eef0f2; }
    .stf-day:last-child { border-bottom: none; }
    .stf-day__head { padding: .6rem 1rem; font-weight: 600; background: #fafaf8; text-transform: capitalize; }
    .stf-pun { display: flex; align-items: center; gap: .7rem; padding: .55rem 1rem; }
    .stf-pun__icon { width: 26px; height: 26px; border-radius: 50%; display: grid; place-items: center; color: #fff; flex: none; font-size: .8rem; }
    .stf-pun__icon--in  { background: #2f8f4e; }
    .stf-pun__icon--out { background: #b4632b; }
    .stf-pun__time { font-variant-numeric: tabular-nums; }
    .stf-late { font-size: .7rem; font-weight: 600; color: #92400e; background: #fef3c7; border-radius: 999px; padding: .1rem .5rem; }
    .stf-reg-empty { padding: 2rem 1rem; text-align: center; color: #9ca3af; }

    /* Edición inline de la hora de un fichaje (estilo Factorial). */
    .pun { display: inline-flex; align-items: center; gap: .4rem; }
    .pun__view, .pun__edit { display: inline-flex; align-items: center; gap: .3rem; }
    .pun__btn { border: none; background: none; cursor: pointer; padding: .2rem .35rem; border-radius: 6px; color: #9ca3af; font-size: .78rem; line-height: 1; }
    .pun__btn:hover { background: #f3f4f6; }
    .pun__pen:hover { color: #2f6f43; }
    .pun__ok { color: #2f8f4e; }
    .pun__ok:hover { background: #e7f3ea; color: #226c39; }
    .pun__cancel:hover { color: #6b7280; }
    .pun__del { color: #b4632b; }
    .pun__del:hover { background: #fbe8dd; color: #9b1c1c; }
    .pun__input { font-size: .9rem; padding: .2rem .35rem; border: 1px solid #2f8f4e; border-radius: 6px; font-variant-numeric: tabular-nums; }
    .pun [hidden] { display: none !important; }

    /* Controles de corrección por fichaje (details inline). */
    .stf-edit { display: inline-block; position: relative; }
    .stf-edit > summary { list-style: none; cursor: pointer; display: inline-flex; align-items: center; gap: .4rem; padding: .15rem .4rem; border-radius: 8px; }
    .stf-edit > summary::-webkit-details-marker { display: none; }
    .stf-edit > summary:hover { background: #f3f4f6; }
    .stf-edit__pen { font-size: .72rem; color: #9ca3af; }
    .stf-edit[open] > summary .stf-edit__pen { color: #2f6f43; }
    .stf-edit__panel { position: absolute; z-index: 10; margin-top: .4rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,.1); padding: .9rem; min-width: 260px; }
    .stf-edit__form { display: flex; flex-direction: column; gap: .5rem; margin-bottom: .6rem; }
    .stf-edit__form label { display: flex; flex-direction: column; font-size: .78rem; color: #6b7280; gap: .2rem; }
    .stf-edit__form input, .stf-edit__form select { font-size: .9rem; padding: .35rem .5rem; border: 1px solid #d1d5db; border-radius: 6px; }
    .stf-edit__void-reason { margin-bottom: .4rem; width: 100%; }
    .stf-add { margin-top: 1.4rem; }
    .stf-add > summary { cursor: pointer; color: #2f6f43; font-weight: 600; }

    /* Fila compacta para añadir un fichaje olvidado (sin motivo: lo pone el backend). */
    .stf-addrow { display: flex; flex-wrap: wrap; align-items: flex-end; gap: .7rem; margin-top: .9rem; }
    .stf-addrow label { display: flex; flex-direction: column; font-size: .75rem; color: #6b7280; gap: .25rem; }
    .stf-addrow select, .stf-addrow input { font-size: .9rem; padding: .4rem .5rem; border: 1px solid #d1d5db; border-radius: 6px; }
    .stf-addrow .csa-btn { white-space: nowrap; }

    /* Aviso de jornada descuadrada / incompleta. */
    .day-warn { display:flex; align-items:flex-start; gap:.6rem; padding:.8rem 1rem; border-radius:10px; margin-bottom:1.2rem; font-size:.9rem; line-height:1.4; }
    .day-warn i { margin-top:.15rem; }
    .day-warn--bad  { background:#fde2e2; color:#9b1c1c; }
    .day-warn--warn { background:#fef3c7; color:#92400e; }
    .day-warn--info { background:#e0f2fe; color:#075985; }
</style>

{# Edición inline de la hora: el lápiz abre el input, Enter o el tick guardan
 # (submit nativo del form), Esc o la ✕ cierran, la papelera anula. Delegado,
 # se monta una vez por página. #}
<script>
(function () {
    function closePun(pun) {
        var view = pun.querySelector('[data-pun-view]');
        var form = pun.querySelector('[data-pun-edit-form]');
        var del = pun.querySelector('[data-pun-void]');
        if (view) { view.hidden = false; }
        if (form) { form.hidden = true; }
        if (del) { del.hidden = true; }
    }

    document.addEventListener('click', function (e) {
        var editBtn = e.target.closest('[data-pun-edit]');
        if (editBtn) {
            var pun = editBtn.closest('[data-pun]');
            document.querySelectorAll('[data-pun]').forEach(function (other) {
                if (other !== pun) { closePun(other); }
            });
            pun.querySelector('[data-pun-view]').hidden = true;
            pun.querySelector('[data-pun-edit-form]').hidden = false;
            var del = pun.querySelector('[data-pun-void]');
            if (del) { del.hidden = false; }
            var input = pun.querySelector('[data-pun-input]');
            if (input) { input.focus(); if (input.select) { input.select(); } }
            return;
        }
        var cancelBtn = e.target.closest('[data-pun-cancel]');
        if (cancelBtn) { closePun(cancelBtn.closest('[data-pun]')); }
    });

    document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') { return; }
        var pun = e.target.closest('[data-pun]');
        if (pun) { closePun(pun); }
    });
})();
</script>
