{# Ficha de trabajador: datos, vacaciones y registro de jornada reciente. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% import 'staff/_punch.html.twig' as p %}

{% block title %}{{ worker.name }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ worker.name }}</span>
{% endblock %}

{% block more_css %}
    {{ parent() }}
    {% include 'staff/_edit_styles.html.twig' %}
{% endblock %}

{% block csa_main %}
    {% set madrid = 'Europe/Madrid' %}

    {{ csa.page_header('Personal', worker.name, worker.active ? 'Trabajador activo' : 'Trabajador inactivo') }}

    <div class="csa-grid-kpi" style="margin-bottom: 1.4rem;">
        {{ csa.kpi('Alta', worker.hireDate ? worker.hireDate|date('d/m/Y') : '—', null, null, null, 'sky', 'fa-calendar') }}
        {{ csa.kpi('Vacaciones ' ~ year, vacation_used ~ ' / ' ~ vacation_total, 'días', null, null, 'ochre', 'fa-umbrella') }}
    </div>

    {# ===== Acceso para fichar ===== #}
    <div class="stf-access" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:1.1rem 1.2rem; margin-bottom:1.6rem;">
        <h2 style="margin:0 0 .7rem; font-size:1.1rem;">Acceso para fichar</h2>
        {% if access_user %}
            <p style="margin:0 0 .8rem; color:#374151;">
                <i class="fa fa-check-circle" style="color:#2f8f4e;"></i>
                Tiene acceso con <strong>{{ access_user.email }}</strong>.
            </p>
            <div class="csa-row" style="gap:.6rem;">
                <form method="post" action="{{ path('staff_access_resend', { id: worker.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('staff_access' ~ worker.id) }}">
                    <button type="submit" class="csa-btn csa-btn--secondary csa-btn--sm"><i class="fa fa-paper-plane"></i><span>Reenviar enlace</span></button>
                </form>
                <form method="post" action="{{ path('staff_access_revoke', { id: worker.id }) }}"
                      onsubmit="return confirm('¿Retirar el acceso de {{ worker.name|e('js') }}? No podrá fichar hasta que se lo vuelvas a dar.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('staff_access' ~ worker.id) }}">
                    <button type="submit" class="csa-btn csa-btn--ghost csa-btn--sm">Retirar acceso</button>
                </form>
            </div>
        {% else %}
            <p style="margin:0 0 .8rem; color:#6b7280;">
                Aún no puede fichar. Dale acceso con su email: si ya tiene cuenta (p. ej. es socix) se la reutiliza; si no, se crea una nueva y se le envía un enlace para entrar.
            </p>
            <form method="post" action="{{ path('staff_access_grant', { id: worker.id }) }}" class="csa-row" style="gap:.6rem; flex-wrap:wrap;">
                <input type="hidden" name="_token" value="{{ csrf_token('staff_access' ~ worker.id) }}">
                <input type="email" name="email" required placeholder="email@ejemplo.org" class="csa-input" style="max-width:280px;">
                <button type="submit" class="csa-btn csa-btn--primary csa-btn--sm"><i class="fa fa-key"></i><span>Dar acceso y enviar enlace</span></button>
            </form>
        {% endif %}
    </div>

    {# ===== Vacaciones y ausencias ===== #}
    {% set abs_type = { vacation: 'Vacaciones', sick_leave: 'Baja médica', permit: 'Permiso', other: 'Otra ausencia' } %}
    {% set abs_state = { requested: ['Solicitada','#92400e','#fef3c7'], approved: ['Aprobada','#2f6f43','#e7f3ea'], rejected: ['Rechazada','#9b1c1c','#fde2e2'], cancelled: ['Cancelada','#6b7280','#f3f4f6'] } %}
    <div class="stf-access" style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:1.1rem 1.2rem; margin-bottom:1.6rem;">
        <div class="csa-row-between" style="margin-bottom:.8rem;">
            <h2 style="margin:0; font-size:1.1rem;">Vacaciones y ausencias</h2>
            {{ csa.btn('Registrar ausencia', { variant: 'secondary', icon: 'fa-plus', href: path('staff_absence_new', { id: worker.id }) }) }}
        </div>
        {% for a in absences %}
            {% set st = abs_state[a.status]|default(['—','#6b7280','#f3f4f6']) %}
            <div class="csa-row-between" style="padding:.55rem 0; border-top:1px solid #f3f4f6;">
                <div>
                    <strong>{{ abs_type[a.type]|default(a.type) }}</strong>
                    <span style="color:#6b7280;">· {{ a.startDate|date('d/m/Y') }} – {{ a.endDate|date('d/m/Y') }} ({{ working_days[a.id] }} día{{ working_days[a.id] == 1 ? '' : 's' }} laborable{{ working_days[a.id] == 1 ? '' : 's' }})</span>
                    <span style="margin-left:.4rem; font-size:.72rem; font-weight:600; border-radius:999px; padding:.1rem .55rem; color:{{ st[1] }}; background:{{ st[2] }};">{{ st[0] }}</span>
                </div>
                <div class="csa-row" style="gap:.4rem;">
                    {% if a.status == 'requested' %}
                        <form method="post" action="{{ path('staff_absence_approve', { id: worker.id, absenceId: a.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('staff_absence' ~ worker.id) }}">
                            <button class="csa-btn csa-btn--primary csa-btn--sm">Aprobar</button>
                        </form>
                        <form method="post" action="{{ path('staff_absence_reject', { id: worker.id, absenceId: a.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('staff_absence' ~ worker.id) }}">
                            <button class="csa-btn csa-btn--ghost csa-btn--sm">Rechazar</button>
                        </form>
                    {% elseif a.status != 'cancelled' and a.status != 'rejected' and a.endDate|date('Y-m-d') >= 'now'|date('Y-m-d') %}
                        {% set abs_in_progress = a.startDate|date('Y-m-d') <= 'now'|date('Y-m-d') %}
                        <form method="post" action="{{ path('staff_absence_cancel', { id: worker.id, absenceId: a.id }) }}"
                              onsubmit="return confirm({{ (abs_in_progress
                                  ? 'Esta ausencia está en curso: se conservarán los días hasta hoy y se liberará el resto. ¿Continuar?'
                                  : '¿Cancelar esta ausencia?')|json_encode }});">
                            <input type="hidden" name="_token" value="{{ csrf_token('staff_absence' ~ worker.id) }}">
                            <button class="csa-btn csa-btn--ghost csa-btn--sm">Cancelar</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <p style="margin:0; color:#9ca3af;">Sin vacaciones ni ausencias registradas.</p>
        {% endfor %}
    </div>

    <div class="csa-row-between" style="margin-bottom: 1.2rem;">
        <h2 style="margin:0; font-size:1.1rem;">Registro reciente</h2>
        <div class="csa-row">
            {{ csa.btn('Ver calendario', { variant: 'secondary', icon: 'fa-calendar', href: path('staff_calendar', { id: worker.id }) }) }}
            {{ csa.btn('Editar ficha', { variant: 'ghost', icon: 'fa-pencil', href: path('staff_edit', { id: worker.id }) }) }}
        </div>
    </div>

    <div class="stf-reg">
        {% for day in days %}
            <div class="stf-day">
                <div class="stf-day__head" style="display:flex; align-items:center; gap:.6rem;">
                    <span>{{ day.date|date('l, j M', madrid) }}</span>
                    {% if day.anomaly %}<span class="stf-late" style="background:#fde2e2; color:#9b1c1c;">Revisar</span>{% endif %}
                    {% if day.open %}<span class="stf-late" style="background:#e0f2fe; color:#075985;">En curso</span>{% endif %}
                    <span style="margin-left:auto; font-variant-numeric:tabular-nums; font-weight:600;">
                        {{ (day.totalMinutes // 60) }}h {{ '%02d'|format(day.totalMinutes % 60) }}m
                    </span>
                </div>
                {% set popts = { csrf_id: 'staff_entry' ~ worker.id, correct_route: 'staff_entry_correct', void_route: 'staff_entry_void', base_params: { id: worker.id } } %}
                {% for seg in day.segments %}
                    <div class="stf-pun">
                        {{ p.punch(seg.in, 'in', madrid, popts) }}
                        <span style="color:#9ca3af;">→</span>
                        {{ p.punch(seg.out, 'out', madrid, popts) }}
                        {% if seg.minutes is not null %}
                            <span style="margin-left:auto; color:#6b7280;">{{ (seg.minutes // 60) }}h {{ '%02d'|format(seg.minutes % 60) }}m</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="stf-reg-empty">Sin fichajes en los últimos días.</div>
        {% endfor %}
    </div>

    {# ===== Añadir fichaje olvidado ===== #}
    <details class="stf-add">
        <summary><i class="fa fa-plus-circle"></i> Añadir un registro olvidado</summary>
        <form method="post" action="{{ path('staff_entry_add', { id: worker.id }) }}" class="stf-addrow">
            <input type="hidden" name="_token" value="{{ csrf_token('staff_entry' ~ worker.id) }}">
            <label>Tipo
                <select name="type" class="csa-input">
                    <option value="in">Entrada</option>
                    <option value="out">Salida</option>
                </select>
            </label>
            <label>Fecha
                <input type="date" name="date" class="csa-input" required>
            </label>
            <label>Hora
                <input type="time" name="time" class="csa-input" required>
            </label>
            <button type="submit" class="csa-btn csa-btn--primary">Añadir</button>
        </form>
    </details>

    {% if is_granted('ROLE_GESTION_LABORAL_EDIT') %}
        {% set entry_count = worker.timeEntries|length %}
        <div class="csa-danger-zone" style="margin-top: 2rem; padding-top: 1.2rem; border-top: 1px solid var(--csa-border, #e5e7eb);">
            <h3 style="margin: 0 0 .3rem; font-size: 1rem; color: var(--csa-terracotta, #9b1c1c);">Zona peligrosa</h3>
            {% if entry_count > 0 %}
                <p style="margin: 0 0 .8rem; color: #6b7280; font-size: .9rem;">
                    Este trabajador tiene <strong>{{ entry_count }}</strong> fichaje{{ entry_count == 1 ? '' : 's' }}.
                    Para una baja real márcalo como <strong>inactivo</strong> (conserva el registro). Borrarlo
                    destruye el registro de jornada y solo debe usarse para limpiar trabajadores de prueba.
                </p>
                <button type="button" class="csa-btn csa-btn--danger"
                        onclick="document.getElementById('confirm-worker-delete').showModal()">
                    <i class="fa fa-trash"></i> Forzar borrado
                </button>
                {{ csa.confirm_dialog('confirm-worker-delete', {
                    variant: 'danger',
                    eyebrow: 'Destruye el registro de jornada',
                    title: 'Borrar definitivamente a ' ~ worker.name,
                    body: 'Se borrarán los ' ~ entry_count ~ ' fichajes (registro que la ley obliga a conservar 4 años), sus ausencias y su cuenta de acceso. No se puede deshacer. Úsalo solo para limpiar trabajadores de prueba; para una baja real marca al trabajador como inactivo.',
                    confirm_label: 'Sí, destruir y borrar',
                    action: path('staff_delete', { id: worker.id }),
                    csrf_token: csrf_token('delete' ~ worker.id),
                    csrf_name: '_token',
                    extra_fields: [{ name: 'force', value: '1' }],
                }) }}
            {% else %}
                <p style="margin: 0 0 .8rem; color: #6b7280; font-size: .9rem;">
                    No tiene fichajes. Se borrará junto con sus ausencias y su cuenta de acceso.
                </p>
                <button type="button" class="csa-btn csa-btn--danger"
                        onclick="document.getElementById('confirm-worker-delete').showModal()">
                    <i class="fa fa-trash"></i> Borrar trabajador
                </button>
                {{ csa.confirm_dialog('confirm-worker-delete', {
                    variant: 'danger',
                    eyebrow: 'Acción permanente',
                    title: 'Borrar a ' ~ worker.name,
                    body: 'Se borrará el trabajador junto con sus ausencias y su cuenta de acceso. No se puede deshacer.',
                    confirm_label: 'Borrar',
                    action: path('staff_delete', { id: worker.id }),
                    csrf_token: csrf_token('delete' ~ worker.id),
                    csrf_name: '_token',
                }) }}
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
