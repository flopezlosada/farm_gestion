{# Calendario laboral de festivos (módulo laboral). #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Personal · Festivos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Festivos</span>
{% endblock %}

{% block more_css %}
    {{ parent() }}
    <style>
        .stf-table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
        .stf-table th { text-align: left; font-size: .8rem; text-transform: uppercase; letter-spacing: .03em; color: #6b7280; padding: .7rem 1rem; border-bottom: 1px solid #eef0f2; }
        .stf-table td { padding: .8rem 1rem; border-bottom: 1px solid #f3f4f6; }
        .stf-table tr:last-child td { border-bottom: none; }
        .stf-table tr:hover td { background: #fafaf8; }
        .stf-empty { padding: 2rem 1rem; text-align: center; color: #9ca3af; }
        .stf-date { font-weight: 600; color: #1d1c17; font-variant-numeric: tabular-nums; }
        .stf-wd { color: #6b7280; text-transform: capitalize; }
        .stf-del { background: none; border: none; color: #9b1c1c; cursor: pointer; font-size: .85rem; }
        .stf-del:hover { text-decoration: underline; }
        .hol-add { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 1.1rem 1.2rem; margin-bottom: 1.4rem; display: flex; gap: .8rem; align-items: flex-end; flex-wrap: wrap; }
        .hol-add .csa-field { margin: 0; }
    </style>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Personal', 'Festivos', 'Días no laborables del calendario laboral. No cuentan como hueco del registro y se marcan en los calendarios. Mételos a mano cada año (nacionales, autonómicos de Madrid y locales).') }}

    {% form_theme form 'form_div_layout.html.twig' %}
    {{ form_start(form, { action: path('staff_holiday_new'), attr: { class: 'hol-add' } }) }}
        {{ csa.field(form.date, 'Fecha') }}
        {{ csa.field(form.name, 'Nombre del festivo') }}
        <button type="submit" class="csa-btn csa-btn--primary">Añadir festivo</button>
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <table class="stf-table">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Día</th>
                <th>Festivo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for holiday in holidays %}
                <tr>
                    <td class="stf-date">{{ holiday.date|date('d/m/Y') }}</td>
                    <td class="stf-wd">{{ holiday.date|date('l', 'Europe/Madrid')|capitalize }}</td>
                    <td>{{ holiday.name }}</td>
                    <td style="text-align: right;">
                        <form method="post" action="{{ path('staff_holiday_delete', { id: holiday.id }) }}" onsubmit="return confirm('¿Borrar el festivo «{{ holiday.name|e('js') }}»?');" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_holiday' ~ holiday.id) }}">
                            <button type="submit" class="stf-del"><i class="fa fa-trash"></i> Borrar</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="stf-empty">Aún no hay festivos. Añade el primero con el formulario de arriba.</td></tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}
