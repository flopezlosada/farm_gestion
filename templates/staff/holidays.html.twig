{# Calendario laboral de festivos (módulo laboral). #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Personal · Festivos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('staff_index') }}">Personal</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Festivos</span>
{% endblock %}

{% block more_css %}
    {{ parent() }}
    <style>
        .hol-add { display: flex; gap: var(--csa-sp-4); align-items: flex-end; flex-wrap: wrap;
                   background: var(--csa-surface); border: 1px solid var(--csa-rule);
                   border-radius: var(--csa-radius-lg); padding: var(--csa-sp-5);
                   margin-bottom: var(--csa-sp-6); }
        .hol-add .csa-field { margin: 0; }
    </style>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Personal', 'Festivos', 'Días no laborables del calendario laboral. No cuentan como hueco del registro y se marcan en los calendarios. Mételos a mano cada año (nacionales, autonómicos de Madrid y locales).') }}

    {% form_theme form 'form_div_layout.html.twig' %}
    {{ form_start(form, { action: path('staff_holiday_new'), attr: { class: 'hol-add' } }) }}
        {{ csa.field(form.date, 'Fecha') }}
        {{ csa.field(form.name, 'Nombre del festivo') }}
        {{ csa.btn('Añadir festivo', { variant: 'primary', type: 'submit' }) }}
        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <div class="csa-table-wrap">
        <table class="csa-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th class="csa-table__col-tight">Día</th>
                    <th>Festivo</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for holiday in holidays %}
                    <tr>
                        <td class="csa-table__primary">{{ holiday.date|date('d/m/Y') }}</td>
                        <td class="csa-table__col-tight csa-muted" style="text-transform: capitalize;">{{ holiday.date|date('l', 'Europe/Madrid')|capitalize }}</td>
                        <td>{{ holiday.name }}</td>
                        <td class="csa-table__actions">
                            <form method="post" action="{{ path('staff_holiday_delete', { id: holiday.id }) }}" onsubmit="return confirm('¿Borrar el festivo «{{ holiday.name|e('js') }}»?');" style="display: inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_holiday' ~ holiday.id) }}">
                                <button type="submit" class="csa-table__action--danger" style="background: none; border: none; cursor: pointer;" title="Borrar" aria-label="Borrar"><i class="fa fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay festivos. Añade el primero con el formulario de arriba.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
