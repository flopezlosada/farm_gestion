{# ============================================================
 # Form compartido de trabajador (new + edit).
 # Espera: form, submit_label, cancel_path.
 # ============================================================ #}
{% form_theme form 'form_div_layout.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

    <div class="csa-stack-lg">

        {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Ficha laboral', subtitle: 'Datos de la relación laboral. El acceso para fichar se gestiona aparte.' } %}
            {% block body %}
                {% import '_macros/csa.html.twig' as csa %}
                <div class="csa-form-grid">
                    {{ csa.field(form.name, 'Nombre completo', { full: true }) }}
                    {{ csa.field(form.hireDate, 'Fecha de alta') }}
                    {{ csa.field(form.annualVacationDays, 'Días de vacaciones al año') }}
                    {{ csa.field(form.active, 'Activo', { full: true }) }}
                </div>
            {% endblock %}
        {% endembed %}

        <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
            <div></div>
            <div class="csa-row">
                {{ csa.btn('Cancelar', { variant: 'ghost', href: cancel_path }) }}
                <button type="submit" class="csa-btn csa-btn--primary">{{ submit_label }}</button>
            </div>
        </div>

    </div>

    {{ form_rest(form) }}
{{ form_end(form, { render_rest: false }) }}
