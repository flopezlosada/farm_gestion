{# ============================================================
 # Rejilla del calendario mensual (compartida por el calendario del
 # supervisor y el del trabajador). Cada día enlaza a su detalle.
 #
 # Espera: weeks, day_route, base_params, madrid.
 # ============================================================ #}
{% set absence_labels = { vacation: 'Vacaciones', sick_leave: 'Baja', permit: 'Permiso', other: 'Ausencia' } %}
<table class="cal-grid">
    <thead>
        <tr><th>Lun</th><th>Mar</th><th>Mié</th><th>Jue</th><th>Vie</th><th>Sáb</th><th>Dom</th></tr>
    </thead>
    <tbody>
        {% for week in weeks %}
            <tr>
                {% for cell in week %}
                    <td class="cal-cell{{ not cell.inMonth ? ' cal-cell--out' : '' }}{{ cell.isToday ? ' cal-cell--today' : '' }}{{ cell.date.format('N') > 5 ? ' cal-cell--weekend' : '' }}">
                        {% if cell.inMonth %}
                            <a href="{{ path(day_route, base_params|merge({ date: cell.date|date('Y-m-d', madrid) })) }}">
                                <span class="cal-num">{{ cell.day }}</span>
                                {% if cell.total %}
                                    {% set ins = cell.total.segments|map(s => s.in)|filter(e => e is not null) %}
                                    {% set outs = cell.total.segments|map(s => s.out)|filter(e => e is not null) %}
                                    {% if ins|length %}
                                        <div class="cal-span">{{ ins|first.occurredAt|date('H:i', madrid) }}–{{ outs|length ? (outs|last).occurredAt|date('H:i', madrid) : '…' }}</div>
                                    {% endif %}
                                    <div class="cal-total">{{ (cell.total.totalMinutes // 60) }}h {{ '%02d'|format(cell.total.totalMinutes % 60) }}m</div>
                                    {% if cell.total.open %}<span class="cal-badge cal-badge--abs">En curso</span>{% endif %}
                                    {% if cell.total.anomaly %}<span class="cal-badge cal-badge--warn">Revisar</span>{% endif %}
                                {% elseif cell.absence %}
                                    <span class="cal-badge cal-badge--abs">{{ absence_labels[cell.absence]|default('Ausencia') }}</span>
                                {% elseif cell.holiday %}
                                    <span class="cal-badge cal-badge--holiday" title="{{ cell.holiday }}">Festivo</span>
                                {% elseif cell.isGap %}
                                    <span class="cal-badge cal-badge--gap">Sin fichar</span>
                                {% endif %}
                            </a>
                        {% else %}
                            <span class="cal-day-wrap"><span class="cal-num">{{ cell.day }}</span></span>
                        {% endif %}
                    </td>
                {% endfor %}
            </tr>
        {% endfor %}
    </tbody>
</table>
