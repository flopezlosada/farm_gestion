{# ============================================================
 # Macro compartido: un fichaje con sus controles de corrección
 # (corregir hora / anular). Si el fichaje no existe (tramo
 # incompleto), pinta un guion. Lo usan el supervisor (ficha y día)
 # y el trabajador (su día), con rutas distintas.
 #
 # opts:
 #   csrf_id        id del token CSRF (p. ej. 'staff_entry5' o 'work_entry')
 #   correct_route  ruta de corregir (p. ej. 'staff_entry_correct')
 #   void_route     ruta de anular
 #   base_params    params fijos de la ruta (p. ej. { id: worker_id }) ó {}
 #   return_to      ymd al que volver tras la acción, o null
 # ============================================================ #}
{% macro punch(entry, side, madrid, opts) %}
    {% if entry %}
        {% set base = opts.base_params|default({}) %}
        <details class="stf-edit">
            <summary>
                <span class="stf-pun__icon stf-pun__icon--{{ side }}" aria-hidden="true"><i class="fa fa-sign-{{ side == 'in' ? 'in' : 'out' }}"></i></span>
                <span class="stf-pun__time">{{ entry.occurredAt|date('H:i', madrid) }}</span>
                <i class="fa fa-pencil stf-edit__pen" aria-hidden="true"></i>
            </summary>
            <div class="stf-edit__panel">
                <form method="post" action="{{ path(opts.correct_route, base|merge({ entryId: entry.id })) }}" class="stf-edit__form">
                    <input type="hidden" name="_token" value="{{ csrf_token(opts.csrf_id) }}">
                    {% if opts.return_to|default(null) %}<input type="hidden" name="return_to" value="{{ opts.return_to }}">{% endif %}
                    <label>Hora correcta
                        <input type="time" name="time" value="{{ entry.occurredAt|date('H:i', madrid) }}" required>
                    </label>
                    <label>Motivo
                        <input type="text" name="reason" placeholder="p. ej. la salida real fue a las 17:00">
                    </label>
                    <button type="submit" class="csa-btn csa-btn--primary csa-btn--sm">Guardar corrección</button>
                </form>
                <form method="post" action="{{ path(opts.void_route, base|merge({ entryId: entry.id })) }}"
                      onsubmit="return confirm('¿Anular este fichaje? Queda registrado como anulado, no se borra.');">
                    <input type="hidden" name="_token" value="{{ csrf_token(opts.csrf_id) }}">
                    {% if opts.return_to|default(null) %}<input type="hidden" name="return_to" value="{{ opts.return_to }}">{% endif %}
                    <input type="text" name="reason" placeholder="Motivo de la anulación" class="stf-edit__void-reason">
                    <button type="submit" class="csa-btn csa-btn--ghost csa-btn--sm">Anular fichaje</button>
                </form>
            </div>
        </details>
    {% else %}
        <span class="stf-pun__time">—</span>
    {% endif %}
{% endmacro %}
