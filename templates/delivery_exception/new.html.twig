{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva excepción de reparto{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('delivery_exception_index') }}">Excepciones de reparto</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Nueva excepción de reparto',
        'Cancela o traslada el reparto de un ciclo, para un nodo o para todos.'
    ) }}

    {{ include('delivery_exception/_form.html.twig', { submit_label: 'Crear excepción' }) }}

{% endblock %}
