{# ============================================================
 # Estilos de la "ficha de socix" (tokens y componentes --prt-*).
 # Extraído de templates/partner/show.html.twig para poder reutilizarlo:
 # lo usa la ficha admin (partner/show) y el panel del socix (Panel/index),
 # que replica el mismo aspecto en solo lectura. Todo está namespaced bajo
 # `.prt`, así que el contenedor que lo use debe llevar class="prt".
 # ============================================================ #}
<style>
/* ============================================================
 * Ficha de socix — tokens locales (--prt-*).
 * Paleta hermana del listado de reparto v2 (--dlv-*).
 * ============================================================ */
.prt {
    --prt-line: #ebe7dd;
    --prt-line-2: #d8d2c2;
    --prt-ink: #1d1c17;
    --prt-ink-soft: #5a564a;
    --prt-ink-faint: #8d8773;
    --prt-sage: #5b7a4c;
    --prt-sage-d: #2f4426;
    --prt-sage-l: #eaf0e2;
    --prt-ochre: #c89a3a;
    --prt-ochre-d: #8c6919;
    --prt-ochre-l: #faf1d8;
    --prt-terra: #b45d3a;
    --prt-terra-d: #7d3a1f;
    --prt-terra-l: #fae6dc;
    --prt-bg: #fbfaf6;
    --prt-surface: #ffffff;
    /* Forzar Inter como base del bloque. El shell del csa-shell la hereda
     * pero Bootstrap 3 (cargado antes) puede meter Helvetica Neue / Arial
     * en small/strong/table; declararla aquí blinda toda la cascada. */
    font-family: 'Inter', sans-serif;
    font-variant-numeric: tabular-nums;
}

/* ---------- hero ---------- */
.prt-hero {
    display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: 22px; padding-bottom: 22px; margin-bottom: 18px;
    border-bottom: 1px solid var(--prt-line);
}
.prt-avatar {
    width: 64px; height: 64px; border-radius: 14px;
    display: grid; place-items: center;
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 22px;
    letter-spacing: -0.01em; color: var(--prt-surface);
    background: var(--prt-sage-d); flex-shrink: 0;
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.08);
}
.prt-avatar--ochre { background: var(--prt-ochre-d); }
.prt-avatar--terra { background: var(--prt-terra-d); }
.prt-avatar--ink   { background: var(--prt-ink); }
.prt-avatar--muted { background: var(--prt-line-2); color: var(--prt-ink-soft); }
/* Especificidad doble (.prt .prt-hero__title) para ganar al shell csa,
 * que fuerza font-weight: 400 en todos los h1/h2/h3/h4 con .csa-app. */
.prt .prt-hero__title {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 26px;
    letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 6px;
    color: var(--prt-ink);
}
.prt-hero__meta {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: 6px 12px; font-size: 12px; color: var(--prt-ink-faint);
}
.prt-hero__meta .sep { color: var(--prt-line-2); }
.prt-hero__actions { display: flex; gap: 8px; }

/* ---------- chip (status / modality / generic) ---------- */
.prt-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 3px 9px 4px; border-radius: 4px;
    font-size: 10.5px; font-weight: 600; letter-spacing: 0.04em;
    text-transform: uppercase; line-height: 1.2; white-space: nowrap;
}
.prt-chip .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.prt-chip--activo  { background: var(--prt-sage-l);  color: var(--prt-sage-d); }
.prt-chip--activo .dot { background: var(--prt-sage); }
.prt-chip--pausado { background: var(--prt-ochre-l); color: var(--prt-ochre-d); }
.prt-chip--pausado .dot { background: var(--prt-ochre); }
.prt-chip--baja    { background: #f0eee7; color: var(--prt-ink-soft); }
.prt-chip--baja .dot { background: var(--prt-ink-faint); }
.prt-chip--mod-1   { background: var(--prt-sage-l);  color: var(--prt-sage-d); }
.prt-chip--mod-1 .dot { background: var(--prt-sage); }
.prt-chip--mod-2   { background: var(--prt-ochre-l); color: var(--prt-ochre-d); }
.prt-chip--mod-2 .dot { background: var(--prt-ochre); }
.prt-chip--mod-3   { background: var(--prt-terra-l); color: var(--prt-terra-d); }
.prt-chip--mod-3 .dot { background: var(--prt-terra); }
.prt-chip--mod-4   { background: transparent; color: var(--prt-sage-d); border: 1px dashed var(--prt-sage); }
.prt-chip--mod-4 .dot { background: var(--prt-sage); }
.prt-chip--mod-5   { background: #fff2d6; color: var(--prt-ochre-d); }
.prt-chip--mod-5 .dot { background: var(--prt-ochre); }
.prt-chip--warn    { background: var(--prt-ochre-l); color: var(--prt-ochre-d); }
.prt-chip--warn .dot { background: var(--prt-ochre); }
.prt-chip--mute    { background: var(--prt-bg); color: var(--prt-ink-soft); border: 1px solid var(--prt-line); }

/* ---------- action bar ---------- */
.prt-actionbar {
    display: flex; flex-wrap: wrap; gap: 8px; align-items: center;
    margin-bottom: 22px;
}
.prt-btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px; border-radius: 6px; border: 1px solid var(--prt-line);
    background: var(--prt-surface); color: var(--prt-ink);
    font-size: 12.5px; font-weight: 500; letter-spacing: 0.01em;
    cursor: pointer; text-decoration: none;
    transition: 0.12s ease;
}
.prt-btn:hover { border-color: var(--prt-line-2); background: var(--prt-bg); color: var(--prt-ink); }
.prt-btn .fa { font-size: 11px; color: var(--prt-ink-faint); }
.prt-btn:hover .fa { color: var(--prt-ink); }
.prt-btn--primary {
    background: var(--prt-sage-d); border-color: var(--prt-sage-d); color: #fff;
}
.prt-btn--primary:hover { background: #233619; border-color: #233619; color: #fff; }
.prt-btn--primary .fa,
.prt-btn--primary:hover .fa { color: rgba(255,255,255,0.85); }
.prt-btn--warn .fa { color: var(--prt-ochre-d); }
.prt-btn--warn:hover { background: var(--prt-ochre-l); border-color: var(--prt-ochre); }
.prt-btn--danger .fa { color: var(--prt-terra-d); }
.prt-btn--danger:hover { background: var(--prt-terra-l); border-color: var(--prt-terra); }
.prt-actionbar__sep {
    width: 1px; height: 20px; background: var(--prt-line); margin: 0 2px;
}

/* ---------- pickup card (nodo + grupo de recogida) ---------- */
.prt-pickup {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 10px 18px 10px 12px; border-radius: 10px;
    border: 1px solid var(--prt-line);
    background: var(--prt-surface);
    margin-bottom: 18px;
    max-width: 100%; flex-wrap: wrap;
}
.prt-pickup__icon {
    width: 38px; height: 38px; border-radius: 9px;
    display: grid; place-items: center; flex-shrink: 0;
    background: var(--prt-sage-d); color: #fff;
    font-size: 16px;
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.08);
}
.prt-pickup__body { min-width: 0; }
.prt-pickup__label {
    font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--prt-ink-faint); font-weight: 600; line-height: 1;
    margin-bottom: 3px;
}
.prt-pickup__node {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 16px;
    letter-spacing: -0.01em; color: var(--prt-ink); line-height: 1.1;
}
.prt-pickup__group {
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px;
    letter-spacing: -0.005em; color: var(--prt-ink); line-height: 1.1;
}
.prt-pickup__sep {
    width: 1px; align-self: stretch;
    background: var(--prt-line-2); margin: 4px 0;
}

/* tonos por nodo — el id mapea a un color para que cada nodo
 * se identifique de un vistazo en cualquier ficha. */
.prt-pickup--sage  { background: var(--prt-sage-l);  border-color: var(--prt-sage); }
.prt-pickup--sage  .prt-pickup__icon { background: var(--prt-sage-d); }
.prt-pickup--ochre { background: var(--prt-ochre-l); border-color: var(--prt-ochre); }
.prt-pickup--ochre .prt-pickup__icon { background: var(--prt-ochre-d); }
.prt-pickup--terra { background: var(--prt-terra-l); border-color: var(--prt-terra); }
.prt-pickup--terra .prt-pickup__icon { background: var(--prt-terra-d); }

/* ---------- card ---------- */
.prt-card {
    background: var(--prt-surface); border: 1px solid var(--prt-line);
    border-radius: 8px; overflow: hidden; margin-bottom: 18px;
}
.prt-card__head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 14px; padding: 12px 18px;
    background: linear-gradient(180deg, var(--prt-bg), var(--prt-surface));
    border-bottom: 1px solid var(--prt-line);
}
/* Especificidad doble (.prt .prt-card__title) por la misma razón que
 * .prt-hero__title — los <h2> son víctimas del shell csa. */
.prt .prt-card__title {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 16px;
    letter-spacing: -0.01em; color: var(--prt-ink); margin: 0;
    display: flex; align-items: center; gap: 10px;
}
.prt-card__title .accent {
    width: 4px; height: 16px; border-radius: 2px; background: var(--prt-sage);
    display: inline-block;
}
.prt-card--ochre .prt-card__title .accent { background: var(--prt-ochre); }
.prt-card--terra .prt-card__title .accent { background: var(--prt-terra); }
.prt-card--ink   .prt-card__title .accent { background: var(--prt-ink); }
.prt-card__head-meta { font-size: 11px; color: var(--prt-ink-faint); letter-spacing: 0.04em; }
.prt-card__body { padding: 16px 18px; }
.prt-card__foot {
    padding: 12px 18px; background: var(--prt-bg);
    border-top: 1px solid var(--prt-line);
    display: flex; flex-wrap: wrap; gap: 8px;
}

/* ---------- datos personales (defs) ---------- */
.prt-defs {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 22px; margin: 0;
}
.prt-defs__row { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
.prt-defs__row--full { grid-column: 1 / -1; }
.prt-defs__label {
    font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--prt-ink-faint); font-weight: 500;
}
.prt-defs__value {
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px;
    letter-spacing: -0.005em;
    color: var(--prt-ink); word-wrap: break-word; min-width: 0;
    line-height: 1.3;
}
.prt-defs__value a { color: var(--prt-sage-d); text-decoration: underline; text-decoration-color: var(--prt-line-2); text-underline-offset: 2px; }
.prt-defs__value a:hover { text-decoration-color: var(--prt-sage); }
.prt-defs__value--muted { color: var(--prt-ink-faint); font-weight: 400; font-style: italic; }

/* ---------- familia ---------- */
.prt-family__intro {
    font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px;
    letter-spacing: -0.005em;
    color: var(--prt-ink-soft); margin: 0 0 12px; line-height: 1.3;
}
.prt-family__intro a { color: var(--prt-sage-d); }
.prt-relatives { list-style: none; margin: 0; padding: 0; }
.prt-relative {
    display: flex; align-items: center; gap: 12px;
    padding: 9px 12px; border: 1px solid var(--prt-line); border-radius: 6px;
    background: var(--prt-bg); margin-bottom: 6px;
}
.prt-relative__dot {
    width: 28px; height: 28px; border-radius: 7px;
    display: grid; place-items: center;
    background: var(--prt-surface); border: 1px solid var(--prt-line-2);
    color: var(--prt-sage-d); font-size: 12px;
}
.prt-relative__name {
    flex: 1; font-family: 'Fraunces', serif; font-weight: 500; font-size: 14px;
    color: var(--prt-ink); text-decoration: none; letter-spacing: -0.005em;
}
.prt-relative__name:hover { color: var(--prt-sage-d); }
.prt-share {
    margin-top: 14px; padding: 12px; background: var(--prt-sage-l);
    border-radius: 6px; font-size: 13px; color: var(--prt-ink);
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
}
.prt-share .fa { color: var(--prt-sage-d); }
.prt-share a { color: var(--prt-sage-d); font-weight: 600; }

/* ---------- cesta (mini stats) ---------- */
.prt-basket__chips {
    display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px;
    padding-bottom: 14px; border-bottom: 1px dashed var(--prt-line);
}
.prt-basket__name {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 18px;
    letter-spacing: -0.015em; color: var(--prt-ink);
    margin-bottom: 2px;
}
.prt-basket__sub {
    font-size: 11.5px; color: var(--prt-ink-faint); letter-spacing: 0.04em;
}
.prt-mini {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px; background: var(--prt-line);
    border: 1px solid var(--prt-line); border-radius: 6px; overflow: hidden;
    margin-top: 14px;
}
.prt-mini__cell { background: var(--prt-surface); padding: 12px 14px; min-width: 0; }
.prt-mini__label {
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--prt-ink-faint); font-weight: 600; margin-bottom: 4px;
}
.prt-mini__value {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 18px;
    letter-spacing: -0.01em; color: var(--prt-ink); line-height: 1.2;
}
.prt-mini__value small {
    display: inline-block; font-family: 'Inter', sans-serif;
    font-size: 11px; font-weight: 500; color: var(--prt-ink-faint);
    margin-left: 4px; letter-spacing: 0.02em;
}
.prt-mini__value--muted { color: var(--prt-ink-faint); font-style: italic; font-weight: 500; font-size: 13px; font-family: 'Inter', sans-serif; }
.prt-mini__value--ochre { color: var(--prt-ochre-d); }
.prt-mini__value--sage  { color: var(--prt-sage-d); }

/* ---------- histórico (timeline) ---------- */
.prt-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
.prt-timeline::before {
    content: ''; position: absolute; left: 11px; top: 8px; bottom: 8px;
    width: 1px; background: var(--prt-line);
}
.prt-timeline__item {
    position: relative; padding: 10px 4px 10px 32px;
}
.prt-timeline__dot {
    position: absolute; left: 6px; top: 14px;
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--prt-surface);
    border: 2px solid var(--prt-ink-faint);
    box-sizing: border-box;
}
.prt-timeline__dot--join   { border-color: var(--prt-sage); background: var(--prt-sage-l); }
.prt-timeline__dot--leave  { border-color: var(--prt-terra); background: var(--prt-terra-l); }
.prt-timeline__dot--pause  { border-color: var(--prt-ochre); background: var(--prt-ochre-l); }
.prt-timeline__dot--basket { border-color: var(--prt-sage-d); background: var(--prt-surface); }
.prt-timeline__dot--swap   { border-color: var(--prt-ochre-d); background: var(--prt-surface); }
.prt-timeline__head {
    display: flex; flex-wrap: wrap; align-items: baseline;
    gap: 5px 10px; margin-bottom: 2px;
}
.prt-timeline__label {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: 14px;
    color: var(--prt-ink); letter-spacing: -0.005em;
}
.prt-timeline__time {
    font-size: 11.5px; color: var(--prt-ink-faint);
    font-variant-numeric: tabular-nums;
}
.prt-timeline__actor {
    display: inline-block; font-size: 10px; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 1px 7px; border-radius: 3px;
    background: var(--prt-bg); color: var(--prt-ink-soft); font-weight: 600;
    border: 1px solid var(--prt-line);
}
.prt-timeline__detail {
    margin-top: 2px; font-size: 12px; color: var(--prt-ink-soft);
}
.prt-timeline__detail b { font-weight: 600; color: var(--prt-ink); }
.prt-timeline__empty {
    padding: 28px 12px; text-align: center; color: var(--prt-ink-faint);
    font-style: italic; font-size: 13px;
    background: var(--prt-bg); border: 1px dashed var(--prt-line-2);
    border-radius: 6px;
}

/* ---------- callout local ---------- */
.prt-callout {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 11px 14px; border-radius: 6px; font-size: 13px;
    margin-bottom: 14px;
}
.prt-callout .fa { margin-top: 2px; }
.prt-callout--info    { background: var(--prt-sage-l);  color: var(--prt-sage-d); }
.prt-callout--warn    { background: var(--prt-ochre-l); color: var(--prt-ochre-d); }
.prt-callout--info .fa    { color: var(--prt-sage-d); }
.prt-callout--warn .fa    { color: var(--prt-ochre-d); }

/* ---------- layout 2 columnas ---------- */
.prt-cols {
    display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 18px; align-items: start;
}
@media (max-width: 980px) {
    .prt-cols { grid-template-columns: 1fr; }
    .prt-hero { grid-template-columns: auto 1fr; }
    .prt-hero__actions { grid-column: 1 / -1; justify-content: flex-start; }
    .prt-defs { grid-template-columns: 1fr; }
    .prt-mini { grid-template-columns: 1fr; }
}
</style>
