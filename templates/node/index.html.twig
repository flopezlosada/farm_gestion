{# ============================================================
 # Listado de nodos físicos de reparto, como tarjetas (estilo
 # reparto v2 / .dlv). Cada tarjeta enlaza a la ficha del nodo.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set weekday_labels = {
    1: 'Lunes', 2: 'Martes', 3: 'Miércoles', 4: 'Jueves',
    5: 'Viernes', 6: 'Sábado', 7: 'Domingo'
} %}
{% set cadence_labels = { 'weekly': 'Semanal', 'biweekly': 'Quincenal' } %}
{% set weekday_short = { 1: 'lun', 2: 'mar', 3: 'mié', 4: 'jue', 5: 'vie', 6: 'sáb', 7: 'dom' } %}
{% set month_short = {
    1: 'ene', 2: 'feb', 3: 'mar', 4: 'abr', 5: 'may', 6: 'jun',
    7: 'jul', 8: 'ago', 9: 'sep', 10: 'oct', 11: 'nov', 12: 'dic'
} %}

{% block title %}Nodos de reparto{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nodos de reparto</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
.nodi {
    --dlv-line: #ebe7dd;
    --dlv-line-2: #d8d2c2;
    --dlv-ink: #1d1c17;
    --dlv-ink-soft: #5a564a;
    --dlv-ink-faint: #8d8773;
    --dlv-sage: #5b7a4c;
    --dlv-sage-d: #2f4426;
    --dlv-ochre: #c89a3a;
    --dlv-ochre-d: #8c6919;
    --dlv-sky-d: #2e6f8e;
    --dlv-bg: #fbfaf6;
    --dlv-surface: #ffffff;
    font-family: var(--csa-sans);
    font-variant-numeric: tabular-nums;
}

/* stat strip */
.nodi-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 22px; }
.nodi-stat { background: var(--dlv-surface); border: 1px solid var(--dlv-line); border-radius: 8px; padding: 14px 18px; }
.nodi-stat .v { font-family: var(--csa-serif); font-weight: 600; font-size: 28px; letter-spacing: -0.02em; color: var(--dlv-ink); line-height: 1; }
.nodi-stat .l { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dlv-ink-faint); margin-top: 7px; font-weight: 500; }
.nodi-stat--socios .v { color: var(--dlv-sage-d); }

/* grid de tarjetas */
.nodi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 16px; }
.nodi-card { display: block; background: var(--dlv-surface); border: 1px solid var(--dlv-line); border-left: 4px solid var(--dlv-line-2); border-radius: 10px; padding: 18px 22px; text-decoration: none; color: inherit; transition: 0.14s; }
.nodi-card--weekly { border-left-color: var(--dlv-sage); }
.nodi-card--biweekly { border-left-color: var(--dlv-ochre); }
.nodi-card:hover { box-shadow: 0 6px 20px rgba(40,36,24,0.08); transform: translateY(-1px); }
.nodi-card__head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
.nodi-card__name { font-family: var(--csa-serif); font-weight: 600; font-size: 19px; letter-spacing: -0.01em; color: var(--dlv-ink); }
.nodi-card__cad { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; white-space: nowrap; }
.nodi-card--weekly .nodi-card__cad { color: var(--dlv-sage-d); }
.nodi-card--biweekly .nodi-card__cad { color: var(--dlv-ochre-d); }
.nodi-card__sub { font-size: 12px; color: var(--dlv-ink-faint); margin-top: 3px; }
.nodi-card__sub b { color: var(--dlv-ink-soft); font-weight: 600; }
.nodi-card__row { display: flex; gap: 22px; margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--dlv-line); }
.nodi-card__metric .n { font-family: var(--csa-serif); font-weight: 600; font-size: 18px; color: var(--dlv-ink); white-space: nowrap; }
.nodi-card__metric .n--grupos { color: var(--dlv-sky-d); }
.nodi-card__metric .n--socios { color: var(--dlv-sage-d); }
.nodi-card__metric .n--next { color: var(--dlv-ochre-d); }
.nodi-card__metric .n--none { color: var(--dlv-ink-faint); }
.nodi-card__metric .k { font-size: 10.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dlv-ink-faint); margin-top: 3px; font-weight: 500; }

.nodi-empty { padding: 40px 18px; text-align: center; color: var(--dlv-ink-faint); font-size: 13px; font-style: italic; background: var(--dlv-surface); border: 1px dashed var(--dlv-line-2); border-radius: 8px; }

@media (max-width: 700px) { .nodi-stats { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block csa_main %}
<div class="nodi">

    {{ csa.page_header(
        'Socixs · Reparto',
        'Nodos de reparto',
        'Sitios físicos donde se entregan las cestas. Cada nodo tiene su día de la semana y cadencia (semanal o quincenal).'
    ) }}

    <div class="nodi-stats">
        <div class="nodi-stat">
            <div class="v">{{ stats.nodes }}</div>
            <div class="l">Nodos</div>
        </div>
        <div class="nodi-stat">
            <div class="v">{{ stats.groups }}</div>
            <div class="l">Grupos de recogida</div>
        </div>
        <div class="nodi-stat nodi-stat--socios">
            <div class="v">{{ stats.active_partners }}</div>
            <div class="l">Socios activos</div>
        </div>
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo nodo', { variant: 'primary', href: path('node_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    {% if nodes|length > 0 %}
        <div class="nodi-grid">
            {% for node in nodes %}
                {% set st = node_stats[node.id] %}
                <a class="nodi-card nodi-card--{{ node.cadence == 'weekly' ? 'weekly' : 'biweekly' }}" href="{{ path('node_show', { id: node.id }) }}">
                    <div class="nodi-card__head">
                        <span class="nodi-card__name">{{ node.name }}</span>
                        <span class="nodi-card__cad">{{ cadence_labels[node.cadence] ?? node.cadence }}</span>
                    </div>
                    <div class="nodi-card__sub">
                        Reparto los <b>{{ (weekday_labels[node.deliveryWeekday] ?? node.deliveryWeekday)|lower }}</b>
                    </div>
                    <div class="nodi-card__row">
                        <div class="nodi-card__metric">
                            <div class="n n--grupos">{{ st.groups }}</div>
                            <div class="k">Grupos</div>
                        </div>
                        <div class="nodi-card__metric">
                            <div class="n n--socios">{{ st.active }}</div>
                            <div class="k">Socios activos</div>
                        </div>
                        <div class="nodi-card__metric">
                            {% if st.next %}
                                <div class="n n--next">{{ weekday_short[st.next|date('N')] }} {{ st.next|date('d') }} {{ month_short[st.next|date('n')] }}</div>
                            {% else %}
                                <div class="n n--none">—</div>
                            {% endif %}
                            <div class="k">Próximo reparto</div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% else %}
        <div class="nodi-empty">Aún no hay nodos definidos.</div>
    {% endif %}

</div>
{% endblock %}
