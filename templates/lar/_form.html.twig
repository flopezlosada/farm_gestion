{# ============================================================
 # Form compartido de proyecto LAR (new + edit).
 # Espera: form, submit_label, cancel_path.
 # ============================================================ #}
{% form_theme form 'form_div_layout.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

    <div class="csa-stack-lg">

        {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Ficha del proyecto', subtitle: 'Lo que se muestra en la web. Las fotos se añaden al guardar.' } %}
            {% block body %}
                {% import '_macros/csa.html.twig' as csa %}
                <div class="csa-form-grid">
                    {{ csa.field(form.title, 'Título', { full: true }) }}
                    {{ csa.field(form.type, 'Tipo') }}
                    {{ csa.field(form.status, 'Estado') }}
                    {{ csa.field(form.summary, 'Resumen', { full: true }) }}
                    {{ csa.field(form.content, 'Descripción', { full: true, widget_class: 'tinymce' }) }}
                    {{ csa.field(form.position, 'Orden') }}
                    {{ csa.field(form.published, 'Publicado') }}
                </div>
            {% endblock %}
        {% endembed %}

        <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
            <div></div>
            <div class="csa-row">
                {{ csa.btn('Cancelar', { variant: 'ghost', href: cancel_path }) }}
                <button type="submit" class="csa-btn csa-btn--primary">{{ submit_label }}</button>
            </div>
        </div>

    </div>

    {{ form_rest(form) }}
{{ form_end(form, { render_rest: false }) }}
