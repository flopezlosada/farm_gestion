{# Contenido editable de la portada del LAR (singleton LarPage) + oferta variable. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% import _self as lar %}

{% block title %}Portada · LAR{% endblock %}

{% macro offer_fields(o) %}
    {% import '_macros/csa.html.twig' as csa %}
    <div class="csa-form-grid">
        {{ csa.field(o.title, 'Título') }}
        {{ csa.field(o.hours, 'Duración') }}
        {{ csa.field(o.body, 'Descripción', { full: true, widget_class: 'csa-textarea' }) }}
    </div>
{% endmacro %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('lar_index') }}">LAR</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Portada</span>
{% endblock %}

{% block csa_main %}
  <div class="csa-form-narrow lar-form">
    {{ csa.page_header('LAR', 'Portada', 'El texto de la página pública del LAR.') }}

    {{ csa.callout('Esto es lo que se ve en la página pública del LAR (' ~ '/lar' ~ '). Cambia el texto de presentación, los datos de contacto —el email es también el buzón al que llega el formulario de la web— y las tarjetas de oferta formativa: puedes añadir o quitar las que quieras. Los proyectos se gestionan aparte, en el listado.', 'info', 'info-circle') }}

    {% form_theme form 'form_div_layout.html.twig' %}
    {{ form_start(form, { attr: { role: 'form' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Introducción', subtitle: 'El texto de presentación del LAR en la cabecera de la portada.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.intro, 'Introducción', { full: true, widget_class: 'tinymce' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Coordinación', subtitle: 'Datos de contacto. El email es también el buzón del formulario de la web.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.coordName, 'Nombre') }}
                        {{ csa.field(form.coordPhone, 'Teléfono') }}
                        {{ csa.field(form.coordEmail, 'Email', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Oferta formativa', subtitle: 'Las tarjetas de formación e inmersión pedagógica. Añade o quita las que necesites.' } %}
                {% block body %}
                    {% import 'lar/page.html.twig' as lar %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div id="lar-offers"
                         data-prototype="{{ lar.offer_fields(form.offers.vars.prototype)|e('html_attr') }}"
                         data-index="{{ form.offers|length }}">
                        {% for offer in form.offers %}
                            <div class="lar-offer">
                                {{ lar.offer_fields(offer) }}
                                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm lar-offer-remove"><i class="fa fa-trash"></i><span>Quitar oferta</span></button>
                            </div>
                        {% endfor %}
                    </div>
                    <button type="button" id="lar-add-offer" class="csa-btn csa-btn--ghost" style="margin-top: var(--csa-sp-4);">
                        <i class="fa fa-plus"></i> Añadir oferta
                    </button>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('lar_index') }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Guardar portada</button>
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

    <style>
        .lar-offer { border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); padding: var(--csa-sp-4); margin-bottom: var(--csa-sp-4); background: var(--csa-surface); }
        /* Aire entre el aviso y el marco de la primera sección (iban pegados). */
        .lar-form .csa-callout { margin-bottom: var(--csa-sp-6); }
    </style>

    <script>
    (function () {
        var wrap = document.getElementById('lar-offers');
        if (!wrap) { return; }

        // Enlaza el botón "quitar" de una tarjeta de oferta.
        function bindRemove(item) {
            var btn = item.querySelector('.lar-offer-remove');
            if (btn) { btn.addEventListener('click', function () { item.parentNode.removeChild(item); }); }
        }

        // Ofertas ya presentes al cargar (caso edición).
        Array.prototype.forEach.call(wrap.querySelectorAll('.lar-offer'), bindRemove);

        document.getElementById('lar-add-offer').addEventListener('click', function () {
            // El índice solo crece, nunca se reutiliza, para no colisionar nombres.
            var index = parseInt(wrap.dataset.index, 10);
            var html = wrap.dataset.prototype.replace(/__offer__/g, index);
            var item = document.createElement('div');
            item.className = 'lar-offer';
            item.innerHTML = html + '<button type="button" class="csa-btn csa-btn--ghost csa-btn--sm lar-offer-remove"><i class="fa fa-trash"></i><span>Quitar oferta</span></button>';
            wrap.appendChild(item);
            wrap.dataset.index = index + 1;
            bindRemove(item);
        });
    })();
    </script>
  </div>
{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
{% endblock %}
