{# Listado de proyectos del LAR. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}LAR · Proyectos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">LAR</span>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('LAR · Laboratorio Agroecológico Rural', 'Proyectos', 'Lo que se dinamiza desde La Cerrada. Solo los publicados se ven en la web.') }}

    <div class="csa-grid-kpi" style="margin-bottom: var(--csa-sp-6);">
        {{ csa.kpi('Proyectos', stats.total, null, null, null, 'sky', 'fa-folder-open') }}
        {{ csa.kpi('Publicados', stats.published, null, null, null, 'green', 'fa-globe') }}
        {{ csa.kpi('Activos', stats.active, null, null, null, 'ochre', 'fa-bolt') }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-4);">
        <div></div>
        {% if is_granted('ROLE_GESTION_LAR_EDIT') %}
            {{ csa.btn('Nuevo proyecto', { variant: 'primary', icon: 'fa-plus', href: path('lar_new') }) }}
        {% endif %}
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table">
            <thead>
                <tr>
                    <th>Título</th>
                    <th class="csa-table__col-tight">Tipo</th>
                    <th class="csa-table__col-tight">Estado</th>
                    <th class="csa-table__col-tight">Publicado</th>
                    <th class="csa-table__col-tight">Orden</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for project in projects %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('lar_edit', { id: project.id }) }}">{{ project.title }}</a>
                        </td>
                        <td class="csa-table__col-tight">{{ csa.badge(project.typeLabel, 'plum') }}</td>
                        <td class="csa-table__col-tight">
                            {% if project.active %}
                                {{ csa.badge('Activo', 'green') }}
                            {% else %}
                                {{ csa.badge('Finalizado', 'neutral') }}
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if project.published %}
                                {{ csa.badge('Sí', 'sky') }}
                            {% else %}
                                {{ csa.badge('Borrador', 'ochre') }}
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">{{ project.position }}</td>
                        <td class="csa-table__actions">
                            {% if project.published %}
                                <a href="{{ path('lar_public_project', { slug: project.slug }) }}" target="_blank" rel="noopener" title="Ver en la web" aria-label="Ver en la web"><i class="fa fa-external-link"></i></a>
                            {% endif %}
                            <a href="{{ path('lar_edit', { id: project.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                            {% if is_granted('ROLE_GESTION_LAR_EDIT') %}
                                <a href="#" title="Borrar" aria-label="Borrar" class="csa-table__action--danger"
                                   onclick="event.preventDefault(); document.getElementById('confirm-lar-delete-{{ project.id }}').showModal();"><i class="fa fa-trash"></i></a>
                                {{ csa.confirm_dialog('confirm-lar-delete-' ~ project.id, {
                                    variant: 'danger',
                                    eyebrow: 'Acción permanente',
                                    title: 'Borrar «' ~ project.title ~ '»',
                                    body: 'Se borrará el proyecto y todas sus fotos. No se puede deshacer.',
                                    confirm_label: 'Borrar',
                                    action: path('lar_delete', { id: project.id }),
                                    csrf_token: csrf_token('delete' ~ project.id),
                                    csrf_name: '_token',
                                }) }}
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay proyectos. Crea el primero con «Nuevo proyecto».
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
