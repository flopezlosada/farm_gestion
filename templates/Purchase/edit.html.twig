{# ============================================================
 # Editar compra — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar compra #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('purchase') }}">Compras</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('purchase_show', { id: entity.id }) }}">#{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Compras',
        'Editar compra #' ~ entity.id,
        'Corrige fecha, proveedorx, producto o cantidades.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'purchase-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('purchase_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Cuándo y a quién', subtitle: 'Fecha y proveedorx.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.purchase_date, 'Fecha de compra', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(edit_form.provider, 'Proveedorx') }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Qué y cuánto', subtitle: 'Producto, cantidad y precio unitario.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.product, 'Producto comprado', { full: true }) }}
                        {{ csa.field(edit_form.amount, 'Cantidad') }}
                        {{ csa.field(edit_form.unity, 'Unidades') }}
                        {{ csa.field(edit_form.single_price, 'Precio por unidad (€)', { hint: 'se multiplica por la cantidad' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Vínculo y estado', subtitle: 'Lote relacionado y estado de pago.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.batch, 'Lote relacionado', { full: true, hint: 'sólo si la compra se asocia a un lote' }) }}
                        {{ csa.field(edit_form.paid, '¿Pagada?') }}
                        {{ csa.field(edit_form.note, 'Notas', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="submit" form="purchase-delete-form" class="csa-btn csa-btn--ghost"
                            onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                        Eliminar compra
                    </button>
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('purchase_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
