{# ============================================================
 # Listado de regalos (Gift).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Regalos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Regalos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comercio · Regalos',
        'Regalos',
        'Productos regalados a agraciadxs. Cada entrada registra fecha, cantidad y precio unitario.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo regalo', { variant: 'primary', href: path('gift_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Agraciadx</th>
                    <th>Producto</th>
                    <th class="csa-table__col-tight">Cantidad</th>
                    <th class="csa-table__col-tight">Unidad</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            {% if entity.giftdate %}
                                <a class="csa-table__primary" href="{{ path('gift_show', { id: entity.id }) }}">{{ entity.giftdate|format_date('medium', locale='es') }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>
                            {% if entity.getRecipient %}
                                <a href="{{ path('recipient_show', { id: entity.getRecipient.id }) }}">{{ entity.getRecipient }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>{% if entity.Product %}{{ entity.Product }}{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.amount }}</td>
                        <td class="csa-table__col-tight">{% if entity.Unity %}{{ entity.Unity }}{% else %}—{% endif %}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('gift_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('gift_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay regalos registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
