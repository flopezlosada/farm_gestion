{# ============================================================
 # CSA Vega de Jarama — Macros de componentes
 # ============================================================
 # Cómo usar:
 #
 #   {% import '_macros/csa.html.twig' as csa %}
 #
 #   {{ csa.btn('Guardar', { variant: 'primary', type: 'submit' }) }}
 #   {{ csa.badge('Activo', 'green') }}
 #   {{ csa.kpi('Huevos hoy', 412, 'unidades', '+8% vs ayer', 'up') }}
 #
 # Convención: el primer argumento es siempre el contenido principal
 # (label, valor, etc). Las opciones van en un hash al final.
 #
 # Componentes con body (card, form_section, field_block) NO viven aquí.
 # Twig 3 retiró {% call %} y caller(), así que esos componentes son
 # partials embebibles — ver templates/_components/.
 #
 # Uso de los partials con body:
 #
 #   {% embed '_components/csa_card.html.twig' with {
 #       title: 'Botones', subtitle: 'Variantes' } %}
 #       {% block body %}
 #           {% import '_macros/csa.html.twig' as csa %}
 #           {{ csa.btn('Aceptar', { variant: 'primary' }) }}
 #       {% endblock %}
 #   {% endembed %}
 #
 # IMPORTANTE: dentro de un {% embed %} hay que reimportar las macros.
 # Twig no propaga los imports del template padre al partial embebido.
 # ============================================================ #}


{# ---------- BOTÓN ----------
 # opts: variant (primary|secondary|ghost|danger), size (sm|lg),
 #       type (button|submit|reset), href (renderiza <a>), icon (clase FA),
 #       disabled, attr (hash de atributos extra)
 #}
{% macro btn(label, opts = {}) %}
    {%- set variant = opts.variant|default('secondary') -%}
    {%- set size = opts.size|default('') -%}
    {%- set classes = ['csa-btn', 'csa-btn--' ~ variant] -%}
    {%- if size %}{% set classes = classes|merge(['csa-btn--' ~ size]) %}{% endif -%}
    {%- if opts.block|default(false) %}{% set classes = classes|merge(['csa-btn--block']) %}{% endif -%}

    {%- if opts.href is defined -%}
        <a href="{{ opts.href }}" class="{{ classes|join(' ') }}"
           {%- if opts.disabled|default(false) %} aria-disabled="true"{% endif -%}
           {%- for k, v in opts.attr|default({}) %} {{ k }}="{{ v }}"{% endfor -%}>
            {%- if opts.icon is defined %}<i class="fa {{ opts.icon }}"></i>{% endif -%}
            <span>{{ label }}</span>
        </a>
    {%- else -%}
        <button type="{{ opts.type|default('button') }}" class="{{ classes|join(' ') }}"
                {%- if opts.disabled|default(false) %} disabled{% endif -%}
                {%- for k, v in opts.attr|default({}) %} {{ k }}="{{ v }}"{% endfor -%}>
            {%- if opts.icon is defined %}<i class="fa {{ opts.icon }}"></i>{% endif -%}
            <span>{{ label }}</span>
        </button>
    {%- endif -%}
{% endmacro %}


{# ---------- BADGE ----------
 # tone: green | ochre | terracotta | sky | plum | neutral
 # opts: no_dot (true para badge sin punto)
 #}
{% macro badge(label, tone = 'neutral', opts = {}) %}
    <span class="csa-badge csa-badge--{{ tone }}{% if opts.no_dot|default(false) %} csa-badge--no-dot{% endif %}">
        {{ label }}
    </span>
{% endmacro %}


{# ---------- KPI ----------
 # value se imprime tal cual (puedes pasar un número formateado).
 # delta_dir: up | down | null
 # tone: green | ochre | terracotta | sky | plum (franja superior + icono)
 # icon: clase de Font Awesome (ej. 'fa-egg'). Decorativo en la esquina;
 #       hereda el color del tono si tone está definido.
 #}
{% macro kpi(label, value, unit = null, delta = null, delta_dir = null, tone = null, icon = null) %}
    <div class="csa-kpi{% if tone %} csa-kpi--{{ tone }}{% endif %}">
        <div class="csa-kpi__head">
            <div class="csa-kpi__label">{{ label }}</div>
            {% if icon %}
                <span class="csa-kpi__icon-box">
                    <i class="fa {{ icon }}" aria-hidden="true"></i>
                </span>
            {% endif %}
        </div>
        <div class="csa-kpi__value">
            {{ value }}{% if unit %}<span class="csa-kpi__unit">{{ unit }}</span>{% endif %}
        </div>
        {% if delta %}
            <div class="csa-kpi__delta{% if delta_dir %} csa-kpi__delta--{{ delta_dir }}{% endif %}">
                {{ delta }}
            </div>
        {% endif %}
    </div>
{% endmacro %}


{# ---------- FIELD ----------
 # Envuelve un Symfony form_widget con la etiqueta y el hint nuestros.
 # Pensado para sustituir el patrón verboso de {{ form_label }} +
 # {{ form_widget }} + {{ form_errors }} repetido en cada formulario.
 #
 # Uso:
 #   {{ csa.field(form.purchase_date, 'Fecha de compra', { hint: 'opcional' }) }}
 #
 # Si necesitas más control sobre el widget, usa el partial
 # _components/csa_field_block.html.twig vía embed.
 #}
{% macro field(field, label, opts = {}) %}
    {%- set required = opts.required ?? field.vars.required ?? false -%}
    {%- set widget_class = opts.widget_class|default('csa-input') -%}
    {%- set is_expanded_multi = (field.vars.expanded|default(false)) and (field.vars.multiple|default(false)) -%}
    <div class="csa-field{% if opts.full|default(false) %} csa-field--full{% endif %}">
        <div class="csa-field__label-row">
            <label class="csa-field__label" for="{{ field.vars.id }}">
                {{ label }}{% if required %}<span class="csa-field__required">*</span>{% endif %}
            </label>
            {% if opts.hint is defined %}
                <span class="csa-field__hint">{{ opts.hint }}</span>
            {% endif %}
        </div>
        {% if is_expanded_multi %}
            {# EntityType expanded+multiple: el widget es un wrapper de
             # checkboxes que se convierten en pills via CSS. No le
             # pasamos csa-input porque fijaría height:40px y las pills
             # se desbordarían fuera del field. #}
            {{ form_widget(field, { attr: opts.attr|default({}) }) }}
        {% else %}
            {{ form_widget(field, { attr: { class: widget_class }|merge(opts.attr|default({})) }) }}
        {% endif %}
        {% if not field.vars.valid %}
            <div class="csa-field__error">{{ form_errors(field) }}</div>
        {% endif %}
    </div>
{% endmacro %}


{# ---------- CALLOUT ----------
 # Mensaje inline destacado dentro de cards o secciones.
 # tone: info | warning | danger (default: info)
 # icon: clase de Font Awesome sin el prefijo "fa fa-"
 #
 #   {{ csa.callout('No se puede cerrar el lote.', 'warning', 'exclamation-triangle') }}
 #}
{% macro callout(message, tone = 'info', icon = 'info-circle') %}
    <p class="csa-callout csa-callout--{{ tone }}">
        <i class="csa-callout__icon fa fa-{{ icon }}"></i>
        <span>{{ message }}</span>
    </p>
{% endmacro %}


{# ---------- PAGE HEADER ----------
 # Cabecera de pantalla: kicker + título + lead.
 #
 #   {{ csa.page_header('Granja · Lotes', 'Listado de lotes', 'Animales activos…') }}
 #}
{# ---------- QTY ----------
 # Cantidad numérica: entero si es redonda, con 1 decimal si lleva media
 # (p.ej. cestas compartidas que pesan ½). Evita pintar "3,0" pero respeta
 # "2,5".
 #
 #   {{ csa.qty(2.5) }}  →  2,5
 #   {{ csa.qty(3) }}    →  3
 #}
{% macro qty(v) %}{{ v == v|round ? v|number_format(0, ',', '.') : v|number_format(1, ',', '.') }}{% endmacro %}


{% macro page_header(kicker = null, title = '', lead = null) %}
    <div class="csa-page-header">
        {% if kicker %}<div class="csa-kicker">{{ kicker }}</div>{% endif %}
        <h1>{{ title }}</h1>
        {% if lead %}<div class="csa-lead">{{ lead }}</div>{% endif %}
    </div>
{% endmacro %}


{# ---------- CROP MARKER ----------
 # Cuadrado-marker con un icono botánico y un color rotativo derivado del id.
 # Sirve para diferenciar visualmente cultivos entre sí en listados, fichas de
 # producción y composición de cestas. No es semántico (la rotación NO mapea
 # familia botánica), solo da diferenciación. Si en el futuro se quieren
 # iconos/colores editables por cultivo, se moverá a Crop.icon / Crop.accent
 # y este macro se quedará como fallback.
 #
 # Uso:
 #   {{ csa.crop_marker(crop) }}
 #   {{ csa.crop_marker(crop, { size: 'lg' }) }}  {# 64px, para cabeceras #}
 #
 # opts:
 #   size  sm (32px) | md (default, 40px) | lg (64px)
 #}
{% macro crop_marker(crop, opts = {}) %}
    {%- set size = opts.size|default('md') -%}
    {%- set accents = ['green', 'ochre', 'sky', 'plum', 'terracotta'] -%}
    {%- set icons   = ['fa-leaf', 'fa-pagelines', 'fa-tree'] -%}
    {%- set idx = (crop.id|default(0)) % accents|length -%}
    {%- set icon_idx = (crop.id|default(0)) % icons|length -%}
    {%- set accent = accents[idx] -%}
    {%- set icon = icons[icon_idx] -%}
    <span class="csa-crop-marker csa-crop-marker--{{ size }} csa-crop-marker--{{ accent }}" aria-hidden="true">
        <i class="fa {{ icon }}"></i>
    </span>
{% endmacro %}


{# ---------- CONFIRM DIALOG ----------
 # Modal de confirmación reutilizable. Sustituye a window.confirm() nativo.
 # El <dialog> envuelve el <form> de POST; el botón "confirmar" es el submit.
 # El trigger (botón que abre el dialog) lo pone el call site con:
 #   onclick="document.getElementById('<id>').showModal()"
 #
 # opts:
 #   variant       danger | warning | info | success (default: info)
 #   eyebrow       texto kicker corto en mayúsculas (opcional)
 #   title         título del modal (Fraunces)
 #   body          párrafo descriptivo
 #   confirm_label texto del botón confirmar
 #   cancel_label  texto del botón cancelar (default: 'Cancelar')
 #   action        URL del POST
 #   csrf_token    valor del CSRF token (opcional)
 #   csrf_name     nombre del campo CSRF (default: '_csrf_token')
 #   extra_fields  array de {name, value} para hidden inputs adicionales
 #
 # Ejemplo:
 #   <button type="button" class="csa-btn csa-btn--danger-soft csa-btn--sm"
 #           onclick="document.getElementById('confirm-baja-{{ p.id }}').showModal()">
 #     Dar de baja
 #   </button>
 #   {{ csa.confirm_dialog('confirm-baja-' ~ p.id, {
 #       variant: 'danger',
 #       eyebrow: 'Acción permanente',
 #       title: 'Dar de baja a este socix',
 #       body: 'Dejará de recibir cesta y se conservará el histórico.',
 #       confirm_label: 'Dar de baja',
 #       action: path('partner_demote', { id: p.id }),
 #   }) }}
 #}
{% macro confirm_dialog(id, opts = {}) %}
    {%- set variant = opts.variant|default('info') -%}
    {%- set csrf_name = opts.csrf_name|default('_csrf_token') -%}
    {%- set form_id = opts.external_form_id|default(null) -%}
    {%- set href = opts.confirm_href|default(null) -%}
    {%- set as_form = not form_id and not href -%}
    <dialog id="{{ id }}" class="csa-modal csa-modal--{{ variant }}"
            role="alertdialog" aria-labelledby="{{ id }}-title">
        {% if as_form %}<form method="post" action="{{ opts.action }}">
            {% if opts.csrf_token is defined and opts.csrf_token %}
                <input type="hidden" name="{{ csrf_name }}" value="{{ opts.csrf_token }}">
            {% endif %}
            {% for f in opts.extra_fields|default([]) %}
                <input type="hidden" name="{{ f.name }}" value="{{ f.value }}">
            {% endfor %}
        {% endif %}

        <button class="csa-modal__close" type="button" aria-label="Cerrar"
                onclick="this.closest('dialog').close()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.8" stroke-linecap="round">
                <path d="M5 5l14 14M19 5L5 19"/>
            </svg>
        </button>

        <header class="csa-modal__header">
            <span class="csa-modal__icon" aria-hidden="true">{{ _self.csa_modal_icon(variant) }}</span>
            <div class="csa-modal__heading">
                {% if opts.eyebrow is defined and opts.eyebrow %}
                    <span class="csa-modal__eyebrow">{{ opts.eyebrow }}</span>
                {% endif %}
                <h2 class="csa-modal__title" id="{{ id }}-title">{{ opts.title }}</h2>
            </div>
        </header>

        <div class="csa-modal__body"><p>{{ opts.body }}</p></div>

        <footer class="csa-modal__footer">
            <button type="button" class="csa-modal__btn csa-modal__btn--ghost"
                    onclick="this.closest('dialog').close()" autofocus>
                {{ opts.cancel_label|default('Cancelar') }}
            </button>
            {% if as_form %}
                <button type="submit" class="csa-modal__btn csa-modal__btn--primary">{{ opts.confirm_label }}</button>
            {% elseif form_id %}
                <button type="submit" form="{{ form_id }}" class="csa-modal__btn csa-modal__btn--primary">{{ opts.confirm_label }}</button>
            {% else %}
                <a href="{{ href }}" class="csa-modal__btn csa-modal__btn--primary">{{ opts.confirm_label }}</a>
            {% endif %}
        </footer>

        {% if as_form %}</form>{% endif %}
    </dialog>
{% endmacro %}

{# ---------- AYUDA CONTEXTUAL ----------
 # «?» discreto que enlaza a la guía de ayuda, directo a la tarjeta de una
 # tarea concreta. Abre en pestaña nueva para no perder un formulario a medias.
 #
 #   {{ csa.help('socios', 'cesta') }}
 #
 # section: slug del área (socios|reparto|cosechas). anchor: id de la tarjeta
 # (opcional; sin él, lleva al principio del área). label: texto accesible.
 #
 # El «?» es un enlace de verdad a la guía: el JS del shell (csa_shell) lo
 # intercepta y abre el modal de ayuda cargando el MISMO parcial de la guía
 # (fuente única). Si el JS no estuviera, el enlace sigue llevando a la guía
 # en una pestaña nueva (degradación elegante). Estilo inline a propósito: así
 # funciona en cualquier pantalla sin recompilar Encore. #}
{% macro help(section, anchor = null, label = 'Ver la guía de ayuda') %}
    <a href="{{ path('help_section', { section: section }) }}{{ anchor ? '#' ~ anchor }}"
       data-help-url="{{ path('help_fragment', { section: section }) }}"{% if anchor %} data-help-anchor="{{ anchor }}"{% endif %}
       target="_blank" rel="noopener"
       title="{{ label }}" aria-label="{{ label }}"
       style="display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;border-radius:50%;background:rgba(0,0,0,.07);color:#5a564a;font-size:11px;font-weight:700;line-height:1;text-decoration:none;border-bottom:0;vertical-align:middle;">?</a>
{% endmacro %}

{# Macro privada: SVG del icono según variante. No se llama desde call sites. #}
{% macro csa_modal_icon(variant) -%}
    {%- if variant == 'danger' -%}
        <svg viewBox="0 0 24 24"><circle cx="10" cy="8" r="4"/><path d="M3 21c0-3.866 3.134-7 7-7s7 3.134 7 7"/><path d="M16 11h6"/></svg>
    {%- elseif variant == 'warning' -%}
        <svg viewBox="0 0 24 24"><rect x="6.5" y="4.5" width="3.5" height="15" rx="1"/><rect x="14" y="4.5" width="3.5" height="15" rx="1"/></svg>
    {%- elseif variant == 'success' -%}
        <svg viewBox="0 0 24 24"><circle cx="10" cy="8" r="4"/><path d="M3 21c0-3.866 3.134-7 7-7s7 3.134 7 7"/><path d="M15.5 12.5l2 2 4-4"/></svg>
    {%- else -%}
        <svg viewBox="0 0 24 24"><path d="M9 14L4 9l5-5"/><path d="M4 9h11a5 5 0 0 1 0 10h-4"/></svg>
    {%- endif -%}
{%- endmacro %}
