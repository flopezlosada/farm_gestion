{# ============================================================
 # Detalle de un producto — shell csa.
 # Se accede desde Sale/index (link al producto vendido).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Producto · {{ entity.name }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ entity.name }}</span>
{% endblock %}

{% block csa_main %}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-leaf"></i>
            </span>
            <div>
                <h1>{{ entity.name }}</h1>
                <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                    Producto del catálogo
                </div>
            </div>
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos', accent: 'sky' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Nombre</dt>
                    <dd class="csa-defs__value">{{ entity.name }}</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">¿Es alimento habitual?</dt>
                    <dd class="csa-defs__value">{{ entity.commonFood ? 'Sí' : 'No' }}</dd>
                </div>
                {% if entity.created %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Creado</dt>
                        <dd class="csa-defs__value">{{ entity.created|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
