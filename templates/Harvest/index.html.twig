{# ============================================================
 # Listado de cosechas (Harvest).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cosechas{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cosechas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Cosechas',
        'Registro de cosechas obtenidas en los cultivos del huerto.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nueva cosecha', { variant: 'primary', href: path('harvest_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Cultivo</th>
                    <th class="csa-table__col-tight">Cantidad</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            {% if entity.harvestdate %}
                                <a class="csa-table__primary" href="{{ path('harvest_show', { id: entity.id }) }}">{{ entity.harvestdate|format_date('medium', locale='es') }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>
                            {% if entity.cropWorking %}{{ entity.cropWorking }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">{{ entity.amount }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('harvest_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('harvest_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay cosechas registradas.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
