{# ============================================================
 # Listado de trabajos culturales (CulturalWork) — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Trabajos culturales{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span>Granja</span>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Trabajos culturales</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Trabajos culturales',
        'Registro histórico de trabajos aplicados al cultivo: riego, deshierbe, abonado, aplicación de caldos…'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo trabajo', { variant: 'primary', href: path('culturalwork_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Notas</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('culturalwork_show', { id: entity.id }) }}">
                                {{ entity.culturalWorkType }}
                            </a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.date %}{{ entity.date|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td>{{ entity.content|striptags|slice(0, 120) }}{% if entity.content|striptags|length > 120 %}…{% endif %}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('culturalwork_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('culturalwork_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay trabajos culturales registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
