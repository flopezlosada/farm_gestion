{# ============================================================
 # Editar trabajo cultural (CulturalWork) — shell csa.
 # ============================================================
 # El controller convierte date a YYYY-MM-DD antes de renderizar
 # para que el input type="date" nativo lo acepte.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar · {{ entity.culturalWorkType }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalwork') }}">Trabajos culturales</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('culturalwork_show', { id: entity.id }) }}">{{ entity.culturalWorkType }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Trabajo cultural',
        'Editar ' ~ entity.culturalWorkType,
        'Actualiza los datos del trabajo cultural.'
    ) }}

    {{ form_start(edit_form, {
        'action': path('culturalwork_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Trabajo', subtitle: 'Tipo y fecha del trabajo realizado.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.cultural_work_type, 'Tipo') }}
                        {{ csa.field(edit_form.date, 'Fecha', { attr: { class: 'csa-input datepicker' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Alcance', subtitle: 'A qué cultivos y sectores afecta el trabajo.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Cultivos trabajados', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.crop_workings) }}
                        {% endblock %}
                    {% endembed %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Sectores afectados', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.sectors) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Descripción', subtitle: 'Detalles del trabajo: producto, dosis, observaciones.' } %}
                {% block body %}
                    {% embed '_components/csa_field_block.html.twig' with { label: 'Descripción', full: true } %}
                        {% block body %}
                            {{ form_widget(edit_form.content, { attr: { class: 'tinymce' } }) }}
                        {% endblock %}
                    {% endembed %}
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('culturalwork_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    <script>
        document.querySelectorAll('.datepicker')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
