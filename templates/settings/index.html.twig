{# ============================================================
 # Configuración de la app — toggles de AppSettings (solo admin).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Configuración{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Configuración</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Administración',
        'Configuración',
        'Ajustes de la app, por categorías. Cambia lo que quieras en cualquier pestaña y guarda una sola vez.'
    ) }}

    {# Salida de la última ejecución manual de un cron (se muestra una sola vez). #}
    {% if cron_output %}
        <div class="csa-card {{ cron_output.ok ? 'csa-card--accent-green' : 'csa-card--accent-terracotta' }}" style="margin-bottom:var(--csa-sp-5);">
            <div class="csa-row-between">
                <strong>Resultado: {{ cron_output.label }}</strong>
                <code class="csa-setting__help">{{ cron_output.command }}</code>
            </div>
            <pre style="margin-top:var(--csa-sp-3); white-space:pre-wrap; overflow:auto; max-height:360px; font-size:12px; background:var(--csa-surface-alt); padding:var(--csa-sp-3); border-radius:6px;">{{ cron_output.output ?: '(sin salida)' }}</pre>
        </div>
    {% endif %}

    {# Pestañas de categoría (cliente): muestran/ocultan cada panel sin recargar,
     # de modo que el form sigue siendo único y un solo "Guardar" persiste todo
     # (los campos ocultos se envían igual). A ancho completo para que quepan en
     # una sola fila; el panel de debajo se limita pero alineado a la izquierda,
     # así su borde izquierdo coincide con el de las pestañas. #}
    <ul class="csa-tabs csa-tabs--folder" data-settings-tabs>
        {% for group in groups|keys %}
            <li class="csa-tabs__item {{ loop.first ? 'active' }}">
                <a class="csa-tabs__link" href="#settings-panel-{{ loop.index }}"
                   data-settings-tab="{{ loop.index }}">{{ group }}</a>
            </li>
        {% endfor %}
    </ul>

    <form method="post" action="{{ path('settings_save') }}" class="csa-form-narrow">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('settings_save') }}">

        <div class="csa-stack-lg">

            {% for group, items in groups %}
                <div id="settings-panel-{{ loop.index }}" data-settings-panel="{{ loop.index }}"
                     {{ not loop.first ? 'hidden' }}>
                    {% embed '_components/csa_form_section.html.twig' with { num: loop.index, title: group } %}
                        {% block body %}
                            <div class="csa-settings-list">
                                {% for s in items %}
                                    <label class="csa-setting">
                                        {% if s.type == 'time' %}
                                            {% set parts = s.value|split(':') %}
                                            <span class="csa-timefield">
                                                <span class="csa-timefield__box">
                                                    <input type="text" inputmode="numeric" maxlength="2"
                                                           class="csa-timefield__input"
                                                           name="settings[{{ s.name }}][h]" value="{{ parts[0] }}"
                                                           aria-label="Hora">
                                                    <span class="csa-timefield__cap">Hora</span>
                                                </span>
                                                <span class="csa-timefield__colon">:</span>
                                                <span class="csa-timefield__box">
                                                    <input type="text" inputmode="numeric" maxlength="2"
                                                           class="csa-timefield__input"
                                                           name="settings[{{ s.name }}][m]" value="{{ parts[1] }}"
                                                           aria-label="Minutos">
                                                    <span class="csa-timefield__cap">Min</span>
                                                </span>
                                            </span>
                                        {% elseif s.type == 'int' %}
                                            <span class="csa-setting__num">
                                                <input type="number" class="csa-input csa-input--compact"
                                                       name="settings[{{ s.name }}]" value="{{ s.value }}"
                                                       min="{{ s.min }}" max="{{ s.max }}" step="1">
                                                {% if s.unit %}<span class="csa-setting__unit">{{ s.unit }}</span>{% endif %}
                                            </span>
                                        {% elseif s.type == 'string' %}
                                            <input type="text" class="csa-input"
                                                   name="settings[{{ s.name }}]" value="{{ s.value }}"
                                                   placeholder="csa@csavegadejarama.org"
                                                   style="min-width: 16rem;">
                                        {% else %}
                                            <span class="csa-toggle">
                                                <input type="checkbox" class="csa-toggle__input"
                                                       name="settings[{{ s.name }}]" value="1" {{ s.value ? 'checked' }}>
                                                <span class="csa-toggle__track"><span class="csa-toggle__thumb"></span></span>
                                            </span>
                                        {% endif %}
                                        <span class="csa-setting__text">
                                            <span class="csa-setting__label">{{ s.label }}</span>
                                            <span class="csa-setting__help">{{ s.help }}</span>
                                        </span>
                                    </label>
                                    {# Tareas programadas: botones de ejecución manual. Los envíos van a
                                     # formularios externos (definidos tras el form de guardado), referenciados
                                     # por `form=`, porque no se pueden anidar formularios. #}
                                    {% if s.command is defined %}
                                        {% set idsafe = s.name|replace({'.': '_'}) %}
                                        <div class="csa-setting__actions" style="display:flex; gap:var(--csa-sp-2); padding:0 0 var(--csa-sp-2) calc(var(--csa-sp-8) + var(--csa-sp-2));">
                                            {% if s.confirm %}
                                                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm"
                                                        onclick="document.getElementById('confirm-cron-{{ idsafe }}').showModal()">Ejecutar ahora</button>
                                            {% else %}
                                                <button type="submit" form="cronrun-{{ idsafe }}" class="csa-btn csa-btn--ghost csa-btn--sm">Ejecutar ahora</button>
                                            {% endif %}
                                            {% if s.dry %}
                                                <button type="submit" form="crondry-{{ idsafe }}" class="csa-btn csa-btn--ghost csa-btn--sm">Previsualizar</button>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endblock %}
                    {% endembed %}
                </div>
            {% endfor %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <button type="submit" class="csa-btn csa-btn--primary">Guardar configuración</button>
            </div>

        </div>
    </form>

    {# Formularios de ejecución manual de crons, fuera del form de guardado (no se
     # pueden anidar). Cada botón "Ejecutar ahora"/"Previsualizar" los referencia
     # por `form=`; los de email confirman antes con un diálogo. #}
    {% for group, items in groups %}
        {% for s in items %}
            {% if s.command is defined %}
                {% set idsafe = s.name|replace({'.': '_'}) %}
                <form id="cronrun-{{ idsafe }}" method="post" action="{{ path('settings_cron_run') }}" hidden>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('settings_cron_run') }}">
                    <input type="hidden" name="cron" value="{{ s.name }}">
                    <input type="hidden" name="mode" value="run">
                </form>
                {% if s.dry %}
                    <form id="crondry-{{ idsafe }}" method="post" action="{{ path('settings_cron_run') }}" hidden>
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('settings_cron_run') }}">
                        <input type="hidden" name="cron" value="{{ s.name }}">
                        <input type="hidden" name="mode" value="dry">
                    </form>
                {% endif %}
                {% if s.confirm %}
                    {{ csa.confirm_dialog('confirm-cron-' ~ idsafe, {
                        variant: 'warning',
                        title: 'Ejecutar ahora: ' ~ s.label,
                        body: 'La tarea se ejecuta de inmediato y enviará correo real, salvo que el envío de emails esté apagado en esta misma pantalla. ¿Continuar?',
                        confirm_label: 'Ejecutar',
                        cancel_label: 'Cancelar',
                        external_form_id: 'cronrun-' ~ idsafe,
                    }) }}
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endfor %}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {# Conmutador de pestañas de configuración (client-side). #}
    <script>
        document.addEventListener('click', function (e) {
            var tab = e.target.closest('[data-settings-tab]');
            if (!tab) { return; }
            e.preventDefault();
            var idx = tab.getAttribute('data-settings-tab');
            document.querySelectorAll('[data-settings-panel]').forEach(function (panel) {
                panel.hidden = panel.getAttribute('data-settings-panel') !== idx;
            });
            document.querySelectorAll('[data-settings-tabs] .csa-tabs__item').forEach(function (item) {
                item.classList.remove('active');
            });
            tab.closest('.csa-tabs__item').classList.add('active');
        });
    </script>
{% endblock %}
