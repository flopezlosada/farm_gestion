{# ============================================================
 # CSA Vega de Jarama — Layout shell nuevo
 # ============================================================
 # Layout con sidebar nuevo + topbar nuevo, separado del de SB Admin 2.
 # Las pantallas migradas extienden de aquí; las viejas siguen
 # extendiendo de layout_list.html.twig / layout_crud.html.twig sin
 # tocar.
 #
 # Herencia:
 #   templates/base.html.twig                     ← raíz (no se toca)
 #     └── templates/_layouts/csa_shell.html.twig ← este archivo
 #            └── templates/Batch/index.html.twig (rediseñado)
 #
 # base.html.twig sigue cargando bootstrap.min.css + sb-admin-2.css.
 # Nosotros añadimos los CSS/JS compilados por Webpack Encore al final
 # vía encore_entry_link_tags / script_tags. Como esto se hace solo en
 # las plantillas que extienden de csa_shell, las pantallas viejas no
 # cargan el bundle nuevo.
 # ============================================================ #}

{% extends 'base.html.twig' %}

{% block more_css %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}

    {# DataTables core (sin el adapter Bootstrap, que rompería csa-table).
     # Opt-in: solo se aplica a tablas con `data-paginate`. El estilo de
     # los controles que DataTables genera está en components.css. #}
    <script src="{{ asset('bundles/app/datatables/media/js/jquery.dataTables.min.js') }}"></script>
    <script>
        $(function() {
            $('.csa-table[data-paginate]').each(function() {
                $(this).DataTable({
                    // l = length, f = filter, r = processing, t = table, i = info, p = paginate
                    dom: '<"csa-dt-top"lf>rt<"csa-dt-bottom"ip>',
                    lengthMenu: [10, 25, 50, 100],
                    // Sin orden inicial: respeta el orden que entrega el server
                    // (cada controller decide su criterio). El usuario puede
                    // ordenar clicando las cabeceras.
                    order: [],
                    language: {
                        lengthMenu: 'Muestra _MENU_ por página',
                        search: 'Buscar:',
                        zeroRecords: 'Sin resultados',
                        info: 'Mostrando _START_–_END_ de _TOTAL_',
                        infoEmpty: '0 registros',
                        infoFiltered: '(filtrado de _MAX_ totales)',
                        paginate: { first: '«', last: '»', next: '›', previous: '‹' }
                    }
                });
            });
        });
    </script>

    {# Drawer móvil: el botón hamburguesa abre/cierra el sidebar; el scrim y
     # la tecla Escape lo cierran. En escritorio el botón está oculto por CSS,
     # así que nada de esto se dispara. #}
    <script>
        (function () {
            var sidebar = document.getElementById('csa-sidebar');
            var toggle = document.querySelector('.csa-sidebar-toggle');
            var overlay = document.getElementById('csa-sidebar-overlay');
            if (!sidebar || !toggle) { return; }

            function open() {
                sidebar.classList.add('csa-sidebar--open');
                if (overlay) { overlay.hidden = false; }
                toggle.setAttribute('aria-expanded', 'true');
            }
            function close() {
                sidebar.classList.remove('csa-sidebar--open');
                if (overlay) { overlay.hidden = true; }
                toggle.setAttribute('aria-expanded', 'false');
            }

            toggle.addEventListener('click', function () {
                sidebar.classList.contains('csa-sidebar--open') ? close() : open();
            });
            if (overlay) { overlay.addEventListener('click', close); }
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { close(); }
            });
        }());
    </script>

    {# Cierre de avisos flash: delegación sobre el botón ×. Anima la salida y
     # retira la alerta del DOM (con respaldo por si no hay transición). #}
    <script>
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.csa-alert__close');
            if (!btn) { return; }
            var alert = btn.closest('.csa-alert');
            if (!alert) { return; }
            alert.classList.add('is-closing');
            setTimeout(function () { alert.remove(); }, 200);
        });
    </script>
{% endblock %}

{% block body %}
<div class="csa-app">
    <div class="csa-shell">

        {# ---------- SIDEBAR ---------- #}
        <aside class="csa-sidebar" id="csa-sidebar">
            <div class="csa-sidebar__brand">
                <div class="csa-sidebar__brand-name">CSA Vega de Jarama</div>
                <div class="csa-sidebar__brand-sub">Gestión interna</div>
            </div>

            <nav class="csa-sidebar__nav">
                {% block csa_nav %}
                    {%- set route = app.request.attributes.get('_route') -%}

                    {# Día a día — siempre visible para usuarios autenticados con cualquier rol de gestión #}
                    <div class="csa-sidebar__group">Día a día</div>
                    {{ _self.nav_link('Panel', path('dashboard'), 'fa-home',
                       route == 'dashboard') }}
                    {{ _self.nav_link('Calendario', path('calendar'), 'fa-calendar',
                       route starts with 'calendar') }}

                    {% if is_granted('ROLE_GESTION_GRANJA') %}
                        <div class="csa-sidebar__group">Granja</div>
                        {{ _self.nav_link('Lotes', path('batch'), 'fa-sliders',
                           route starts with 'batch') }}
                        {{ _self.nav_link('Cultivos', path('crop'), 'fa-leaf',
                           route starts with 'crop') }}
                        {{ _self.nav_link('Tareas', path('task'), 'fa-tasks',
                           route starts with 'task') }}
                        {{ _self.nav_link('Cosechas / huevos', path('lay'), 'fa-egg',
                           route starts with 'lay') }}
                        {{ _self.nav_link('Trabajos culturales', path('culturalwork'), 'fa-compass',
                           route starts with 'culturalwork') }}
                        {{ _self.nav_link('Compost', path('compostcollection'), 'fa-recycle',
                           route starts with 'compostcollection') }}
                        {# Composición de las cestas que se cosechan cada viernes (no confundir con
                         # el reparto a socixs, que vive en el grupo Socixs > Reparto semanal). #}
                        {{ _self.nav_link('Composición de cestas', path('production_show_basket', { year: 'now'|date('Y') }), 'fa-shopping-basket',
                           route starts with 'production') }}
                    {% endif %}

                    {% if is_granted('ROLE_GESTION_SOCIXS') %}
                        <div class="csa-sidebar__group">Socixs</div>
                        {{ _self.nav_link('Listado', path('partner_index'), 'fa-people-carry',
                           (route starts with 'partner_' and not (route starts with 'partner_basket_share')) and route != 'partner_evolution') }}
                        {{ _self.nav_link('Reparto semanal', path('delivery_by_node_default'), 'fa-cart-arrow-down',
                           route starts with 'delivery_by_node') }}
                        {{ _self.nav_link('Cambiar día de reparto', path('delivery_shifts_index'), 'fa-exchange',
                           route starts with 'delivery_shifts') }}
                        {{ _self.nav_link('Grupos de recogida', path('weekly_basket_group_index'), 'fa-map-marker',
                           route starts with 'weekly_basket_group') }}
                        {{ _self.nav_link('Nodos de reparto', path('node_index'), 'fa-sitemap',
                           route starts with 'node_') }}
                        {{ _self.nav_link('Excepciones de reparto', path('delivery_exception_index'), 'fa-calendar-times-o',
                           route starts with 'delivery_exception') }}
                        {{ _self.nav_link('Evolución', path('partner_evolution'), 'fa-line-chart',
                           route == 'partner_evolution') }}
                    {% endif %}

                    {# Comercio: ya no incluye Cestas (eso es composición de cosecha, está en Granja). #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="csa-sidebar__group">Comercio</div>
                        {{ _self.nav_link('Ventas', path('sale'), 'fa-money',
                           route starts with 'sale') }}
                        {{ _self.nav_link('Compras', path('purchase'), 'fa-eur',
                           route starts with 'purchase') }}
                    {% endif %}

                    {% if is_granted('ROLE_BLOG') %}
                        <div class="csa-sidebar__group">Comunicación</div>
                        {{ _self.nav_link('Blog', path('blog'), 'fa-newspaper-o',
                           route starts with 'blog') }}
                        {{ _self.nav_link('Eventos públicos', path('booking'), 'fa-calendar-check-o',
                           route starts with 'booking') }}
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="csa-sidebar__group">Administración</div>
                        {{ _self.nav_link('Usuarias', path('user'), 'fa-users',
                           route starts with 'user') }}
                    {% endif %}
                {% endblock %}
            </nav>
        </aside>

        {# Scrim del drawer móvil: cubre el contenido cuando el sidebar está
         # abierto; tocarlo lo cierra. Oculto por defecto y en escritorio. #}
        <div class="csa-sidebar-overlay" id="csa-sidebar-overlay" hidden></div>

        {# ---------- MAIN ---------- #}
        <div class="csa-main">

            {# TOPBAR #}
            <header class="csa-topbar">
                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm csa-sidebar-toggle"
                        aria-label="Abrir navegación" aria-controls="csa-sidebar" aria-expanded="false">
                    <i class="fa fa-bars"></i>
                </button>

                <nav class="csa-topbar__crumbs" aria-label="Migas de pan">
                    {% block csa_crumbs %}
                        <a href="{{ path('dashboard') }}">Inicio</a>
                    {% endblock %}
                </nav>

                <div class="csa-topbar__user">
                    {# Muestra el switch "Mi panel" cuando el user está vinculado
                     # a un Partner real. No usamos is_granted('ROLE_PARTNER') porque
                     # ROLE_ADMIN lo incluye por jerarquía, lo cual mete a admins
                     # sin Partner en el flujo /panel/setup. La fuente de verdad es
                     # User.partner: si está vinculado, hay panel. #}
                    {% if app.user and app.user.partner %}
                        <div class="csa-areaswitch" role="group" aria-label="Cambiar de área">
                            <span class="csa-areaswitch__item csa-areaswitch__item--active" aria-current="page">
                                <i class="fa fa-cog" aria-hidden="true"></i>
                                <span class="csa-areaswitch__label">Gestión</span>
                                <span class="csa-areaswitch__short" aria-hidden="true">G</span>
                            </span>
                            <a href="{{ path('panel') }}" class="csa-areaswitch__item" title="Ir a mi panel personal">
                                <i class="fa fa-user" aria-hidden="true"></i>
                                <span class="csa-areaswitch__label">Mi panel</span>
                                <span class="csa-areaswitch__short" aria-hidden="true">P</span>
                            </a>
                        </div>
                    {% endif %}

                    <a href="{{ path('homepage') }}" class="csa-topbar__util" target="_blank" rel="noopener" title="Abrir la web pública">
                        <i class="fa fa-globe" aria-hidden="true"></i>
                        <span class="csa-topbar__util-label">Ver web</span>
                    </a>

                    {% if app.user %}
                        <div class="csa-me">
                            <span class="csa-me__id csa-me__id--static">
                                <span class="csa-avatar">{{- app.user.userIdentifier|first|upper -}}</span>
                                <span class="csa-me__name">{{ app.user.userIdentifier }}</span>
                            </span>
                            <a href="{{ path('app_logout') }}" class="csa-me__logout" title="Cerrar sesión" aria-label="Cerrar sesión">
                                <i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </header>

            {# CONTENIDO #}
            <main class="csa-content">
                {# Flash messages: si no se pintan aquí, se quedan en sesión y
                 # aparecen en la siguiente página que los renderice (que era
                 # la confusión: dabas de baja y veías el mensaje al entrar
                 # luego en una ficha). #}
                {% include '_components/csa_flashes.html.twig' %}

                {% block csa_main %}{% endblock %}
            </main>
        </div>

    </div>
</div>
{% endblock %}


{# Macro local: link de la sidebar.
 # Definido como _self porque solo se usa aquí. #}
{% macro nav_link(label, href, icon = null, active = false) %}
    <a href="{{ href }}" class="csa-sidebar__link{% if active %} csa-sidebar__link--active{% endif %}">
        {% if icon %}<i class="csa-sidebar__icon fa {{ icon }}"></i>{% endif %}
        <span>{{ label }}</span>
    </a>
{% endmacro %}
