{# ============================================================
 # CSA Vega de Jarama — Layout shell nuevo
 # ============================================================
 # Layout con sidebar nuevo + topbar nuevo, separado del de SB Admin 2.
 # Las pantallas migradas extienden de aquí; las viejas siguen
 # extendiendo de layout_list.html.twig / layout_crud.html.twig sin
 # tocar.
 #
 # Herencia:
 #   templates/base.html.twig                     ← raíz (no se toca)
 #     └── templates/_layouts/csa_shell.html.twig ← este archivo
 #            └── templates/Batch/index.html.twig (rediseñado)
 #
 # base.html.twig sigue cargando bootstrap.min.css + sb-admin-2.css.
 # Nosotros añadimos los CSS/JS compilados por Webpack Encore al final
 # vía encore_entry_link_tags / script_tags. Como esto se hace solo en
 # las plantillas que extienden de csa_shell, las pantallas viejas no
 # cargan el bundle nuevo.
 # ============================================================ #}

{% extends 'base.html.twig' %}

{% block more_css %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}

    {# Estilos del contenido de ayuda dentro del modal contextual (los «?»).
     # Las tarjetas (.csa-card) ya tienen estilo del bundle; aquí solo los
     # pasos, que son propios de la guía. Replican lo justo de help/section.
     # html.twig — es CSS de presentación, no contenido (el texto vive en un
     # único parcial servido por help_fragment). #}
    <style>
        #csa-help-modal .csa-card { margin-bottom: 14px; }
        #csa-help-modal .csa-card:last-child { margin-bottom: 0; }
        #csa-help-modal .help-steps { margin: 0; padding-left: 1.4em; }
        #csa-help-modal .help-steps > li { margin-bottom: 11px; line-height: 1.65;
            font-size: 14.5px; color: #2b2b2b; }
        #csa-help-modal .help-steps > li:last-child { margin-bottom: 0; }
        #csa-help-modal .help-steps strong { font-weight: 600; color: #1d1c17; }
        #csa-help-modal kbd { background: #f0ede6; border-radius: 4px; padding: 1px 7px;
            font-family: inherit; font-weight: 600; font-size: 0.95em; }
        #csa-help-modal .csa-modal__body { max-height: 70vh; overflow-y: auto; }

        /* Grupos colapsables del sidebar: la cabecera clona el estilo de
         * .csa-sidebar__group pero es un botón con chevron. Plegado oculta los
         * items y gira el chevron. */
        .csa-navgroup__head {
            display: flex; align-items: center; justify-content: space-between; gap: 8px;
            width: 100%; background: none; border: 0; cursor: pointer; font-family: inherit;
            padding: var(--csa-sp-4) var(--csa-sp-5) var(--csa-sp-2);
            font-size: var(--csa-fs-xs); letter-spacing: 0.1em; text-transform: uppercase;
            color: var(--csa-sage-muted); font-weight: 500;
        }
        .csa-navgroup__head:hover { color: var(--csa-sage-text); }
        .csa-navgroup__chev { font-size: 9px; opacity: 0.6; transition: transform 0.15s ease; }
        .csa-navgroup.is-collapsed .csa-navgroup__chev { transform: rotate(-90deg); }
        .csa-navgroup.is-collapsed .csa-navgroup__items { display: none; }
    </style>
{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}

    {# DataTables core (sin el adapter Bootstrap, que rompería csa-table).
     # Opt-in: solo se aplica a tablas con `data-paginate`. El estilo de
     # los controles que DataTables genera está en components.css. #}
    <script src="{{ asset('bundles/app/datatables/media/js/jquery.dataTables.min.js') }}"></script>
    <script>
        $(function() {
            $('.csa-table[data-paginate]').each(function() {
                // No inicializar tablas sin filas de datos reales: una fila
                // placeholder («Sin datos…») es un único <td colspan>, y
                // DataTables peta («Requested unknown parameter») al no casar
                // las celdas con las cabeceras. Si la primera fila del cuerpo no
                // tiene tantas celdas como columnas, la tabla no se pagina (sin
                // datos no hace falta) en vez de romper.
                var cols = $(this).find('thead th').length;
                var firstRow = $(this).find('tbody tr').first();
                if (firstRow.length === 0 || firstRow.children('td, th').length !== cols) {
                    return;
                }
                $(this).DataTable({
                    // l = length, f = filter, r = processing, t = table, i = info, p = paginate
                    dom: '<"csa-dt-top"lf>rt<"csa-dt-bottom"ip>',
                    lengthMenu: [10, 25, 50, 100],
                    // Sin orden inicial: respeta el orden que entrega el server
                    // (cada controller decide su criterio). El usuario puede
                    // ordenar clicando las cabeceras.
                    order: [],
                    language: {
                        lengthMenu: 'Muestra _MENU_ por página',
                        search: 'Buscar:',
                        zeroRecords: 'Sin resultados',
                        info: 'Mostrando _START_–_END_ de _TOTAL_',
                        infoEmpty: '0 registros',
                        infoFiltered: '(filtrado de _MAX_ totales)',
                        paginate: { first: '«', last: '»', next: '›', previous: '‹' }
                    }
                });
            });
        });
    </script>

    {# Drawer móvil: el botón hamburguesa abre/cierra el sidebar; el scrim y
     # la tecla Escape lo cierran. En escritorio el botón está oculto por CSS,
     # así que nada de esto se dispara. #}
    <script>
        (function () {
            var sidebar = document.getElementById('csa-sidebar');
            var toggle = document.querySelector('.csa-sidebar-toggle');
            var overlay = document.getElementById('csa-sidebar-overlay');
            if (!sidebar || !toggle) { return; }

            function open() {
                sidebar.classList.add('csa-sidebar--open');
                if (overlay) { overlay.hidden = false; }
                toggle.setAttribute('aria-expanded', 'true');
            }
            function close() {
                sidebar.classList.remove('csa-sidebar--open');
                if (overlay) { overlay.hidden = true; }
                toggle.setAttribute('aria-expanded', 'false');
            }

            toggle.addEventListener('click', function () {
                sidebar.classList.contains('csa-sidebar--open') ? close() : open();
            });
            if (overlay) { overlay.addEventListener('click', close); }
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { close(); }
            });
        }());

        // Grupos colapsables del sidebar: clic en la cabecera pliega/despliega.
        // El grupo de la pantalla activa SIEMPRE se expande (aunque arrancara
        // plegado para el admin), para que se vea dónde estás.
        (function () {
            document.querySelectorAll('.csa-navgroup').forEach(function (group) {
                var head = group.querySelector('.csa-navgroup__head');
                if (head) {
                    head.addEventListener('click', function () {
                        group.classList.toggle('is-collapsed');
                    });
                }
                if (group.querySelector('.csa-sidebar__link--active')) {
                    group.classList.remove('is-collapsed');
                }
            });
        }());
    </script>
    {# Ayuda contextual: los «?» (csa.help) son enlaces a la guía; aquí los
     # interceptamos para abrir el modal cargando el MISMO parcial de la guía
     # (fuente única) por fetch. Si algo falla, dejamos pasar el click y el
     # enlace lleva a la guía como respaldo. Delegación en document para que
     # cubra «?» pintados en cualquier pantalla. #}
    <script>
        (function () {
            var modal = document.getElementById('csa-help-modal');
            if (!modal || typeof modal.showModal !== 'function') { return; }
            var body = modal.querySelector('[data-help-body]');

            document.addEventListener('click', function (e) {
                var link = e.target.closest('a[data-help-url]');
                if (!link) { return; }
                e.preventDefault();

                var url = link.getAttribute('data-help-url');
                var anchor = link.getAttribute('data-help-anchor');
                var title = modal.querySelector('#csa-help-modal-title');

                body.innerHTML = '<p style="color:#8d8773;">Cargando ayuda…</p>';
                title.textContent = 'Cómo se hace';
                modal.showModal();

                fetch(url, { credentials: 'same-origin' })
                    .then(function (r) { if (!r.ok) { throw new Error(r.status); } return r.text(); })
                    .then(function (html) {
                        var card = null;
                        if (anchor) {
                            var tmp = document.createElement('div');
                            tmp.innerHTML = html;
                            card = tmp.querySelector('#' + (window.CSS && CSS.escape ? CSS.escape(anchor) : anchor));
                        }
                        if (card) {
                            // Solo la tarea pedida. Su título sube a la cabecera del
                            // modal para no repetirlo dentro de la tarjeta.
                            var head = card.querySelector('.csa-card__title');
                            if (head) { title.textContent = head.textContent.trim(); }
                            var cardHead = card.querySelector('.csa-card__header');
                            if (cardHead) { cardHead.remove(); }
                            body.innerHTML = '';
                            body.appendChild(card);
                        } else {
                            // Sin ancla (o no encontrada): el área entera, como respaldo.
                            body.innerHTML = html;
                        }
                        body.scrollTop = 0;
                    })
                    .catch(function () {
                        // Respaldo: que el enlace haga su trabajo (abre la guía).
                        modal.close();
                        window.open(link.href, '_blank', 'noopener');
                    });
            });

            // Cerrar al hacer click en el backdrop (fuera del contenido).
            modal.addEventListener('click', function (e) {
                if (e.target === modal) { modal.close(); }
            });
        }());
    </script>

    {# El cierre de los avisos flash lo aporta el propio componente
     # _components/csa_flashes.html.twig (autónomo), compartido con el panel. #}
{% endblock %}

{% block body %}
<div class="csa-app">
    <div class="csa-shell">

        {# ---------- SIDEBAR ---------- #}
        <aside class="csa-sidebar" id="csa-sidebar">
            <div class="csa-sidebar__brand">
                <div class="csa-sidebar__brand-name">CSA Vega de Jarama</div>
                <div class="csa-sidebar__brand-sub">Gestión interna</div>
            </div>

            <nav class="csa-sidebar__nav">
                {% block csa_nav %}
                    {%- set route = app.request.attributes.get('_route') -%}

                    {# Día a día — accesos generales, siempre visibles. Colapsable como
                     # el resto (coherencia), pero abierto por defecto. #}
                    <div class="csa-navgroup">
                        <button type="button" class="csa-navgroup__head">Día a día <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                        <div class="csa-navgroup__items">
                            {{ _self.nav_link('Panel', path('dashboard'), 'fa-home',
                               route == 'dashboard') }}
                            {{ _self.nav_link('Calendario', path('calendar'), 'fa-calendar',
                               route starts with 'calendar') }}
                            {{ _self.nav_link('Ayuda', path('help_index'), 'fa-question-circle',
                               route starts with 'help') }}
                        </div>
                    </div>

                    {# Administración va PRIMERO: es el dominio propio del admin. Sólo lo
                     # ve ROLE_ADMIN, así que para los gestores no-admin el menú no cambia.
                     # El resto de grupos (que el admin también tiene por jerarquía) quedan
                     # debajo, secundarios. #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="csa-navgroup">
                            <button type="button" class="csa-navgroup__head">Administración <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Usuarias', path('user'), 'fa-users',
                                   route starts with 'user') }}
                                {{ _self.nav_link('Configuración', path('settings_index'), 'fa-sliders',
                                   (route starts with 'settings') and not (route starts with 'settings_diagnostics')) }}
                                {{ _self.nav_link('Diagnóstico de envíos', path('settings_diagnostics'), 'fa-paper-plane',
                                   route starts with 'settings_diagnostics') }}
                                {{ _self.nav_link('Estadísticas de uso', path('usage_stats_index'), 'fa-bar-chart',
                                   route starts with 'usage_stats') }}
                            </div>
                        </div>
                    {% endif %}

                    {# Grupos de rol: colapsables. Para el admin arrancan PLEGADOS
                     # (su dominio es Administración, arriba); el JS expande siempre el
                     # grupo de la pantalla activa. Para un gestor no-admin arrancan
                     # abiertos. #}
                    {%- set sec_collapsed = is_granted('ROLE_ADMIN') ? ' is-collapsed' : '' -%}

                    {% if is_granted('ROLE_GESTION_GRANJA') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Granja <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Lotes', path('batch'), 'fa-sliders',
                                   route starts with 'batch') }}
                                {{ _self.nav_link('Cultivos', path('crop'), 'fa-leaf',
                                   route starts with 'crop') }}
                                {{ _self.nav_link('Tareas', path('task'), 'fa-tasks',
                                   route starts with 'task') }}
                                {{ _self.nav_link('Cosechas / huevos', path('lay'), 'fa-egg',
                                   route starts with 'lay') }}
                                {{ _self.nav_link('Trabajos culturales', path('culturalwork'), 'fa-compass',
                                   route starts with 'culturalwork') }}
                                {{ _self.nav_link('Compost', path('compostcollection'), 'fa-recycle',
                                   route starts with 'compostcollection') }}
                                {# Composición de las cestas que se cosechan cada viernes (no confundir con
                                 # el reparto a socixs, que vive en el grupo Socixs > Reparto semanal). #}
                                {{ _self.nav_link('Composición de cestas', path('production_show_basket', { year: 'now'|date('Y') }), 'fa-shopping-basket',
                                   route starts with 'production') }}
                            </div>
                        </div>
                    {% endif %}

                    {% if is_granted('ROLE_GESTION_SOCIXS') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Socios <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Listado', path('partner_index'), 'fa-people-carry',
                                   (route starts with 'partner_' and not (route starts with 'partner_basket_share')) and route != 'partner_evolution') }}
                                {{ _self.nav_link('Evolución', path('partner_evolution'), 'fa-line-chart',
                                   route == 'partner_evolution') }}
                            </div>
                        </div>
                    {% endif %}

                    {% if is_granted('ROLE_GESTION_ALBERGUE') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Albergue <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Calendario', path('albergue_timeline'), 'fa-calendar',
                                   route == 'albergue_timeline') }}
                                {{ _self.nav_link('Voluntarios', path('helper_index'), 'fa-bed',
                                   route starts with 'helper_' or route starts with 'stay_') }}
                                {{ _self.nav_link('Aforo', path('hosting_capacity_index'), 'fa-calendar-check-o',
                                   route starts with 'hosting_capacity') }}
                                {{ _self.nav_link('Métricas', path('albergue_stats'), 'fa-bar-chart',
                                   route == 'albergue_stats') }}
                            </div>
                        </div>
                    {% endif %}

                    {% if is_granted('ROLE_GESTION_REPARTO') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Reparto <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Reparto semanal', path('delivery_by_node_default'), 'fa-cart-arrow-down',
                                   route starts with 'delivery_by_node') }}
                                {{ _self.nav_link('Histórico de cambios', path('delivery_shifts_index'), 'fa-exchange',
                                   route starts with 'delivery_shifts') }}
                                {{ _self.nav_link('Grupos de recogida', path('weekly_basket_group_index'), 'fa-map-marker',
                                   route starts with 'weekly_basket_group') }}
                                {{ _self.nav_link('Nodos de reparto', path('node_index'), 'fa-sitemap',
                                   route starts with 'node_') }}
                                {{ _self.nav_link('Excepciones de reparto', path('delivery_exception_index'), 'fa-calendar-times-o',
                                   route starts with 'delivery_exception') }}
                            </div>
                        </div>
                    {% endif %}

                    {# Comercio (Ventas/Compras) retirado del menú 2026-06-07 — pendiente
                     # decidir si se usa en el futuro. Rutas y controllers siguen vivos.
                     # Ver deuda comercio-menu-retirado-debt. #}

                    {% if is_granted('ROLE_BLOG') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Comunicación <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Blog', path('blog'), 'fa-newspaper-o',
                                   route starts with 'blog') }}
                                {{ _self.nav_link('Eventos públicos', path('booking_index'), 'fa-calendar-check-o',
                                   route starts with 'booking') }}
                            </div>
                        </div>
                    {% endif %}

                    {% if is_granted('ROLE_GESTION_ENCUESTAS') and is_granted('FEATURE_SURVEYS') %}
                        <div class="csa-navgroup{{ sec_collapsed }}">
                            <button type="button" class="csa-navgroup__head">Encuestas <i class="csa-navgroup__chev fa fa-chevron-down" aria-hidden="true"></i></button>
                            <div class="csa-navgroup__items">
                                {{ _self.nav_link('Encuestas', path('survey_index'), 'fa-check-square-o',
                                   route starts with 'survey') }}
                            </div>
                        </div>
                    {% endif %}

                {% endblock %}
            </nav>
        </aside>

        {# Scrim del drawer móvil: cubre el contenido cuando el sidebar está
         # abierto; tocarlo lo cierra. Oculto por defecto y en escritorio. #}
        <div class="csa-sidebar-overlay" id="csa-sidebar-overlay" hidden></div>

        {# ---------- MAIN ---------- #}
        <div class="csa-main">

            {# TOPBAR #}
            <header class="csa-topbar">
                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm csa-sidebar-toggle"
                        aria-label="Abrir navegación" aria-controls="csa-sidebar" aria-expanded="false">
                    <i class="fa fa-bars"></i>
                </button>

                <nav class="csa-topbar__crumbs" aria-label="Migas de pan">
                    {% block csa_crumbs %}
                        <a href="{{ path('dashboard') }}">Inicio</a>
                    {% endblock %}
                </nav>

                <div class="csa-topbar__user">
                    {# Muestra el switch "Mi panel" cuando el user está vinculado
                     # a un Partner real. No usamos is_granted('ROLE_PARTNER') porque
                     # ROLE_ADMIN lo incluye por jerarquía, lo cual mete a admins
                     # sin Partner en el flujo /panel/setup. La fuente de verdad es
                     # User.partner: si está vinculado, hay panel. #}
                    {% if app.user and app.user.partner %}
                        <div class="csa-areaswitch" role="group" aria-label="Cambiar de área">
                            <span class="csa-areaswitch__item csa-areaswitch__item--active" aria-current="page">
                                <i class="fa fa-cog" aria-hidden="true"></i>
                                <span class="csa-areaswitch__label">Gestión</span>
                                <span class="csa-areaswitch__short" aria-hidden="true">G</span>
                            </span>
                            <a href="{{ path('panel') }}" class="csa-areaswitch__item" title="Ir a mi panel personal">
                                <i class="fa fa-user" aria-hidden="true"></i>
                                <span class="csa-areaswitch__label">Mi panel</span>
                                <span class="csa-areaswitch__short" aria-hidden="true">P</span>
                            </a>
                        </div>
                    {% endif %}

                    <a href="{{ path('homepage') }}" class="csa-topbar__util" target="_blank" rel="noopener" title="Abrir la web pública">
                        <i class="fa fa-globe" aria-hidden="true"></i>
                        <span class="csa-topbar__util-label">Ver web</span>
                    </a>

                    {% if app.user %}
                        <div class="csa-me">
                            <span class="csa-me__id csa-me__id--static">
                                <span class="csa-avatar">{{- app.user.userIdentifier|first|upper -}}</span>
                                <span class="csa-me__name">{{ app.user.userIdentifier }}</span>
                            </span>
                            <a href="{{ path('app_logout') }}" class="csa-me__logout" title="Cerrar sesión" aria-label="Cerrar sesión">
                                <i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </header>

            {# CONTENIDO #}
            <main class="csa-content">
                {# Flash messages: si no se pintan aquí, se quedan en sesión y
                 # aparecen en la siguiente página que los renderice (que era
                 # la confusión: dabas de baja y veías el mensaje al entrar
                 # luego en una ficha). #}
                {% include '_components/csa_flashes.html.twig' %}

                {% block csa_main %}{% endblock %}
            </main>
        </div>

    </div>
</div>

{# Modal de ayuda contextual. Vacío: el JS le inyecta el parcial de la guía
 # al pulsar un «?». Único en el shell, reutilizado por todas las pantallas. #}
<dialog id="csa-help-modal" class="csa-modal csa-modal--info" aria-labelledby="csa-help-modal-title">
    <button class="csa-modal__close" type="button" aria-label="Cerrar" onclick="this.closest('dialog').close()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M5 5l14 14M19 5L5 19"/></svg>
    </button>
    <header class="csa-modal__header">
        <div class="csa-modal__heading">
            <span class="csa-modal__eyebrow">Ayuda</span>
            <h2 class="csa-modal__title" id="csa-help-modal-title">Cómo se hace</h2>
        </div>
    </header>
    <div class="csa-modal__body" data-help-body></div>
    <footer class="csa-modal__footer">
        <button type="button" class="csa-modal__btn csa-modal__btn--ghost" onclick="this.closest('dialog').close()">Cerrar</button>
    </footer>
</dialog>
{% endblock %}


{# Macro local: link de la sidebar.
 # Definido como _self porque solo se usa aquí. #}
{% macro nav_link(label, href, icon = null, active = false) %}
    <a href="{{ href }}" class="csa-sidebar__link{% if active %} csa-sidebar__link--active{% endif %}">
        {% if icon %}<i class="csa-sidebar__icon fa {{ icon }}"></i>{% endif %}
        <span>{{ label }}</span>
    </a>
{% endmacro %}
