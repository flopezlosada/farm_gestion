{# ============================================================
 # Layout de la jornada del trabajador (vista propia, faceta laboral).
 # Hermano de csa_panel (socix): misma estructura, pero su área es "Mi
 # jornada" (fichar y ver lo mío), no "Mi panel". Separado a propósito
 # para no mezclar las dos facetas personales de una misma persona.
 # ============================================================ #}

{% extends 'base.html.twig' %}

{% block more_css %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}
{% endblock %}

{% block body %}
<div class="csa-app">
    <div class="csa-shell">

        {% set route = app.request.attributes.get('_route') %}

        {# ---------- SIDEBAR ---------- #}
        <aside class="csa-sidebar" id="csa-sidebar">
            <div class="csa-sidebar__brand">
                <div class="csa-sidebar__brand-name">CSA Vega de Jarama</div>
                <div class="csa-sidebar__brand-sub">Mi jornada</div>
            </div>

            <nav class="csa-sidebar__nav">
                <div class="csa-sidebar__group">Mi área</div>
                {{ _self.nav_link('Fichar', path('work'), 'fa-clock-o', route == 'work') }}
                {{ _self.nav_link('Mi calendario', path('work_calendar'), 'fa-calendar', route == 'work_calendar' or route == 'work_day') }}
                {{ _self.nav_link('Mis vacaciones', path('work_vacations'), 'fa-umbrella', route == 'work_vacations') }}
            </nav>
        </aside>

        {# ---------- MAIN ---------- #}
        <div class="csa-main">
            <header class="csa-topbar">
                <button type="button" class="csa-btn csa-btn--ghost csa-btn--sm csa-sidebar-toggle"
                        aria-label="Abrir navegación"
                        onclick="document.getElementById('csa-sidebar').classList.toggle('csa-sidebar--open')">
                    <i class="fa fa-bars"></i>
                </button>

                <nav class="csa-topbar__crumbs" aria-label="Migas de pan">
                    {% block csa_crumbs %}
                        <a href="{{ path('work') }}">Mi jornada</a>
                    {% endblock %}
                </nav>

                <div class="csa-topbar__user">
                    {# Conmutador compartido; aquí, activa Mi jornada. #}
                    {% include '_components/area_switch.html.twig' with { active: 'work' } %}

                    <a href="{{ path('homepage') }}" class="csa-topbar__util" target="_blank" rel="noopener" title="Abrir la web pública">
                        <i class="fa fa-globe" aria-hidden="true"></i>
                        <span class="csa-topbar__util-label">Ver web</span>
                    </a>

                    {% if app.user %}
                        {# El nombre de la faceta laboral: el del Worker si está
                         # vinculado, con caída al identificador del User. #}
                        {% set me_worker = app.user.worker %}
                        {% set me_name = me_worker ? me_worker.name : app.user.userIdentifier %}
                        <div class="csa-me">
                            <span class="csa-me__id">
                                <span class="csa-avatar">{{- me_name|first|upper -}}</span>
                                <span class="csa-me__name">{{ me_name }}</span>
                            </span>
                            <a href="{{ path('app_logout') }}" class="csa-me__logout" title="Cerrar sesión" aria-label="Cerrar sesión">
                                <i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    {% endif %}
                </div>
            </header>

            <main class="csa-content">
                {% include '_components/csa_flashes.html.twig' %}

                {% block csa_main %}{% endblock %}
            </main>
        </div>

    </div>
</div>
{% endblock %}


{# Helper idéntico al de los otros layouts. Se duplica porque cada layout es self-contained. #}
{% macro nav_link(label, href, icon, active) %}
    <a href="{{ href }}" class="csa-sidebar__link{% if active %} csa-sidebar__link--active{% endif %}">
        {% if icon %}<i class="csa-sidebar__icon fa {{ icon }}"></i>{% endif %}
        <span>{{ label }}</span>
    </a>
{% endmacro %}
