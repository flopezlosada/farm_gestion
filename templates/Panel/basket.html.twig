{% extends '_layouts/csa_panel.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Mi cesta{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('panel') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Mi cesta</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Mi área · Cesta',
        'Mi cesta y mi grupo',
        'Lo que recibes y dónde lo recoges.'
    ) }}

    <div class="csa-dashboard-pair">

        {# ===== Cesta activa ===== #}
        {% embed '_components/csa_card.html.twig' with { title: 'Mi cesta activa', accent: 'green' } %}
            {% block body %}
                {% if active_share %}
                    <dl class="csa-defs">
                        <dt>Tipo</dt>
                        <dd>{{ active_share.basketShare.name|default('—') }}</dd>
                        <dt>Cantidad de cestas</dt>
                        <dd>{{ active_share.vegetablesBasketAmount|default(1) }}</dd>
                        <dt>Precio mensual</dt>
                        <dd>{% if active_share.monthPrice %}{{ active_share.monthPrice }} €{% else %}—{% endif %}</dd>
                        <dt>Huevos</dt>
                        <dd>
                            {% if active_share.eggAmount and active_share.eggPeriod %}
                                {{ active_share.eggAmount.amount|default(active_share.eggAmount) }} · {{ active_share.eggPeriod.name|default(active_share.eggPeriod) }}
                            {% else %}
                                <span class="csa-muted">— sin huevos —</span>
                            {% endif %}
                        </dd>
                        <dt>Carne</dt>
                        <dd>{{ partner.eatMeat ? 'Sí' : 'No' }}</dd>
                        <dt>En vigor desde</dt>
                        <dd>{{ active_share.startDate ? active_share.startDate|date('d/m/Y') : '—' }}</dd>
                    </dl>
                {% else %}
                    <p class="csa-muted">No tienes una cesta activa registrada actualmente.</p>
                    <p>Si crees que es un error o quieres darte de alta, escríbenos a <a href="mailto:info@csavegadejarama.org">info@csavegadejarama.org</a>.</p>
                {% endif %}
            {% endblock %}
        {% endembed %}

        {# ===== Grupo de recogida ===== #}
        {% embed '_components/csa_card.html.twig' with { title: 'Mi grupo de recogida', accent: 'ochre' } %}
            {% block body %}
                {% if group %}
                    <dl class="csa-defs">
                        <dt>Grupo habitual</dt>
                        <dd>{{ group.name }}</dd>
                        {% if group.address is defined and group.address %}
                            <dt>Punto de entrega</dt>
                            <dd>{{ group.address }}</dd>
                        {% endif %}
                        {% if group.day is defined and group.day %}
                            <dt>Día de reparto</dt>
                            <dd>{{ group.day }}</dd>
                        {% endif %}
                    </dl>
                {% else %}
                    <p class="csa-muted">Aún no tienes asignado un grupo de recogida.</p>
                {% endif %}
            {% endblock %}
        {% endembed %}

    </div>

    {# ===== Acciones puntuales sobre la próxima cesta ===== #}
    {% if next_basket %}
        {% embed '_components/csa_card.html.twig' with { title: 'Próxima cesta', accent: 'sky' } %}
            {% block body %}
                <p>
                    Tu próxima cesta es el
                    <strong>{{ next_basket.basket.date|format_date('full', locale='es') }}</strong>
                    {% if next_basket_group %}
                        en <strong>{{ next_basket_group.name }}</strong>
                    {% endif %}.
                </p>

                {% if next_basket_skipped %}
                    <div class="csa-alert csa-alert--warning" role="status" style="margin: var(--csa-sp-3) 0;">
                        Has marcado que <strong>no recogerás</strong> la cesta esta semana.
                    </div>
                {% endif %}

                {% if can_change_next %}
                    <div class="csa-stack" style="margin-top: var(--csa-sp-4);">

                        {# --- Saltar / recuperar --- #}
                        <form action="{{ path('panel_basket_skip_toggle') }}" method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('panel_basket_skip') }}">
                            {% if next_basket_skipped %}
                                <button type="submit" class="csa-btn csa-btn--secondary csa-btn--block">
                                    Al final sí recogeré la cesta
                                </button>
                            {% else %}
                                <button type="submit" class="csa-btn csa-btn--secondary csa-btn--block"
                                        onclick="return confirm('¿Confirmas que NO recoges la cesta de esta semana?');">
                                    No recogeré la cesta esta semana
                                </button>
                            {% endif %}
                        </form>

                        {# --- Cambiar de nodo puntualmente --- #}
                        {% if not next_basket_skipped and pickup_groups|length > 1 %}
                            <form action="{{ path('panel_basket_change_group') }}" method="post" class="csa-stack">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('panel_basket_change_group') }}">
                                <div class="csa-field">
                                    <label for="csa-pickup-group" class="csa-field__label">
                                        Cambiar nodo de recogida solo para esta semana
                                    </label>
                                    <select id="csa-pickup-group" name="group_id" class="csa-input" required>
                                        <option value="">— selecciona un grupo —</option>
                                        {% for g in pickup_groups %}
                                            <option value="{{ g.id }}"
                                                    {% if next_basket_group and next_basket_group.id == g.id %}selected{% endif %}>
                                                {{ g.name }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="csa-btn csa-btn--secondary csa-btn--block">
                                    Cambiar nodo para esta cesta
                                </button>
                            </form>
                        {% endif %}

                        {# --- Cambiar viernes (quincenales/mensuales) --- #}
                        {% if shift_existing %}
                            <div class="csa-alert csa-alert--warning" role="status">
                                Has pedido cambio puntual:
                                en lugar de recoger el <strong>{{ shift_existing.fromBasket.date|date('d/m/Y') }}</strong>,
                                recoges el <strong>{{ shift_existing.toBasket.date|date('d/m/Y') }}</strong>.
                            </div>
                            <form action="{{ path('panel_basket_shift_cancel') }}" method="post">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('panel_basket_shift_cancel') }}">
                                <button type="submit" class="csa-btn csa-btn--secondary csa-btn--block"
                                        onclick="return confirm('¿Quieres deshacer el cambio y volver a recoger el viernes original?');">
                                    Deshacer el cambio de viernes
                                </button>
                            </form>
                        {% elseif not next_basket_skipped and shift_candidates|length > 0 %}
                            <form action="{{ path('panel_basket_shift_request') }}" method="post" class="csa-stack">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('panel_basket_shift') }}">
                                <div class="csa-field">
                                    <label for="csa-shift-to" class="csa-field__label">
                                        Cambiar el viernes de recogida (esta cesta a otro viernes)
                                    </label>
                                    <select id="csa-shift-to" name="to_basket_id" class="csa-input" required>
                                        <option value="">— elige un viernes —</option>
                                        {% for b in shift_candidates %}
                                            <option value="{{ b.id }}">{{ b.date|date('d/m/Y') }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <button type="submit" class="csa-btn csa-btn--secondary csa-btn--block">
                                    Pedir cambio de viernes
                                </button>
                                <p class="csa-muted" style="font-size: var(--csa-fs-sm); margin: 0;">
                                    Si las reglas de equilibrio no lo permiten, el sistema te avisará y tendrás que contactar con la administración.
                                </p>
                            </form>
                        {% endif %}

                        <p class="csa-muted" style="font-size: var(--csa-fs-sm); margin: 0;">
                            Plazo para cambiar: hasta el
                            <strong>{{ pickup_deadline|format_datetime('long', 'short', locale='es') }}</strong>.
                            Después tendrás que avisar a la administración.
                        </p>
                    </div>
                {% else %}
                    <p class="csa-muted" style="margin-top: var(--csa-sp-3);">
                        Ya no puedes cambiar la cesta de esta semana desde aquí — el plazo terminó.
                        Si necesitas avisar, escribe a
                        <a href="mailto:info@csavegadejarama.org">info@csavegadejarama.org</a>.
                    </p>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% else %}
        {# No hay WeeklyBasket futura para este socix. Pasa cuando todavía
         # no se ha generado el listado del próximo viernes o cuando el
         # socix no tiene cesta asignada para esa fecha (modalidad
         # quincenal/mensual que no le toca, baja, etc). #}
        {% embed '_components/csa_card.html.twig' with { title: 'Próxima cesta', accent: 'sky' } %}
            {% block body %}
                {% if active_share %}
                    <p>Aún no se ha publicado el reparto de tu próxima cesta. Vuelve unos días antes del viernes para ver los detalles y, si lo necesitas, marcar que no la recoges o cambiar de nodo puntualmente.</p>
                {% else %}
                    <p>No tienes una cesta activa registrada, así que no hay nada que mostrar aquí. Si crees que es un error, escribe a <a href="mailto:info@csavegadejarama.org">info@csavegadejarama.org</a>.</p>
                {% endif %}
            {% endblock %}
        {% endembed %}
    {% endif %}

{% endblock %}
