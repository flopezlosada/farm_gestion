{% extends '_layouts/csa_panel.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme password_form 'form_div_layout.html.twig' %}

{% block title %}Cambiar contraseña{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('panel') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('panel_profile') }}">Mi perfil</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cambiar contraseña</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Mi área · Perfil',
        'Cambiar contraseña',
        'Necesitamos tu contraseña actual para confirmar que eres tú.'
    ) }}

    {% for label, messages in app.flashes(['notice', 'error']) %}
        {% for message in messages %}
            <div class="csa-callout csa-callout--{{ label == 'notice' ? 'success' : 'danger' }}" style="margin-bottom: var(--csa-sp-5);">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="csa-stack-lg">

        {{ form_start(password_form, { attr: { class: 'csa-form-narrow' } }) }}
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Nueva contraseña', subtitle: 'Mínimo 8 caracteres.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(password_form.currentPassword, 'Contraseña actual', { full: true }) }}
                        {{ csa.field(password_form.newPassword.first, 'Nueva contraseña') }}
                        {{ csa.field(password_form.newPassword.second, 'Repetir contraseña') }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <a href="{{ path('panel_profile') }}" class="csa-btn csa-btn--secondary">Volver</a>
                <button type="submit" class="csa-btn csa-btn--primary">Cambiar contraseña</button>
            </div>
            {{ form_rest(password_form) }}
        {{ form_end(password_form, { render_rest: false }) }}

    </div>

{% endblock %}
