{# ============================================================
 # Listado de animales (Fowl).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Animales{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Animales</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Animales',
        'Animales',
        'Listado de animales registrados. Cada animal pertenece a un lote y registra su estado actual, fecha de baja y destino.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Id</th>
                    <th>Lote</th>
                    <th>Estado</th>
                    <th>Destino</th>
                    <th class="csa-table__col-tight">Fecha baja</th>
                    <th class="csa-table__col-tight">Peso canal</th>
                    <th class="csa-table__col-tight">€/Kg</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <a class="csa-table__primary" href="{{ path('fowl_show', { id: entity.id }) }}">{{ entity.id }}</a>
                        </td>
                        <td>
                            {% if entity.batch %}
                                <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>{% if entity.fowlstatus %}{{ entity.fowlstatus }}{% else %}—{% endif %}</td>
                        <td>{% if entity.fowldestination %}{{ entity.fowldestination }}{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">
                            {% if entity.putdowndate %}{{ entity.putdowndate|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.carcassweight %}{{ entity.carcassweight }} Kg{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.saleprice %}{{ entity.saleprice }} €{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('fowl_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('fowl_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay animales registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
