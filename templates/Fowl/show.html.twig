{# ============================================================
 # Detalle de un animal — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Animal #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('fowl') }}">Animales</a>
    {% if entity.batch %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'fowl-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-dove"></i>
            </span>
            <div>
                <h1>Animal #{{ entity.id }}</h1>
                {% if entity.batch %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Lote {{ entity.batch }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-fowl-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-fowl-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'fowl-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('fowl_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {% if entity.batch %}
                {{ csa.btn('Volver al lote', { variant: 'ghost', href: path('batch_show', { id: entity.batch.id }) }) }}
            {% else %}
                {{ csa.btn('Volver', { variant: 'ghost', href: path('fowl') }) }}
            {% endif %}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Estado del animal', accent: 'sky' } %}
        {% block body %}
            <dl class="csa-defs">
                {% if entity.fowlstatus %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Estado</dt>
                        <dd class="csa-defs__value">{{ entity.fowlstatus }}</dd>
                    </div>
                {% endif %}
                {% if entity.putdowndate %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Fecha de sacrificio/muerte</dt>
                        <dd class="csa-defs__value">{{ entity.putdowndate|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if entity.note %}
                    <div class="csa-defs__row csa-defs__row--full">
                        <dt class="csa-defs__label">Notas</dt>
                        <dd class="csa-defs__value">{{ entity.note|nl2br }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

    {% if entity.putdownweight or entity.carcassweight or entity.fowldestination or entity.saleprice %}
        <div style="margin-top: var(--csa-sp-5);">
        {% embed '_components/csa_card.html.twig' with { title: 'Sacrificio y destino', accent: 'terracotta' } %}
            {% block body %}
                <dl class="csa-defs">
                    {% if entity.putdownweight %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Peso vivo</dt>
                            <dd class="csa-defs__value">{{ entity.putdownweight }} Kg</dd>
                        </div>
                    {% endif %}
                    {% if entity.carcassweight %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Peso en canal</dt>
                            <dd class="csa-defs__value">{{ entity.carcassweight }} Kg</dd>
                        </div>
                    {% endif %}
                    {% if entity.fowldestination %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Destino</dt>
                            <dd class="csa-defs__value">{{ entity.fowldestination }}</dd>
                        </div>
                    {% endif %}
                    {% if entity.saleprice %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Precio de venta</dt>
                            <dd class="csa-defs__value">{{ entity.saleprice }} €/Kg</dd>
                        </div>
                    {% endif %}
                    {% if entity.fowlpurchaser %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Cliente</dt>
                            <dd class="csa-defs__value">{{ entity.fowlpurchaser }}</dd>
                        </div>
                    {% endif %}
                    {% if entity.fowlrecipient %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Agraciada/o</dt>
                            <dd class="csa-defs__value">{{ entity.fowlrecipient }}</dd>
                        </div>
                    {% endif %}
                    {% if entity.fowluser %}
                        <div class="csa-defs__row">
                            <dt class="csa-defs__label">Repartido a</dt>
                            <dd class="csa-defs__value">{{ entity.fowluser }}</dd>
                        </div>
                    {% endif %}
                </dl>
            {% endblock %}
        {% endembed %}
        </div>
    {% endif %}

{% endblock %}
