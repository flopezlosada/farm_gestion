{# ============================================================
 # Editar animal — shell csa.
 #
 # Conserva los wrappers con id y clase `hide` que el script JS
 # del bloque more_js usa para mostrar/ocultar campos según el
 # valor de fowl_status y fowl_destination. NO renombrar los ids.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar animal #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('fowl') }}">Animales</a>
    {% if entity.batch %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('fowl_show', { id: entity.id }) }}">#{{ entity.id }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Animal',
        'Editar animal #' ~ entity.id,
        entity.batch ? ('Lote ' ~ entity.batch ~ '. Los campos de sacrificio y destino aparecen al elegir el estado correspondiente.') : 'Los campos de sacrificio y destino aparecen al elegir el estado correspondiente.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'fowl-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('fowl_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Estado', subtitle: 'Estado actual del animal y notas.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.fowl_status, 'Estado del animal', { full: true }) }}
                        {{ csa.field(edit_form.note, 'Notas', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {# Sección condicional. Cada wrapper conserva su id y la clase `hide`
               porque el JS del bloque more_js los muestra/oculta a mano. #}
            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Sacrificio y destino', subtitle: 'Sólo aplica cuando el estado lo requiere.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        <div id="put_down_date" class="csa-field--full hide">
                            {{ csa.field(edit_form.put_down_date, 'Fecha de sacrificio/muerte', { full: true, attr: { class: 'csa-input datepicker' } }) }}
                        </div>
                        <div id="put_down_weight" class="csa-field--full hide">
                            {{ csa.field(edit_form.put_down_weight, 'Peso vivo al sacrificio (Kg)', { full: true }) }}
                        </div>
                        <div id="carcass_weight" class="csa-field--full hide">
                            {{ csa.field(edit_form.carcass_weight, 'Peso en canal (Kg)', { full: true }) }}
                        </div>
                        <div id="fowl_destination" class="csa-field--full hide">
                            {{ csa.field(edit_form.fowl_destination, 'Destino del animal', { full: true }) }}
                        </div>
                        <div id="sale_price" class="csa-field--full hide">
                            {{ csa.field(edit_form.sale_price, 'Precio de venta (€/Kg)', { full: true }) }}
                        </div>
                        <div id="fowl_purchaser" class="csa-field--full hide">
                            {{ csa.field(edit_form.fowl_purchaser, 'Cliente', { full: true }) }}
                        </div>
                        <div id="fowl_recipient" class="csa-field--full hide">
                            {{ csa.field(edit_form.fowl_recipient, 'Agraciada/o', { full: true }) }}
                        </div>
                        <div id="fowl_user" class="csa-field--full hide">
                            {{ csa.field(edit_form.fowl_user, 'Repartido a', { full: true }) }}
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-fowl-delete').showModal()">
                        Eliminar animal
                    </button>
            {{ csa.confirm_dialog('confirm-fowl-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'fowl-delete-form',
            }) }}
                </div>
                <div class="csa-row">
                    {% if entity.batch %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('batch_show', { id: entity.batch.id }) }) }}
                    {% else %}
                        {{ csa.btn('Cancelar', { variant: 'ghost', href: path('fowl_show', { id: entity.id }) }) }}
                    {% endif %}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });

        $('#fowl_fowl_status').change(function () {
            if ($(this).val() == 1 || $(this).val() == 2 || $(this).val() == 3) {
                $('#fowl_put_down_weight').val('');
                $('#put_down_weight').hide('slow');
                $('#fowl_carcass_weight').val('');
                $('#carcass_weight').hide('slow');
                $('#fowl_fowl_destination').val('');
                $('#fowl_destination').hide('slow');
                $('#fowl_sale_price').val('');
                $('#sale_price').hide('slow');
                $('#fowl_sale_price').prop('required', false);
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');

                if ($(this).val() == 1) {
                    $('#fowl_put_down_date').val('');
                    $('#put_down_date').hide('slow');
                } else {
                    $('#put_down_date').removeClass('hide');
                    $('#put_down_date').show('slow');
                }
            } else if ($(this).val() == 4) {
                $('#put_down_date').removeClass('hide');
                $('#put_down_date').show('slow');
                $('#put_down_weight').removeClass('hide');
                $('#put_down_weight').show('slow');
                $('#carcass_weight').removeClass('hide');
                $('#carcass_weight').show('slow');
                $('#fowl_destination').removeClass('hide');
                $('#fowl_destination').show('slow');
            } else {
                $('#put_down_date').removeClass('hide');
                $('#put_down_date').show('slow');
                $('#put_down_weight').removeClass('hide');
                $('#put_down_weight').show('slow');
                $('#carcass_weight').removeClass('hide');
                $('#carcass_weight').show('slow');
                $('#fowl_destination').removeClass('hide');
                $('#fowl_destination').show('slow');
                $('#fowl_put_down_weight').val('');
                $('#put_down_weight').hide('slow');
                $('#fowl_carcass_weight').val('');
                $('#carcass_weight').hide('slow');
                $('#fowl_fowl_destination').val('');
                $('#fowl_destination').hide('slow');
                $('#fowl_sale_price').val('');
                $('#sale_price').hide('slow');
                $('#fowl_sale_price').prop('required', false);
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');
                $('#fowl_put_down_date').val('');
                $('#put_down_date').hide('slow');
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');
                $('#fowl_fowl_recipient').val('');
                $('#fowl_recipient').hide('slow');
                $('#fowl_fowl_user').val('');
                $('#fowl_user').hide('slow');
            }
        });

        $('#fowl_fowl_destination').change(function () {
            if ($(this).val() == 1) {
                $('#sale_price').removeClass('hide');
                $('#sale_price').show('slow');
                $('#fowl_sale_price').prop('required', true);

                $('#fowl_purchaser').removeClass('hide');
                $('#fowl_purchaser').show('slow');
                $('#fowl_fowl_recipient').val('');
                $('#fowl_recipient').hide('slow');
                $('#fowl_fowl_user').val('');
                $('#fowl_user').hide('slow');
            } else if ($(this).val() == 2) {
                $('#fowl_sale_price').val('');
                $('#sale_price').show('slow');
                $('#fowl_sale_price').prop('required', false);
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');
                $('#fowl_fowl_user').val('');
                $('#fowl_user').hide('slow');

                $('#fowl_recipient').removeClass('hide');
                $('#fowl_recipient').show('slow');
            } else if ($(this).val() == 3) {
                $('#fowl_sale_price').val('');
                $('#sale_price').hide('slow');
                $('#fowl_sale_price').prop('required', false);
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');
                $('#fowl_fowl_recipient').val('');
                $('#fowl_recipient').hide('slow');

                $('#fowl_user').removeClass('hide');
                $('#fowl_user').show('slow');
            } else {
                $('#fowl_sale_price').val('');
                $('#sale_price').hide('slow');
                $('#fowl_sale_price').prop('required', false);
                $('#fowl_fowl_purchaser').val('');
                $('#fowl_purchaser').hide('slow');
                $('#fowl_fowl_recipient').val('');
                $('#fowl_recipient').hide('slow');
                $('#fowl_fowl_user').val('');
                $('#fowl_user').hide('slow');
            }
        });

        if ($('#fowl_fowl_status').val() == 4) {
            $('#put_down_date').removeClass('hide');
            $('#put_down_date').show('slow');
            $('#put_down_weight').removeClass('hide');
            $('#put_down_weight').show('slow');
            $('#carcass_weight').removeClass('hide');
            $('#carcass_weight').show('slow');
            $('#fowl_destination').removeClass('hide');
            $('#fowl_destination').show('slow');
        }
        if ($('#fowl_fowl_status').val() == 2 || $('#fowl_fowl_status').val() == 3) {
            $('#put_down_date').removeClass('hide');
            $('#put_down_date').show('slow');
        }
        if ($('#fowl_fowl_destination').val() == 1) {
            $('#sale_price').removeClass('hide');
            $('#sale_price').show('slow');
            $('#fowl_sale_price').prop('required', true);
            $('#fowl_purchaser').removeClass('hide');
            $('#fowl_purchaser').show('slow');
        }
        if ($('#fowl_fowl_destination').val() == 2) {
            $('#fowl_recipient').removeClass('hide');
            $('#fowl_recipient').show('slow');
        }
        if ($('#fowl_fowl_destination').val() == 3) {
            $('#fowl_user').removeClass('hide');
            $('#fowl_user').show('slow');
        }
    </script>
{% endblock %}
