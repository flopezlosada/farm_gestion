{# Editar el aforo de un mes — shell csa. #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% set month_names = {
    1: 'Enero', 2: 'Febrero', 3: 'Marzo', 4: 'Abril', 5: 'Mayo', 6: 'Junio',
    7: 'Julio', 8: 'Agosto', 9: 'Septiembre', 10: 'Octubre', 11: 'Noviembre', 12: 'Diciembre'
} %}
{% set month_label = (month_names[month] ?? month) ~ ' ' ~ year %}

{% block title %}Aforo · {{ month_label }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('helper_index') }}">Albergue</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('hosting_capacity_index', { year: year }) }}">Aforo {{ year }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ month_names[month] ?? month }}</span>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header('Albergue', 'Aforo de ' ~ month_label, 'Plazas que ofrecéis ese mes, o ciérralo para no admitir a nadie.') }}

    {{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">
            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Aforo del mes', subtitle: 'Apertura y plazas.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.open, 'Abierto este mes', { full: true }) }}
                        {{ csa.field(form.capacity, 'Plazas (aforo operativo)') }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('hosting_capacity_index', { year: year }) }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Guardar aforo</button>
                </div>
            </div>
        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}
