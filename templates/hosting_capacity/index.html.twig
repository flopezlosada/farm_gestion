{# ============================================================
 # Calendario de aforo del albergue: los 12 meses de un año.
 # ============================================================ #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set month_names = {
    1: 'Enero', 2: 'Febrero', 3: 'Marzo', 4: 'Abril', 5: 'Mayo', 6: 'Junio',
    7: 'Julio', 8: 'Agosto', 9: 'Septiembre', 10: 'Octubre', 11: 'Noviembre', 12: 'Diciembre'
} %}

{% block title %}Albergue · Aforo {{ year }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('helper_index') }}">Albergue</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Aforo {{ year }}</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
.cap-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 14px; }
.cap-card { display: block; text-decoration: none; color: inherit; background: #fff; border: 1px solid var(--csa-rule, #ebe7dd); border-left: 4px solid var(--csa-line-2, #d8d2c2); border-radius: 10px; padding: 16px 18px; transition: 0.14s; }
.cap-card:hover { box-shadow: 0 6px 20px rgba(40,36,24,0.08); transform: translateY(-1px); }
.cap-card--open { border-left-color: #5b7a4c; }
.cap-card--closed { border-left-color: #b15c3b; background: #fbf4f1; }
.cap-card--default { border-left-color: #d8d2c2; }
.cap-card__month { font-family: var(--csa-serif); font-weight: 600; font-size: 17px; color: var(--csa-ink, #1d1c17); }
.cap-card__cap { margin-top: 10px; font-family: var(--csa-serif); font-weight: 600; font-size: 26px; line-height: 1; color: #2f4426; }
.cap-card__cap--closed { color: #8c3b1f; font-size: 18px; }
.cap-card__cap--default { color: #8d8773; }
.cap-card__note { font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--csa-ink-faint, #8d8773); margin-top: 6px; font-weight: 500; }

/* Ancla: camas de la casa (aforo físico), editable aquí. */
.cap-physical { background: #fff; border: 1px solid var(--csa-rule, #ebe7dd); border-radius: 10px; padding: 16px 20px; margin-bottom: 22px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
.cap-physical__label { font-family: var(--csa-serif); font-weight: 600; font-size: 15px; color: var(--csa-ink, #1d1c17); }
.cap-physical__form { display: flex; align-items: center; gap: 8px; }
.cap-physical__input { width: 72px; height: 36px; box-sizing: border-box; border: 1px solid var(--csa-line-2, #d8d2c2); border-radius: 6px; padding: 0 10px; font-size: 16px; text-align: center; font-family: var(--csa-serif); }
.cap-physical__help { font-size: 12px; color: var(--csa-ink-faint, #8d8773); flex: 1 1 100%; }
</style>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header(
        'Albergue',
        'Aforo del albergue',
        'Cada mes ofrece por defecto las camas de la casa. Aquí puedes cerrar meses (vacaciones, obras…) o reducir las plazas de un mes concreto.'
    ) }}

    {# Ancla: las camas de la casa. Es el máximo; el aforo de cada mes no lo supera. #}
    {% set can_edit = is_granted('ROLE_GESTION_ALBERGUE_EDIT') %}
    <div class="cap-physical">
        <div class="cap-physical__label">Camas en la casa</div>
        {% if can_edit %}
            <form method="post" action="{{ path('hosting_capacity_set_physical') }}" class="cap-physical__form">
                <input type="hidden" name="_token" value="{{ csrf_token('hosting_physical') }}">
                <input type="hidden" name="year" value="{{ year }}">
                <input type="number" name="physical_capacity" value="{{ physical_capacity }}" min="0" max="50" class="cap-physical__input">
                {{ csa.btn('Guardar', { variant: 'secondary', size: 'sm', type: 'submit' }) }}
            </form>
            <div class="cap-physical__help">Es el máximo de plazas: el aforo de cada mes no puede superarlo. Por defecto, cada mes ofrece estas camas.</div>
        {% else %}
            <div class="cap-physical__input" style="display: inline-flex; align-items: center; justify-content: center;">{{ physical_capacity }}</div>
            <div class="cap-physical__help">Es el máximo de plazas: el aforo de cada mes no puede superarlo. Por defecto, cada mes ofrece estas camas.</div>
        {% endif %}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div class="csa-row" style="align-items: center; gap: 12px;">
            {{ csa.btn('◂ ' ~ (year - 1), { variant: 'ghost', href: path('hosting_capacity_index', { year: year - 1 }) }) }}
            <strong style="font-family: var(--csa-serif); font-size: 20px;">{{ year }}</strong>
            {{ csa.btn((year + 1) ~ ' ▸', { variant: 'ghost', href: path('hosting_capacity_index', { year: year + 1 }) }) }}
        </div>
        {{ csa.btn('Volver a voluntarios', { variant: 'ghost', href: path('helper_index') }) }}
    </div>

    <div class="cap-grid">
        {% for month, row in months %}
            {% if row is null %}
                {% set kind = 'default' %}
            {% elseif row.open %}
                {% set kind = 'open' %}
            {% else %}
                {% set kind = 'closed' %}
            {% endif %}
            {% if can_edit %}<a class="cap-card cap-card--{{ kind }}" href="{{ path('hosting_capacity_edit', { year: year, month: month }) }}">{% else %}<div class="cap-card cap-card--{{ kind }}">{% endif %}
                <div class="cap-card__month">{{ month_names[month] }}</div>
                {% if row is null %}
                    <div class="cap-card__cap cap-card__cap--default">{{ physical_capacity }}</div>
                    <div class="cap-card__note">Sin configurar (físico)</div>
                {% elseif row.open %}
                    <div class="cap-card__cap">{{ row.capacity }}</div>
                    <div class="cap-card__note">Plazas</div>
                {% else %}
                    <div class="cap-card__cap cap-card__cap--closed">Cerrado</div>
                    <div class="cap-card__note">No se admite a nadie</div>
                {% endif %}
            {% if can_edit %}</a>{% else %}</div>{% endif %}
        {% endfor %}
    </div>
{% endblock %}
