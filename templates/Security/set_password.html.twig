{# ============================================================
 # /account/password — (re)establecer contraseña
 # ============================================================
 # Pantalla bloqueante a la que llega cualquier cuenta con
 # passwordSet = false: primer acceso por magic-link, o forzado
 # por la administración. Hasta que no se elija una contraseña
 # válida no se puede usar el resto de la aplicación (lo impone
 # ForcePasswordChangeSubscriber).
 # ============================================================ #}
{% extends "_layouts/csa_auth.html.twig" %}

{% block title %}Establece tu contraseña{% endblock %}

{% block csa_main %}

    <section class="csa-auth__card" aria-labelledby="csa-auth-title">

        <h1 id="csa-auth-title" class="csa-auth__title">Establece tu contraseña</h1>
        <p class="csa-auth__lead">
            Para continuar, elige una contraseña. La usarás para entrar con tu email la próxima vez.
        </p>

        {{ form_start(form, {'attr': {'class': 'csa-auth__form'}}) }}

            <div class="csa-field">
                {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'csa-field__label', 'for': 'csa-pwd-1'}}) }}
                {{ form_widget(form.plainPassword.first, {
                    'attr': {
                        'class': 'csa-input',
                        'id': 'csa-pwd-1',
                        'autocomplete': 'new-password',
                        'required': 'required',
                        'autofocus': 'autofocus',
                    }
                }) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="csa-field">
                {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'csa-field__label', 'for': 'csa-pwd-2'}}) }}
                {{ form_widget(form.plainPassword.second, {
                    'attr': {
                        'class': 'csa-input',
                        'id': 'csa-pwd-2',
                        'autocomplete': 'new-password',
                        'required': 'required',
                    }
                }) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>

            {{ form_errors(form.plainPassword) }}

            {{ form_widget(form.submit, {'attr': {'class': 'csa-btn csa-btn--primary csa-btn--block csa-auth__submit'}}) }}

        {{ form_end(form) }}

        <p class="csa-auth__note">
            Mínimo 8 caracteres, con al menos una letra y un número.
        </p>

    </section>

{% endblock %}
