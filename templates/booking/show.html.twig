{# ============================================================
 # Detalle de un evento público (Booking) — admin.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Evento público · {{ booking.title }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('booking_index') }}">Eventos públicos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">{{ booking.title }}</span>
{% endblock %}

{% block csa_main %}

    <form id="booking-delete-form" method="post"
          action="{{ path('booking_delete', { id: booking.id }) }}"
          style="display: none;">
        <input type="hidden" name="_method" value="DELETE">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ booking.id) }}">
    </form>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-calendar-check-o"></i>
            </span>
            <div>
                <h1>{{ booking.title }}</h1>
                <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                    {% if booking.beginAt %}{{ booking.beginAt|format_date('long', locale='es') }}{% endif %}
                    {% if booking.endAt %} — {{ booking.endAt|format_date('long', locale='es') }}{% endif %}
                </div>
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-booking-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-booking-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'booking-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('booking_edit', { id: booking.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('booking_index') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos del evento', accent: 'sky' } %}
        {% block body %}
            <dl class="csa-defs">
                {% if booking.beginAt %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Inicio</dt>
                        <dd class="csa-defs__value">{{ booking.beginAt|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if booking.endAt %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Fin</dt>
                        <dd class="csa-defs__value">{{ booking.endAt|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if booking.content is defined and booking.content %}
                    <div class="csa-defs__row csa-defs__row--full">
                        <dt class="csa-defs__label">Contenido</dt>
                        <dd class="csa-defs__value">{{ booking.content|raw }}</dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
