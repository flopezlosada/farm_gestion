{# ============================================================
 # Nuevo evento público (Booking) — admin.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo evento público{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('booking_index') }}">Eventos públicos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Web pública',
        'Nuevo evento público',
        'Aparecerá en el calendario de la web pública.'
    ) }}

    {{ form_start(form, {
        action: path('booking_new'),
        method: 'post',
        attr: { role: 'form', class: 'csa-form-narrow', enctype: 'multipart/form-data' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Título y descripción.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.title, 'Título', { full: true }) }}
                        {{ csa.field(form.content, 'Contenido', { full: true, attr: { class: 'tinymce', 'data-theme': 'advanced' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Fechas', subtitle: 'Cuándo empieza y termina el evento.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.beginAt, 'Inicio', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.endAt, 'Fin', { attr: { class: 'csa-input datepicker' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Imagen', subtitle: 'Cartel o ilustración del evento.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.file, 'Archivo de imagen', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('booking_index') }) }}
                    <button type="submit" class="csa-btn csa-btn--primary">Crear evento</button>
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    {{ tinymce_init() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
