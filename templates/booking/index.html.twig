{# ============================================================
 # Listado de eventos públicos (Booking) — admin.
 # La vista pública es Booking/calendar.html.twig (no se toca).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Eventos públicos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Eventos públicos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Comunicación · Web pública',
        'Eventos públicos',
        'Citas que aparecen en el calendario de la web pública (booking).'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo evento', { variant: 'primary', href: path('booking_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Título</th>
                    <th class="csa-table__col-tight">Inicio</th>
                    <th class="csa-table__col-tight">Fin</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for booking in bookings %}
                    <tr>
                        <td>
                            <a class="csa-table__primary" href="{{ path('booking_show', { id: booking.id }) }}">{{ booking.title }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if booking.beginAt %}{{ booking.beginAt|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if booking.endAt %}{{ booking.endAt|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('booking_show', { id: booking.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('booking_edit', { id: booking.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay eventos públicos.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
