{# ============================================================
 # Listado de sacos de pienso/grano usados en lotes (Sack).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Sacos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Sacos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Gallinas',
        'Sacos de pienso y grano',
        'Sacos asignados a cada lote de gallinas como alimento. Cada saco registra fecha de uso, peso y precio total.'
    ) }}

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Id</th>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Lote</th>
                    <th class="csa-table__col-tight">Peso</th>
                    <th class="csa-table__col-tight">Precio total</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            <a class="csa-table__primary" href="{{ path('sack_show', { id: entity.id }) }}">{{ entity.id }}</a>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.deliverydate %}{{ entity.deliverydate|format_date('medium', locale='es') }}{% else %}—{% endif %}
                        </td>
                        <td>
                            {% if entity.batch %}
                                <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td class="csa-table__col-tight">{{ entity.weight }} Kg</td>
                        <td class="csa-table__col-tight">{{ entity.totalprice }} €</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('sack_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('sack_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay sacos registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
