{# ============================================================
 # Detalle de un saco — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Saco #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('sack') }}">Sacos</a>
    {% if entity.batch %}
        <span class="csa-topbar__crumbs-sep">/</span>
        <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
    {% endif %}
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'sack-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-shopping-bag"></i>
            </span>
            <div>
                <h1>Saco #{{ entity.id }}</h1>
                {% if entity.batch %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Lote {{ entity.batch }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-sack-delete').showModal()">
                Eliminar
            </button>
            {{ csa.confirm_dialog('confirm-sack-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'sack-delete-form',
            }) }}
            {{ csa.btn('Editar', { variant: 'secondary', href: path('sack_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {% if entity.batch %}
                {{ csa.btn('Volver al lote', { variant: 'ghost', href: path('batch_show', { id: entity.batch.id }) }) }}
            {% else %}
                {{ csa.btn('Volver', { variant: 'ghost', href: path('sack') }) }}
            {% endif %}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos del saco', accent: 'ochre' } %}
        {% block body %}
            <dl class="csa-defs">
                {% if entity.deliverydate %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Fecha de uso</dt>
                        <dd class="csa-defs__value">{{ entity.deliverydate|format_date('long', locale='es') }}</dd>
                    </div>
                {% endif %}
                {% if entity.product %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Producto</dt>
                        <dd class="csa-defs__value">{{ entity.product }}</dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Peso</dt>
                    <dd class="csa-defs__value">{{ entity.weight }} Kg</dd>
                </div>
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Precio total</dt>
                    <dd class="csa-defs__value">{{ entity.totalprice }} €</dd>
                </div>
                {% if entity.batch %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Lote</dt>
                        <dd class="csa-defs__value">
                            <a href="{{ path('batch_show', { id: entity.batch.id }) }}">{{ entity.batch }}</a>
                        </dd>
                    </div>
                {% endif %}
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
