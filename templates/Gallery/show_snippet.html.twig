{# ============================================================
 # Galería inline para un post del blog público.
 #
 # Lo invoca AppExtension al expandir [[insert_media_gallery_<id>]]
 # dentro del cuerpo del post. Renderiza todas las imágenes
 # `Image` con `single=0` asociadas al blog en un grid responsivo
 # y arranca lightGallery (cargada desde CDN en base_front.html.twig)
 # para abrir el lightbox al click.
 # ============================================================ #}

<div class="csa-gallery" id="csa-gallery-{{ blog.id }}">
    {% for image in images %}
        <a href="{{ asset('uploads/gallery/images/' ~ image.image) }}"
           data-sub-html="<h4>{{ image.title|default('') }}</h4>">
            <img src="{{ asset('uploads/gallery/images/' ~ image.image)|imagine_filter('image_history') }}"
                 alt="{{ image.title|default('') }}">
        </a>
    {% endfor %}
</div>

<style>
    .csa-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 6px;
        margin: 1.25rem 0;
    }
    .csa-gallery a {
        display: block;
        overflow: hidden;
        border-radius: 4px;
    }
    .csa-gallery img {
        width: 100%;
        height: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
        transition: transform .3s ease, opacity .2s ease;
    }
    .csa-gallery a:hover img {
        transform: scale(1.04);
        opacity: .92;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var el = document.getElementById('csa-gallery-{{ blog.id }}');
        if (el && typeof lightGallery === 'function') {
            lightGallery(el, {
                selector: 'a',
                download: false,
                speed: 350
            });
        }
    });
</script>
