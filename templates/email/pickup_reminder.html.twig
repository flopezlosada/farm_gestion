<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <title>Recordatorio de cesta · CSA Vega de Jarama</title>
</head>
<body style="font-family: Arial, sans-serif; color: #333; max-width: 580px; margin: 0 auto; padding: 24px;">

    <h2 style="color: #5a8f3d; margin-top: 0;">Hola {{ partner.name }},</h2>

    <p>Te recordamos que <strong>el {{ pickup_date|format_date('full', locale='es') }}</strong>
       te toca recoger tu cesta {{ modality }}{% if node_name %} en <strong>{{ node_name }}</strong>{% else %} en la CSA Vega de Jarama{% endif %}.</p>

    {% if was_shifted %}
        <p style="background: #fdf3e0; border-left: 3px solid #d99820; padding: 10px 14px;">
            <strong>Atención:</strong> el reparto se ha desplazado a esta fecha (no es el día habitual).
        </p>
    {% endif %}

    {% set deadline_phrase %}{% if deadline %}antes del <strong>{{ deadline|format_datetime(pattern="EEEE d 'de' MMMM 'a las' HH:mm", locale='es') }}</strong>{% else %}con la debida antelación{% endif %}{% endset %}

    {% if can_act %}
        <p>Si no puedes recoger tu cesta esta semana o quieres cambiar tu turno A↔B puntualmente,
           puedes hacerlo tú directamente desde tu calendario {{ deadline_phrase|raw }}:</p>
        <p style="text-align: center; margin: 24px 0;">
            <a href="{{ calendar_url }}"
               style="background: #5a8f3d; color: #fff; text-decoration: none; padding: 12px 22px; border-radius: 6px; display: inline-block;">
                Ver mi calendario de recogida
            </a>
        </p>
    {% else %}
        <p>Si por cualquier motivo no puedes recoger tu cesta esta semana o quieres cambiar tu turno A↔B
           puntualmente, dínoslo {{ deadline_phrase|raw }}.</p>
    {% endif %}

    <p style="margin-top: 32px; color: #777; font-size: 13px;">
        Un abrazo,<br>
        CSA Vega de Jarama<br>
        <a href="https://csavegadejarama.org">csavegadejarama.org</a>
    </p>

</body>
</html>
