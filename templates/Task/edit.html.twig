{# ============================================================
 # Editar tarea — shell csa.
 #
 # Nota: el edit usa TaskType (base) que sólo expone title, content,
 # labour, crop_workings y users. Las fechas y month/period no se
 # editan desde aquí (sería bug del legacy si se necesita).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar tarea · {{ entity.title }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task_show', { id: entity.id }) }}">{{ entity.title }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Tareas',
        'Editar tarea',
        'Cambia título, descripción, labor, cultivos o responsables.'
    ) }}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'task-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        action: path('task_update', { id: entity.id }),
        method: 'put',
        attr: { role: 'form', class: 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Título y descripción.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.title, 'Título', { full: true }) }}
                        {{ csa.field(edit_form.content, 'Contenido', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Cultivo y labor', subtitle: 'Si la tarea pertenece a uno o varios cultivos.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.labour, 'Labor', { full: true }) }}
                        {{ csa.field(edit_form.crop_workings, 'Cultivos asociados', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Responsables', subtitle: 'Personas asignadas a la tarea.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.users, 'Responsables', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="submit" form="task-delete-form" class="csa-btn csa-btn--ghost"
                            onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                        Eliminar tarea
                    </button>
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('task_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}
