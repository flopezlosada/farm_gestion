{# ============================================================
 # Nueva tarea con fecha fija (tipo 2) — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nueva tarea con fecha fija{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task_dashboard') }}">Nueva</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Fecha fija</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Tareas',
        'Nueva tarea con fecha fija',
        'Tareas con día concreto de realización.'
    ) }}

    {{ form_start(form, { attr: { role: 'form', class: 'csa-form-narrow' } }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Título y descripción.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.title, 'Título', { full: true }) }}
                        {{ csa.field(form.content, 'Contenido', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '2', title: 'Fecha', subtitle: 'Día concreto en el que se realiza.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.expected_date, 'Fecha de realización', { full: true, attr: { class: 'csa-input datepicker' } }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '3', title: 'Cultivo y labor', subtitle: 'Si la tarea pertenece a uno o varios cultivos.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.labour, 'Labor', { full: true }) }}
                        {{ csa.field(form.crop_workings, 'Cultivos asociados', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed '_components/csa_form_section.html.twig' with { num: '4', title: 'Responsables', subtitle: 'Personas asignadas a la tarea.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.users, 'Responsables', { full: true }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('task_dashboard') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Crear tarea',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
