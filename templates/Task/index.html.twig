{# ============================================================
 # Panel de tareas con tabs por tipo y estado.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Tareas{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Tareas</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Tareas',
        'Tareas ' ~ ('now'|format_datetime(locale='es', pattern='MMMM yyyy')),
        'Pendientes del mes, asignadas a ti, relacionadas con cultivos, y finalizadas.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nueva tarea', { variant: 'primary', href: path('task_dashboard'), icon: 'fa-plus' }) }}
        </div>
    </div>

    {# Tabs estilo Bootstrap 3 (el shell csa los hereda visualmente). #}
    <ul class="nav nav-tabs" role="tablist">
        <li role="presentation" class="active"><a href="#my_task" data-toggle="tab" aria-controls="my_task" role="tab">Mis tareas</a></li>
        <li role="presentation"><a href="#home" data-toggle="tab" aria-controls="home" role="tab">Pendientes del mes</a></li>
        <li role="presentation"><a href="#crop" data-toggle="tab" aria-controls="crop" role="tab">De cultivos</a></li>
        <li role="presentation"><a href="#aprox" data-toggle="tab" aria-controls="aprox" role="tab">Aproximadas</a></li>
        <li role="presentation"><a href="#periodic" data-toggle="tab" aria-controls="periodic" role="tab">Periódicas</a></li>
        <li role="presentation"><a href="#date" data-toggle="tab" aria-controls="date" role="tab">Con fecha</a></li>
        <li role="presentation"><a href="#punctual" data-toggle="tab" aria-controls="punctual" role="tab">Sin fecha</a></li>
        <li role="presentation"><a href="#ended" data-toggle="tab" aria-controls="ended" role="tab">Finalizadas</a></li>
    </ul>

    <div class="tab-content" style="padding-top: var(--csa-sp-5);">
        <div role="tabpanel" class="tab-pane fade in active" id="my_task">
            <h3>Mis tareas pendientes</h3>
            {% for task in user_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No tienes tareas asignadas pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="home">
            <h3>Tareas pendientes este mes</h3>
            {% for task in pending_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas pendientes este mes.</p>
            {% endfor %}
            {% for task in punctual_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="crop">
            <h3>Tareas relacionadas con cultivos</h3>
            {% for task in crop_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas de cultivo pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="aprox">
            <h3>Con fecha aproximada ({{ aprox_tasks|length }})</h3>
            {% for task in aprox_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas aproximadas pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="periodic">
            <h3>Tareas periódicas</h3>
            {% for task in periodic_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas periódicas pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="date">
            <h3>Con fecha fija</h3>
            {% for task in date_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas con fecha fija pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="punctual">
            <h3>Sin fecha</h3>
            {% for task in punctual_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas sin fecha pendientes.</p>
            {% endfor %}
        </div>
        <div role="tabpanel" class="tab-pane fade" id="ended">
            <h3>Finalizadas este mes</h3>
            {% for task in ended_tasks %}
                {% include 'Task/_card.html.twig' with { task: task } %}
            {% else %}
                <p class="csa-muted">No hay tareas finalizadas este mes.</p>
            {% endfor %}
        </div>
    </div>

{% endblock %}
