{# ============================================================
 # Selector de tipo de tarea antes de crear una nueva.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Nueva tarea{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('task') }}">Tareas</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nueva</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Tareas',
        'Añadir tarea',
        'Elige el tipo de tarea según cuándo se tenga que realizar.'
    ) }}

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--csa-sp-5); margin-top: var(--csa-sp-5);">

        <a href="{{ path('task_aprox_new', { task_type_id: 3 }) }}" class="csa-link-card" style="display: block; text-decoration: none; padding: var(--csa-sp-6); border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); background: var(--csa-ochre-soft); border-left: 4px solid var(--csa-ochre);">
            <i class="fa fa-compass" style="font-size: 32px; color: var(--csa-amber);"></i>
            <h3 style="margin: var(--csa-sp-3) 0 var(--csa-sp-2);">Con fecha aproximada</h3>
            <p class="csa-soft" style="margin: 0;">Indicas el mes (o una fecha tentativa).</p>
        </a>

        <a href="{{ path('task_new', { task_type_id: 1 }) }}" class="csa-link-card" style="display: block; text-decoration: none; padding: var(--csa-sp-6); border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); background: var(--csa-green-soft); border-left: 4px solid var(--csa-green);">
            <i class="fa fa-crosshairs" style="font-size: 32px; color: var(--csa-green);"></i>
            <h3 style="margin: var(--csa-sp-3) 0 var(--csa-sp-2);">Sin fecha</h3>
            <p class="csa-soft" style="margin: 0;">Cuando no es urgente y no hay deadline.</p>
        </a>

        <a href="{{ path('task_date_new', { task_type_id: 2 }) }}" class="csa-link-card" style="display: block; text-decoration: none; padding: var(--csa-sp-6); border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); background: var(--csa-terracotta-soft); border-left: 4px solid var(--csa-terracotta);">
            <i class="fa fa-gavel" style="font-size: 32px; color: var(--csa-terracotta);"></i>
            <h3 style="margin: var(--csa-sp-3) 0 var(--csa-sp-2);">Fecha fija</h3>
            <p class="csa-soft" style="margin: 0;">Día concreto en el que hay que ejecutarla.</p>
        </a>

        <a href="{{ path('task_periodic_new', { task_type_id: 4 }) }}" class="csa-link-card" style="display: block; text-decoration: none; padding: var(--csa-sp-6); border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); background: var(--csa-plum-soft); border-left: 4px solid var(--csa-plum);">
            <i class="fa fa-cogs" style="font-size: 32px; color: var(--csa-plum);"></i>
            <h3 style="margin: var(--csa-sp-3) 0 var(--csa-sp-2);">Periódica</h3>
            <p class="csa-soft" style="margin: 0;">Se repite cada cierto número de días.</p>
        </a>

    </div>

    <div style="margin-top: var(--csa-sp-6);">
        {{ csa.btn('Volver al listado', { variant: 'ghost', href: path('task'), icon: 'fa-arrow-left' }) }}
    </div>

{% endblock %}
