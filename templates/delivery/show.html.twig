{# ============================================================
 # Detalle del reparto de un viernes concreto.
 # Recibe:
 #   - basket     Basket de ese viernes (entidad).
 #   - report     WeeklyDeliveryReport con totales y agrupaciones.
 #   - exception  DeliveryException si la hay para ese viernes; si null, reparto normal.
 #   - rows       Lista plana para DataTables.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Reparto · {{ basket.date|format_date('full', locale='es') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('calendar') }}">Calendario</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Reparto del {{ basket.date|format_date('medium', locale='es') }}</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Reparto del ' ~ basket.date|format_date('full', locale='es'),
        'Cesta #' ~ basket.id ~ (basket.amount ? ' · ' ~ basket.amount ~ ' kg' : '')
    ) }}

    {% if exception %}
        <div class="csa-alert csa-alert--warning" style="margin-bottom: var(--csa-sp-5);">
            <i class="fa fa-exclamation-triangle"></i>
            {% if exception.cancelled %}
                <strong>Este viernes está marcado como SIN REPARTO.</strong>
                {% if exception.notes %} {{ exception.notes }}{% endif %}
            {% else %}
                <strong>El reparto está desplazado al {{ exception.shiftedDate|format_date('full', locale='es') }}.</strong>
                {% if exception.notes %} {{ exception.notes }}{% endif %}
            {% endif %}
        </div>
    {% endif %}

    {# Resumen rápido por modalidad #}
    <div class="csa-row" style="gap: var(--csa-sp-3); flex-wrap: wrap; margin-bottom: var(--csa-sp-5);">
        {% set total = report.basket_weekly_partners_amount + report.basket_biweekly_partners_amount + report.basket_monthly_partners_amount + report.basket_old_half_basket_partners_amount %}
        {% set tiles = [
            { label: 'Total cestas',  value: total,                                          tone: 'green' },
            { label: 'Semanales',     value: report.basket_weekly_partners_amount,           tone: 'sky' },
            { label: 'Quincenales',   value: report.basket_biweekly_partners_amount,         tone: 'plum' },
            { label: 'Mensuales',     value: report.basket_monthly_partners_amount,          tone: 'ochre' },
            { label: 'Media cesta',   value: report.basket_old_half_basket_partners_amount,  tone: 'terracotta' },
            { label: 'Solo huevos',   value: report.basket_only_egg_partners_amount,         tone: 'neutral' }
        ] %}
        {% for t in tiles %}
            <div class="csa-card csa-card--accent-{{ t.tone }}" style="flex: 1; min-width: 140px; text-align: center; padding: var(--csa-sp-3);">
                <div class="csa-muted csa-small">{{ t.label }}</div>
                <div style="font-size: 1.6em; font-weight: 600;">{{ t.value }}</div>
            </div>
        {% endfor %}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-3);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('PDF por ciudad', { variant: 'ghost', href: path('generate_pdf_basket_weekly', { basket_id: basket.id, alternative_order: 0 }), icon: 'fa-file-pdf-o' }) }}
            {{ csa.btn('PDF por grupo de recogida', { variant: 'ghost', href: path('generate_pdf_basket_weekly', { basket_id: basket.id, alternative_order: 1 }), icon: 'fa-file-pdf-o' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Socix</th>
                    <th class="csa-table__col-tight">Modalidad</th>
                    <th class="csa-table__col-tight">Nodo</th>
                    <th class="csa-table__col-tight">Grupo A/B</th>
                    <th class="csa-table__col-tight">Cestas</th>
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    <tr>
                        <td>{{ row.surname }}{% if row.name %}, {{ row.name }}{% endif %}</td>
                        <td class="csa-table__col-tight">{{ row.modality }}</td>
                        <td class="csa-table__col-tight">{{ row.node|default('—') }}</td>
                        <td class="csa-table__col-tight">{{ row.group|default('—') }}</td>
                        <td class="csa-table__col-tight">{{ row.amount }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay nadie en este reparto.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
