{# ============================================================
 # Registro de cambios de reparto de una semana (Basket).
 # Pantalla de CONSULTA: el alta de cambios vive en el calendario de
 # recogida de la ficha del socix (partner_delivery_calendar).
 # Recibe:
 #   - selected     Basket (viernes-ciclo) seleccionado.
 #   - is_future    bool, si la semana aún no ha pasado (habilita "Deshacer").
 #   - week_strip   { weeks: [{basket, active, past, has_activity}], prev_id, next_id }
 #   - shifts       PartnerDeliveryShift cuyo origen es la semana seleccionada.
 #   - skips        WeeklyBasket en "no recoge" de la semana, sin cambio de día.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{# Macros autocontenidos: en Twig los macros NO ven las variables del
 # template, así que el array de meses se define dentro de cada uno. #}
{% macro week_label(date) %}
    {%- set m = ['', 'ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'] -%}
    {%- set s = date|date_modify('-4 days') -%}
    {%- set e = date|date_modify('+2 days') -%}
    {{- s|date('j') }}–{{ e|date('j') }} {{ m[s|date('n')] }}{% if (s|date('n')) != (e|date('n')) %}–{{ m[e|date('n')] }}{% endif -%}
{% endmacro %}

{% macro daymon(date) %}
    {%- set m = ['', 'ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'] -%}
    {{- date|date('j') }} {{ m[date|date('n')] -}}
{% endmacro %}

{% macro initials(p) %}
    {%- set a = (p.surname ?: p.name)|default('?')|slice(0, 1) -%}
    {%- set b = (p.surname and p.name) ? p.name|slice(0, 1) : '' -%}
    {{- (a ~ b)|upper -}}
{% endmacro %}

{% block title %}Histórico de cambios{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('calendar') }}">Calendario</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Histórico de cambios</span>
{% endblock %}

{% block csa_main %}
    {% import 'delivery/shifts_index.html.twig' as self %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Histórico de cambios',
        'Consulta de cambios de día y de no-recoge, semana a semana. Aquí no se registran cambios: para hacer uno, usa el calendario de recogida de la ficha del socix.'
    ) }}

    {# ===== Tira selectora de semana (morada, distinta de la de reparto) ===== #}
    <nav class="dlv-reg-weeks" aria-label="Selector de semana de reparto">
        {% if week_strip.prev_id %}
            <a class="dlv-reg-weeks__nav" title="Semanas anteriores"
               href="{{ path('delivery_shifts_index', { basket: week_strip.prev_id }) }}">‹</a>
        {% else %}
            <span class="dlv-reg-weeks__nav dlv-reg-weeks__nav--off" aria-hidden="true">‹</span>
        {% endif %}

        {% for w in week_strip.weeks %}
            <a href="{{ path('delivery_shifts_index', { basket: w.basket.id }) }}"
               class="dlv-reg-weeks__chip{{ w.active ? ' is-active' }}{{ w.past ? ' is-past' }}{{ w.closed ? ' is-closed' }}"
               {{ w.active ? 'aria-current="true"' }}
               {{ w.closed ? 'title="Semana cerrada · sin reparto"' }}>
                <span class="dlv-reg-weeks__top">{{ w.closed ? 'cerrada' : 'semana' }}</span>
                <span class="dlv-reg-weeks__num">{{ self.week_label(w.basket.date)|trim }}</span>
                {% if w.closed %}<span class="dlv-reg-weeks__dot dlv-reg-weeks__dot--closed" title="Semana cerrada"></span>
                {% elseif w.has_activity %}<span class="dlv-reg-weeks__dot" title="Tiene cambios"></span>{% endif %}
            </a>
        {% endfor %}

        {% if week_strip.next_id %}
            <a class="dlv-reg-weeks__nav" title="Semanas siguientes"
               href="{{ path('delivery_shifts_index', { basket: week_strip.next_id }) }}">›</a>
        {% else %}
            <span class="dlv-reg-weeks__nav dlv-reg-weeks__nav--off" aria-hidden="true">›</span>
        {% endif %}
    </nav>

    {% if closure %}
        <div class="chg-closure" role="status">
            <span class="chg-closure__icon"><i class="fa fa-ban" aria-hidden="true"></i></span>
            <div class="chg-closure__body">
                <strong>Semana cerrada · no hay reparto</strong>
                <span>{{ closure.notes ?: 'Cierre general de todos los nodos esta semana.' }} Los cambios de día de abajo suelen ser consecuencia del cierre.</span>
            </div>
        </div>
    {% endif %}

    {% set _have_any = shifts is not empty or skips is not empty %}

    <div class="chg-wrap">

        {% if shifts is not empty %}
            {% embed '_components/csa_card.html.twig' with {
                title: 'Cambios de día',
                subtitle: 'Socixs que esta semana recogen otro día distinto al que les tocaba.',
                accent: 'plum',
                icon: 'fa-exchange',
            } %}
                {% block body %}
                    {% import 'delivery/shifts_index.html.twig' as self %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <ul class="chg-list">
                        {% for shift in shifts %}
                            <li class="chg-row">
                                <span class="chg-avatar chg-avatar--plum">{{ self.initials(shift.partner)|trim }}</span>
                                <div class="chg-main">
                                    <span class="chg-name">{{ shift.partner.surname }}{% if shift.partner.name %}, {{ shift.partner.name }}{% endif %}</span>
                                    <span class="chg-meta">Registrado el {{ shift.created|date('d/m/Y') }} a las {{ shift.created|date('H:i') }}</span>
                                </div>
                                <span class="chg-move" title="Recoge el {{ shift.toBasket.date|date('d/m/Y') }} en lugar del {{ shift.fromBasket.date|date('d/m/Y') }}">
                                    <span class="chg-move__from">{{ self.daymon(shift.fromBasket.date) }}</span>
                                    <i class="fa fa-long-arrow-right" aria-hidden="true"></i>
                                    <span class="chg-move__to">{{ self.daymon(shift.toBasket.date) }}</span>
                                </span>
                                {% if is_future %}
                                    <button type="button" class="csa-btn csa-btn--info-soft csa-btn--sm csa-btn--undo chg-undo"
                                            onclick="document.getElementById('confirm-shift-cancel-{{ shift.id }}').showModal()">
                                        <span class="csa-btn__icon-chip" aria-hidden="true"><i class="fa fa-undo"></i></span>
                                        Deshacer
                                    </button>
                                    {{ csa.confirm_dialog('confirm-shift-cancel-' ~ shift.id, {
                                        variant: 'info',
                                        eyebrow: 'Deshacer',
                                        title: 'Deshacer el cambio de día',
                                        body: 'Antes de deshacer un cambio, asegúrate de haberlo hablado con el socix. Volverá a recoger en su día original.',
                                        confirm_label: 'Deshacer',
                                        action: path('delivery_shifts_cancel', { id: shift.id }),
                                        csrf_token: csrf_token('delivery_shift_cancel_' ~ shift.id),
                                    }) }}
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if skips is not empty %}
            {% embed '_components/csa_card.html.twig' with {
                title: 'No recogen esta semana',
                subtitle: 'Socixs que se saltan la cesta sin cambiar de día.',
                accent: 'terracotta',
                icon: 'fa-ban',
            } %}
                {% block body %}
                    {% import 'delivery/shifts_index.html.twig' as self %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <ul class="chg-list">
                        {% for wb in skips %}
                            <li class="chg-row">
                                <span class="chg-avatar chg-avatar--terracotta">{{ self.initials(wb.partner)|trim }}</span>
                                <div class="chg-main">
                                    <span class="chg-name">{{ wb.partner.surname }}{% if wb.partner.name %}, {{ wb.partner.name }}{% endif %}</span>
                                    <span class="chg-meta">No recoge la cesta de esta semana</span>
                                </div>
                                {% if is_future %}
                                    <button type="button" class="csa-btn csa-btn--info-soft csa-btn--sm csa-btn--undo chg-undo"
                                            onclick="document.getElementById('confirm-skip-undo-{{ wb.partner.id }}-{{ selected.id }}').showModal()">
                                        <span class="csa-btn__icon-chip" aria-hidden="true"><i class="fa fa-undo"></i></span>
                                        Deshacer
                                    </button>
                                    {{ csa.confirm_dialog('confirm-skip-undo-' ~ wb.partner.id ~ '-' ~ selected.id, {
                                        variant: 'info',
                                        eyebrow: 'Deshacer',
                                        title: 'Deshacer el salto de cesta',
                                        body: 'Antes de deshacer, asegúrate de haberlo hablado con el socix. Volverá a recoger esta semana.',
                                        confirm_label: 'Deshacer',
                                        action: path('delivery_shifts_skip_toggle'),
                                        csrf_token: csrf_token('delivery_shift_skip'),
                                        extra_fields: [
                                            { name: 'partner_id', value: wb.partner.id },
                                            { name: 'basket_id', value: selected.id },
                                        ],
                                    }) }}
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endblock %}
            {% endembed %}
        {% endif %}

        {% if not _have_any %}
            {% embed '_components/csa_card.html.twig' with { title: 'Sin cambios', accent: 'plum' } %}
                {% block body %}
                    <div class="chg-empty">
                        <i class="fa fa-check-circle" aria-hidden="true"></i>
                        <p>No hay cambios ni saltos registrados para esta semana.</p>
                    </div>
                {% endblock %}
            {% endembed %}
        {% endif %}

    </div>

    <style>
        /* ===== Tira selectora de semana (registro) =====
           Misma metáfora que la mini-timeline de reparto pero en morado
           (plum) para que se lea como "consulta/histórico" y no se confunda
           con la tira operativa azul de la pantalla de reparto v2. */
        .dlv-reg-weeks {
            display: flex; align-items: stretch; gap: 6px;
            flex-wrap: wrap;
            margin-top: var(--csa-sp-4);
        }
        .dlv-reg-weeks__nav,
        .dlv-reg-weeks__chip {
            display: inline-flex; flex-direction: column; align-items: center; justify-content: center;
            min-width: 78px; padding: 7px 12px;
            border: 1px solid var(--csa-rule, #e7e2d8);
            border-radius: var(--csa-radius-md, 10px);
            background: var(--csa-surface, #fff);
            text-decoration: none; color: var(--csa-ink, #2b2b2b);
            font-family: inherit; line-height: 1.2;
        }
        .dlv-reg-weeks__nav {
            justify-content: center; font-size: 18px; min-width: 40px;
            color: var(--csa-plum); cursor: pointer;
        }
        .dlv-reg-weeks__nav--off { color: var(--csa-ink-soft); opacity: .4; cursor: default; }
        .dlv-reg-weeks__chip { transition: background 120ms ease, border-color 120ms ease, transform 80ms ease; }
        .dlv-reg-weeks__chip:hover { background: var(--csa-plum-soft); border-color: var(--csa-plum-soft); }
        .dlv-reg-weeks__chip:active { transform: translateY(1px); }
        .dlv-reg-weeks__chip.is-past { opacity: .6; }
        .dlv-reg-weeks__chip.is-active {
            position: relative;
            background: var(--csa-plum); border-color: var(--csa-plum); color: #fff;
            opacity: 1; box-shadow: 0 2px 8px rgba(0,0,0,.12);
        }
        .dlv-reg-weeks__top { font-size: 10px; letter-spacing: .08em; text-transform: uppercase; opacity: .7; }
        .dlv-reg-weeks__num { font-weight: 700; font-size: var(--csa-fs-sm, 13px); white-space: nowrap; }
        .dlv-reg-weeks__dot {
            position: absolute; top: 6px; right: 7px;
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--csa-amber);
            box-shadow: 0 0 0 2px var(--csa-surface, #fff);
        }
        .dlv-reg-weeks__dot--closed { background: var(--csa-terracotta); }
        .dlv-reg-weeks__chip.is-active .dlv-reg-weeks__dot { box-shadow: 0 0 0 2px var(--csa-plum); }
        /* Semana cerrada: borde terracota y "cerrada" tenue; cuando además está
           activa, conserva el fondo plum y solo cambia el indicador. */
        .dlv-reg-weeks__chip.is-closed:not(.is-active) {
            border-color: var(--csa-terracotta);
            background: var(--csa-terracotta-soft);
        }
        .dlv-reg-weeks__chip.is-closed:not(.is-active) .dlv-reg-weeks__top { color: var(--csa-terracotta); opacity: 1; }

        /* ===== Banner de cierre de semana ===== */
        .chg-closure {
            display: flex; align-items: flex-start; gap: var(--csa-sp-3);
            margin-top: var(--csa-sp-5);
            padding: var(--csa-sp-3) var(--csa-sp-4);
            border: 1px solid var(--csa-terracotta);
            border-left-width: 4px;
            border-radius: var(--csa-radius-md, 10px);
            background: var(--csa-terracotta-soft);
        }
        .chg-closure__icon { color: var(--csa-terracotta); font-size: 18px; line-height: 1.4; }
        .chg-closure__body { display: flex; flex-direction: column; gap: 2px; }
        .chg-closure__body strong { color: var(--csa-ink); }
        .chg-closure__body span { font-size: var(--csa-fs-sm, 13px); color: var(--csa-ink-soft); }

        /* ===== Filas de cambio ===== */
        .chg-wrap { margin-top: var(--csa-sp-6); display: flex; flex-direction: column; gap: var(--csa-sp-5); }
        .chg-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
        .chg-row {
            display: flex; align-items: center; gap: var(--csa-sp-4);
            padding: var(--csa-sp-3) var(--csa-sp-1);
            border-bottom: 1px solid var(--csa-rule-soft, #efeae0);
        }
        .chg-list .chg-row:last-child { border-bottom: none; }

        .chg-avatar {
            flex: 0 0 auto;
            display: inline-flex; align-items: center; justify-content: center;
            width: 38px; height: 38px; border-radius: 50%;
            font-weight: 700; font-size: 13px; letter-spacing: .02em;
        }
        .chg-avatar--plum { background: var(--csa-plum-soft); color: var(--csa-plum); }
        .chg-avatar--terracotta { background: var(--csa-terracotta-soft); color: var(--csa-terracotta); }

        .chg-main { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
        .chg-name { font-weight: 600; color: var(--csa-ink); }
        .chg-meta { font-size: var(--csa-fs-sm, 13px); color: var(--csa-ink-soft); }

        .chg-move {
            display: inline-flex; align-items: center; gap: 8px;
            margin-left: auto;
            padding: 5px 12px; border-radius: 999px;
            background: var(--csa-plum-soft);
            font-size: var(--csa-fs-sm, 13px); white-space: nowrap;
        }
        .chg-move__from { color: var(--csa-ink-soft); text-transform: capitalize; }
        .chg-move i { color: var(--csa-plum); }
        .chg-move__to { font-weight: 700; color: var(--csa-plum); text-transform: capitalize; }

        /* No-recogen (sin badge): el botón se empuja a la derecha. Cambios de
           día: el badge ya tiene margin-left:auto y el botón se le pega detrás. */
        .chg-undo { flex: 0 0 auto; margin-left: auto; }
        .chg-move + .chg-undo { margin-left: 8px; }

        .csa-btn--undo { display: inline-flex; align-items: center; gap: 8px; padding-left: 6px; }
        .csa-btn__icon-chip {
            display: inline-flex; align-items: center; justify-content: center;
            width: 22px; height: 22px; border-radius: 50%;
            background: rgba(255,255,255,0.85); color: inherit; font-size: 11px;
        }

        .chg-empty {
            display: flex; flex-direction: column; align-items: center; gap: var(--csa-sp-2);
            padding: var(--csa-sp-5) 0; color: var(--csa-ink-soft); text-align: center;
        }
        .chg-empty i { font-size: 28px; color: var(--csa-plum); opacity: .55; }
        .chg-empty p { margin: 0; }

        @media (max-width: 640px) {
            .chg-row { flex-wrap: wrap; }
            .chg-move { margin-left: 52px; }
            .chg-undo { margin-left: auto !important; }
        }
    </style>

{% endblock %}
