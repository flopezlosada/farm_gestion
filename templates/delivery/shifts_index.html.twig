{# ============================================================
 # Gestión de cambios puntuales de viernes (DeliveryShift).
 # Recibe:
 #   - shifts            Lista de PartnerDeliveryShift activos.
 #   - partners          Lista de Partner para el selector (datalist).
 #   - upcoming_baskets  Baskets futuros para los selectores from/to.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Cambios puntuales de viernes{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('calendar') }}">Calendario</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Cambios puntuales de viernes</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Socixs · Reparto',
        'Cambios puntuales de viernes',
        'Intercambios entre viernes pedidos por socixs o registrados por administración.'
    ) }}

    {# ===== Nuevo cambio ===== #}
    {% embed '_components/csa_card.html.twig' with { title: 'Registrar nuevo cambio', accent: 'sky' } %}
        {% block body %}
            <form action="{{ path('delivery_shifts_apply') }}" method="post" class="csa-stack">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('delivery_shift_apply') }}">

                <div class="csa-field">
                    <label for="csa-shift-partner" class="csa-field__label">Socix</label>
                    <input type="text" id="csa-shift-partner-name" list="csa-shift-partner-list"
                           class="csa-input" placeholder="Empieza a escribir nombre o apellido…"
                           autocomplete="off">
                    <input type="hidden" id="csa-shift-partner" name="partner_id" required>
                    <datalist id="csa-shift-partner-list">
                        {% for p in partners %}
                            <option value="{{ p.surname }}, {{ p.name }}" data-id="{{ p.id }}"></option>
                        {% endfor %}
                    </datalist>
                </div>

                <div class="csa-field">
                    <label for="csa-shift-from" class="csa-field__label">Viernes origen (donde le tocaba)</label>
                    <select id="csa-shift-from" name="from_basket_id" class="csa-input" required>
                        <option value="">— elige un viernes —</option>
                        {% for b in upcoming_baskets %}
                            <option value="{{ b.id }}">{{ b.date|date('d/m/Y') }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="csa-field">
                    <label for="csa-shift-to" class="csa-field__label">Viernes destino (donde recogerá)</label>
                    <select id="csa-shift-to" name="to_basket_id" class="csa-input" required>
                        <option value="">— elige un viernes —</option>
                        {% for b in upcoming_baskets %}
                            <option value="{{ b.id }}">{{ b.date|date('d/m/Y') }}</option>
                        {% endfor %}
                    </select>
                </div>

                <label class="csa-field__inline">
                    <input type="checkbox" name="force_bypassable" value="1">
                    Forzar reglas que admiten bypass (equilibrio &le; 3 cestas, deadline pasado).
                </label>

                <button type="submit" class="csa-btn csa-btn--primary">Registrar cambio</button>
            </form>

            <script>
                (function () {
                    var nameInput = document.getElementById('csa-shift-partner-name');
                    var idInput = document.getElementById('csa-shift-partner');
                    var list = document.getElementById('csa-shift-partner-list');
                    if (!nameInput || !idInput || !list) return;
                    nameInput.addEventListener('input', function () {
                        var match = Array.from(list.options).find(function (o) {
                            return o.value === nameInput.value;
                        });
                        idInput.value = match ? match.getAttribute('data-id') : '';
                    });
                }());
            </script>
        {% endblock %}
    {% endembed %}

    {# ===== Lista de shifts activos ===== #}
    {% embed '_components/csa_card.html.twig' with { title: 'Cambios activos', accent: 'plum' } %}
        {% block body %}
            {% if shifts is empty %}
                <p class="csa-muted">No hay cambios puntuales registrados.</p>
            {% else %}
                <div class="csa-table-wrap">
                    <table class="csa-table">
                        <thead>
                            <tr>
                                <th>Socix</th>
                                <th class="csa-table__col-tight">Viernes original</th>
                                <th class="csa-table__col-tight">Viernes destino</th>
                                <th class="csa-table__col-tight">Registrado</th>
                                <th class="csa-table__col-tight">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for shift in shifts %}
                                <tr>
                                    <td>
                                        {{ shift.partner.surname }}{% if shift.partner.name %}, {{ shift.partner.name }}{% endif %}
                                    </td>
                                    <td class="csa-table__col-tight">{{ shift.fromBasket.date|date('d/m/Y') }}</td>
                                    <td class="csa-table__col-tight">{{ shift.toBasket.date|date('d/m/Y') }}</td>
                                    <td class="csa-table__col-tight">{{ shift.created|date('d/m/Y H:i') }}</td>
                                    <td class="csa-table__col-tight">
                                        <form action="{{ path('delivery_shifts_cancel', { id: shift.id }) }}" method="post"
                                              onsubmit="return confirm('¿Cancelar este cambio puntual?');"
                                              style="display: inline-flex; gap: var(--csa-sp-2); align-items: center;">
                                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('delivery_shift_cancel_' ~ shift.id) }}">
                                            <label class="csa-small csa-muted">
                                                <input type="checkbox" name="force_bypassable" value="1">
                                                forzar
                                            </label>
                                            <button type="submit" class="csa-btn csa-btn--secondary csa-btn--small">Cancelar</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}

{% endblock %}
