{# ============================================================
 # Listado de reparto SEMANAL — elegir nodos e imprimir el viernes en curso.
 # Se llega desde el botón "Listado semanal" de la pantalla de reparto.
 #
 # Recibe (de DeliveryController::printableSelect):
 #   - basket   Basket del viernes.
 #   - nodes    list<{node, delivers:bool, physical_date:?Date}>.
 #   - any_delivers  bool.
 # ============================================================ #}
{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% set _month_es = ['', 'enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'] %}

{% block title %}Imprimir reparto semanal · {{ basket.date|date('d/m/Y') }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    Reparto
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Listado semanal</span>
{% endblock %}

{% block more_css %}
{{ parent() }}
<style>
.npick { display: grid; border: 1px solid var(--csa-rule); border-radius: var(--csa-radius-md); overflow: hidden; max-width: 620px; }
.npick__item { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border-bottom: 1px solid var(--csa-rule-soft); cursor: pointer; }
.npick__item:last-child { border-bottom: 0; }
.npick__item:hover { background: var(--csa-surface-alt); }
.npick__item input { width: 17px; height: 17px; accent-color: var(--csa-green); }
.npick__name { font-weight: 600; color: var(--csa-ink); }
.npick__meta { margin-left: auto; font-size: var(--csa-fs-xs); color: var(--csa-ink-muted); }
.npick__meta--off { color: var(--csa-terracotta); }
.npick__actions { display: flex; gap: 10px; align-items: center; margin-top: 20px; }
</style>
{% endblock %}

{% block csa_main %}
    {{ csa.page_header(
        'Reparto · Listado semanal',
        'Viernes ' ~ basket.date|date('j') ~ ' de ' ~ _month_es[basket.date|date('n')],
        'Elige los nodos a incluir. Cada nodo sale en su propia hoja.'
    ) }}

    {% embed '_components/csa_card.html.twig' with { title: 'Nodos a incluir', accent: 'green' } %}
        {% block body %}
            {% import '_macros/csa.html.twig' as csa %}
            <form method="get" action="{{ path('delivery_printable_pdf', { basketId: basket.id }) }}" target="_blank">
                <div class="npick">
                    {% for row in nodes %}
                        <label class="npick__item">
                            <input type="checkbox" name="nodes[]" value="{{ row.node.id }}" {{ row.delivers ? 'checked' : 'disabled' }}>
                            <span class="npick__name">{{ row.node.name }}</span>
                            {% if row.delivers %}
                                <span class="npick__meta">reparte el viernes {{ row.physical_date ? row.physical_date|date('d/m') : '—' }}</span>
                            {% else %}
                                <span class="npick__meta npick__meta--off">no reparte ese viernes</span>
                            {% endif %}
                        </label>
                    {% endfor %}
                </div>

                {% if not any_delivers %}
                    {{ csa.callout('Ningún nodo reparte ese viernes: no hay listado que imprimir.', 'warning', 'exclamation-triangle') }}
                {% endif %}

                <div class="npick__actions">
                    {{ csa.btn('Generar listado semanal', { variant: 'primary', icon: 'fa-print', type: 'submit', disabled: not any_delivers }) }}
                    {{ csa.btn('Volver al reparto', { variant: 'ghost', href: path('delivery_by_node', { nodeId: nodes|first.node.id, basketId: basket.id }) }) }}
                </div>
            </form>
        {% endblock %}
    {% endembed %}
{% endblock %}
