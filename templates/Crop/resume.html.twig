{% extends 'layout_list.html.twig' %}

{% block main %}
<div class="panel panel-default">
    <div class="panel-heading">
        Listado producción por años
    </div>
    <div class="panel-body">
        <div class="table-responsive">
            <table id="table_list" class="table table-striped table-bordered table-hover dataTable no-footer"
                   aria-describedby="dataTables-example_info">
                <thead>
                <tr>
                    <th>Cultivo</th>
                    {% for year in years %}
                        <th>{{ year }}</th>
                    {% endfor %}
                </tr>
                </thead>
                <tfoot>
                <tr role="row">
                </tr>
                </tfoot>
                <tbody>
                {% for crop_production in production %}
                    {% if crop_production[1]>0 %}
                        <tr>
                            <td>{{ crop_production[0].name }}</td>
                            <td>{{ crop_production [1] }}</td>
                            <td>{{ crop_production [2] }}</td>
                            <td>{{ crop_production [3] }}</td>
                            <td>{{ crop_production [4] }}</td>
                        </tr>
                    {% endif %}
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}

{% block title_wrapper %}

{% endblock %}


