{# ============================================================
 # Editar cultivo (Crop) — migrado al shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme edit_form 'form_div_layout.html.twig' %}

{% block title %}Editar · {{ entity }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('crop') }}">Catálogo de cultivos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('crop_show', { id: entity.id }) }}">{{ entity }}</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Editar</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Cultivo',
        'Editar ' ~ entity,
        'Renombra el cultivo o ajusta su nombre científico.'
    ) }}

    {# delete_form oculto fuera del edit_form para no anidar — el botón
     # del footer se asocia vía atributo HTML5 form="..." #}
    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'crop-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    {{ form_start(edit_form, {
        'action': path('crop_update', { id: entity.id }),
        'method': 'put',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Identidad', subtitle: 'Nombre común y nombre científico.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(edit_form.name, 'Nombre') }}
                        {{ csa.field(edit_form.latin_name, 'Nombre en latín', { hint: 'opcional' }) }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div>
                    <button type="button" class="csa-btn csa-btn--ghost"
                    onclick="document.getElementById('confirm-crop-delete').showModal()">
                        Eliminar cultivo
                    </button>
            {{ csa.confirm_dialog('confirm-crop-delete', {
                variant: 'danger',
                eyebrow: 'Acción permanente',
                title: 'Eliminar este registro',
                body: 'Se borrará de forma definitiva y no podrá recuperarse.',
                confirm_label: 'Eliminar',
                external_form_id: 'crop-delete-form',
            }) }}
                </div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('crop_show', { id: entity.id }) }) }}
                    {{ form_widget(edit_form.submit, {
                        label: 'Guardar cambios',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(edit_form) }}
    {{ form_end(edit_form, { render_rest: false }) }}

{% endblock %}
