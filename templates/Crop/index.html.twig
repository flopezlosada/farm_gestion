{# ============================================================
 # Listado de cultivos (Crop) — migrado al shell csa.
 # ============================================================
 # Crop = catálogo de cultivos. CropWorking = ciclo concreto de
 # un cultivo en una temporada. Desde aquí se "pone en producción"
 # un cultivo, lo que crea un CropWorking nuevo asociado.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Catálogo de cultivos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span>Granja</span>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Catálogo de cultivos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Huerta',
        'Catálogo de cultivos',
        'Listado de variedades cultivables. Producción registrada en ' ~ year ~ '. Para abrir un ciclo nuevo, "Poner en producción".'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo cultivo', { variant: 'primary', href: path('crop_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th>Cultivo</th>
                    <th class="csa-table__col-tight">Producción {{ year }}</th>
                    <th class="csa-table__col-tight">Estado</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td>
                            <div class="csa-table__id-cell">
                                {{ csa.crop_marker(entity) }}
                                <div>
                                    <a class="csa-table__primary" href="{{ path('crop_show', { id: entity.id }) }}">
                                        {{ entity.name }}
                                    </a>
                                    {% if entity.latinName %}
                                        <div class="csa-table__sub csa-italic">{{ entity.latinName }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.totalProduction %}
                                <strong>{{ entity.totalProduction }}</strong> kg
                            {% else %}
                                <span class="csa-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="csa-table__col-tight">
                            {% if entity.isInProduction == 1 %}
                                {{ csa.badge('En producción', 'green') }}
                            {% else %}
                                {{ csa.badge('Inactivo', 'neutral') }}
                            {% endif %}
                        </td>
                        <td class="csa-table__actions">
                            <a href="{{ path('crop_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('crop_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                            {% if entity.isInProduction == 0 %}
                                <a href="{{ path('cropworking_new', { crop_id: entity.id }) }}" title="Poner en producción" aria-label="Poner en producción"><i class="fa fa-play"></i></a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            No hay cultivos en el catálogo.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
