{# ============================================================
 # Detalle de un reparto — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Reparto #{{ entity.id }}{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('collect') }}">Repartos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">#{{ entity.id }}</span>
{% endblock %}

{% block csa_main %}

    <div style="display: none;">
        {{ form_start(delete_form, { attr: { id: 'collect-delete-form' } }) }}
            {{ form_rest(delete_form) }}
        {{ form_end(delete_form, { render_rest: false }) }}
    </div>

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-6); align-items: flex-start;">
        <div class="csa-row" style="align-items: flex-start; gap: var(--csa-sp-4);">
            <span class="csa-table__id-marker" style="width: 64px; height: 64px; font-size: 28px; border-radius: var(--csa-radius-lg);">
                <i class="fa fa-shopping-basket"></i>
            </span>
            <div>
                <h1>Reparto del {{ entity.collectDate|format_date('long', locale='es') }}</h1>
                {% if entity.user %}
                    <div class="csa-serif csa-italic csa-soft" style="margin-top: var(--csa-sp-2);">
                        Para {{ entity.user }}
                    </div>
                {% endif %}
            </div>
        </div>
        <div class="csa-row">
            <button type="submit" form="collect-delete-form" class="csa-btn csa-btn--ghost"
                    onclick="return confirm('¿Seguro? Esta acción no se puede deshacer.');">
                Eliminar
            </button>
            {{ csa.btn('Editar', { variant: 'secondary', href: path('collect_edit', { id: entity.id }), icon: 'fa-pencil' }) }}
            {{ csa.btn('Volver', { variant: 'ghost', href: path('collect') }) }}
        </div>
    </div>

    {% embed '_components/csa_card.html.twig' with { title: 'Datos del reparto', accent: 'green' } %}
        {% block body %}
            <dl class="csa-defs">
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Fecha</dt>
                    <dd class="csa-defs__value">{{ entity.collectDate|format_date('long', locale='es') }}</dd>
                </div>
                {% if entity.product %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Producto</dt>
                        <dd class="csa-defs__value">{{ entity.product }}</dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Cantidad</dt>
                    <dd class="csa-defs__value">{{ entity.amount }}{% if entity.unity %} {{ entity.unity }}{% endif %}</dd>
                </div>
                {% if entity.user %}
                    <div class="csa-defs__row">
                        <dt class="csa-defs__label">Quién lo recibe</dt>
                        <dd class="csa-defs__value">{{ entity.user }}</dd>
                    </div>
                {% endif %}
                <div class="csa-defs__row">
                    <dt class="csa-defs__label">Semana del año</dt>
                    <dd class="csa-defs__value">{{ entity.week }}</dd>
                </div>
            </dl>
        {% endblock %}
    {% endembed %}

{% endblock %}
