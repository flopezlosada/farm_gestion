{# ============================================================
 # Nuevo reparto — shell csa.
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}
{% form_theme form 'form_div_layout.html.twig' %}

{% block title %}Nuevo reparto{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <a href="{{ path('collect') }}">Repartos</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Nuevo</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Reparto interno',
        'Nuevo reparto',
        'Cantidad de producto que recoges. Se anotará en tu cuenta.'
    ) }}

    {{ form_start(form, {
        'action': path('collect_create'),
        'method': 'post',
        'attr': { 'role': 'form', 'class': 'csa-form-narrow' }
    }) }}

        <div class="csa-stack-lg">

            {% embed '_components/csa_form_section.html.twig' with { num: '1', title: 'Datos del reparto', subtitle: 'Fecha, producto y cantidad.' } %}
                {% block body %}
                    {% import '_macros/csa.html.twig' as csa %}
                    <div class="csa-form-grid">
                        {{ csa.field(form.collect_date, 'Fecha de reparto', { attr: { class: 'csa-input datepicker' } }) }}
                        {{ csa.field(form.amount, 'Cantidad') }}
                        {{ csa.field(form.product, 'Producto repartido', { full: true }) }}
                        {{ csa.field(form.unity, 'Unidades') }}
                    </div>
                {% endblock %}
            {% endembed %}

            <div class="csa-row-between" style="padding-top: var(--csa-sp-5); border-top: 1px solid var(--csa-rule);">
                <div></div>
                <div class="csa-row">
                    {{ csa.btn('Cancelar', { variant: 'ghost', href: path('collect') }) }}
                    {{ form_widget(form.submit, {
                        label: 'Añadir reparto',
                        attr: { class: 'csa-btn csa-btn--primary' }
                    }) }}
                </div>
            </div>

        </div>

        {{ form_rest(form) }}
    {{ form_end(form, { render_rest: false }) }}

{% endblock %}

{% block more_js %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.datepicker, .datepicker2, .datepicker3')
            .forEach(function (el) { el.type = 'date'; });
    </script>
{% endblock %}
