{# ============================================================
 # Listado de repartos (Collect).
 # ============================================================ #}

{% extends '_layouts/csa_shell.html.twig' %}
{% import '_macros/csa.html.twig' as csa %}

{% block title %}Repartos{% endblock %}

{% block csa_crumbs %}
    <a href="{{ path('dashboard') }}">Inicio</a>
    <span class="csa-topbar__crumbs-sep">/</span>
    <span class="csa-topbar__crumb-active">Repartos</span>
{% endblock %}

{% block csa_main %}

    {{ csa.page_header(
        'Granja · Reparto interno',
        'Repartos',
        'Cantidad de productos que se llevan socixs o personas trabajadoras. Se anotan en sus cuentas.'
    ) }}

    <div class="csa-row-between" style="margin-bottom: var(--csa-sp-5);">
        <div></div>
        <div class="csa-row">
            {{ csa.btn('Nuevo reparto', { variant: 'primary', href: path('collect_new'), icon: 'fa-plus' }) }}
        </div>
    </div>

    <div class="csa-table-wrap">
        <table class="csa-table" data-paginate>
            <thead>
                <tr>
                    <th class="csa-table__col-tight">Fecha</th>
                    <th>Producto</th>
                    <th>Quién</th>
                    <th class="csa-table__col-tight">Cantidad</th>
                    <th class="csa-table__col-tight">Semana</th>
                    <th class="csa-table__actions">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% for entity in entities %}
                    <tr>
                        <td class="csa-table__col-tight">
                            {% if entity.collectdate %}
                                <a class="csa-table__primary" href="{{ path('collect_show', { id: entity.id }) }}">{{ entity.collectdate|format_date('medium', locale='es') }}</a>
                            {% else %}—{% endif %}
                        </td>
                        <td>{% if entity.product %}{{ entity.product }}{% else %}—{% endif %}</td>
                        <td>{% if entity.user %}{{ entity.user }}{% else %}—{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.amount }}{% if entity.unity %} {{ entity.unity }}{% endif %}</td>
                        <td class="csa-table__col-tight">{{ entity.week }}</td>
                        <td class="csa-table__actions">
                            <a href="{{ path('collect_show', { id: entity.id }) }}" title="Ver" aria-label="Ver"><i class="fa fa-eye"></i></a>
                            <a href="{{ path('collect_edit', { id: entity.id }) }}" title="Editar" aria-label="Editar"><i class="fa fa-pencil"></i></a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="csa-muted" style="text-align: center; padding: var(--csa-sp-8);">
                            Aún no hay repartos registrados.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}
