# In all environments, the following files are loaded if they exist,
# the later taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices/configuration.html#infrastructure-related-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=***REMOVED***
#TRUSTED_PROXIES=127.0.0.1,127.0.0.2
#TRUSTED_HOSTS='^localhost|example\.com$'
###< symfony/framework-bundle ###
###> doctrine/doctrine-bundle ###
# DDEV crea por defecto la BBDD 'db' con credenciales 'db:db' en el host 'db'.
# Estas credenciales son públicas (estándar DDEV), no son secretos.
DATABASE_URL=mysql://db:db@db:3306/db?serverVersion=8.0
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# DDEV expone Mailpit en localhost:1025 dentro del contenedor web.
# Web UI: http://csa-vega.ddev.site:8025
MAILER_DSN=smtp://localhost:1025
# Remitente por defecto. Cada entorno lo puede overridear en su .env.local
# (p.ej. staging añade un prefijo [STAGING] para no confundir con producción).
MAILER_FROM="CSA Vega de Jarama <noreply@csavegadejarama.org>"
# La red de seguridad de destinatarios para staging (redirigir todos los emails
# a una bandeja propia) NO vive aquí: es un ajuste del sistema de configuración
# (AppSettings::EMAIL_REDIRECT_TO), conmutable desde /gestion/settings/diagnostics.
###< symfony/mailer ###

###> symfony/routing ###
# Base para URLs absolutas generadas fuera de HTTP (emails enviados por
# comandos de cron). En prod: https://csavegadejarama.org via .env.local.
DEFAULT_URI=https://csa-vega.ddev.site
###< symfony/routing ###

###> knpuniversity/oauth2-client-bundle ###
# SSO con Google. Vacíos por defecto: se rellenan en .env.local (dev) y en
# prod vía `composer dump-env prod` (.env.local.php chmod 600). NO commitear
# secretos aquí. Crear el cliente OAuth en Google Cloud Console y registrar la
# redirect URI: https://<host>/connect/google/check
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
###< knpuniversity/oauth2-client-bundle ###

# Umbral operativo de la regla de balance entre viernes consecutivos
# en cambios puntuales de viernes (DeliveryShift). Default 3 cestas.
# En desarrollo se puede subir desde .env.local para sortear datasets
# históricos con cohortes A/B desbalanceadas.
BALANCE_THRESHOLD=3
