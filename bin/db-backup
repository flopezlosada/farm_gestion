#!/usr/bin/env bash
# Vuelca el golden (db_prod_snapshot, la fuente de verdad) a un fichero
# fuera del repo. Ejecutar SIEMPRE tras tocar el golden.
# El fichero lleva datos personales reales (LOPD): nunca va al repo.
set -euo pipefail

DEST="${HOME}/csa-backups"
TS="$(date +%Y%m%d-%H%M%S)"
FILE="${DEST}/golden-${TS}.sql.gz"

mkdir -p "${DEST}"
ddev exec 'mysqldump -udb -pdb --single-transaction --no-tablespaces db_prod_snapshot' \
  2>/dev/null | gzip > "${FILE}"

# Sanity check: que el dump no esté vacío.
if [ "$(gunzip -c "${FILE}" | grep -c 'INSERT INTO `partner`')" -lt 1 ]; then
  echo "ERROR: el dump no contiene datos de partner. Revisar." >&2
  rm -f "${FILE}"
  exit 1
fi

echo "Backup golden -> ${FILE}"
ls -lh "${DEST}"
