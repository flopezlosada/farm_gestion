# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
# Gate de deprecations: cero tolerancia con las NUESTRAS (self/direct, son
# arreglables al momento), tope altísimo para el total porque el parser de
# anotaciones de Doctrine (74 entidades aún con @ORM\, ver CLAUDE.md) emite
# millones de avisos indirectos por suite — con el tope viejo de 999999 la
# suite salía verde pero con exit code 1. quiet[] recorta el listado para
# que el informe siga siendo legible. Revisar al migrar a ORM 3/attributes.
SYMFONY_DEPRECATIONS_HELPER='max[total]=999999999&max[self]=0&max[direct]=0&quiet[]=indirect&quiet[]=other'
PANTHER_APP_ENV=panther

# BBDD aislada para tests, en el mismo MySQL de DDEV.
# Se sobrescribe el DATABASE_URL de .env.local cuando APP_ENV=test.
DATABASE_URL=mysql://db:db@db:3306/db_test?serverVersion=8.0

# Mailer null:// para que los tests no intenten conectar al Mailpit de
# DDEV (puede no estar corriendo cuando arrancan los tests).
MAILER_DSN=null://null
