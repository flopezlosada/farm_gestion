{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "a2lix/translation-form-bundle": "^3.0@dev",
        "beberlei/doctrineextensions": "^1.2",
        "composer/package-versions-deprecated": "1.11.99.1",
        "doctrine/annotations": "^1.0",
        "doctrine/common": "^3.4",
        "doctrine/doctrine-bundle": "^2.0@dev",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "doctrine/orm": "^2.6",
        "dompdf/dompdf": "^2.0",
        "flopezlosada/calendar-bundle": "dev-master",
        "friendsofsymfony/ckeditor-bundle": "^2.1",
        "friendsofsymfony/jsrouting-bundle": "^3.0",
        "gedmo/doctrine-extensions": "^3.0",
        "knplabs/knp-paginator-bundle": "^6.0",
        "liip/imagine-bundle": "^2.1",
        "mhujer/breadcrumbs-bundle": "^1.5.7",
        "phpdocumentor/reflection-docblock": "^5.2",
        "phpoffice/phpspreadsheet": "^1.10",
        "stfalcon/tinymce-bundle": "^3.0",
        "stof/doctrine-extensions-bundle": "^1.5",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/expression-language": "7.4.*",
        "symfony/flex": "^2.4",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/monolog-bundle": "^3.4",
        "symfony/process": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/property-info": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/web-link": "7.4.*",
        "symfony/webpack-encore-bundle": "^2.0",
        "symfony/workflow": "7.4.*",
        "symfony/yaml": "7.4.*",
        "tattali/calendar-bundle": "^1.2",
        "twig/intl-extra": "^3.12",
        "twig/string-extra": "^3.12",
        "twig/twig": "^3.12"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "fakerphp/faker": "^1.20",
        "rector/rector": "^2.4",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/debug-bundle": "7.4.*",
        "symfony/maker-bundle": "^1.0@dev",
        "symfony/phpunit-bridge": "^7.4",
        "symfony/stopwatch": "7.4.*",
        "symfony/var-dumper": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "composer/package-versions-deprecated": true,
            "symfony/runtime": true,
            "symfony/recipes": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "restore-legacy-assets-symlink": [
            "ln -sfn ../../src/Resources/public public/bundles/app"
        ],
        "post-install-cmd": [
            "@auto-scripts",
            "@restore-legacy-assets-symlink"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@restore-legacy-assets-symlink"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },

    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "7.4.*"
        }
    }
}
