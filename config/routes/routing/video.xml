<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="video" path="/">
        <default key="_controller">App\Controller\VideoController::index</default>
    </route>

    <route id="video_show" path="/{id}/show">
        <default key="_controller">App\Controller\VideoController::show</default>
    </route>

    <route id="video_new" path="/new/{foreign_key}/{object_class}">
        <default key="_controller">App\Controller\VideoController::new</default>
    </route>

    <route id="video_create" path="/create/{foreign_key}/{object_class}" methods="POST">
        <default key="_controller">App\Controller\VideoController::create</default>
    </route>

    <route id="video_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\VideoController::edit</default>
    </route>

    <route id="video_update" path="/{id}/update" methods="POST|PUT">
        <default key="_controller">App\Controller\VideoController::update</default>
    </route>

    <route id="video_delete" path="/{id}/delete" methods="POST|DELETE">
        <default key="_controller">App\Controller\VideoController::delete</default>
    </route>
    <route id="video_fast_delete" path="/{id}/delete" methods="GET">
        <default key="_controller">App\Controller\VideoController::fastDelete</default>
    </route>
</routes>
