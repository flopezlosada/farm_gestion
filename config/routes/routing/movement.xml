<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="movement" path="/">
        <default key="_controller">App\Controller\MovementController::index</default>
    </route>

    <route id="movement_show" path="/{id}/show">
        <default key="_controller">App\Controller\MovementController::show</default>
    </route>

    <route id="movement_new" path="/new/{batch_id}">
        <default key="_controller">App\Controller\MovementController::new</default>
    </route>

    <route id="movement_create" path="/create/{batch_id}" methods="POST">
        <default key="_controller">App\Controller\MovementController::create</default>
    </route>

    <route id="movement_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\MovementController::edit</default>
    </route>

    <route id="movement_update" path="/{id}/update" methods="POST|PUT">
        <default key="_controller">App\Controller\MovementController::update</default>
    </route>

    <route id="movement_delete" path="/{id}/delete" methods="POST|DELETE">
        <default key="_controller">App\Controller\MovementController::delete</default>
    </route>

</routes>
