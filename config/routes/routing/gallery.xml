<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="gallery" path="/">
        <default key="_controller">App\Controller\GalleryController:index</default>
    </route>

    <route id="gallery_show" path="/{id}/show">
        <default key="_controller">App\Controller\GalleryController:show</default>
    </route>

    <route id="gallery_new" path="/new/{foreign_key}/{object_class}">
        <default key="_controller">App\Controller\GalleryController:new</default>
    </route>

    <route id="gallery_create" path="/create/{foreign_key}/{object_class}" methods="POST">
        <default key="_controller">App\Controller\GalleryController:create</default>
    </route>

    <route id="gallery_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\GalleryController:edit</default>
    </route>

    <route id="gallery_update" path="/{id}/update" methods="POST|PUT">
        <default key="_controller">App\Controller\GalleryController:update</default>
    </route>

    <route id="gallery_delete" path="/{id}/delete" methods="POST|DELETE">
        <default key="_controller">App\Controller\GalleryController:delete</default>
    </route>

    <route id="gallery_new_single" path="/new">
        <default key="_controller">App\Controller\GalleryController:newSingle</default>
    </route>

    <route id="gallery_create_single" path="/create" methods="POST">
        <default key="_controller">App\Controller\GalleryController:createSingle</default>
    </route>

  <route id="gallery_image_list" path="/gallery_image_list/{id}">
        <default key="_controller">App\Controller\GalleryController:imageList</default>
    </route>

</routes>
