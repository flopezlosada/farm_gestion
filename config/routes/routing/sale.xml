<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="sale" path="/">
        <default key="_controller">App\Controller\SaleController:index</default>
    </route>

    <route id="sale_show" path="/{id}/show">
        <default key="_controller">App\Controller\SaleController:show</default>
    </route>

    <route id="sale_new" path="/new">
        <default key="_controller">App\Controller\SaleController:new</default>
    </route>

    <route id="sale_create" path="/create">
        <default key="_controller">App\Controller\SaleController:create</default>
        <requirement key="_method">post</requirement>
    </route>

    <route id="sale_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\SaleController:edit</default>
    </route>

    <route id="sale_update" path="/{id}/update">
        <default key="_controller">App\Controller\SaleController:update</default>
        <requirement key="_method">post|put</requirement>
    </route>

    <route id="sale_delete" path="/{id}/delete">
        <default key="_controller">App\Controller\SaleController:delete</default>
        <requirement key="_method">post|delete</requirement>
    </route>
    <route id="sale_pay" path="/{id}/sale_pay">
        <default key="_controller">App\Controller\SaleController:pay</default>
    </route>

</routes>
