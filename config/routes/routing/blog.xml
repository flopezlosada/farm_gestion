<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="blog" path="/">
        <default key="_controller">App\Controller\BlogController::index</default>
    </route>

    <route id="blog_categories" path="/categories">
        <default key="_controller">App\Controller\Blog::categories</default>
    </route>

    <route id="blog_show" path="/{id}/show">
        <default key="_controller">App\Controller\BlogController::show</default>
    </route>

    <route id="blog_new" path="/new">
        <default key="_controller">App\Controller\BlogController::new</default>
    </route>

    <route id="blog_second_step" path="/second/{id}">
        <default key="_controller">App\Controller\BlogController::second</default>
    </route>

    <route id="blog_create" path="/create/" methods="POST">
        <default key="_controller">App\Controller\BlogController::create</default>
    </route>

    <route id="blog_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\BlogController::edit</default>
    </route>

    <route id="blog_edition" path="/{id}/{object_class}/edition">
        <default key="_controller">App\Controller\BlogController::edition</default>
    </route>

    <route id="blog_update" path="/{id}/update" methods="POST|PUT">
        <default key="_controller">App\Controller\BlogController::update</default>
    </route>

    <route id="blog_update_second" path="/{id}/update_second" methods="POST|PUT">
        <default key="_controller">App\Controller\BlogController::updateSecond</default>
    </route>

    <route id="blog_delete" path="/{id}/delete" methods="POST|DELETE">
        <default key="_controller">App\Controller\BlogController::delete</default>
    </route>

</routes>
