<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="gift" path="/">
        <default key="_controller">App\Controller\GiftController::index</default>
    </route>

    <route id="gift_show" path="/{id}/show">
        <default key="_controller">App\Controller\GiftController::show</default>
    </route>

    <route id="gift_new" path="/new">
        <default key="_controller">App\Controller\GiftController::new</default>
    </route>

    <route id="gift_create" path="/create">
        <default key="_controller">App\Controller\GiftController::create</default>
        <requirement key="_method">post</requirement>
    </route>

    <route id="gift_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\GiftController::edit</default>
    </route>

    <route id="gift_update" path="/{id}/update">
        <default key="_controller">App\Controller\GiftController::update</default>
        <requirement key="_method">post|put</requirement>
    </route>

    <route id="gift_delete" path="/{id}/delete">
        <default key="_controller">App\Controller\GiftController::delete</default>
        <requirement key="_method">post|delete</requirement>
    </route>

</routes>
