<?xml version="1.0" encoding="UTF-8" ?>

<routes xmlns="http://symfony.com/schema/routing"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/routing http://symfony.com/schema/routing/routing-1.0.xsd">

    <route id="purchase" path="/">
        <default key="_controller">App\Controller\PurchaseController::index</default>
    </route>

    <route id="purchase_show" path="/{id}/show">
        <default key="_controller">App\Controller\PurchaseController::show</default>
    </route>

    <route id="purchase_new" path="/new">
        <default key="_controller">App\Controller\PurchaseController::new</default>
    </route>

    <route id="purchase_create" path="/create">
        <default key="_controller">App\Controller\PurchaseController::create</default>
        <requirement key="_method">post</requirement>
    </route>

    <route id="purchase_edit" path="/{id}/edit">
        <default key="_controller">App\Controller\PurchaseController::edit</default>
    </route>

    <route id="purchase_update" path="/{id}/update">
        <default key="_controller">App\Controller\PurchaseController::update</default>
        <requirement key="_method">post|put</requirement>
    </route>

    <route id="purchase_delete" path="/{id}/delete">
        <default key="_controller">App\Controller\PurchaseController::delete</default>
        <requirement key="_method">post|delete</requirement>
    </route>

</routes>
